PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX smart: <https://w3id.org/standards/smart/ontologies/core/>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX ex: <https://example.org/>

# CQ: What is the latest version of standard X ? (e.g. iso 9000)

SELECT ?latest_version
WHERE {
  VALUES ?main_standard { <https://example.org/standards/iso_std_iso_9000> }
    
  # Any descendant reached through one or more hasVersion links
  ?main_standard dcterms:hasVersion+ ?latest_version .

  # Keep only leaves
  FILTER NOT EXISTS {
    ?latest_version dcterms:hasVersion ?any_child .
  }

  # Exclude leaves that belong to an outdated branch
  FILTER NOT EXISTS {    
    ?ancestor dcterms:hasVersion* ?latest_version .
    ?newer dcterms:replaces+ ?ancestor .
    ?main_standard dcterms:hasVersion* ?ancestor ;
                   dcterms:hasVersion* ?newer .
  }
}
