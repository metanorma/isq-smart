###  http://www.w3.org/ns/oa#hasSource
oa:hasSource rdf:type owl:AnnotationProperty .


###  https://w3id.org/standards/smart/ontologies/core/hasContent
smart:hasContent rdf:type owl:AnnotationProperty .


###  https://w3id.org/standards/smart/ontologies/core/hasStrippedContent
smart:hasStrippedContent rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Classes
#################################################################

###  http://www.w3.org/ns/oa#Selector
oa:Selector rdf:type owl:Class .


###  http://www.w3.org/ns/oa#SpecificResource
oa:SpecificResource rdf:type owl:Class .


###  http://www.w3.org/ns/oa#XPathSelector
oa:XPathSelector rdf:type owl:Class ;
                 rdfs:subClassOf oa:Selector .


###  https://w3id.org/standards/smart/ontologies/core/Provision
smart:Provision rdf:type owl:Class .


###  https://w3id.org/standards/smart/ontologies/core/Standard
smart:PublicationDocument rdf:type owl:Class .


###  https://w3id.org/standards/smart/ontologies/core/Textual
smart:Textual rdf:type owl:Class ;
             rdfs:comment "Spelling preserved from the diagram; if this was meant to be smart:Textual, rename accordingly." .


