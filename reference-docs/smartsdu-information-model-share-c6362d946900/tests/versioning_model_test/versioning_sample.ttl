:content_1 rdf:type owl:NamedIndividual ,
                    oa:SpecificResource ,
                    smart:Textual ;
           oa:hasSelector :selector_1 ;
           oa:hasSource :provision_1 ;
           smart:hasStrippedContent "Lorem ipsum"@en ,
                                   "Lorem ipsum"@fr .


