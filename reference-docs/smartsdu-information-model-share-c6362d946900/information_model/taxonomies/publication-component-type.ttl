@prefix oa: <http://www.w3.org/ns/oa#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix publication-component-type: <https://w3id.org/standards/smart/taxonomies/publication-component-type/> .

publication-component-type: rdf:type skos:ConceptScheme ;
             dcterms:description "The types of components found within the content of a publication."@en ;
             dcterms:license <https://creativecommons.org/licenses/by-sa/4.0> ;
             dcterms:publisher <https://www.iec.ch> ,
                               <https://www.iso.org> ;
             rdfs:label "Publication Component Type Taxonomy"@en ;
             skos:hasTopConcept publication-component-type:code, publication-component-type:figure, publication-component-type:mathematicalFormula, publication-component-type:table, publication-component-type:textual ;
             owl:versionInfo "2.0.0" .

publication-component-type:code rdf:type smart:PublicationComponentType, skos:Concept ;
                 skos:topConceptOf publication-component-type: ;
                 skos:inScheme publication-component-type: ;
                 rdfs:label "Code"@en ;
                 skos:prefLabel "Note"@en ;
                 skos:definition "The content which is compilable into executable code"@en .


publication-component-type:figure rdf:type smart:PublicationComponentType, skos:Concept ;
                   skos:topConceptOf publication-component-type: ;
                   skos:inScheme publication-component-type: ;
                   rdfs:label "Figure"@en ;
                   skos:prefLabel "Figure"@en ;
                   skos:altLabel "Graphic"@en ;
                   skos:definition "Content in the form of a Graphic"@en .

publication-component-type:mathematicalFormula rdf:type smart:PublicationComponentType, skos:Concept ;
                                skos:topConceptOf publication-component-type: ;
                                skos:inScheme publication-component-type: ;
                                rdfs:label "Mathematical Formula"@en ;
                                skos:definition "A mathematical formula uses symbols to express the relationship between quantities."@en ;
                                skos:prefLabel "Mathematical Formula"@en.


publication-component-type:table rdf:type smart:PublicationComponentType, skos:Concept ;
                  skos:topConceptOf publication-component-type: ;
                  skos:inScheme publication-component-type: ;
                  rdfs:label "Table"@en ;
                  skos:definition "The content that is formulated as a table."@en ;
                  skos:prefLabel "Table"@en.

publication-component-type:textual rdf:type smart:PublicationComponentType, skos:Concept ;
                    skos:topConceptOf publication-component-type: ;
                    skos:inScheme publication-component-type: ;
                    rdfs:label "Textual"@en ;
                    skos:definition "The content that is formulated in natural language."@en ;
                    skos:prefLabel "Textual"@en.
