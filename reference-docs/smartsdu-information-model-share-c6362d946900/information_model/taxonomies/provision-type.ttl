@prefix oa: <http://www.w3.org/ns/oa#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix provision-type: <https://w3id.org/standards/smart/taxonomies/provision-type/> .

provision-type: rdf:type skos:ConceptScheme ;
               dcterms:description "The Provision Type Taxonomy defines categories of Provision types. Example of Provision type categories are governing or assertional."@en ;
               dcterms:license <https://creativecommons.org/licenses/by-sa/4.0> ;
               dcterms:publisher <https://www.iec.ch> ,
                                 <https://www.iso.org> ;
               rdfs:label "Provision Type Taxonomy"@en ;
               skos:hasTopConcept provision-type:assertionalProvision, provision-type:governingProvision ;
               owl:versionInfo "2.0.0" .

provision-type:assertionalProvision rdf:type smart:ProvisionType, skos:Concept ;
                                   skos:topConceptOf provision-type: ;
                                   skos:inScheme provision-type: ;
                                   rdfs:label "Assertional Provision"@en ;
                                   skos:prefLabel "Assertional Provision"@en ;
                                   skos:definition "Provision that has only an informative function"@en ;
                                   skos:example "Capability, Possibility"@en .

provision-type:governingProvision rdf:type smart:ProvisionType, skos:Concept ;
                                 skos:topConceptOf provision-type: ;
                                 skos:inScheme provision-type: ;
                                 rdfs:label "Governing Provision"@en ;
                                 skos:prefLabel "Governing Provision"@en ;
                                 skos:definition "A provision that conveys information that guides actions or results within the scope of the document or the series of documents, this document is part of"@en ;
                                 skos:example "Requirement, Instruction"@en .
