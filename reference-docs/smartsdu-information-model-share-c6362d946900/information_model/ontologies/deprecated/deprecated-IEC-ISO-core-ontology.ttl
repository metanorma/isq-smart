@prefix : <https://w3id.org/standards/smart/ontologies/core#> .
@prefix oa: <http://www.w3.org/ns/oa#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix tbx: <https://w3id.org/standards/smart/ontologies/tbx#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://w3id.org/standards/smart/ontologies/core#> .

<https://w3id.org/standards/smart/ontologies/deprecated-core#> rdf:type owl:Ontology ;
                                                     dcterms:description "Ontology representing the IEC/ISO Standards - core common parts"@en ;
                                                     dcterms:license <https://creativecommons.org/licenses/by-sa/4.0> ;
                                                     dcterms:publisher <https://www.iec.ch> ,
                                                                       <https://www.iso.org> ;
                                                     dcterms:title "Deprecated Classes, Properties and Individuals from Core Ontology v1" ;
                                                     rdfs:label "Deprecated Classes, Properties and Individuals from Core Ontology v1."@en ;
                                                     skos:editorialNote "Only classes, properties or individuals witl true as value for owl:deprecated are considered deprecated."@en;
                                                     owl:versionInfo "2.0.0-0.4.0" .


#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/standards/smart/ontologies/core#belongsToStandard
smart:belongsToStandard rdf:type owl:ObjectProperty ;
                       rdfs:domain smart:Provision ;
                       dcterms:created "2022-06-05"^^xsd:date ;
                       dcterms:creator "The IEC SG12 SIM group" ;
                       dcterms:isReplacedBy dcterms:isPartOf ;
                       rdfs:label "DEPRECATED belongs to standard"@en ;
                       owl:deprecated "true"^^xsd:boolean ;
                       skos:definition "Refer to the IRI describing a complete standard or publication, from which this entity is a fragment or part."@en .


###  https://w3id.org/standards/smart/ontologies/core#comprises
smart:comprises rdf:type owl:ObjectProperty ;
               dcterms:isReplacedBy dcterms:hasPart ;
               rdfs:label "DEPRECATED comprises"@en ;
               owl:deprecated "true"^^xsd:boolean ;
               skos:editorialNote "The meaning of this property is not clear and it is not defined. Looking at its domain and usage, it seems to link a provision group with the provisions that are part of it." .



###  https://w3id.org/standards/smart/ontologies/core#comprisesProvision
smart:comprisesProvision rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf smart:comprises ;
                        rdfs:domain smart:ProvisionSet ;
                        rdfs:range smart:Provision ;
                        dcterms:created "2022-06-05"^^xsd:date ;
                        dcterms:creator "The IEC SG12 SIM group" ;
                        dcterms:isReplacedBy dcterms:hasPart ;
                        rdfs:label "comprises provision"@en ;
                        owl:deprecated "true"^^xsd:boolean .


###  https://w3id.org/standards/smart/ontologies/core#comprisesProvisionSet
smart:comprisesProvisionSet rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf smart:comprises ;
                           rdfs:domain smart:ProvisionSet ;
                           rdfs:range smart:ProvisionSet ;
                           dcterms:created "2022-06-05"^^xsd:date ;
                           dcterms:creator "The IEC SG12 SIM group" ;
                           dcterms:isReplacedBy dcterms:hasPart ;
                           rdfs:label "DEPRECATED comprises provision set"@en ;
                           owl:deprecated "true"^^xsd:boolean .

###  https://w3id.org/standards/smart/ontologies/core#hasAsset
smart:hasAsset rdf:type owl:ObjectProperty ;
              rdfs:label "DEPRECATED has asset"@en ;
              owl:deprecated "true"^^xsd:boolean ;
              skos:editorialNote "Grapic is deprecated" .

###  https://w3id.org/standards/smart/ontologies/core#hasContent
smart:hasContent rdf:type owl:ObjectProperty ;
                rdfs:label "DEPRECATED has content"@en ;
                rdfs:seeAlso smart:hasPublicationComponentType ;
                owl:deprecated "true"^^xsd:boolean ;
                skos:definition "DEPRECATED Describe the content of this entity."@en ;
                skos:editorialNote "The Range of this property were deprecated."@en .

###  https://w3id.org/standards/smart/ontologies/core#hasProvisionRelation
smart:hasProvisionRelation rdf:type owl:ObjectProperty ;
                          rdfs:domain smart:Provision ;
                          rdfs:range smart:Provision ;
                          dcterms:created "2022-06-05"^^xsd:date ;
                          dcterms:creator "The IEC SG12 SIM group" ;
                          rdfs:label "has provision relation"@en ;
                          owl:deprecated "true"^^xsd:boolean ;
                          skos:definition "TBD: what kind of relation would this express - in RDF we cannot bear metadata on an object property so the scoping and naming must be very concise." .


###  https://w3id.org/standards/smart/ontologies/core#hasReference
smart:hasReference rdf:type owl:ObjectProperty ;
                  dcterms:isReplacedBy dcterms:references ;
                  rdfs:comment "Not defined. Seesm to duplicate dcterms:references already defined in the Ontology." ;
                  rdfs:label "DEPRECATED has reference"@en ;
                  owl:deprecated "true"^^xsd:boolean ;
                  skos:definition "DEPRECATED TBD: what does this refer to ?" .

###  https://w3id.org/standards/smart/ontologies/core#hasRelatedClause
smart:hasRelatedClause rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf smart:hasProvisionRelation ;
                      rdfs:domain [ rdf:type owl:Class ;
                                    owl:unionOf ( smart:Provision
                                                  smart:ProvisionSupplement
                                                )
                                  ] ;
                      rdfs:range smart:Clause ;
                      dcterms:isReplacedBy dcterms:relation ;
                      rdfs:label "has related clause"@en ;
                      owl:deprecated "true"^^xsd:boolean .

###  https://w3id.org/standards/smart/ontologies/core#referencesStandard
smart:referencesStandard rdf:type owl:ObjectProperty ;
                        dcterms:isReplacedBy dcterms:references ;
                        rdfs:comment "Creating a Property per range type, conflates the number of properties." ;
                        rdfs:label "DEPRECATED references standard"@en ;
                        owl:deprecated "true"^^xsd:boolean ;
                        skos:definition "DEPRECATED A special type of reference allowing for pointing to another standard than the one in which the reference is defined"@en .


###  https://w3id.org/standards/smart/ontologies/core#see
smart:see rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf smart:hasProvisionRelation ;
         rdfs:domain smart:Provision ;
         rdfs:range [ rdf:type owl:Class ;
                      owl:unionOf ( smart:Provision
                                    smart:ProvisionSet
                                  )
                    ] ;
         dcterms:isReplacedBy rdfs:seeAlso ;
         rdfs:label "see"@en ;
         owl:deprecated "true"^^xsd:boolean .

###  https://w3id.org/standards/smart/ontologies/core#withinClause
smart:withinClause rdf:type owl:ObjectProperty ;
                  rdfs:domain [ rdf:type owl:Class ;
                                owl:unionOf ( smart:Provision
                                              smart:ProvisionSet
                                            )
                              ] ;
                  rdfs:range smart:Clause ;
                  dcterms:isReplacedBy dcterms:isPartOf ;
                  rdfs:label "within clause"@en ;
                  owl:deprecated "true"^^xsd:boolean ;
                  skos:definition "DEPRECATED Relates a provision or supplement to its closest (parent) containing Clause or Subclause" .


#################################################################
#    Data properties
#################################################################


###  https://w3id.org/standards/smart/ontologies/tbx#definition
tbx:definition rdf:type owl:DatatypeProperty ;
               owl:deprecated "true"^^xsd:boolean ;
               dcterms:isReplacedBy skos:definition ;
               owl:deprecated "true"^^xsd:boolean ;
               skos:editorialNote "This label duplicates skos:definition. There should be no duplication of labels."@en .


###  https://w3id.org/standards/smart/ontologies/core#hasFormattedContent
smart:hasFormattedContent rdf:type owl:DatatypeProperty ;
                         rdfs:subPropertyOf smart:hasSourceContent ;
                         rdfs:domain smart:Content ;
                         rdfs:range xsd:string ;
                         rdfs:label "DEPRECATED has formatted content"@en ;
                         owl:deprecated "true"^^xsd:boolean ;
                         skos:definition "DEPRECATED The raw data content of a Content, in the native encoding of the original source. For XML, this means the string including all tags and attributes that can be handed over to an XML parser."@en ;
                         skos:editorialNote "Content format of entities such as Provision are modeled using dcat:Distribution"@en .


###  https://w3id.org/standards/smart/ontologies/core#hasFormattedDefinition
smart:hasFormattedDefinition rdf:type owl:DatatypeProperty ,
                                     owl:FunctionalProperty ;
                            rdfs:domain smart:TermEntry ;
                            rdfs:range rdf:langString ;
                            rdfs:comment "Terms and Definitions are implemented using skos (skos:definition, ...) and skosxl." ;
                            rdfs:label "DEPRECATED has formatted definition"@en ;
                            rdfs:seeAlso skos:definition ;
                            owl:deprecated "true"^^xsd:boolean .


###  https://w3id.org/standards/smart/ontologies/core#hasPlainContent
smart:hasPlainContent rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf smart:hasSourceContent ;
                     rdfs:domain smart:Content ;
                     rdfs:range xsd:string ;
                     rdfs:label "DEPRECATED has plain content"@en ;
                     owl:deprecated "true"^^xsd:boolean ;
                     skos:definition "DEPRECATED A digested version of the source content. For XML, this means only the text nodes."@en ;
                     skos:editorialNote "Content format of entities such as Provision are modeled using dcat:Distribution"@en .


###  https://w3id.org/standards/smart/ontologies/core#hasPlainDefinition
smart:hasPlainDefinition rdf:type owl:DatatypeProperty ,
                                 owl:FunctionalProperty ;
                        rdfs:domain smart:TermEntry ;
                        rdfs:range rdf:langString ;
                        rdfs:label "DEPRECATED has plain definition"@en ;
                        rdfs:seeAlso skos:definition ;
                        owl:deprecated "true"^^xsd:boolean ;
                        skos:editorialNote "Terms and Definitions are implemented using skos (skos:definition, ...) and skosxl."@en .



###  https://w3id.org/standards/smart/ontologies/core#hasSourceContent
smart:hasSourceContent rdf:type owl:DatatypeProperty ,
                               owl:FunctionalProperty ;
                      rdfs:domain smart:Content ;
                      rdfs:range rdf:langString ;
                      rdfs:label "DEPRECATED has source content"@en ;
                      owl:deprecated "true"^^xsd:boolean ;
                      skos:editorialNote "Content format of entities such as Provision are modeled using dcat:Distribution"@en .


#################################################################
#    Classes
#################################################################


###  https://w3id.org/standards/smart/ontologies/core#AssertionalProvision
smart:AssertionalProvision rdf:type owl:Class ;
                          dcterms:created "2022-06-05"^^xsd:date ;
                          dcterms:creator "The IEC SG12 SIM group" ;
                          rdfs:label "DEPRECATED Assertional Provision"@en ;
                          owl:deprecated "true"^^xsd:boolean ;
                          skos:editorialNote "This class definition is very close to bindingness-type:informative"@en ;
                          dcterms:isReplacedBy <https://w3id.org/standards/smart/taxonomies/bindingness-type/assertionalProvision> ;
                          skos:definition "DEPRECATED Provision that has only an informative function"@en .

###  https://w3id.org/standards/smart/ontologies/core#Code
smart:Code rdf:type owl:Class ;
          rdfs:subClassOf smart:Content ;
          rdfs:label "DEPRECATED Code"@en ;
          owl:deprecated "true"^^xsd:boolean ;
          dcterms:isReplacedBy <https://w3id.org/standards/smart/taxonomies/publication-component-type/code> ;
          skos:definition "DEPRECATED The content which is compilable into executable code"@en ;
          skos:editorialNote "Publication content Component types are now defined as skos taxonomy (see publication-component-type.ttl taxonomy). They can be associated with a ProvisionSupplement or a Provision using the property hasPublicationComponentType."@en .


###  https://w3id.org/standards/smart/ontologies/core#Content
smart:Content rdf:type owl:Class ;
             rdfs:label "DEPRECATED Content"@en ;
             rdfs:seeAlso "https://w3id.org/standards/smart/taxonomies/publication-component-type/"@en ;
             owl:deprecated "true"^^xsd:boolean ;
             dcterms:isReplacedBy smart:PublicationComponentType ;
             skos:definition "DEPRECATED The actual information provided by a provision"@en ;
             skos:editorialNote """The Content class has a mix of data structure (e.g. Table) and format (e.g. MathML) as subclasses. That makes its meaining not clear. It looks like it is an attempt to define part of the publication content components as introduced by the directives part 2 (https://www.iec.ch/standards-development/isoiec-directives-part-2#article-header-id-5629-text-components). Furthemore, many more types of components can be found within a publication hinting that a taxonomy is more fitted that a flat class hierarchy in this case.

Publication content Component types are now defined as skos taxonomy (see publication-component-type.ttl taxonomy). They can be associated with a ProvisionSupplement or a Provision using the property hasPublicationComponentType."""@en .

###  https://w3id.org/standards/smart/ontologies/core#Example
smart:Example rdf:type owl:Class ;
             dcterms:isReplacedBy <https://w3id.org/standards/smart/taxonomies/provision-supplement-type/example> ;
             rdfs:label "DEPRECATED Example"@en ;
             owl:deprecated "true"^^xsd:boolean ;
             skos:definition "DEPRECATED Instance of a Provision illustrating it in a tangible way"@en ;
             skos:editorialNote "The Provision supplement types can be many and increase over time. It should be possible to add more of those without touching the Core Ontology which therefore becomes  more stable. Provision supplement types are now defined as skos Concept (see provision-supplement-type.ttl taxonomy). They can be associated with a ProvisionSupplement using the property hasSupplementType"@en .


###  https://w3id.org/standards/smart/ontologies/core#Figure
smart:Figure rdf:type owl:Class ;
            dcterms:isReplacedBy <https://w3id.org/standards/smart/taxonomies/publication-component-type/figure> ;
            rdfs:label "DEPRECATED Figure"@en ;
            owl:deprecated "true"^^xsd:boolean ;
            skos:definition "DEPRECATED A graphical means of representation used when they are the most efficient means of presenting information in an easily comprehensible form"@en ;
            skos:editorialNote "The Provision supplement types can be many and increase over time. It should be possible to add more of those without touching the Core Ontology which therefore becomes  more stable. Provision supplement types are now defined as skos Concept (see provision-supplement-type.ttl taxonomy). They can be associated with a ProvisionSupplement using the property hasSupplementType"@en .


###  https://w3id.org/standards/smart/ontologies/core#Footnote
smart:Footnote rdf:type owl:Class ;
              dcterms:isReplacedBy <https://w3id.org/standards/smart/taxonomies/provision-supplement-type/footnote> ;
              rdfs:label "DEPRECATED Footnote"@en ;
              owl:deprecated "true"^^xsd:boolean ;
              skos:definition "DEPRECATED Additional textual information to a Provision that supports or extends its meaning, but is not necessary for the Provision to be understood"@en ;
              skos:editorialNote "The Provision supplement types can be many and increase over time. It should be possible to add more of those without touching the Core Ontology which therefore becomes  more stable. Provision supplement types are now defined as skos Concept (see provision-supplement-type.ttl taxonomy). They can be associated with a ProvisionSupplement using the property hasSupplementType"@en ;
              skos:prefLabel "DEPRECATED Footnote"@en ;
              skos:scopeNote "Footnote is defined similarly to Note in the DP2. For textual content they are exactly equivalent. Differences arise re. their use for Figures and Tables where they can contain Requirements." .


###  https://w3id.org/standards/smart/ontologies/core#TermDefinition
smart:TermDefinition rdf:type owl:Class ;
                    skos:editorialNote "Term Entry are now implemented using skosxl"@en ;
                    rdfs:label "DEPRECATED Term Definition"@en ;
                    dcterms:isReplacedBy smart:TermEntry ;
                    owl:deprecated "true"^^xsd:boolean ;
                    skos:definition "DEPRECATED A definition of a term within a Publication"@en .


###  https://w3id.org/standards/smart/ontologies/core#usesTerm
smart:usesTerm rdf:type owl:ObjectProperty ;
              dcterms:isReplacedBy dcterms:references ;
              rdfs:label "DEPRECATED uses term"@en ;
              owl:deprecated "true"^^xsd:boolean ;
              skos:definition "DEPRECATED Links a term mentioned in the provision content with the term definition"@en ;
              skos:editorialNote "Favoring the more standard dcterms:references for any reference to a Term."@en .


###  https://w3id.org/standards/smart/ontologies/core#Formula
smart:Formula rdf:type owl:Class ;
             dcterms:isReplacedBy <https://w3id.org/standards/smart/taxonomies/provision-supplement-type/mathematicalFormula> ;
             rdfs:label "DEPRECATED Formula"@en ;
             owl:deprecated "true"^^xsd:boolean ;
             skos:definition "DEPRECATED A mathematical formula uses symbols to express the relationship between quantities"@en ;
             skos:editorialNote "The term Formula is too general since it can also mean a list of ingredients from which something is made. Since the skos:definition refers to Mathematical Formula, it makes sense to use that more specific term. The Provision supplement types can be many and increase over time. It should be possible to add more of those without touching the Core Ontology which therefore becomes  more stable. Provision supplement types are now defined as skos Concept (see provision-supplement-type.ttl taxonomy). They can be associated with a ProvisionSupplement using the property hasSupplementType."@en .


###  https://w3id.org/standards/smart/ontologies/core#GoverningProvision
smart:GoverningProvision rdf:type owl:Class ;
                        dcterms:created "2022-06-05"^^xsd:date ;
                        dcterms:creator "The IEC SG12 SIM group" ;
                        owl:deprecated "true"^^xsd:boolean ;
                        rdfs:label "DEPRECATED Governing Provision"@en ;
                        skos:editorialNote "This class definition is very close to bindingness-type:normative"@en ;
                        dcterms:isReplacedBy <https://w3id.org/standards/smart/taxonomies/bindingness-type/governingProvision> ;
                        skos:definition "DEPRECATED A provision that conveys information that guides actions or results within the scope of the document or the series of documents, this document is part of"@en .


###  https://w3id.org/standards/smart/ontologies/core#Graphic
smart:Graphic rdf:type owl:Class ;
             rdfs:subClassOf smart:Content ;
             rdfs:label "Deprecated Graphic"@en ;
             owl:deprecated "true"^^xsd:boolean ;
             dcterms:isReplacedBy <https://w3id.org/standards/smart/taxonomies/publication-component-type/figure> ;
             skos:definition "DEPRECATED Description of and pointer to an external file containing a still image"@en ;
             skos:editorialNote "Publication content Component types are now defined as skos taxonomy (see publication-component-type.ttl taxonomy). They can be associated with a ProvisionSupplement or a Provision using the property hasPublicationComponentType."@en .


###  https://w3id.org/standards/smart/ontologies/core#MathML
smart:MathML rdf:type owl:Class ;
            rdfs:subClassOf smart:Content ;
            dcterms:creator "The IEC SG12 SIM group" ;
            rdfs:comment "DEPRECATED MathML is an XML-based language for describing mathematical notations"@en ;
            rdfs:label "DEPRECATED MathML"@en ;
            dcterms:isReplacedBy <https://w3id.org/standards/smart/taxonomies/publication-component-type/mathematicalFormula> ;
            owl:deprecated "true"^^xsd:boolean ;
            skos:definition "DEPRECATED The content that is formulated complying to Mathematical Markup Language (MathML)"@en ;
            skos:editorialNote "Publication content Component types are now defined as skos taxonomy (see publication-component-type.ttl taxonomy). They can be associated with a ProvisionSupplement or a Provision using the property hasPublicationComponentType."@en .


###  https://w3id.org/standards/smart/ontologies/core#Note
smart:Note rdf:type owl:Class ;
          dcterms:isReplacedBy <https://w3id.org/standards/smart/taxonomies/provision-supplement-type/note> ;
          rdfs:label "DEPRECATED Note"@en ;
          owl:deprecated "true"^^xsd:boolean ;
          skos:definition "DEPRECATED Additional textual information to a Provision that supports or extends its meaning, but is not necessary for the Provision to be understood"@en ;
          skos:editorialNote "The Provision supplement types can be many and increase over time. It should be possible to add more of those without touching the Core Ontology which therefore becomes  more stable. Provision supplement types are now defined as skos Concept (see provision-supplement-type.ttl taxonomy). They can be associated with a ProvisionSupplement using the property hasSupplementType"@en ;
          skos:prefLabel "DEPRECATED"@en .


###  https://w3id.org/standards/smart/ontologies/core#Table
smart:Table rdf:type owl:Class ;
           rdfs:subClassOf smart:Content ;
           dcterms:creator "The IEC SG12 SIM group" ;
           dcterms:isReplacedBy <https://w3id.org/standards/smart/taxonomies/publication-component-type/table> ;
           rdfs:label "DEPRECATED Table"@en ;
           owl:deprecated "true"^^xsd:boolean ;
           skos:definition "DEPRECATED The content that is formulated as a table, but does not provide any schema that would describe the inner structure of a table"@en ;
           skos:editorialNote "Publication content Component types are now defined as skos taxonomy (see publication-component-type.ttl taxonomy). They can be associated with a ProvisionSupplement or a Provision using the property hasPublicationComponentType."@en .


###  https://w3id.org/standards/smart/ontologies/core#Textual
smart:Textual rdf:type owl:Class ;
             rdfs:subClassOf smart:Content ;
             dcterms:creator "The IEC SG12 SIM group" ;
             rdfs:label "DEPRECATED Textual"@en ;
             owl:deprecated "true"^^xsd:boolean ;
             dcterms:isReplacedBy <https://w3id.org/standards/smart/taxonomies/publication-component-type/textual> ;
             skos:definition "DEPRECATED The content that is formulated in natural language for human consumption"@en ;
             skos:editorialNote "Publication content Component types are now defined as skos taxonomy (see publication-component-type.ttl taxonomy). They can be associated with a ProvisionSupplement or a Provision using the property hasPublicationComponentType."@en .

#################################################################
#    Individuals
#################################################################

###  https://w3id.org/standards/smart/ontologies/core#Informative
smart:Informative rdf:type owl:NamedIndividual ,
                          smart:BindingnessType ;
                 owl:differentFrom smart:Normative ;
                 rdfs:label "DEPRECATED Informative"@en ;
                 dcterms:isReplacedBy <https://w3id.org/standards/smart/taxonomies/bindingness-type/informative> ;
                 owl:deprecated "true"^^xsd:boolean ;
                 skos:definition "DEPRECATED A non-normative i.e. bindingness type" ;
                 skos:editorialNote "Bindingness types are now defined as skos Concept (see bindingness-type.ttl taxonomy). They can be associated with a Provision or ProvisionSupplement using the property hasBindingnessType"@en .


###  https://w3id.org/standards/smart/ontologies/core#Normative
smart:Normative rdf:type owl:NamedIndividual ,
                        smart:BindingnessType ;
               rdfs:label "DEPRECATED Normative"@en ;
               owl:deprecated "true"^^xsd:boolean ;
               dcterms:isReplacedBy <https://w3id.org/standards/smart/taxonomies/bindingness-type/normative> ;
               skos:editorialNote "Bindingness types are now defined as skos Concept (see bindingness-type.ttl taxonomy). They can be associated with a Provision or ProvisionSupplement using the property hasBindingnessType"@en ;
               skos:prefLabel "DEPRECATED Normative"@en .


###  https://w3id.org/standards/smart/ontologies/core#isPredecessorOf
smart:isPredecessorOf rdf:type owl:ObjectProperty ;
                     rdfs:comment "The inverse property smart:isSuccessorOf is adequate to model sequences." ;
                     rdfs:label "DEPRECATED is predecessor of"@en ;
                     owl:deprecated "true"^^xsd:boolean ;
                     skos:definition "DEPRECATED A provision or clause is the predecessor, i.e. immediately before in reading order, to another one"@en .