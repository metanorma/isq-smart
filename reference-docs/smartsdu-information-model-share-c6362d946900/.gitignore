# Basic .gitignore

# IntelliJ (for those using it)
/.idea

# Generated by MacOS
.DS_Store

# Generated by Windows
Thumbs.db

# Generated by Protégé
catalog-v*.xml

# CI/CD to check and generate documentation about the ontology, when running locally, derive artefacts in this directory.
# Avoid committing those.
/output
/site/

# Environment variables
*.env

# Python virtual environment
.venv/

# Python build / packaging artefacts
*.egg-info/

# Python cache
__pycache__/
*.py[cod]

# Pytest cache
.pytest_cache/

# Coverage reports
.coverage
htmlcov/

# Build artefacts
build/
dist/
