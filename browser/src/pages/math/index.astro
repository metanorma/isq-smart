---
import DefaultLayout from '../../layouts/DefaultLayout.astro'
import EntryBrowser from '../../components/EntryBrowser.vue'
import PageHero from '../../components/PageHero.astro'
import { getDomain, getPartsByDomain, getPartEntryCount, isBilingual, partUrl, sectionLabel } from '../../data/index'
import { mathIndex, symbolCache } from '../../data/generated/domain-index'

const domainKey = 'math' as const
const domain = getDomain(domainKey)!
const parts = getPartsByDomain(domainKey)
const totalEntries = parts.reduce((sum, p) => sum + getPartEntryCount(p.partKey), 0)
---

<DefaultLayout title="Mathematical Notation — ISO 80000 & IEC 80000" description="Browse mathematical notation defined in ISO 80000-2.">
  <div>
    <!-- Domain hero -->
    <PageHero
      variant="violet"
      crumbs={[{ label: 'Home', href: '/' }, { label: 'Mathematical Notation' }]}
      title={domain.label}
      description={domain.description}
      stats={[
        { value: parts.length, label: 'subparts' },
        { value: totalEntries.toLocaleString(), label: 'entries' },
      ]}
    />

    <!-- Part navigation strip -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-4 relative z-10 mb-6">
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-2">
        {parts.map((part) => (
          <a href={partUrl(part.partKey)} class="group flex items-center gap-2.5 px-3 py-2.5 rounded-xl bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 hover:border-violet-200 dark:hover:border-violet-700 hover:shadow-sm transition-all">
            <span class="text-base">{part.icon}</span>
            <div class="min-w-0">
              <div class="flex items-center gap-1">
                <span class="text-xs font-semibold text-slate-800 dark:text-slate-200 group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors">{part.parentPart ? sectionLabel(part.partKey) : part.partKey}</span>
                {isBilingual(part.partKey) && <span class="text-xs font-bold text-amber-700 bg-amber-50 border border-amber-200/60 px-1 py-px rounded leading-none">FR</span>}
              </div>
              <div class="text-xs text-slate-500 dark:text-slate-400 truncate">{part.title}</div>
              <div class="text-xs text-slate-400 dark:text-slate-500 tabular-nums">{getPartEntryCount(part.partKey)} entries</div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Interactive entry browser (search, filter, list) -->
    <EntryBrowser client:idle domainKey={domainKey} parts={parts} index={mathIndex} symbolCache={symbolCache} />
  </div>
</DefaultLayout>
