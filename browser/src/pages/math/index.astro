---
import DefaultLayout from '../../layouts/DefaultLayout.astro'
import EntryBrowser from '../../components/EntryBrowser.vue'
import { getDomain, getPartsByDomain, getPartEntryCount, isBilingual, partUrl } from '../../data/index'
import { mathIndex, symbolCache } from '../../data/generated/domain-index'

const domainKey = 'math' as const
const domain = getDomain(domainKey)!
const parts = getPartsByDomain(domainKey)
const totalEntries = parts.reduce((sum, p) => sum + getPartEntryCount(p.partKey), 0)
---

<DefaultLayout title="Mathematical Notation — ISO 80000 & IEC 80000" description="Browse mathematical notation defined in ISO 80000-2.">
  <div>
    <!-- Domain hero -->
    <section class="relative overflow-hidden bg-gradient-to-br from-violet-950 via-violet-900 to-indigo-950">
      <div class="absolute inset-0 hero-pattern"></div>
      <div class="grain-overlay absolute inset-0"></div>
      <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-violet-500/10 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/3"></div>
      <div class="hero-float-1 absolute top-[15%] right-[18%] w-3 h-3 rounded-full bg-violet-400/20"></div>
      <div class="hero-float-2 absolute top-[30%] right-[8%] w-2 h-2 rounded-full bg-white/10"></div>
      <div class="hero-float-4 absolute top-[20%] left-[5%] w-16 h-16 rounded-full border border-white/[0.04]"></div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
        <div class="max-w-3xl page-enter">
          <div class="flex items-center gap-2 text-xs text-violet-300/60 mb-5">
            <a href="/" class="hover:text-violet-200 transition-colors">Home</a>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
          </div>
          <div class="flex items-end gap-5 flex-wrap">
            <div>
              <div class="text-3xl mb-2">{domain.icon}</div>
              <h1 class="text-3xl sm:text-4xl font-bold text-white tracking-tight heading-serif">{domain.label}</h1>
              <p class="mt-2 text-sm leading-relaxed max-w-xl text-violet-300/80">{domain.description}</p>
            </div>
            <div class="flex gap-2 ml-auto flex-shrink-0 mb-1">
              <div class="px-3 py-1.5 rounded-lg bg-white/[0.06] border border-white/[0.08]">
                <span class="text-lg font-bold text-white heading-serif">{parts.length}</span>
                <span class="text-xs ml-1 text-violet-300/70">parts</span>
              </div>
              <div class="px-3 py-1.5 rounded-lg bg-white/[0.06] border border-white/[0.08]">
                <span class="text-lg font-bold text-white heading-serif tabular-nums">{totalEntries.toLocaleString()}</span>
                <span class="text-xs ml-1 text-violet-300/70">entries</span>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="absolute bottom-0 inset-x-0 h-12 bg-gradient-to-t from-slate-50 dark:from-dark-950 to-transparent z-10"></div>
    </section>

    <!-- Part navigation strip -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-4 relative z-10 mb-6">
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-2">
        {parts.map((part) => (
          <a href={partUrl(part.partKey)} class="group flex items-center gap-2.5 px-3 py-2.5 rounded-xl bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 hover:border-violet-200 dark:hover:border-violet-700 hover:shadow-sm transition-all">
            <span class="text-base">{part.icon}</span>
            <div class="min-w-0">
              <div class="flex items-center gap-1">
                <span class="text-xs font-semibold text-slate-800 dark:text-slate-200 group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors">{part.parentPart ? `§${part.partKey.split('-')[1]}` : part.partKey}</span>
                {isBilingual(part.partKey) && <span class="text-[8px] font-bold text-amber-700 bg-amber-50 border border-amber-200/60 px-1 py-px rounded leading-none">FR</span>}
              </div>
              <div class="text-[10px] text-slate-500 dark:text-slate-400 truncate">{part.title}</div>
              <div class="text-[9px] text-slate-400 dark:text-slate-500 tabular-nums">{getPartEntryCount(part.partKey)} entries</div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Interactive entry browser (search, filter, list) -->
    <EntryBrowser client:idle domainKey={domainKey} parts={parts} index={mathIndex} symbolCache={symbolCache} />
  </div>
</DefaultLayout>
