---
import DefaultLayout from '../../../layouts/DefaultLayout.astro'
import { asset } from '../../../lib/asset'
import MathRenderer from '../../../components/MathRenderer.vue'
import LanguageToggle from '../../../components/LanguageToggle.vue'
import ReferenceBadge from '../../../components/ReferenceBadge.vue'
import JsonLdActions from '../../../components/JsonLdActions.vue'
import CitationBuilder from '../../../components/CitationBuilder.vue'
import PartIcon from '../../../components/PartIcon.vue'
import EntryOntologyPanel from '../../../components/EntryOntologyPanel.vue'
import {
  getPartsByDomain, getPartMeta, getPartEntryCount, isBilingual, getPartEditions,
  partUrl, EntryModel,
} from '../../../data/index'
import { DataLoader } from '../../../data/DataLoader'
import {
  resolveEntryDetailView, stripStem, renderDesignationText, unitLink,
} from '../../../data/entryViewModel'
import type { Entry } from '../../../data/types'

interface Props {
  partKey: string
  entryId: string
  entries: Entry[]
  mathCache: Record<string, string>
  latexCache: Record<string, string>
}

export async function getStaticPaths() {
  const parts = getPartsByDomain('math')
  const paths = []
  for (const p of parts) {
    const data = await DataLoader.loadPart(p.partKey)
    // Deduplicate by entry ID — keep last (latest edition) when multiple editions exist
    const byId = new Map<string, Entry>()
    for (const entry of data.entries) byId.set(entry.id, entry)
    for (const [id, entry] of byId) {
      paths.push({
        params: { part: p.partKey, id },
        props: {
          partKey: p.partKey,
          entryId: id,
          entries: [...byId.values()],
          mathCache: data.mathCache,
          latexCache: data.latexCache,
        },
      })
    }
  }
  return paths
}

const { partKey, entryId, entries, mathCache, latexCache } = Astro.props
const meta = getPartMeta(partKey)!

const entry = entries.find(e => e.id === entryId)!

const view = resolveEntryDetailView(
  entry,
  partKey,
  meta,
  'math',
  getPartEditions(partKey),
  isBilingual(partKey),
  entries,
  { mathCache, latexCache },
)
---

<DefaultLayout
  title={`Entry ${entry.num} — Part ${partKey} | ISQ Browser`}
  description={meta.description}
>
  <div>
    <!-- Breadcrumb -->
    <section class="border-b border-slate-200/60 dark:border-dark-600/60 bg-slate-50/30 dark:bg-dark-800/30">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
        <div class="flex items-center gap-2 text-xs text-slate-400">
          <a href={asset("/")} class="hover:text-brand-600 dark:hover:text-brand-400 transition-colors">Home</a>
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
          <a href={asset("/math")} class="hover:text-brand-600 dark:hover:text-brand-400 transition-colors">Math</a>
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
          <a href={partUrl(partKey)} class="hover:text-brand-600 dark:hover:text-brand-400 transition-colors flex items-center gap-1.5">
            <PartIcon meta={meta} size="sm" class="!w-5 !h-5 !text-[10px] !rounded" />
            {view.partLabel}
          </a>
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
          <span class="text-slate-600 dark:text-slate-300 font-mono font-medium">{entry.num}</span>
        </div>
      </div>
    </section>

    <!-- Part context -->
    <section class="border-b border-slate-200/40 dark:border-dark-600/40" style={view.accent.headerBg}>
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-2.5">
        <div class="flex items-center gap-3">
          <a href={partUrl(partKey)} class="group flex items-center gap-2.5 text-xs text-slate-500 dark:text-slate-400 hover:text-brand-600 dark:hover:text-brand-400 transition-colors">
            <PartIcon meta={meta} size="sm" class="!w-7 !h-7 !text-sm !rounded-lg" />
            <span>
              <span class="font-semibold text-slate-700 dark:text-slate-300 group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">{view.partLabel}: {meta.title}</span>
              <span class="text-slate-400 dark:text-slate-500 mx-1">&middot;</span>
              <span class="tabular-nums">{getPartEntryCount(partKey)} entries</span>
            </span>
          </a>
        </div>
      </div>
    </section>

    <!-- Entry content -->
    <section class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14 page-enter">
      <div class="absolute top-20 right-0 w-[500px] h-[500px] rounded-full pointer-events-none -z-10" style={`background: ${view.accent.heroGlow.background}`} />
      <div class="accent-orb w-[300px] h-[300px] -top-20 -left-32 -z-10" style={`background: ${view.accent.accentFrom}08`} />
      <div class="accent-orb w-[200px] h-[200px] bottom-40 right-0 -z-10" style={`animation-delay: -3s; background: ${view.accent.accentFrom}06`} />

      <!-- Top bar -->
      <div class="flex items-center gap-3 mb-8">
        {view.bilingual && <LanguageToggle client:idle />}
        <span class="text-xs text-slate-400 dark:text-slate-500 ml-auto font-mono tabular-nums">{view.siblings.idx} / {view.siblings.total}</span>
      </div>

      <!-- In this section -->
      {view.sectionEntries.length > 1 && (
        <div class="mb-8 -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-[10px] font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-[0.12em]">Section {view.sectionLabel}</span>
            <span class="text-[10px] text-slate-300 dark:text-slate-600 tabular-nums">{view.sectionEntries.length} entries</span>
          </div>
          <div class="flex gap-1.5 overflow-x-auto no-scrollbar pb-1">
            {view.sectionEntries.map((se) => (
              <a
                href={`${partUrl(partKey)}/${se.id}`}
                class={`flex-shrink-0 flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-xs border transition-all ${se.id === entry.id
                  ? 'bg-brand-600 text-white border-brand-500 shadow-sm'
                  : 'bg-white dark:bg-dark-800 text-slate-500 dark:text-slate-400 border-slate-200 dark:border-dark-600 hover:border-brand-200 dark:hover:border-brand-700 hover:text-brand-600 dark:hover:text-brand-400'}`}
              >
                <span class="font-mono font-medium">{se.num}</span>
                <span class="max-w-[120px] truncate hidden sm:inline">{EntryModel.name(se, 'en')}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Header -->
      <header class="mb-10">
        <div class="flex items-start gap-4 flex-wrap">
          <span class="font-mono text-sm font-bold text-brand-700 dark:text-brand-400 bg-brand-50 dark:bg-brand-950/40 border border-brand-100/60 dark:border-brand-800/40 px-3 py-1.5 rounded-lg mt-1">{entry.num}</span>
          <div class="min-w-0 flex-1">
            <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-slate-100 tracking-tight heading-serif leading-tight" set:html={view.renderedNameHtml} />
          </div>
        </div>

        <!-- Identifiers -->
        <div class="mt-4 flex flex-wrap items-center gap-3">
          <ReferenceBadge client:idle part={partKey} edition={view.edition} entryNum={entry.num} bilingual={view.bilingual} />
          {view.jsonLd && <JsonLdActions client:idle data={view.jsonLd} filename={`iso80000-${entry.id}.jsonld`} />}
          <div class="flex items-center gap-2 ml-auto text-xs">
            <span class="text-[10px] font-semibold text-slate-400 uppercase tracking-wider">Download RDF</span>
            <a href={asset(`/math/part-${partKey}/${entry.id}.jsonld`)} class="inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-xs font-medium text-slate-500 dark:text-slate-400 bg-slate-50 dark:bg-dark-800/50 border border-slate-200/60 dark:border-dark-600/60 hover:bg-slate-100 dark:hover:bg-dark-700 hover:text-slate-700 dark:hover:text-slate-300 transition-all">.jsonld</a>
            <a href={asset(`/math/part-${partKey}/${entry.id}.ttl`)} class="inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-xs font-medium text-slate-500 dark:text-slate-400 bg-slate-50 dark:bg-dark-800/50 border border-slate-200/60 dark:border-dark-600/60 hover:bg-slate-100 dark:hover:bg-dark-700 hover:text-slate-700 dark:hover:text-slate-300 transition-all">.ttl</a>
          </div>
        </div>

        <!-- Citation builder -->
        <div class="mt-3">
          <CitationBuilder client:idle entry={entry} meta={meta} edition={view.edition} />
        </div>

        <!-- ISQ URNs -->
        {view.dualUrn && (
          <div class="mt-4 rounded-lg border border-slate-200/60 dark:border-dark-600/60 bg-slate-50/50 dark:bg-dark-800/50 p-3">
            <div class="text-[10px] font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">ISQ Identifiers</div>
            <div class="grid sm:grid-cols-2 gap-2">
              <div>
                <div class="text-[10px] font-semibold text-brand-600 dark:text-brand-400 mb-0.5">ISO</div>
                <code class="text-[11px] font-mono text-slate-600 dark:text-slate-400 break-all block bg-white dark:bg-dark-700 px-2 py-1.5 rounded">{view.dualUrn.iso}</code>
              </div>
              <div>
                <div class="text-[10px] font-semibold text-teal-600 dark:text-teal-400 mb-0.5">IEC</div>
                <code class="text-[11px] font-mono text-slate-600 dark:text-slate-400 break-all block bg-white dark:bg-dark-700 px-2 py-1.5 rounded">{view.dualUrn.iec}</code>
              </div>
            </div>
          </div>
        )}

        <!-- Designations -->
        {(entry.designations.length > 1 || view.bilingual) && (
          <div class="mt-6">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-[10px] font-semibold text-slate-400 uppercase tracking-[0.15em]">Designations</span>
              <div class="flex-1 h-px bg-slate-200/60 dark:bg-dark-700/60" />
            </div>
            <div class="flex flex-wrap gap-2">
              {entry.designations.map((des) => (
                <div class="px-3 py-2 rounded-lg border border-slate-200/60 dark:border-dark-600/60 bg-white dark:bg-dark-800 text-sm">
                  {des.designation.en && (
                    <div class="flex items-baseline gap-2">
                      <span class="text-[10px] font-semibold text-brand-600 dark:text-brand-400 uppercase bg-brand-50 dark:bg-brand-950/40 px-1.5 py-0.5 rounded flex-shrink-0">EN</span>
                      <span class="text-slate-800 dark:text-slate-200" set:html={renderDesignationText(des.designation.en.text, mathCache)} />
                    </div>
                  )}
                  {des.designation.fr && (
                    <div class={`flex items-baseline gap-2 ${des.designation.en ? 'mt-1' : ''}`}>
                      <span class="text-[10px] font-semibold text-amber-600 dark:text-amber-400 uppercase bg-amber-50 dark:bg-amber-950/40 px-1.5 py-0.5 rounded flex-shrink-0">FR</span>
                      <span class="text-slate-800 dark:text-slate-200" set:html={renderDesignationText(des.designation.fr.text, mathCache)} />
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Symbol showcase -->
        {entry.symbols?.length && (
          <div class="mt-8">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-[10px] font-semibold text-slate-400 uppercase tracking-[0.15em]">Symbol</span>
              <div class="flex-1 h-px bg-slate-200/60 dark:bg-dark-700/60" />
            </div>
            <div class="relative rounded-2xl border border-slate-200/50 dark:border-dark-600/50 overflow-hidden group/symbol">
              <div class="absolute inset-0 pointer-events-none" style={view.accent.showcasePattern} />
              <div class="absolute inset-0 rounded-2xl ring-1 ring-inset ring-slate-200/30 dark:ring-dark-600/30 group-hover/symbol:ring-brand-200/40 dark:group-hover/symbol:ring-brand-700/40 transition-all duration-500 pointer-events-none" />
              <div class="bg-gradient-to-br from-slate-50/80 dark:from-dark-800/80 via-white dark:via-dark-800 to-slate-50/50 dark:to-dark-800/80 p-6 sm:p-8">
                <div class="relative flex items-center justify-center gap-5 sm:gap-8 flex-wrap">
                  {entry.symbols.map((sym) => (
                    <div class="symbol-card px-7 sm:px-10 py-4 sm:py-5 rounded-xl bg-white dark:bg-dark-800 border border-slate-200/50 dark:border-dark-600/50 text-2xl sm:text-3xl shadow-sm hover:shadow-lg transition-all duration-300" style={view.accent.symbolGlow}>
                      <MathRenderer client:visible expression={sym} cache={mathCache} />
                    </div>
                  ))}
                </div>
              </div>
            </div>

            <!-- Notation systems -->
            {entry.symbols.length > 0 && (
              <div class="mt-3">
                <div class="text-[10px] font-semibold text-slate-400 uppercase tracking-[0.15em] mb-3">Notation systems</div>
                <div class="grid gap-2">
                  {entry.symbols.map((sym) => (
                    <div class="flex items-baseline gap-4 px-4 py-2 rounded-lg bg-slate-50/70 dark:bg-dark-800/70 border border-slate-200/50 dark:border-dark-600/50 text-sm">
                      <div class="flex-shrink-0 w-20 text-[10px] font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider">AsciiMath</div>
                      <code class="font-mono text-slate-700 dark:text-slate-300 text-[13px]">{sym}</code>
                    </div>
                  ))}
                  {entry.symbols.filter(sym => latexCache[sym]).map((sym) => (
                    <div class="flex items-baseline gap-4 px-4 py-2 rounded-lg bg-slate-50/70 dark:bg-dark-800/70 border border-slate-200/50 dark:border-dark-600/50 text-sm">
                      <div class="flex-shrink-0 w-20 text-[10px] font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider">LaTeX</div>
                      <code class="font-mono text-slate-700 dark:text-slate-300 text-[13px]">{latexCache[sym]}</code>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        )}
      </header>

      <!-- Definition -->
      <div class="mb-12">
        <h2 class="flex items-center gap-2 text-[10px] font-semibold text-slate-400 uppercase tracking-[0.15em] mb-4">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.351.026.622.31.802.677L12 21l2.652-5.227c.18-.366.451-.65.802-.677a42.377 42.377 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/></svg>
          Definition
        </h2>
        <div class="relative rounded-2xl bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 overflow-hidden shadow-sm group/def">
          <div class="absolute left-0 inset-y-0 w-1.5 transition-all duration-300 group-hover/def:w-2" style={view.accent.defAccentStyle} />
          <div class="p-6 sm:p-8 pl-7 sm:pl-9">
            <div class="text-slate-700 dark:text-slate-300 leading-relaxed text-[15px] sm:text-base" set:html={view.defHtml} />
          </div>
        </div>
      </div>

      <!-- Remarks -->
      {view.remHtml && (
        <div class="mb-12">
          <h2 class="flex items-center gap-2 text-[10px] font-semibold text-slate-400 uppercase tracking-[0.15em] mb-4">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/></svg>
            Remarks
          </h2>
          <div class="relative rounded-2xl bg-amber-50/60 dark:bg-amber-950/30 border border-amber-200/50 dark:border-amber-700/30 overflow-hidden">
            <div class="absolute left-0 inset-y-0 w-1.5 bg-gradient-to-b from-amber-400 to-amber-600 dark:from-amber-500 dark:to-amber-700" />
            <div class="p-6 sm:p-8 pl-7 sm:pl-9">
              <div class="text-slate-700 dark:text-slate-200 leading-relaxed text-[15px] sm:text-base" set:html={view.remHtml} />
            </div>
          </div>
        </div>
      )}

      <!-- Referenced by -->
      {view.referencedBy.length > 0 && (
        <div class="mb-12">
          <h2 class="flex items-center gap-2 text-[10px] font-semibold text-slate-400 uppercase tracking-[0.15em] mb-4">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.86-2.06a4.5 4.5 0 00-1.242-7.244l-4.5-4.5a4.5 4.5 0 00-6.364 6.364L4.34 8.374"/></svg>
            Referenced by
          </h2>
          <div class="flex flex-wrap gap-2">
            {view.referencedBy.map((ref) => (
              <a
                href={ref.href}
                class="group flex items-center gap-2 px-3 py-2 rounded-lg border border-slate-200/60 dark:border-dark-600/60 bg-white dark:bg-dark-800 hover:border-brand-200 dark:hover:border-brand-700 hover:shadow-sm transition-all text-sm"
              >
                <span class="font-medium text-slate-700 group-hover:text-brand-600 transition-colors">{ref.name}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Ontology -->
      <EntryOntologyPanel client:idle entry={entry} partParam={partKey} />

      <!-- Sibling navigation -->
      <nav class="mt-16 pt-8 border-t border-slate-200/60 dark:border-dark-600/60">
        <div class="hidden sm:flex items-center justify-center gap-3 text-[10px] text-slate-300 mb-4">
          <span class="flex items-center gap-1"><kbd class="bg-slate-100 dark:bg-dark-700 px-1.5 py-0.5 rounded font-mono border border-slate-200 dark:border-dark-600">k</kbd> Previous</span>
          <span class="flex items-center gap-1"><kbd class="bg-slate-100 dark:bg-dark-700 px-1.5 py-0.5 rounded font-mono border border-slate-200 dark:border-dark-600">j</kbd> Next</span>
          <span class="flex items-center gap-1"><kbd class="bg-slate-100 dark:bg-dark-700 px-1.5 py-0.5 rounded font-mono border border-slate-200 dark:border-dark-600">esc</kbd> Back to part</span>
        </div>
        <div class="flex items-center justify-between gap-4">
          {view.siblings.prev ? (
            <a
              href={`${partUrl(partKey)}/${view.siblings.prev.id}`}
              class="group flex items-center gap-3 px-5 py-4 rounded-xl border border-slate-200/70 dark:border-dark-600/60 bg-white dark:bg-dark-800 hover:border-brand-200 dark:hover:border-brand-700 hover:shadow-sm transition-all max-w-[45%]"
            >
              <svg class="w-4 h-4 text-slate-300 dark:text-slate-600 group-hover:text-brand-500 dark:group-hover:text-brand-400 transition-colors flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M15 19l-7-7 7-7"/></svg>
              <div class="min-w-0">
                <div class="font-mono text-xs text-slate-500 dark:text-slate-400 group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">{view.siblings.prev.num}</div>
                <div class="hidden sm:block truncate text-xs text-slate-400 dark:text-slate-500 group-hover:text-brand-500 dark:group-hover:text-brand-400 transition-colors mt-0.5">{EntryModel.name(view.siblings.prev, 'en')}</div>
              </div>
            </a>
          ) : <div />}

          {view.siblings.next ? (
            <a
              href={`${partUrl(partKey)}/${view.siblings.next.id}`}
              class="group flex items-center gap-3 px-5 py-4 rounded-xl border border-slate-200/70 dark:border-dark-600/60 bg-white dark:bg-dark-800 hover:border-brand-200 dark:hover:border-brand-700 hover:shadow-sm transition-all text-right max-w-[45%]"
            >
              <div class="min-w-0">
                <div class="font-mono text-xs text-slate-500 dark:text-slate-400 group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">{view.siblings.next.num}</div>
                <div class="hidden sm:block truncate text-xs text-slate-400 dark:text-slate-500 group-hover:text-brand-500 dark:group-hover:text-brand-400 transition-colors mt-0.5">{EntryModel.name(view.siblings.next, 'en')}</div>
              </div>
              <svg class="w-4 h-4 text-slate-300 dark:text-slate-600 group-hover:text-brand-500 dark:group-hover:text-brand-400 transition-colors flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          ) : <div />}
        </div>
      </nav>
    </section>

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(view.jsonLd)} />
  </div>
</DefaultLayout>
