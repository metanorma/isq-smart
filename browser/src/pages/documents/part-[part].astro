---
import DefaultLayout from '../../layouts/DefaultLayout.astro'
import DocumentPartPage from '../../components/pages/DocumentPartPage.vue'
import { getAllDocuments } from '../../data/index'

export function getStaticPaths() {
  return getAllDocuments().map(doc => ({
    params: { part: doc.partKey },
    props: { partKey: doc.partKey },
  }))
}

const { partKey } = Astro.props
---

<DefaultLayout title={`Document Part ${partKey} | ISQ Browser`}>
  <DocumentPartPage part={partKey} />
</DefaultLayout>
