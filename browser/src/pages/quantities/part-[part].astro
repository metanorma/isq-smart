---
import DefaultLayout from '../../layouts/DefaultLayout.astro'
import PartPage from '../../components/pages/PartPage.vue'
import { getPartsByDomain, getPartMeta } from '../../data/index'

export function getStaticPaths() {
  return getPartsByDomain('quantities').map(p => ({
    params: { part: p.partKey },
    props: { partKey: p.partKey },
  }))
}

const { partKey } = Astro.props
const meta = getPartMeta(partKey)
---

<DefaultLayout
  title={`Part ${partKey} — ${meta?.title ?? 'Quantities'} | ISQ Browser`}
  description={meta?.description ?? ''}
>
  <PartPage part={partKey} />
</DefaultLayout>
