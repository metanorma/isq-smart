---
import DefaultLayout from '../../layouts/DefaultLayout.astro'
import EntryBrowser from '../../components/EntryBrowser.vue'
import PageHero from '../../components/PageHero.astro'
import { getDomain, getPartsByDomain, getPartEntryCount, isBilingual, partUrl, sectionLabel } from '../../data/index'
import { quantitiesIndex, symbolCache } from '../../data/generated/domain-index'

const domainKey = 'quantities' as const
const domain = getDomain(domainKey)!
const parts = getPartsByDomain(domainKey)
const totalEntries = parts.reduce((sum, p) => sum + getPartEntryCount(p.partKey), 0)
---

<DefaultLayout title="Quantities — ISO 80000 & IEC 80000" description="Browse all quantities defined in the ISO 80000 & IEC 80000 series.">
  <div>
    <!-- Domain hero -->
    <PageHero
      variant="brand"
      crumbs={[{ label: 'Home', href: '/' }, { label: 'Quantities' }]}
      title={domain.label}
      description={domain.description}
      stats={[
        { value: parts.length, label: 'parts' },
        { value: totalEntries.toLocaleString(), label: 'entries' },
      ]}
    />

    <!-- Part navigation strip -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-4 relative z-10 mb-6">
      <div class="flex items-center gap-2 mb-3">
        <div class="flex-1 h-px bg-slate-200/60 dark:bg-dark-700/60"></div>
        <a href="/dimensions" class="text-[10px] font-medium text-slate-400 dark:text-slate-500 hover:text-brand-600 dark:hover:text-brand-400 transition-colors inline-flex items-center gap-1">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/></svg>
          View by dimension
        </a>
        <div class="flex-1 h-px bg-slate-200/60 dark:bg-dark-700/60"></div>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-2">
        {parts.map((part) => (
          <a href={partUrl(part.partKey)} class="group flex items-center gap-2.5 px-3 py-2.5 rounded-xl bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 hover:border-brand-200 dark:hover:border-brand-700 hover:shadow-sm transition-all">
            <span class="text-base">{part.icon}</span>
            <div class="min-w-0">
              <div class="flex items-center gap-1">
                <span class="text-xs font-semibold text-slate-800 dark:text-slate-200 group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">{part.parentPart ? sectionLabel(part.partKey) : part.partKey}</span>
                {isBilingual(part.partKey) && <span class="text-[8px] font-bold text-amber-700 bg-amber-50 border border-amber-200/60 px-1 py-px rounded leading-none">FR</span>}
              </div>
              <div class="text-[10px] text-slate-500 dark:text-slate-400 truncate">{part.title}</div>
              <div class="text-[9px] text-slate-400 dark:text-slate-500 tabular-nums">{getPartEntryCount(part.partKey)} entries</div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Interactive entry browser (search, filter, list) -->
    <EntryBrowser client:idle domainKey={domainKey} parts={parts} index={quantitiesIndex} symbolCache={symbolCache} />
  </div>
</DefaultLayout>
