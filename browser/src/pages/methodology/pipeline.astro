---
import DefaultLayout from '../../layouts/DefaultLayout.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import MethodologyNav from '../../components/MethodologyNav.astro'
---

<DefaultLayout title="Data Pipeline — Methodology — ISQ Browser" description="How YAML source data flows through the build pipeline into static pages.">
  <div>
    <section class="relative overflow-hidden bg-gradient-to-br from-teal-950 via-teal-900 to-emerald-950">
      <div class="absolute inset-0 hero-pattern"></div>
      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-12">
        <div class="max-w-3xl page-enter">
          <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Methodology', href: '/methodology' }, { label: 'Data Pipeline' }]} variant="dark" />
          <h1 class="text-3xl sm:text-4xl font-bold text-white tracking-tight heading-serif">Data Pipeline</h1>
          <p class="mt-3 text-base text-teal-200/70 leading-relaxed">
            YAML sources are processed at build time into typed TypeScript modules and static HTML pages. No runtime data fetching.
          </p>
        </div>
      </div>
      <div class="absolute bottom-0 inset-x-0 h-12 bg-gradient-to-t from-slate-50 dark:from-dark-950 to-transparent z-10"></div>
    </section>

    <MethodologyNav active="pipeline" />

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14 space-y-12">

      <section>
        <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100 heading-serif mb-4">Build Flow</h2>
        <div class="rounded-2xl border border-slate-200/60 dark:border-dark-600/60 bg-white dark:bg-dark-800 p-6">
          <svg viewBox="0 0 900 200" class="w-full h-auto" role="img" aria-label="Data pipeline flow">
            <title>Data Pipeline — from YAML to static HTML</title>
            <rect x="20" y="30" width="180" height="140" rx="10" fill="#fffbeb" stroke="#fbbf24" stroke-width="1"/>
            <text x="110" y="50" font-size="9" font-weight="700" fill="#92400e" text-anchor="middle">SOURCES</text>
            <text x="110" y="75" font-size="11" font-weight="600" fill="#0f172a" text-anchor="middle">ISO 80000 YAML</text>
            <text x="110" y="92" font-size="9" fill="#64748b" text-anchor="middle">quantities.yaml</text>
            <text x="110" y="122" font-size="11" font-weight="600" fill="#0f172a" text-anchor="middle">UnitsDB</text>
            <text x="110" y="155" font-size="11" font-weight="600" fill="#0f172a" text-anchor="middle">SmartSDU</text>
            <line x1="205" y1="100" x2="240" y2="100" stroke="#94a3b8" stroke-width="2"/>
            <polygon points="240,100 232,95 232,105" fill="#94a3b8"/>
            <rect x="245" y="30" width="240" height="140" rx="10" fill="#eef2ff" stroke="#818cf8" stroke-width="1"/>
            <text x="365" y="50" font-size="9" font-weight="700" fill="#4338ca" text-anchor="middle">BUILD STAGES (VITE)</text>
            <text x="265" y="72" font-size="9" font-family="monospace" fill="#4f46e5">build-kinds.ts</text>
            <text x="265" y="86" font-size="9" font-family="monospace" fill="#4f46e5">build-hierarchy.ts</text>
            <text x="265" y="100" font-size="9" font-family="monospace" fill="#4f46e5">build-entities.ts</text>
            <text x="265" y="114" font-size="9" font-family="monospace" fill="#4f46e5">build-concept-links.ts</text>
            <text x="265" y="128" font-size="9" font-family="monospace" fill="#4f46e5">build-units.ts</text>
            <text x="265" y="142" font-size="9" font-family="monospace" fill="#4f46e5">build-dimensions.ts</text>
            <line x1="490" y1="100" x2="525" y2="100" stroke="#94a3b8" stroke-width="2"/>
            <polygon points="525,100 517,95 517,105" fill="#94a3b8"/>
            <rect x="530" y="30" width="160" height="140" rx="10" fill="#f0fdf4" stroke="#4ade80" stroke-width="1"/>
            <text x="610" y="50" font-size="9" font-weight="700" fill="#166534" text-anchor="middle">GENERATED TS</text>
            <text x="610" y="75" font-size="9" font-family="monospace" fill="#16a34a" text-anchor="middle">kinds.ts</text>
            <text x="610" y="89" font-size="9" font-family="monospace" fill="#16a34a" text-anchor="middle">hierarchy.ts</text>
            <text x="610" y="103" font-size="9" font-family="monospace" fill="#16a34a" text-anchor="middle">entities.ts</text>
            <text x="610" y="117" font-size="9" font-family="monospace" fill="#16a34a" text-anchor="middle">part-*.ts</text>
            <text x="610" y="155" font-size="9" fill="#64748b" text-anchor="middle">43 modules</text>
            <line x1="695" y1="100" x2="730" y2="100" stroke="#94a3b8" stroke-width="2"/>
            <polygon points="730,100 722,95 722,105" fill="#94a3b8"/>
            <rect x="735" y="30" width="145" height="140" rx="10" fill="#fdf2f8" stroke="#f472b6" stroke-width="1"/>
            <text x="807" y="50" font-size="9" font-weight="700" fill="#9d174d" text-anchor="middle">STATIC PAGES</text>
            <text x="807" y="75" font-size="10" font-weight="600" fill="#0f172a" text-anchor="middle">/quantities/*</text>
            <text x="807" y="91" font-size="10" font-weight="600" fill="#0f172a" text-anchor="middle">/kinds/*</text>
            <text x="807" y="107" font-size="10" font-weight="600" fill="#0f172a" text-anchor="middle">/units/*</text>
            <text x="807" y="123" font-size="10" font-weight="600" fill="#0f172a" text-anchor="middle">/dimensions/*</text>
            <text x="807" y="155" font-size="9" fill="#64748b" text-anchor="middle">1,675 pages</text>
          </svg>
        </div>
      </section>

      <section>
        <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100 heading-serif mb-4">Principles</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          <div class="p-5 rounded-xl bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60">
            <div class="flex items-center gap-2 mb-2">
              <div class="w-2 h-2 rounded-full bg-amber-400"></div>
              <span class="text-xs font-bold uppercase tracking-wider text-amber-600">Zero runtime fetching</span>
            </div>
            <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">All data processing happens at build time. The generated static site contains no server-side logic — just HTML, CSS, and pre-computed JSON-LD.</p>
          </div>
          <div class="p-5 rounded-xl bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60">
            <div class="flex items-center gap-2 mb-2">
              <div class="w-2 h-2 rounded-full bg-indigo-400"></div>
              <span class="text-xs font-bold uppercase tracking-wider text-indigo-600">Derived data is disposable</span>
            </div>
            <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">Kinds, hierarchy, and entity links are derived from the YAML source — never hand-edited. Delete <code class="font-mono text-xs">generated/</code> and rebuild to refresh.</p>
          </div>
          <div class="p-5 rounded-xl bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60">
            <div class="flex items-center gap-2 mb-2">
              <div class="w-2 h-2 rounded-full bg-emerald-400"></div>
              <span class="text-xs font-bold uppercase tracking-wider text-emerald-600">Single responsibility stages</span>
            </div>
            <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">Each build stage does one thing: <code class="font-mono text-xs">build-kinds</code> derives kinds, <code class="font-mono text-xs">build-hierarchy</code> derives broader/narrower. No overlap.</p>
          </div>
          <div class="p-5 rounded-xl bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60">
            <div class="flex items-center gap-2 mb-2">
              <div class="w-2 h-2 rounded-full bg-rose-400"></div>
              <span class="text-xs font-bold uppercase tracking-wider text-rose-600">Type-safe throughout</span>
            </div>
            <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">Concept types are discriminated unions. Adding a new level extends the union without modifying existing code (Open/Closed Principle).</p>
          </div>
        </div>
      </section>

    </div>
  </div>
</DefaultLayout>
