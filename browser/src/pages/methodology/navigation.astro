---
import DefaultLayout from '../../layouts/DefaultLayout.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import MethodologyNav from '../../components/MethodologyNav.astro'
import { asset } from '../../lib/asset'

const modes = [
  { icon: '📚', title: 'By Part', href: '/quantities', color: 'brand', desc: 'Browse the traditional ISO 80000 & IEC 80000 structure — Part 3 (Space & Time), Part 4 (Mechanics), through Part 13.', example: 'ISO 80000-3 → 42 entries on space and time' },
  { icon: '📐', title: 'By Kind', href: '/kinds', color: 'indigo', desc: 'Browse quantities grouped by their physical dimension. All quantities sharing the same dimension vector form a kind of quantity.', example: 'Kind L → length, width, height, wavelength, altitude' },
  { icon: '🔤', title: 'By Dimension', href: '/dimensions', color: 'indigo', desc: 'Browse by dimensional composition — the fundamental building blocks L, M, T, I, Θ, N, J. Cross-referenced with UnitsDB.', example: 'L T⁻¹ → all velocity-type quantities' },
  { icon: '⚖️', title: 'By Unit', href: '/units', color: 'teal', desc: 'Browse the complete catalog of measurement units — SI base units, derived units, accepted non-SI units.', example: 'metre (m) → used by 28+ quantities' },
  { icon: '🔗', title: 'By Concept', href: '/ontology', color: 'emerald', desc: 'Browse the ontology — SKOS concept scheme with broader/narrower relationships and RDF/JSON-LD exports.', example: 'speed → broader → phase speed, group speed' },
]
---

<DefaultLayout title="Navigation — Methodology — ISQ Browser" description="Five ways to browse the ISQ Browser dataset.">
  <div>
    <section class="relative overflow-hidden bg-gradient-to-br from-indigo-950 via-brand-950 to-iec-950">
      <div class="absolute inset-0 hero-pattern"></div>
      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-12">
        <div class="max-w-3xl page-enter">
          <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Methodology', href: '/methodology' }, { label: 'Navigation' }]} variant="dark" />
          <h1 class="text-3xl sm:text-4xl font-bold text-white tracking-tight heading-serif">Navigation</h1>
          <p class="mt-3 text-base text-indigo-200/70 leading-relaxed">
            The same dataset can be navigated through different entry points — each reveals a different facet of the ISO 80000 & IEC 80000 series.
          </p>
        </div>
      </div>
      <div class="absolute bottom-0 inset-x-0 h-12 bg-gradient-to-t from-slate-50 dark:from-dark-950 to-transparent z-10"></div>
    </section>

    <MethodologyNav active="navigation" />

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
      <div class="grid sm:grid-cols-2 gap-5">
        {modes.map((mode) => (
          <a href={asset(mode.href)} class="group relative p-6 rounded-2xl border border-slate-200/60 dark:border-dark-600/60 bg-white dark:bg-dark-800 hover:shadow-lg hover:-translate-y-0.5 transition-all">
            <div class="text-3xl mb-3">{mode.icon}</div>
            <h3 class="text-lg font-bold text-slate-900 dark:text-slate-100 mb-2">{mode.title}</h3>
            <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed mb-3">{mode.desc}</p>
            <div class="text-xs font-mono px-2 py-1 rounded bg-slate-50 dark:bg-dark-700 text-slate-600 dark:text-slate-300 inline-block">
              {mode.example}
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</DefaultLayout>
