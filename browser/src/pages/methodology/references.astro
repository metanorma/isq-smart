---
import DefaultLayout from '../../layouts/DefaultLayout.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import MethodologyNav from '../../components/MethodologyNav.astro'

const references = [
  { citation: 'JCGM (2012)', title: 'JCGM 200:2012 — International Vocabulary of Metrology (VIM)', source: 'Joint Committee for Guides in Metrology. Sèvres: BIPM.', doi: '10.59161/jcgm200-2012', note: 'Normative reference for the ISO 80000 & IEC 80000 series — defines core concepts including "kind of quantity," "quantity," and "measurement." Also published as ISO/IEC Guide 99:2007.' },
  { citation: 'Pendrill, L. R. (2024)', title: 'Quantities and units: order amongst complexity', source: 'Chapter 2 in Models, Measurement, and Metrology extending the SI. De Gruyter.', doi: '10.1515/9783111036496-002', note: 'Source of the concept system hierarchy with four levels (0–3) across three axes implemented on this site.' },
  { citation: 'Dybkaer, R. (2010)', title: 'An ontology on property for physical, chemical, and biological quantities', source: 'Metrologia, 47(3), 80–93.', doi: '10.1088/0026-1394/47/3/001', note: 'Foundation for the systematic quantity term column in Pendrill\'s hierarchy.' },
  { citation: 'Fleischman, E. (1960)', title: 'Sachgrösse und Grössenwert', source: 'Zeitschrift für Physik, 159, 1–12.', doi: null, note: 'Origin of the "Sachgrösse" (entity quantity) concept at Level 2.' },
  { citation: 'Maxwell, J. C. (1873)', title: 'A Treatise on Electricity and Magnetism', source: 'Oxford: Clarendon Press. Vol. 1, §3.', doi: null, note: 'Established the quantity value equation Q = {Q} · [Q].' },
]
---

<DefaultLayout title="References — Methodology — ISQ Browser" description="Academic references for the concept system and methodology.">
  <div>
    <section class="relative overflow-hidden bg-gradient-to-br from-amber-950 via-amber-900 to-orange-950">
      <div class="absolute inset-0 hero-pattern"></div>
      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-12">
        <div class="max-w-3xl page-enter">
          <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Methodology', href: '/methodology' }, { label: 'References' }]} variant="dark" />
          <h1 class="text-3xl sm:text-4xl font-bold text-white tracking-tight heading-serif">References</h1>
          <p class="mt-3 text-base text-amber-200/70 leading-relaxed">
            The concept system, terminology, and methodology draw on the following sources.
          </p>
        </div>
      </div>
      <div class="absolute bottom-0 inset-x-0 h-12 bg-gradient-to-t from-slate-50 dark:from-dark-950 to-transparent z-10"></div>
    </section>

    <MethodologyNav active="references" />

    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14 space-y-4">
      {references.map((ref) => (
        <div class="p-5 rounded-xl bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60">
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-brand-50 dark:bg-brand-950/40 border border-brand-100/60 dark:border-brand-800/40 flex items-center justify-center">
              <svg class="w-5 h-5 text-brand-600 dark:text-brand-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-xs font-bold uppercase tracking-wider text-brand-600 dark:text-brand-400 mb-0.5">{ref.citation}</div>
              <h4 class="text-base font-bold text-slate-900 dark:text-slate-100 leading-snug mb-1">{ref.title}</h4>
              <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed mb-2">{ref.source}</p>
              {ref.doi && (
                <a href={`https://doi.org/${ref.doi}`} target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-xs font-mono text-brand-600 dark:text-brand-400 hover:underline">
                  doi:{ref.doi}
                </a>
              )}
              <p class="text-xs text-slate-400 dark:text-slate-500 italic leading-relaxed mt-2">{ref.note}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</DefaultLayout>
