---
import DefaultLayout from '../../layouts/DefaultLayout.astro'
import MathRenderer from '../../components/MathRenderer.vue'
import DimensionOntologyPanel from '../../components/DimensionOntologyPanel.vue'
import { physicalDimensions } from '../../data/generated/physical-dimensions'
import { dimensionToKind } from '../../data/generated/concept-links'
import { entryUrl } from '../../data/PartRegistry'
import { quantitiesIndex, symbolCache } from '../../data/generated/domain-index'
import { dimensionUrns } from '../../data/urn'
import { asset } from '../../lib/asset'


export function getStaticPaths() {
  return physicalDimensions
    .filter(d => d.slug)
    .map(dim => ({
      params: { part: dim.slug },
      props: { part: dim.slug },
    }))
}

const { part } = Astro.props

const dim = physicalDimensions.find(d => d.slug === part)
const urns = dim ? dimensionUrns(dim.unitsmlId) : null
const kindLink = dim ? dimensionToKind[dim.slug] : null

const BASE_DIM_META: Record<string, { name: string; color: string }> = {
  L: { name: 'Length', color: 'sky' },
  M: { name: 'Mass', color: 'amber' },
  T: { name: 'Time', color: 'violet' },
  I: { name: 'Electric Current', color: 'orange' },
  'Θ': { name: 'Temperature', color: 'rose' },
  N: { name: 'Amount of Substance', color: 'emerald' },
  J: { name: 'Luminous Intensity', color: 'yellow' },
  'φ': { name: 'Plane Angle', color: 'cyan' },
}

function baseMeta(sym: string) {
  return BASE_DIM_META[sym] ?? { name: sym, color: 'slate' }
}

function dimColorClasses(color: string): string {
  const map: Record<string, string> = {
    sky: 'bg-sky-50 dark:bg-sky-950/30 border-sky-200 dark:border-sky-800',
    amber: 'bg-amber-50 dark:bg-amber-950/30 border-amber-200 dark:border-amber-800',
    violet: 'bg-violet-50 dark:bg-violet-950/30 border-violet-200 dark:border-violet-800',
    orange: 'bg-orange-50 dark:bg-orange-950/30 border-orange-200 dark:border-orange-800',
    rose: 'bg-rose-50 dark:bg-rose-950/30 border-rose-200 dark:border-rose-800',
    emerald: 'bg-emerald-50 dark:bg-emerald-950/30 border-emerald-200 dark:border-emerald-800',
    yellow: 'bg-yellow-50 dark:bg-yellow-950/30 border-yellow-200 dark:border-yellow-800',
    cyan: 'bg-cyan-50 dark:bg-cyan-950/30 border-cyan-200 dark:border-cyan-800',
    slate: 'bg-slate-50 dark:bg-slate-800 border-slate-200 dark:border-slate-700',
  }
  return map[color] ?? map.slate
}

// Find ISO entries linked to this dimension, enriched with symbols from quantitiesIndex
const isoEntries = dim ? dim.isoEntries.map(e => {
  const idx = quantitiesIndex.find(q => q.i === e.id)
  return {
    ...e,
    symbols: idx?.s ?? [],
    unitSymbols: idx?.u ?? [],
  }
}) : []
---

<DefaultLayout title={`Dimension: ${part} | ISQ Browser`}>
  {dim ? (
    <div>
      <section class="relative overflow-hidden bg-gradient-to-br from-indigo-950 via-indigo-900 to-violet-950">
        <div class="absolute inset-0 hero-pattern" />
        <div class="grain-overlay absolute inset-0" />
        <div class="absolute top-0 right-0 w-[800px] h-[800px] rounded-full blur-[120px] -translate-y-1/2 translate-x-1/3 bg-indigo-500/10" />
        <div class="hero-float-1 absolute top-[15%] right-[18%] w-3 h-3 rounded-full bg-indigo-400/20" />
        <div class="hero-float-2 absolute top-[30%] right-[8%] w-2 h-2 rounded-full bg-white/10" />
        <div class="hero-float-4 absolute top-[20%] left-[5%] w-16 h-16 rounded-full border border-white/[0.04]" />
        <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
          <div class="max-w-3xl page-enter">
            <div class="flex items-center gap-2 text-xs text-indigo-300/60 mb-5">
              <a href={asset("/")} class="hover:text-indigo-200 transition-colors">Home</a>
              <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
              <a href={asset("/dimensions")} class="hover:text-indigo-200 transition-colors">Dimensions</a>
              <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
            </div>

            <div class="flex items-end gap-5 flex-wrap">
              <a href="https://www.unitsml.org" target="_blank" rel="noopener" class="group flex-shrink-0">
                <img src={asset('/img/unitsml-symbol.svg')} alt="UnitsML" class="h-10 w-auto" />
              </a>
              <div>
                <div class="flex items-center gap-3">
                  <h1 class="text-3xl sm:text-4xl font-bold text-white tracking-tight heading-serif">{dim.name}</h1>
                  <a href="https://www.unitsml.org" target="_blank" rel="noopener" class="group">
                    <img src={asset('/img/unitsml-text.svg')} alt="UnitsML" class="h-4 w-auto brightness-0 invert" />
                  </a>
                </div>
                <p class="mt-1 text-sm text-indigo-300/60">
                  Dimension vector
                  {!dim.dimensionless && (
                    <span class="font-mono text-white/80 ml-1">{dim.vectorNotation}</span>
                  )}
                  {dim.dimensionless && (
                    <span class="text-emerald-300/80 ml-1">dimensionless</span>
                  )}
                  <span class="mx-1.5 text-indigo-400/30">&middot;</span>
                  <span class="font-mono">{dim.unitsmlId}</span>
                  <span class="mx-1.5 text-indigo-400/30">&middot;</span>
                  <a href={`https://unitsml.org/unitsdb/dimensions/${dim.unitsmlId}`} target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-indigo-300 hover:text-indigo-200 transition-colors">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
                    UnitsML
                  </a>
                </p>
              </div>

              <div class="flex gap-2 ml-auto flex-shrink-0 mb-1">
                {dim.isoEntries.length > 0 && (
                  <div class="px-3 py-1.5 rounded-lg bg-white/[0.06] border border-white/[0.08]">
                    <span class="text-lg font-bold text-white heading-serif tabular-nums">{dim.isoEntries.length}</span>
                    <span class="text-xs ml-1 text-indigo-300/70">ISQ</span>
                  </div>
                )}
                {dim.isoUnitSlugs.length > 0 && (
                  <div class="px-3 py-1.5 rounded-lg bg-white/[0.06] border border-white/[0.08]">
                    <span class="text-lg font-bold text-white heading-serif tabular-nums">{dim.isoUnitSlugs.length}</span>
                    <span class="text-xs ml-1 text-indigo-300/70">units</span>
                  </div>
                )}
              </div>
            </div>
          </div>
        </div>
        <div class="absolute bottom-0 inset-x-0 h-12 bg-gradient-to-t from-slate-50 dark:from-dark-950 to-transparent z-10" />
      </section>

      {kindLink?.kindId && (
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-2 mb-6 relative z-20">
          <a
            href={asset(`/kinds/${kindLink.kindId.replace(/^kind-/, '')}`)}
            class="group flex items-center gap-4 p-4 rounded-xl border border-indigo-200/50 dark:border-indigo-800/40 bg-gradient-to-r from-indigo-50/60 to-violet-50/40 dark:from-indigo-950/30 dark:to-violet-950/20 hover:shadow-sm transition-all"
          >
            <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-indigo-100 dark:bg-indigo-900/40 flex items-center justify-center">
              <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25a2.25 2.25 0 01-2.25-2.25v-2.25z"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-[10px] font-bold uppercase tracking-wider text-indigo-500 dark:text-indigo-400 mb-0.5">Corresponding kind of quantity</div>
              <div class="text-sm font-bold text-slate-900 dark:text-slate-100 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
                {kindLink.kindMemberCount} {kindLink.kindMemberCount === 1 ? 'quantity' : 'quantities'} of this kind
                {kindLink.kindOnlyQuantityIds.length > 0 && (
                  <span class="text-[10px] font-normal text-slate-400 ml-1">({kindLink.kindOnlyQuantityIds.length} additional from unit analysis)</span>
                )}
              </div>
            </div>
            <svg class="w-4 h-4 text-slate-300 dark:text-slate-600 group-hover:text-indigo-500 dark:group-hover:text-indigo-400 group-hover:translate-x-0.5 transition-all flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      )}

      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-4 relative z-20 mb-6">
        {dim.vector.length > 0 && (
          <div class="rounded-xl bg-white dark:bg-dark-900 border border-slate-200/70 dark:border-dark-600/60 p-5">
            <h3 class="text-xs font-bold text-slate-900 dark:text-slate-100 uppercase tracking-wider mb-3">Base dimension composition</h3>
            <div class="flex flex-wrap gap-3">
              {dim.vector.map((comp) => (
                <div class={`flex items-center gap-2 px-4 py-2.5 rounded-lg border ${dimColorClasses(baseMeta(comp.base).color)}`}>
                  <span class="font-mono text-xl font-bold">{comp.base}</span>
                  <div>
                    <div class="text-xs font-medium text-slate-700 dark:text-slate-300">{baseMeta(comp.base).name}</div>
                    <div class="text-[10px] font-mono text-slate-500 dark:text-slate-400">power = {comp.power}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </section>

      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        {urns && (
          <div class="mb-6 rounded-xl border border-slate-200/60 dark:border-dark-600/60 bg-white dark:bg-dark-900 p-5">
            <h3 class="text-[10px] font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-3">ISQ Identifiers</h3>
            <div class="grid sm:grid-cols-2 gap-3">
              <div>
                <div class="text-[10px] font-semibold text-brand-600 dark:text-brand-400 mb-1">ISO URN</div>
                <code class="text-xs font-mono text-slate-700 dark:text-slate-300 break-all block bg-brand-50/50 dark:bg-brand-950/20 px-3 py-2 rounded-lg">{urns.iso}</code>
              </div>
              <div>
                <div class="text-[10px] font-semibold text-teal-600 dark:text-teal-400 mb-1">IEC URN</div>
                <code class="text-xs font-mono text-slate-700 dark:text-slate-300 break-all block bg-teal-50/50 dark:bg-teal-950/20 px-3 py-2 rounded-lg">{urns.iec}</code>
              </div>
            </div>
          </div>
        )}

        <DimensionOntologyPanel client:idle dim={dim} />
      </section>

      {isoEntries.length > 0 && (
        <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
          <div class="flex items-center gap-2 mb-4">
            <h3 class="text-xs font-bold text-slate-900 dark:text-slate-100 uppercase tracking-wider">ISO 80000 &amp; IEC 80000 quantities with this dimension</h3>
            <div class="flex-1 h-px bg-slate-200/60 dark:bg-dark-600/60" />
            <span class="text-[10px] text-slate-400 dark:text-slate-500">{isoEntries.length} quantit{isoEntries.length === 1 ? 'y' : 'ies'}</span>
          </div>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-2">
            {isoEntries.map((entry) => (
              <a
                href={entryUrl(entry.part, entry.id)}
                class="group flex items-center gap-3 px-4 py-3 rounded-xl border border-slate-200/60 dark:border-dark-600/60 bg-white dark:bg-dark-900 hover:border-indigo-200 dark:hover:border-indigo-800 hover:shadow-sm transition-all"
              >
                <span class="font-mono text-[11px] font-semibold text-brand-700 dark:text-brand-400 bg-brand-50/80 dark:bg-brand-950/40 px-2 py-0.5 rounded flex-shrink-0">{entry.num}</span>
                <div class="min-w-0">
                  <span class="text-sm font-medium text-slate-800 dark:text-slate-200 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors truncate block">{entry.name}</span>
                  <span class="text-[10px] text-slate-400 dark:text-slate-500">
                    Part {entry.part}
                    {entry.unitSymbols.length > 0 && (
                      <>
                        <span> &middot; </span>
                        {entry.unitSymbols.map((us, usi) => (
                          <>
                            {symbolCache[us] ? (
                              <MathRenderer client:visible expression={us} cache={symbolCache} />
                            ) : (
                              <span class="font-mono">{us}</span>
                            )}
                            {usi < entry.unitSymbols.length - 1 && <span>, </span>}
                          </>
                        ))}
                      </>
                    )}
                  </span>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      {dim.isoUnitSlugs.length > 0 && (
        <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
          <div class="flex items-center gap-2 mb-4">
            <h3 class="text-xs font-bold text-slate-900 dark:text-slate-100 uppercase tracking-wider">Units with this dimension</h3>
            <div class="flex-1 h-px bg-slate-200/60 dark:bg-dark-600/60" />
          </div>
          <div class="flex flex-wrap gap-2">
            {dim.isoUnitSlugs.map((uslug) => (
              <a
                href={`/units/${uslug}`}
                class="group px-3 py-2 rounded-lg border border-slate-200/60 dark:border-dark-600/60 bg-white dark:bg-dark-900 hover:border-teal-200 dark:hover:border-teal-800 hover:shadow-sm transition-all text-sm"
              >
                <span class="font-medium text-slate-800 dark:text-slate-200 group-hover:text-teal-600 dark:group-hover:text-teal-400 transition-colors">{uslug.replace(/-/g, ' ')}</span>
              </a>
            ))}
          </div>
        </section>
      )}

      {dim.linkedQuantities.length > 0 && (
        <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
          <div class="flex items-center gap-2 mb-4">
            <h3 class="text-xs font-bold text-slate-900 dark:text-slate-100 uppercase tracking-wider">UnitsML quantities</h3>
            <div class="flex-1 h-px bg-slate-200/60 dark:bg-dark-600/60" />
            <span class="text-[10px] font-medium text-indigo-500/60 bg-indigo-50 dark:bg-indigo-950/30 px-2 py-0.5 rounded-md">UnitsML</span>
          </div>
          <div class="flex flex-wrap gap-2">
            {dim.linkedQuantities.map((qn) => (
              <span class="px-3 py-1.5 rounded-lg bg-slate-50 dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 text-xs font-medium text-slate-700 dark:text-slate-300">{qn.replace(/_/g, ' ')}</span>
            ))}
          </div>
        </section>
      )}
    </div>
  ) : (
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
      <div class="text-4xl mb-4">📐</div>
      <h1 class="text-2xl font-bold text-slate-900 dark:text-slate-100 heading-serif">Dimension not found</h1>
      <p class="text-sm text-slate-500 dark:text-slate-400 mt-2">"{part}" is not a valid physical dimension.</p>
      <a href={asset("/dimensions")} class="mt-6 inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-brand-600 text-white text-sm font-medium hover:bg-brand-700 transition-colors">
        View all dimensions
      </a>
    </div>
  )}
</DefaultLayout>
