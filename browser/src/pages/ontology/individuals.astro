---
import DefaultLayout from '../../layouts/DefaultLayout.astro'
import { asset } from '../../lib/asset'
import { ontologyEntities } from '../../data/generated/ontology'

interface Entity {
  uri: string
  qname: string
  slug: string
  label: string
  description: string
  ontology: string
  type: string
  instanceOf?: string[]
}

const allEntities = ontologyEntities as readonly Entity[]
const individuals = allEntities.filter(e => e.type === 'individual')

function badgeColor(e: Entity) {
  if (e.ontology === 'smart') return 'bg-emerald-50 text-emerald-600 dark:bg-emerald-900/40 dark:text-emerald-400'
  if (e.ontology === 'isq') return 'bg-brand-50 text-brand-600 dark:bg-brand-900/40 dark:text-brand-400'
  return 'bg-slate-100 text-slate-600 dark:bg-dark-700 dark:text-slate-400'
}

function entitySlug(qname: string | undefined) {
  if (!qname) return undefined
  return allEntities.find(e => e.qname === qname)?.slug
}
---

<DefaultLayout title="Ontology Named Individuals — ISQ Browser" description="Named individuals of the ISO & IEC 80000 and SMART Core ontologies.">
  <div>
    <!-- Hero -->
    <section class="relative overflow-hidden bg-gradient-to-br from-emerald-950 via-emerald-900 to-teal-950">
      <div class="absolute inset-0 hero-pattern"></div>
      <div class="grain-overlay absolute inset-0"></div>
      <div class="absolute top-0 right-0 w-[800px] h-[800px] rounded-full blur-[120px] -translate-y-1/2 translate-x-1/3 bg-emerald-500/10"></div>
      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
        <div class="max-w-3xl page-enter">
          <div class="flex items-center gap-2 text-xs text-emerald-300/60 mb-5">
            <a href={asset("/")} class="hover:text-emerald-200 transition-colors">Home</a>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
            <a href={asset("/ontology")} class="hover:text-emerald-200 transition-colors">Ontology</a>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
            <span class="text-emerald-200">Individuals</span>
          </div>

          <h1 class="text-3xl sm:text-4xl font-bold text-white tracking-tight heading-serif">Named Individuals</h1>
          <p class="mt-2 text-sm leading-relaxed max-w-xl text-emerald-300/80">
            Concrete instances of ontology classes — specific named entities with defined identities.
          </p>
          <div class="flex gap-2 mt-4">
            <div class="px-3 py-1.5 rounded-lg bg-white/[0.06] border border-white/[0.08]">
              <span class="text-lg font-bold text-white heading-serif tabular-nums">{individuals.length}</span>
              <span class="text-xs ml-1 text-emerald-300/70">individuals</span>
            </div>
          </div>
        </div>
      </div>
      <div class="absolute bottom-0 inset-x-0 h-12 bg-gradient-to-t from-slate-50 dark:from-dark-950 to-transparent z-10"></div>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      {individuals.length === 0 ? (
        <div class="rounded-2xl border border-slate-200/80 dark:border-dark-600/80 bg-white dark:bg-dark-800 p-8 text-center">
          <p class="text-sm text-slate-500">No named individuals defined.</p>
        </div>
      ) : (
        <div class="rounded-2xl border border-slate-200/80 dark:border-dark-600/80 bg-white dark:bg-dark-800 overflow-hidden">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-slate-50/80 dark:bg-dark-800/80 border-b border-slate-200/60 dark:border-dark-600/60">
                <th class="text-left px-4 py-2 font-semibold text-slate-500 text-xs">Individual</th>
                <th class="text-left px-4 py-2 font-semibold text-slate-500 text-xs">Instance Of</th>
                <th class="text-left px-4 py-2 font-semibold text-slate-500 text-xs">Description</th>
                <th class="text-center px-4 py-2 font-semibold text-slate-500 text-xs">Ontology</th>
              </tr>
            </thead>
            <tbody>
              {individuals.map((ind) => (
                <tr class="border-b border-slate-100/60 dark:border-dark-700/60 last:border-0 hover:bg-slate-50/50 dark:hover:bg-dark-700/50">
                  <td class="px-4 py-2">
                    <a href={asset(`/ontology/${ind.slug}`)} class="text-brand-600 dark:text-brand-400 hover:underline font-medium">{ind.label}</a>
                    <code class="ml-1 text-xs text-slate-400">{ind.qname}</code>
                  </td>
                  <td class="px-4 py-2">
                    {ind.instanceOf?.length ? ind.instanceOf.map((t, i) => (
                      <span>
                        {i > 0 && ', '}
                        {entitySlug(t) ? (
                          <a href={asset(`/ontology/${entitySlug(t)}`)} class="text-blue-600 dark:text-blue-400 hover:underline">{t}</a>
                        ) : t}
                      </span>
                    )) : <span class="text-slate-400">—</span>}
                  </td>
                  <td class="px-4 py-2 text-slate-600 dark:text-slate-400 max-w-sm truncate">{ind.description || '—'}</td>
                  <td class="px-4 py-2 text-center">
                    <span class={`text-xs font-semibold px-1.5 py-0.5 rounded ${badgeColor(ind)}`}>{ind.ontology}</span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </section>
  </div>
</DefaultLayout>
