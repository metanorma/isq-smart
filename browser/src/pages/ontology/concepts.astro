---
import DefaultLayout from '../../layouts/DefaultLayout.astro'
import { asset } from '../../lib/asset'
import { ontologyEntities } from '../../data/generated/ontology'

interface Entity {
  uri: string
  qname: string
  slug: string
  label: string
  description: string
  ontology: string
  type: string
  scheme?: string
  instanceOf?: string[]
  topConcepts?: string[]
}

const allEntities = ontologyEntities as readonly Entity[]

const concepts = allEntities.filter(e => e.type === 'concept')
const conceptSchemes = allEntities.filter(e => e.type === 'conceptScheme')

function entitySlug(qname: string | undefined) {
  if (!qname) return undefined
  return allEntities.find(e => e.qname === qname)?.slug
}

// Group concepts by scheme; concepts without a scheme go into "unassigned"
const conceptsByScheme = (() => {
  const groups = new Map<string | null, Entity[]>()
  for (const c of concepts) {
    const key = c.scheme ?? null
    if (!groups.has(key)) groups.set(key, [])
    groups.get(key)!.push(c)
  }
  return groups
})()
---

<DefaultLayout title="Ontology SKOS Concepts — ISQ Browser" description="SKOS concepts and concept schemes of the ISO & IEC 80000 and SMART Core ontologies.">
  <div>
    <!-- Hero -->
    <section class="relative overflow-hidden bg-gradient-to-br from-emerald-950 via-emerald-900 to-teal-950">
      <div class="absolute inset-0 hero-pattern"></div>
      <div class="grain-overlay absolute inset-0"></div>
      <div class="absolute top-0 right-0 w-[800px] h-[800px] rounded-full blur-[120px] -translate-y-1/2 translate-x-1/3 bg-emerald-500/10"></div>
      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
        <div class="max-w-3xl page-enter">
          <div class="flex items-center gap-2 text-xs text-emerald-300/60 mb-5">
            <a href={asset("/")} class="hover:text-emerald-200 transition-colors">Home</a>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
            <a href={asset("/ontology")} class="hover:text-emerald-200 transition-colors">Ontology</a>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
            <span class="text-emerald-200">Concepts</span>
          </div>

          <h1 class="text-3xl sm:text-4xl font-bold text-white tracking-tight heading-serif">SKOS Concepts</h1>
          <p class="mt-2 text-sm leading-relaxed max-w-xl text-emerald-300/80">
            Controlled vocabularies and taxonomies defined using SKOS (Simple Knowledge Organization System).
          </p>
          <div class="flex gap-2 mt-4">
            <div class="px-3 py-1.5 rounded-lg bg-white/[0.06] border border-white/[0.08]">
              <span class="text-lg font-bold text-white heading-serif tabular-nums">{conceptSchemes.length}</span>
              <span class="text-xs ml-1 text-emerald-300/70">concept schemes</span>
            </div>
            <div class="px-3 py-1.5 rounded-lg bg-white/[0.06] border border-white/[0.08]">
              <span class="text-lg font-bold text-white heading-serif tabular-nums">{concepts.length}</span>
              <span class="text-xs ml-1 text-emerald-300/70">concepts</span>
            </div>
          </div>
        </div>
      </div>
      <div class="absolute bottom-0 inset-x-0 h-12 bg-gradient-to-t from-slate-50 dark:from-dark-950 to-transparent z-10"></div>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-6">
      {conceptSchemes.length === 0 && concepts.length === 0 ? (
        <div class="rounded-2xl border border-slate-200/80 dark:border-dark-600/80 bg-white dark:bg-dark-800 p-8 text-center">
          <p class="text-sm text-slate-500">No SKOS concepts or concept schemes defined.</p>
        </div>
      ) : (
        <>
          {conceptSchemes.map((scheme) => {
            const schemeConcepts = conceptsByScheme.get(scheme.qname) ?? []
            return (
              <div class="rounded-2xl border border-slate-200/80 dark:border-dark-600/80 bg-white dark:bg-dark-800 p-6">
                <div class="flex items-center gap-2 mb-3">
                  <span class="text-[9px] font-semibold px-1.5 py-0.5 rounded bg-cyan-50 text-cyan-600 dark:bg-cyan-950/40 dark:text-cyan-400">Scheme</span>
                  <a href={asset(`/ontology/${scheme.slug}`)} class="text-sm font-bold text-slate-800 dark:text-slate-200 hover:underline">{scheme.label}</a>
                  <span class="text-xs text-slate-400">({schemeConcepts.length} concepts)</span>
                </div>
                <code class="text-xs text-slate-500 font-mono block mb-3 break-all">{scheme.uri}</code>
                {scheme.description && <p class="text-xs text-slate-500 mb-3">{scheme.description}</p>}
                <div class="overflow-x-auto rounded-lg border border-slate-200/60 dark:border-dark-600/60">
                  <table class="w-full text-xs">
                    <thead>
                      <tr class="bg-slate-50/80 dark:bg-dark-800/80 border-b border-slate-200/60 dark:border-dark-600/60">
                        <th class="text-left px-3 py-2 font-semibold text-slate-500">Concept</th>
                        <th class="text-left px-3 py-2 font-semibold text-slate-500">Description</th>
                        <th class="text-left px-3 py-2 font-semibold text-slate-500">Instance Of</th>
                      </tr>
                    </thead>
                    <tbody>
                      {schemeConcepts.map((c) => (
                        <tr class="border-b border-slate-100/60 dark:border-dark-700/60 last:border-0 hover:bg-slate-50/50 dark:hover:bg-dark-700/50">
                          <td class="px-3 py-2">
                            <a href={asset(`/ontology/${c.slug}`)} class="text-teal-700 dark:text-teal-400 hover:underline font-medium">{c.label}</a>
                            <code class="ml-1 text-[9px] text-slate-400">{c.qname}</code>
                          </td>
                          <td class="px-3 py-2 text-slate-600 dark:text-slate-400 max-w-sm">{c.description || '—'}</td>
                          <td class="px-3 py-2">
                            {c.instanceOf?.length ? c.instanceOf.map((t, i) => (
                              <span>
                                {i > 0 && ', '}
                                {entitySlug(t) ? (
                                  <a href={asset(`/ontology/${entitySlug(t)}`)} class="text-blue-600 dark:text-blue-400 hover:underline">{t}</a>
                                ) : t}
                              </span>
                            )) : <span class="text-slate-400">—</span>}
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            )
          })}

          {/* Unassigned concepts (no scheme) */}
          {(() => {
            const unassigned = conceptsByScheme.get(null) ?? []
            if (unassigned.length === 0) return null
            return (
              <div class="rounded-2xl border border-slate-200/80 dark:border-dark-600/80 bg-white dark:bg-dark-800 p-6">
                <div class="flex items-center gap-2 mb-3">
                  <span class="text-[9px] font-semibold px-1.5 py-0.5 rounded bg-slate-100 text-slate-500 dark:bg-dark-700 dark:text-slate-400">Unassigned</span>
                  <h2 class="text-sm font-bold text-slate-700 dark:text-slate-200">Concepts without a scheme</h2>
                  <span class="text-xs text-slate-400">({unassigned.length})</span>
                </div>
                <div class="flex flex-wrap gap-1.5">
                  {unassigned.map((c) => (
                    <a
                      href={asset(`/ontology/${c.slug}`)}
                      class="text-[10px] font-medium px-2 py-1 rounded-lg border border-slate-200/60 dark:border-dark-600/60 bg-slate-50/50 dark:bg-dark-700/50 text-slate-600 dark:text-slate-400 hover:border-teal-200 hover:text-teal-600 dark:hover:text-teal-400 transition-colors"
                    >
                      {c.label}
                    </a>
                  ))}
                </div>
              </div>
            )
          })()}
        </>
      )}
    </section>
  </div>
</DefaultLayout>
