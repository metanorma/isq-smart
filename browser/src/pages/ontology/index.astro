            </div>
            <code class="text-xs text-slate-500 block mb-3">{scheme.uri}</code>
            <div class="overflow-x-auto rounded-lg border border-slate-200/60">
              <table class="w-full text-xs">
                <thead>
                  <tr class="bg-slate-50/80 dark:bg-dark-800/80 border-b border-slate-200/60 dark:border-dark-600/60">
                    <th class="text-left px-3 py-2 font-semibold text-slate-500">Concept</th>
                    <th class="text-left px-3 py-2 font-semibold text-slate-500">Description</th>
                    <th class="text-left px-3 py-2 font-semibold text-slate-500">Instance Of</th>
                  </tr>
                </thead>
                <tbody>
                  {allEntities.filter(e => e.type === 'concept' && e.scheme === scheme.qname).map((c) => (
                    <tr class="border-b border-slate-100/60 last:border-0 hover:bg-slate-50/50 dark:hover:bg-dark-700/50">
                      <td class="px-3 py-2">
                        <a href={`/ontology/${c.slug}`} class="text-teal-700 hover:underline font-medium">{c.label}</a>
                        <code class="ml-1 text-[9px] text-slate-400">{c.qname}</code>
                      </td>
                      <td class="px-3 py-2 text-slate-600 max-w-sm">{c.description || '—'}</td>
                      <td class="px-3 py-2">
                        {c.instanceOf?.length ? c.instanceOf.map((t, i) => (
                          <Fragment>
                            <a href={`/ontology/${allEntities.find(e => e.qname === t)?.slug}`} class="text-blue-600 hover:underline">{t}</a>
                            {i < c.instanceOf!.length - 1 && <span>, </span>}
                          </Fragment>
                        )) : null}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        ))}
      </div>

      <!-- ═══════════════════════════════════════════════════════════════════════ -->
      <!-- SHAPES                                                                -->
      <!-- ═══════════════════════════════════════════════════════════════════════ -->
      <div data-section="shapes" class="mt-8 space-y-4 hidden">
        {shapes.map((s) => (
          <div class="rounded-2xl border border-slate-200/80 dark:border-dark-600/80 bg-white dark:bg-dark-800 p-6 filter-entity" data-label={s.label.toLowerCase()} data-qname={s.qname.toLowerCase()} data-ontology={s.ontology}>
            <div class="flex items-center gap-2 mb-2">
              <span class="text-[9px] font-semibold px-1.5 py-0.5 rounded bg-purple-50 text-purple-600">Shape</span>
              <a href={`/ontology/${s.slug}`} class="text-sm font-bold text-brand-600 hover:underline">{s.qname}</a>
              <span class={`text-[9px] font-semibold px-1.5 py-0.5 rounded ${badgeColor(s)}`}>{s.ontology}</span>
            </div>
            <div class="text-xs text-slate-500 mb-3">
              {s.targetClass && <span>Target: <a href={`/ontology/${allEntities.find(e => e.qname === s.targetClass)?.slug}`} class="text-blue-600 hover:underline">{s.targetClass}</a></span>}
              {s.targetSubjectsOf && <span>Subjects of: <a href={`/ontology/${allEntities.find(e => e.qname === s.targetSubjectsOf)?.slug}`} class="text-blue-600 hover:underline">{s.targetSubjectsOf}</a></span>}
              {s.targetObjectsOf && <span>Objects of: {s.targetObjectsOf}</span>}
            </div>
            {s.constraints?.length ? (
              <div class="overflow-x-auto rounded-lg border border-slate-200/60">
                <table class="w-full text-xs">
                  <thead>
                    <tr class="bg-slate-50/80 dark:bg-dark-800/80 border-b border-slate-200/60 dark:border-dark-600/60">
                      <th class="text-left px-3 py-2 font-semibold text-slate-500">Property</th>
                      <th class="text-center px-3 py-2 font-semibold text-slate-500">Min</th>
                      <th class="text-center px-3 py-2 font-semibold text-slate-500">Max</th>
                      <th class="text-left px-3 py-2 font-semibold text-slate-500">Type / Class</th>
                      <th class="text-left px-3 py-2 font-semibold text-slate-500">Node Kind</th>
                    </tr>
                  </thead>
                  <tbody>
                    {s.constraints.map((c, i) => (
                      <tr class="border-b border-slate-100/60 last:border-0">
                        <td class="px-3 py-2">
                          {allEntities.find(e => e.qname === c.path) ? (
                            <a href={`/ontology/${allEntities.find(e => e.qname === c.path)!.slug}`} class="text-blue-600 hover:underline">{c.path}</a>
                          ) : (
                            <span class="font-mono">{c.path}</span>
                          )}
                        </td>
                        <td class="px-3 py-2 text-center">{c.minCount ?? '—'}</td>
                        <td class="px-3 py-2 text-center">{c.maxCount ?? '—'}</td>
                        <td class="px-3 py-2">
                          {c.datatype && <span class="italic">{c.datatype}</span>}
                          {!c.datatype && c.classValue && (
                            <a href={`/ontology/${allEntities.find(e => e.qname === c.classValue)?.slug}`} class="text-blue-600 hover:underline">{c.classValue}</a>
                          )}
                          {c.hasValue && <span class="text-slate-400 ml-1">= {c.hasValue}</span>}
                        </td>
                        <td class="px-3 py-2">{c.nodeKind || '—'}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ) : null}
          </div>
        ))}
      </div>

      <!-- ═══════════════════════════════════════════════════════════════════════ -->
      <!-- INDIVIDUALS                                                           -->
      <!-- ═══════════════════════════════════════════════════════════════════════ -->
      <div data-section="individuals" class="mt-8 space-y-4 hidden">
        <div class="rounded-2xl border border-slate-200/80 dark:border-dark-600/80 bg-white dark:bg-dark-800 overflow-hidden">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-slate-50/80 dark:bg-dark-800/80 border-b border-slate-200/60 dark:border-dark-600/60">
                <th class="text-left px-4 py-2 font-semibold text-slate-500 text-xs">Individual</th>
                <th class="text-left px-4 py-2 font-semibold text-slate-500 text-xs">Instance Of</th>
                <th class="text-center px-4 py-2 font-semibold text-slate-500 text-xs">Ontology</th>
              </tr>
            </thead>
            <tbody>
              {individuals.map((ind) => (
                <tr class="border-b border-slate-100/60 last:border-0 hover:bg-slate-50/50 dark:hover:bg-dark-700/50 filter-entity" data-label={ind.label.toLowerCase()} data-qname={ind.qname.toLowerCase()} data-ontology={ind.ontology}>
                  <td class="px-4 py-2">
                    <a href={`/ontology/${ind.slug}`} class="text-brand-600 hover:underline font-medium">{ind.label}</a>
                    <code class="ml-1 text-[9px] text-slate-400">{ind.qname}</code>
                  </td>
                  <td class="px-4 py-2">
                    {ind.instanceOf?.length ? ind.instanceOf.map((t, i) => (
                      <Fragment>
                        <a href={`/ontology/${allEntities.find(e => e.qname === t)?.slug}`} class="text-blue-600 hover:underline">{t}</a>
                        {i < ind.instanceOf!.length - 1 && <span>, </span>}
                      </Fragment>
                    )) : null}
                  </td>
                  <td class="px-4 py-2 text-center">
                    <span class={`text-[9px] font-semibold px-1.5 py-0.5 rounded ${badgeColor(ind)}`}>{ind.ontology}</span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════════════════════════════ -->
      <!-- STATISTICS                                                            -->
      <!-- ═══════════════════════════════════════════════════════════════════════ -->
      <div data-section="statistics" class="mt-8 space-y-6 hidden">
        <!-- Entity type bar chart (loaded lazily via client script) -->
        <div class="rounded-2xl border border-slate-200/80 dark:border-dark-600/80 bg-white dark:bg-dark-800 p-6">
          <h3 class="text-sm font-bold text-slate-700 dark:text-slate-200 mb-4">Entity Distribution</h3>
          <div class="h-64">
            <canvas id="type-chart" data-types={JSON.stringify(chartTypeLabels)} data-counts={JSON.stringify(chartTypeCounts)} data-colors={JSON.stringify(chartTypeColors)}></canvas>
          </div>
          <div class="mt-4 grid sm:grid-cols-2 gap-3">
            {Object.entries(typeMeta).map(([type, meta]) => (
              <div class="flex items-center gap-3 px-3 py-2 rounded-lg bg-slate-50 dark:bg-dark-700 border border-slate-200/60 dark:border-dark-600/60">
                <span class={`w-2.5 h-2.5 rounded-full flex-shrink-0 ${meta.colorDot}`}></span>
                <span class="text-xs text-slate-700 dark:text-slate-300">{meta.label}</span>
                <span class="ml-auto text-sm font-bold text-slate-900 dark:text-slate-100 tabular-nums">{allEntities.filter(e => e.type === type).length}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Ontology breakdown doughnut -->
        <div class="grid sm:grid-cols-2 gap-6">
          <div class="rounded-2xl border border-slate-200/80 dark:border-dark-600/80 bg-white dark:bg-dark-800 p-6">
            <h3 class="text-sm font-bold text-slate-700 dark:text-slate-200 mb-4">Ontology Breakdown</h3>
            <div class="h-56">
              <canvas id="onto-chart" data-labels={JSON.stringify(ontoDisplayLabels)} data-counts={JSON.stringify(ontoCounts)} data-colors={JSON.stringify(ontoColors)}></canvas>
            </div>
          </div>

          <div class="rounded-2xl border border-slate-200/80 dark:border-dark-600/80 bg-white dark:bg-dark-800 p-6">
            <h3 class="text-sm font-bold text-slate-700 dark:text-slate-200 mb-4">Summary</h3>
            <div class="space-y-3">
              {ontologyNamespaces.map((onto) => (
                <div class={`px-4 py-3 rounded-xl border ${onto.color === 'emerald' ? 'bg-emerald-50/50 border-emerald-200/40' : 'bg-brand-50/50 border-brand-200/40'}`}>
                  <div class={`text-2xl font-bold ${onto.color === 'emerald' ? 'text-emerald-700' : 'text-brand-700'}`}>{allEntities.filter(e => e.ontology === onto.prefix).length}</div>
                  <div class={`text-[10px] font-semibold uppercase tracking-wider mt-1 ${onto.color === 'emerald' ? 'text-emerald-600' : 'text-brand-600'}`}>{onto.title}</div>
                </div>
              ))}
              <div class="px-4 py-3 rounded-xl bg-slate-50 dark:bg-dark-700 border border-slate-200/60 dark:border-dark-600/60">
                <div class="text-2xl font-bold text-slate-900 dark:text-slate-100">{allEntities.length}</div>
                <div class="text-[10px] font-semibold text-slate-400 uppercase tracking-wider mt-1">Total Entities</div>
              </div>
            </div>
          </div>
        </div>

        <div class="rounded-2xl border border-slate-200/80 dark:border-dark-600/80 bg-white dark:bg-dark-800 p-6">
          <h3 class="text-sm font-bold text-slate-700 dark:text-slate-200 mb-4">Namespaces Used ({ontologyPrefixes.length})</h3>
          <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-2">
            {ontologyPrefixes.map((ns) => (
              <div class="flex items-center gap-2 px-3 py-2 rounded-lg bg-slate-50 dark:bg-dark-700 border border-slate-200/60 dark:border-dark-600/60">
                <span class="text-[10px] font-semibold px-1.5 py-0.5 rounded bg-slate-200 dark:bg-dark-600 text-slate-700 dark:text-slate-300 font-mono">{ns.prefix || ':'}</span>
                <span class="text-xs text-slate-500 font-mono truncate">{ns.uri}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

    </section>
  </div>

  <script>
    // Tab switching
    const tabs = document.querySelectorAll('[data-section-btn]')
    const sections = document.querySelectorAll('[data-section]')
    const filterWrapper = document.getElementById('filter-wrapper')
    const ontologyFilter = document.getElementById('ontology-filter')
    const filterableSections = ['classes', 'properties', 'az', 'shapes', 'individuals', 'skos']
    const ontologyFilterSections = ['classes', 'properties', 'skos', 'shapes', 'individuals']

    tabs.forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-section-btn')!
        // Update tab styles
        tabs.forEach(t => {
          t.classList.remove('bg-white', 'dark:bg-dark-800', 'text-slate-800', 'dark:text-slate-100', 'shadow-sm', 'dark:shadow-none')
          t.classList.add('text-slate-500', 'hover:text-slate-700', 'dark:hover:text-slate-300')
        })
        btn.classList.add('bg-white', 'dark:bg-dark-800', 'text-slate-800', 'dark:text-slate-100', 'shadow-sm', 'dark:shadow-none')
        btn.classList.remove('text-slate-500', 'hover:text-slate-700', 'dark:hover:text-slate-300')
        // Show/hide sections
        sections.forEach(s => {
          if (s.getAttribute('data-section') === target) {
            s.classList.remove('hidden')
          } else {
            s.classList.add('hidden')
          }
        })
        // Show/hide filter input
        if (filterWrapper) {
          filterableSections.includes(target) ? filterWrapper.classList.remove('hidden') : filterWrapper.classList.add('hidden')
        }
        // Show/hide ontology filter
        if (ontologyFilter) {
          ontologyFilterSections.includes(target) ? ontologyFilter.classList.remove('hidden') : ontologyFilter.classList.add('hidden')
        }
        // Lazy-load charts when statistics tab is opened
        if (target === 'statistics') loadCharts()
      })
    })

    // Entity filter
    const filterInput = document.getElementById('entity-filter') as HTMLInputElement | null
    filterInput?.addEventListener('input', () => {
      const q = filterInput.value.toLowerCase()
      document.querySelectorAll('.filter-entity').forEach(el => {
        const label = el.getAttribute('data-label') || ''
        const qname = el.getAttribute('data-qname') || ''
        const visible = !q || label.includes(q) || qname.includes(q)
        ;(el as HTMLElement).style.display = visible ? '' : 'none'
      })
    })

    // Ontology filter
    let currentOntologyFilter = 'all'
    document.querySelectorAll('[data-ontology-filter]').forEach(btn => {
      btn.addEventListener('click', () => {
        currentOntologyFilter = btn.getAttribute('data-ontology-filter')!
        // Update button styles
        document.querySelectorAll('[data-ontology-filter]').forEach(b => {
          b.classList.remove('bg-white', 'dark:bg-dark-800', 'shadow-sm', 'dark:shadow-none',
            'text-brand-700', 'dark:text-brand-400', 'text-emerald-700', 'dark:text-emerald-400',
            'text-slate-800', 'dark:text-slate-100')
          b.classList.add('text-slate-500', 'hover:text-slate-700', 'dark:hover:text-slate-300')
        })
        const activeClasses: Record<string, string[]> = {
          isq: ['bg-white', 'dark:bg-dark-800', 'text-brand-700', 'dark:text-brand-400', 'shadow-sm', 'dark:shadow-none'],
          smart: ['bg-white', 'dark:bg-dark-800', 'text-emerald-700', 'dark:text-emerald-400', 'shadow-sm', 'dark:shadow-none'],
          all: ['bg-white', 'dark:bg-dark-800', 'text-slate-800', 'dark:text-slate-100', 'shadow-sm', 'dark:shadow-none'],
        }
        activeClasses[currentOntologyFilter].forEach(c => btn.classList.add(c))
        btn.classList.remove('text-slate-500', 'hover:text-slate-700', 'dark:hover:text-slate-300')
        // Filter entities
        document.querySelectorAll('.filter-entity').forEach(el => {
          const ontology = el.getAttribute('data-ontology') || ''
          const visible = currentOntologyFilter === 'all' || ontology === currentOntologyFilter
          ;(el as HTMLElement).style.display = visible ? '' : 'none'
        })
      })
    })

    // Class tree expand/collapse all
    const expandAllBtn = document.getElementById('expand-all-btn')
    const collapseAllBtn = document.getElementById('collapse-all-btn')
    const treeRoot = document.getElementById('class-tree-root')
    expandAllBtn?.addEventListener('click', () => {
      treeRoot?.dispatchEvent(new CustomEvent('expand-all'))
    })
    collapseAllBtn?.addEventListener('click', () => {
      treeRoot?.dispatchEvent(new CustomEvent('collapse-all'))
    })

    // Lazy chart loading
    let chartsLoaded = false
    async function loadCharts() {
      if (chartsLoaded) return
      chartsLoaded = true
      const typeCanvas = document.getElementById('type-chart') as HTMLCanvasElement | null
      const ontoCanvas = document.getElementById('onto-chart') as HTMLCanvasElement | null
      if (!typeCanvas || !ontoCanvas) return
      const { Chart, registerables } = await import('chart.js')
      Chart.register(...registerables)
      const isDark = document.documentElement.classList.contains('dark')

      const typeLabels = JSON.parse(typeCanvas.dataset.types || '[]')
      const typeCounts = JSON.parse(typeCanvas.dataset.counts || '[]')
      const typeColors = JSON.parse(typeCanvas.dataset.colors || '[]')
      new Chart(typeCanvas, {
        type: 'bar',
        data: {
          labels: typeLabels,
          datasets: [{
            data: typeCounts,
            backgroundColor: typeColors.map((c: string) => c + (isDark ? '66' : '33')),
            borderColor: typeColors.map((c: string) => isDark ? c + 'cc' : c),
            borderWidth: 1.5,
            borderRadius: 6,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            y: { beginAtZero: true, ticks: { stepSize: 5, color: isDark ? '#a89ea6' : '#64748b' } },
            x: { ticks: { font: { size: 10 }, color: isDark ? '#a89ea6' : '#64748b' } },
          },
        },
      })

      const ontoLabels = JSON.parse(ontoCanvas.dataset.labels || '[]')
      const ontoCounts = JSON.parse(ontoCanvas.dataset.counts || '[]')
      const ontoColors = JSON.parse(ontoCanvas.dataset.colors || '[]')
      new Chart(ontoCanvas, {
        type: 'doughnut',
        data: {
          labels: ontoLabels,
          datasets: [{
            data: ontoCounts,
            backgroundColor: ontoColors.map((c: string) => c + (isDark ? 'bb' : '99')),
            borderColor: isDark ? '#1e0f18' : '#fff',
            borderWidth: 2,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { position: 'bottom', labels: { font: { size: 11 }, padding: 16, color: isDark ? '#a89ea6' : '#374151' } },
          },
        },
      })
    }
  </script>
</DefaultLayout>
