---
import DefaultLayout from '../../layouts/DefaultLayout.astro'
import { asset } from '../../lib/asset'
import { ontologyEntities } from '../../data/generated/ontology'

interface Entity {
  uri: string
  qname: string
  slug: string
  label: string
  description: string
  ontology: string
  type: string
  targetClass?: string
  targetSubjectsOf?: string
  targetObjectsOf?: string
  constraints?: { path: string; minCount?: number; maxCount?: number; datatype?: string; nodeKind?: string; classValue?: string; hasValue?: string; uniqueLang?: boolean }[]
}

const allEntities = ontologyEntities as readonly Entity[]
const shapes = allEntities.filter(e => e.type === 'shape')

function badgeColor(e: Entity) {
  if (e.ontology === 'smart') return 'bg-emerald-50 text-emerald-600 dark:bg-emerald-900/40 dark:text-emerald-400'
  if (e.ontology === 'isq') return 'bg-brand-50 text-brand-600 dark:bg-brand-900/40 dark:text-brand-400'
  return 'bg-slate-100 text-slate-600 dark:bg-dark-700 dark:text-slate-400'
}

function entitySlug(qname: string | undefined) {
  if (!qname) return undefined
  return allEntities.find(e => e.qname === qname)?.slug
}
---

<DefaultLayout title="Ontology SHACL Shapes — ISQ Browser" description="SHACL validation shapes of the ISO & IEC 80000 and SMART Core ontologies.">
  <div>
    <!-- Hero -->
    <section class="relative overflow-hidden bg-gradient-to-br from-emerald-950 via-emerald-900 to-teal-950">
      <div class="absolute inset-0 hero-pattern"></div>
      <div class="grain-overlay absolute inset-0"></div>
      <div class="absolute top-0 right-0 w-[800px] h-[800px] rounded-full blur-[120px] -translate-y-1/2 translate-x-1/3 bg-emerald-500/10"></div>
      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
        <div class="max-w-3xl page-enter">
          <div class="flex items-center gap-2 text-xs text-emerald-300/60 mb-5">
            <a href={asset("/")} class="hover:text-emerald-200 transition-colors">Home</a>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
            <a href={asset("/ontology")} class="hover:text-emerald-200 transition-colors">Ontology</a>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
            <span class="text-emerald-200">Shapes</span>
          </div>

          <h1 class="text-3xl sm:text-4xl font-bold text-white tracking-tight heading-serif">SHACL Shapes</h1>
          <p class="mt-2 text-sm leading-relaxed max-w-xl text-emerald-300/80">
            Validation constraints defined using SHACL (Shapes Constraint Language) that enforce structural rules on ontology data.
          </p>
          <div class="flex gap-2 mt-4">
            <div class="px-3 py-1.5 rounded-lg bg-white/[0.06] border border-white/[0.08]">
              <span class="text-lg font-bold text-white heading-serif tabular-nums">{shapes.length}</span>
              <span class="text-xs ml-1 text-emerald-300/70">shapes</span>
            </div>
            <div class="px-3 py-1.5 rounded-lg bg-white/[0.06] border border-white/[0.08]">
              <span class="text-lg font-bold text-white heading-serif tabular-nums">{shapes.reduce((sum, s) => sum + (s.constraints?.length ?? 0), 0)}</span>
              <span class="text-xs ml-1 text-emerald-300/70">constraints</span>
            </div>
          </div>
        </div>
      </div>
      <div class="absolute bottom-0 inset-x-0 h-12 bg-gradient-to-t from-slate-50 dark:from-dark-950 to-transparent z-10"></div>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-4">
      {shapes.length === 0 ? (
        <div class="rounded-2xl border border-slate-200/80 dark:border-dark-600/80 bg-white dark:bg-dark-800 p-8 text-center">
          <p class="text-sm text-slate-500">No SHACL shapes defined.</p>
        </div>
      ) : (
        shapes.map((s) => (
          <div class="rounded-2xl border border-slate-200/80 dark:border-dark-600/80 bg-white dark:bg-dark-800 p-6">
            <div class="flex items-center gap-2 mb-2 flex-wrap">
              <span class="text-xs font-semibold px-1.5 py-0.5 rounded bg-purple-50 text-purple-600 dark:bg-purple-950/40 dark:text-purple-400">Shape</span>
              <a href={asset(`/ontology/${s.slug}`)} class="text-sm font-bold text-brand-600 dark:text-brand-400 hover:underline">{s.qname}</a>
              <span class={`text-xs font-semibold px-1.5 py-0.5 rounded ${badgeColor(s)}`}>{s.ontology}</span>
            </div>
            {s.description && <p class="text-xs text-slate-500 dark:text-slate-400 mb-2">{s.description}</p>}
            <div class="text-xs text-slate-500 mb-3">
              {s.targetClass && (
                <span>Target class: {
                  entitySlug(s.targetClass)
                    ? <a href={asset(`/ontology/${entitySlug(s.targetClass)}`)} class="text-blue-600 dark:text-blue-400 hover:underline">{s.targetClass}</a>
                    : s.targetClass
                }</span>
              )}
              {s.targetSubjectsOf && (
                <span>Subjects of: {
                  entitySlug(s.targetSubjectsOf)
                    ? <a href={asset(`/ontology/${entitySlug(s.targetSubjectsOf)}`)} class="text-blue-600 dark:text-blue-400 hover:underline">{s.targetSubjectsOf}</a>
                    : s.targetSubjectsOf
                }</span>
              )}
              {s.targetObjectsOf && <span>Objects of: {s.targetObjectsOf}</span>}
            </div>
            {s.constraints?.length ? (
              <div class="overflow-x-auto rounded-lg border border-slate-200/60 dark:border-dark-600/60">
                <table class="w-full text-xs">
                  <thead>
                    <tr class="bg-slate-50/80 dark:bg-dark-800/80 border-b border-slate-200/60 dark:border-dark-600/60">
                      <th class="text-left px-3 py-2 font-semibold text-slate-500">Property</th>
                      <th class="text-center px-3 py-2 font-semibold text-slate-500">Min</th>
                      <th class="text-center px-3 py-2 font-semibold text-slate-500">Max</th>
                      <th class="text-left px-3 py-2 font-semibold text-slate-500">Type / Class</th>
                      <th class="text-left px-3 py-2 font-semibold text-slate-500">Node Kind</th>
                    </tr>
                  </thead>
                  <tbody>
                    {s.constraints.map((c) => (
                      <tr class="border-b border-slate-100/60 dark:border-dark-700/60 last:border-0">
                        <td class="px-3 py-2">
                          {entitySlug(c.path) ? (
                            <a href={asset(`/ontology/${entitySlug(c.path)}`)} class="text-blue-600 dark:text-blue-400 hover:underline">{c.path}</a>
                          ) : <span class="font-mono">{c.path}</span>}
                        </td>
                        <td class="px-3 py-2 text-center">{c.minCount ?? '—'}</td>
                        <td class="px-3 py-2 text-center">{c.maxCount ?? '—'}</td>
                        <td class="px-3 py-2">
                          {c.datatype && <span class="italic">{c.datatype}</span>}
                          {!c.datatype && c.classValue && (
                            entitySlug(c.classValue)
                              ? <a href={asset(`/ontology/${entitySlug(c.classValue)}`)} class="text-blue-600 dark:text-blue-400 hover:underline">{c.classValue}</a>
                              : c.classValue
                          )}
                          {c.hasValue && <span class="text-slate-400 ml-1">= {c.hasValue}</span>}
                        </td>
                        <td class="px-3 py-2">{c.nodeKind || '—'}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ) : (
              <p class="text-xs text-slate-400 italic">No constraints defined.</p>
            )}
          </div>
        ))
      )}
    </section>
  </div>
</DefaultLayout>
