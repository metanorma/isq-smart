                    ))}
                  </div>
                </div>
              )}

              {/* SHACL Shapes */}
              {ontologyShapes.length > 0 && (
                <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4">
                  <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">
                    SHACL Shapes ({ontologyShapes.length})
                  </h3>
                  <div class="overflow-x-auto rounded-lg border border-slate-200/60">
                    <table class="w-full text-xs">
                      <thead>
                        <tr class="bg-slate-50/80 border-b border-slate-200/60">
                          <th class="text-left px-3 py-1.5 font-semibold text-slate-500">Shape</th>
                          <th class="text-left px-3 py-1.5 font-semibold text-slate-500">Target</th>
                          <th class="text-center px-3 py-1.5 font-semibold text-slate-500">Constraints</th>
                        </tr>
                      </thead>
                      <tbody>
                        {ontologyShapes.map((s) => (
                          <tr class="border-b border-slate-100 dark:border-dark-700/60 last:border-0 hover:bg-slate-50/50 dark:hover:bg-dark-700/50">
                            <td class="px-3 py-1.5">
                              <a href={`/ontology/${s.slug}`} class="text-purple-700 hover:underline font-medium">{s.qname}</a>
                            </td>
                            <td class="px-3 py-1.5">
                              {s.targetClass && linkTo(s.targetClass) ? <a href={linkTo(s.targetClass)} class="text-blue-600 hover:underline">{s.targetClass}</a>
                                : s.targetClass ? <span>{s.targetClass}</span>
                                : <span class="text-slate-400">—</span>}
                            </td>
                            <td class="px-3 py-1.5 text-center tabular-nums">{s.constraints?.length || 0}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>
              )}

              {/* Concept Schemes */}
              {ontologyConceptSchemes.length > 0 && (
                <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4">
                  <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">
                    Concept Schemes ({ontologyConceptSchemes.length})
                  </h3>
                  <div class="flex flex-wrap gap-1.5">
                    {ontologyConceptSchemes.map((s) => (
                      <a href={`/ontology/${s.slug}`} class="text-[10px] font-medium px-2 py-1 rounded-lg border border-cyan-200/60 bg-cyan-50/50 text-cyan-700 hover:border-cyan-300 hover:text-cyan-800 transition-colors">
                        {s.qname}
                      </a>
                    ))}
                  </div>
                </div>
              )}

              {/* SKOS Concepts */}
              {ontologyConcepts.length > 0 && (
                <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4">
                  <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">
                    SKOS Concepts ({ontologyConcepts.length})
                  </h3>
                  <div class="overflow-x-auto rounded-lg border border-slate-200/60">
                    <table class="w-full text-xs">
                      <thead>
                        <tr class="bg-slate-50/80 border-b border-slate-200/60">
                          <th class="text-left px-3 py-1.5 font-semibold text-slate-500">Concept</th>
                          <th class="text-left px-3 py-1.5 font-semibold text-slate-500">Description</th>
                          <th class="text-left px-3 py-1.5 font-semibold text-slate-500">Instance Of</th>
                        </tr>
                      </thead>
                      <tbody>
                        {ontologyConcepts.map((c) => (
                          <tr class="border-b border-slate-100 dark:border-dark-700/60 last:border-0 hover:bg-slate-50/50 dark:hover:bg-dark-700/50">
                            <td class="px-3 py-1.5">
                              <a href={`/ontology/${c.slug}`} class="text-teal-700 hover:underline font-medium">{c.label}</a>
                              <code class="ml-1 text-[9px] text-slate-400">{c.qname}</code>
                            </td>
                            <td class="px-3 py-1.5 text-slate-600 dark:text-slate-400 max-w-sm truncate">{c.description || '—'}</td>
                            <td class="px-3 py-1.5">
                              {c.instanceOf?.length ? c.instanceOf.map((t, i) => (
                                <Fragment>
                                  {linkTo(t) ? <a href={linkTo(t)} class="text-blue-600 hover:underline">{t}</a> : <span>{t}</span>}
                                  {i < c.instanceOf!.length - 1 && <span>, </span>}
                                </Fragment>
                              )) : null}
                            </td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>
              )}

              {/* Named Individuals */}
              {ontologyIndividuals.length > 0 && (
                <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4">
                  <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">
                    Named Individuals ({ontologyIndividuals.length})
                  </h3>
                  <div class="overflow-x-auto rounded-lg border border-slate-200/60">
                    <table class="w-full text-xs">
                      <thead>
                        <tr class="bg-slate-50/80 border-b border-slate-200/60">
                          <th class="text-left px-3 py-1.5 font-semibold text-slate-500">Individual</th>
                          <th class="text-left px-3 py-1.5 font-semibold text-slate-500">Instance Of</th>
                        </tr>
                      </thead>
                      <tbody>
                        {ontologyIndividuals.map((ind) => (
                          <tr class="border-b border-slate-100 dark:border-dark-700/60 last:border-0 hover:bg-slate-50/50 dark:hover:bg-dark-700/50">
                            <td class="px-3 py-1.5">
                              <a href={`/ontology/${ind.slug}`} class="text-brand-600 hover:underline font-medium">{ind.label}</a>
                              <code class="ml-1 text-[9px] text-slate-400">{ind.qname}</code>
                            </td>
                            <td class="px-3 py-1.5">
                              {ind.instanceOf?.length ? ind.instanceOf.map((t, i) => (
                                <Fragment>
                                  {linkTo(t) ? <a href={linkTo(t)} class="text-blue-600 hover:underline">{t}</a> : <span>{t}</span>}
                                  {i < ind.instanceOf!.length - 1 && <span>, </span>}
                                </Fragment>
                              )) : null}
                            </td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>
              )}
            </Fragment>
          )}

          {/* Where Used (all entity types) */}
          {whereUsed.length > 0 && (
            <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4">
              <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Where Used ({whereUsed.length})</h3>
              <ul class="space-y-1">
                {whereUsed.map((wu) => (
                  <li>
                    <a href={`/ontology/${wu.entity.slug}`} class="text-blue-600 hover:underline">{wu.entity.qname}</a>
                    <span class="text-gray-400 text-xs ml-2">via {wu.context}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>

        {/* ═══════════════════════════════════════════════════════════════ */}
        {/* RDF SOURCE TAB                                                 */}
        {/* ═══════════════════════════════════════════════════════════════ */}
        <div data-detail-section="rdf" class="hidden">
          <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4 space-y-3">
            <div class="flex items-center justify-between">
              <div class="flex gap-1 p-1 rounded-lg bg-slate-100 dark:bg-dark-700 border border-slate-200/60 dark:border-dark-600/60">
                <button data-rdf-format="turtle" class="px-3 py-1.5 rounded-md text-xs font-medium transition-all bg-white dark:bg-dark-700 text-slate-800 dark:text-slate-200 shadow-sm">
                  Turtle
                </button>
                <button data-rdf-format="jsonld" class="px-3 py-1.5 rounded-md text-xs font-medium transition-all text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200">
                  JSON-LD
                </button>
              </div>
              <button id="rdf-download" class="px-3 py-1.5 rounded-lg text-xs font-medium bg-slate-100 dark:bg-dark-700 border border-slate-200/60 dark:border-dark-600/60 text-slate-600 dark:text-slate-400 hover:bg-slate-200 dark:hover:bg-dark-600 transition-colors">
                Download .ttl
              </button>
            </div>
            <pre class="bg-slate-900 text-green-300 text-xs p-4 rounded-lg overflow-x-auto whitespace-pre-wrap"><code id="rdf-output" data-turtle={turtleCode} data-jsonld={jsonldCode}>{turtleCode}</code></pre>
          </div>
        </div>
      </div>
    )}

  </div>

  <script define:vars={{ slug }}>
    // Detail tab switching
    const detailTabs = document.querySelectorAll('[data-detail-tab]')
    const detailSections = document.querySelectorAll('[data-detail-section]')

    detailTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-detail-tab') ?? ''
        detailTabs.forEach(t => {
          t.classList.remove('bg-white', 'dark:bg-dark-800', 'text-slate-800', 'dark:text-slate-100', 'shadow-sm')
          t.classList.add('text-slate-500', 'dark:text-slate-400', 'hover:text-slate-700', 'dark:hover:text-slate-300')
        })
        tab.classList.add('bg-white', 'dark:bg-dark-800', 'text-slate-800', 'dark:text-slate-100', 'shadow-sm')
        tab.classList.remove('text-slate-500', 'dark:text-slate-400', 'hover:text-slate-700', 'dark:hover:text-slate-300')
        detailSections.forEach(s => {
          if (s.getAttribute('data-detail-section') === target) {
            s.classList.remove('hidden')
          } else {
            s.classList.add('hidden')
          }
        })
      })
    })

    // RDF format toggle
    const rdfFormatBtns = document.querySelectorAll('[data-rdf-format]')
    const rdfOutput = document.getElementById('rdf-output')
    const downloadBtn = document.getElementById('rdf-download')
    let currentFormat = 'turtle'

    rdfFormatBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        currentFormat = btn.getAttribute('data-rdf-format') ?? 'turtle'
        rdfFormatBtns.forEach(b => {
          b.classList.remove('bg-white', 'dark:bg-dark-700', 'text-slate-800', 'dark:text-slate-200', 'shadow-sm')
          b.classList.add('text-slate-500', 'dark:text-slate-400', 'hover:text-slate-700', 'dark:hover:text-slate-200')
        })
        btn.classList.add('bg-white', 'dark:bg-dark-700', 'text-slate-800', 'dark:text-slate-200', 'shadow-sm')
        btn.classList.remove('text-slate-500', 'dark:text-slate-400', 'hover:text-slate-700', 'dark:hover:text-slate-200')
        if (rdfOutput) {
          rdfOutput.textContent = currentFormat === 'turtle' ? rdfOutput.dataset.turtle : rdfOutput.dataset.jsonld
        }
        if (downloadBtn) {
          downloadBtn.textContent = `Download .${currentFormat === 'turtle' ? 'ttl' : 'jsonld'}`
        }
      })
    })

    // RDF download
    downloadBtn?.addEventListener('click', () => {
      if (!rdfOutput) return
      const content = currentFormat === 'turtle' ? rdfOutput.dataset.turtle : rdfOutput.dataset.jsonld
      const ext = currentFormat === 'turtle' ? 'ttl' : 'jsonld'
      const mime = currentFormat === 'turtle' ? 'text/turtle' : 'application/ld+json'
      const blob = new Blob([content], { type: mime })
      const url = URL.createObjectURL(blob)
      const a = document.createElement('a')
      a.href = url
      a.download = `${slug}.${ext}`
      a.click()
      URL.revokeObjectURL(url)
    })
  </script>
</DefaultLayout>
