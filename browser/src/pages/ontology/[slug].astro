---
import OntologyLayout from '../../layouts/OntologyLayout.astro'
import { asset } from '../../lib/asset'
import OntologyLink from '../../components/OntologyLink.astro'
import { ontologyEntities, ontologyTypeMeta, ontologyPrefixes, ontologyNamespaces, ontologyImportChain } from '../../data/generated/ontology'
import { resolveOntologyEntityView, type OntologyEntityData } from '../../data/ontologyViewModel'
import { toTurtle, toJsonLd } from '../../lib/rdf'

type Entity = OntologyEntityData

export function getStaticPaths() {
  return ontologyEntities
    .filter(e => e.slug && /^[a-zA-Z0-9_-]+$/.test(e.slug))
    .map(entity => ({
      params: { slug: entity.slug },
      props: { slug: entity.slug },
    }))
}

const { slug } = Astro.props


const allEntities = ontologyEntities as readonly Entity[]
const typeMeta = ontologyTypeMeta as Record<string, { label: string; color: string; colorDot: string }>

const entity = allEntities.find(e => e.slug === slug)

function badgeColor(e: Entity) {
  if (e.ontology === 'smart') return 'bg-emerald-50 text-emerald-600 dark:bg-emerald-900/40 dark:text-emerald-400'
  if (e.ontology === 'isq') return 'bg-brand-50 text-brand-600 dark:bg-brand-900/40 dark:text-brand-400'
  return 'bg-slate-100 text-slate-600 dark:bg-dark-700 dark:text-slate-400'
}

// Resolve all derived views via the indexed view model
const view = entity ? resolveOntologyEntityView(entity, allEntities) : null

const parentOntologyEntity = view?.parentOntologyEntity
const siblings = view?.siblings ?? { prev: undefined, next: undefined }
const subclasses = view?.subclasses ?? []
const allDescendants = view?.allDescendants ?? []
const targetingShapes = view?.targetingShapes ?? []
const ancestors = view?.ancestors ?? []
const inferredProperties = view?.inferredProperties ?? []
const groupedUsage = view?.groupedUsage ?? []
const instances = view?.instances ?? []
const relatedProperties = view?.relatedProperties ?? { domain: [], range: [] }
const schemeConcepts = view?.schemeConcepts ?? []
const conceptShapes = view?.conceptShapes ?? []
const ontologyClasses = view?.ontologyScoped.classes ?? []
const ontologyObjProps = view?.ontologyScoped.objectProperties ?? []
const ontologyDtProps = view?.ontologyScoped.datatypeProperties ?? []
const ontologyAnnProps = view?.ontologyScoped.annotationProperties ?? []
const ontologyShapes = view?.ontologyScoped.shapes ?? []
const ontologyConcepts = view?.ontologyScoped.concepts ?? []
const ontologyConceptSchemes = view?.ontologyScoped.conceptSchemes ?? []
const ontologyIndividuals = view?.ontologyScoped.individuals ?? []
const whereUsed = view?.whereUsed ?? []

// Ontology namespace lookup (not part of the view model — depends on ontologyNamespaces)
const ontologyPrefix = entity ? entity.qname.split(':')[0] : ''
const ontologyNs = ontologyNamespaces.find(n => n.prefix === ontologyPrefix)

// RDF export (pre-computed)
const turtleCode = entity ? toTurtle(entity) : ''
const jsonldCode = entity ? toJsonLd(entity) : ''

function truncate(s: string, n: number) {
  return s.length > n ? s.slice(0, n) + '…' : s
}
---

<OntologyLayout title={`Ontology: ${slug} | ISQ Browser`}>
  <div>
    {!entity ? (
      <div class="p-8 text-center text-gray-500">
        <p class="text-xl">Entity not found</p>
        <p class="mt-2">No entity with slug "{slug}"</p>
        <a href={asset("/ontology")} class="text-blue-600 hover:underline mt-4 inline-block">
          Back to Ontology
        </a>
      </div>
    ) : (
      <div class="max-w-5xl mx-auto p-6 space-y-6">
        <!-- Breadcrumb + prev/next -->
        <div class="flex items-center justify-between">
          <nav class="flex items-center gap-2 text-sm text-gray-500">
            <a href={asset("/ontology")} class="hover:text-blue-600">Ontology</a>
            <span>/</span>
            {parentOntologyEntity ? (
              <Fragment>
                <a href={`/ontology/${parentOntologyEntity.slug}`} class="hover:text-blue-600">{entity.ontology}</a>
                <span>/</span>
              </Fragment>
            ) : null}
            <span class="text-gray-900 font-medium">{entity.label}</span>
          </nav>
          <div class="flex items-center gap-3 text-xs">
            {siblings.prev ? (
              <a href={`/ontology/${siblings.prev.slug}`} class="flex items-center gap-1 text-slate-500 hover:text-brand-600 transition-colors">
                <span>←</span> {siblings.prev.label}
              </a>
            ) : (
              <span class="text-slate-300">←</span>
            )}
            {siblings.next ? (
              <a href={`/ontology/${siblings.next.slug}`} class="flex items-center gap-1 text-slate-500 hover:text-brand-600 transition-colors">
                {siblings.next.label} <span>→</span>
              </a>
            ) : (
              <span class="text-slate-300">→</span>
            )}
          </div>
        </div>

        <div>
          <h1 class="text-2xl font-bold text-gray-900">{entity.label}</h1>
          <div class="flex items-center gap-2 mt-1">
            <span class={`inline-block px-2 py-0.5 rounded text-xs font-medium ${typeMeta[entity.type]?.color || 'bg-gray-100 text-gray-800'}`}>
              {typeMeta[entity.type]?.label || entity.type}
            </span>
            {entity.ontology !== 'external' && (
              <span class={`inline-block px-2 py-0.5 rounded text-xs font-medium ${entity.ontology === 'smart' ? 'bg-emerald-50 text-emerald-600' : 'bg-brand-50 text-brand-600'}`}>
                {entity.ontology}
              </span>
            )}
            <code class="text-xs text-slate-400">{entity.qname}</code>
          </div>
        </div>

        <!-- Tab bar -->
        <div class="flex gap-1 p-1 rounded-lg bg-slate-100/80 dark:bg-dark-700/80 border border-slate-200/60 dark:border-dark-600/60 w-fit">
          <button data-detail-tab="overview" class="px-3 py-1.5 rounded-md text-xs font-medium transition-all bg-white dark:bg-dark-800 text-slate-800 dark:text-slate-100 shadow-sm">
            Overview
          </button>
          <button data-detail-tab="rdf" class="px-3 py-1.5 rounded-md text-xs font-medium transition-all text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-300">
            RDF Source
          </button>
        </div>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- OVERVIEW TAB                                                   -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <div data-detail-section="overview" class="space-y-6">
          <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4">
            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">URI</h3>
            <code class="text-sm break-all">{entity.uri}</code>
          </div>

          <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4">
            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Qualified Name</h3>
            <code class="text-sm">{entity.qname}</code>
          </div>

          {entity.description && (
            <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4">
              <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Definition</h3>
              <p class="text-gray-700 whitespace-pre-line">{entity.description}</p>
            </div>
          )}

          {entity.scopeNote && (
            <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4">
              <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Scope Note</h3>
              <p class="text-gray-700 whitespace-pre-line">{entity.scopeNote}</p>
            </div>
          )}

          {entity.example && (
            <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4">
              <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Example</h3>
              <p class="text-gray-700">{entity.example}</p>
            </div>
          )}

          {entity.altLabel && (
            <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4">
              <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Alternative Label</h3>
              <p class="text-gray-700">{entity.altLabel}</p>
            </div>
          )}

          {entity.seeAlso?.length ? (
            <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4">
              <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">See Also</h3>
              <ul class="space-y-1">
                {entity.seeAlso.map((link) => (
                  <li>
                    <a href={link} target="_blank" rel="noopener" class="text-blue-600 hover:underline text-sm break-all">{link}</a>
                  </li>
                ))}
              </ul>
            </div>
          ) : null}

          {/* ─── Class-specific ────────────────────────────────────────── */}
          {entity.type === 'class' && (
            <Fragment>
              {/* Tree diagram */}
              <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4">
                <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">Hierarchy</h3>
                <div class="font-mono text-xs space-y-0.5">
                  {/* Ancestors (reversed, root first) */}
                  {[...ancestors].reverse().map((a, i) => (
                    <div style={`padding-left: ${i * 1.5}rem`} class="flex items-center gap-1.5 text-slate-400">
                      <span class="w-4 text-center">└</span>
                      <a href={`/ontology/${a.slug}`} class="hover:text-blue-600 hover:underline">{a.qname}</a>
                    </div>
                  ))}
                  {/* Self (highlighted) */}
                  <div style={`padding-left: ${ancestors.length * 1.5}rem`} class="flex items-center gap-1.5 py-1 px-2 -mx-2 rounded bg-brand-50/50 border border-brand-200/30">
                    <span class="w-4 text-center font-bold text-brand-500">★</span>
                    <span class="text-brand-700 font-bold">{entity.qname}</span>
                  </div>
                  {/* Children */}
                  {subclasses.map((sc) => (
                    <div style={`padding-left: ${(ancestors.length + 1) * 1.5}rem`} class="flex items-center gap-1.5">
                      <span class="w-4 text-center text-slate-300">└</span>
                      <a href={`/ontology/${sc.slug}`} class="text-blue-600 hover:underline">{sc.qname}</a>
                    </div>
                  ))}
                </div>
              </div>

              {/* Inherited properties */}
              {inferredProperties.length > 0 && (
                <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4">
                  <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">
                    Inherited Properties ({inferredProperties.length})
                  </h3>
                  <p class="text-xs text-slate-400 mb-3">Properties inherited from ancestor classes.</p>
                  <div class="flex flex-wrap gap-1.5">
                    {inferredProperties.map((p) => (
                      <a href={`/ontology/${p.slug}`} class="text-xs font-medium px-2 py-1 rounded-lg border border-slate-200/60 dark:border-dark-600/60 bg-slate-50/50 dark:bg-dark-700/50 text-slate-600 dark:text-slate-400 hover:border-brand-200 hover:text-brand-600 transition-colors inline-flex items-center gap-1">
                        <span class={`w-1.5 h-1.5 rounded-full ${typeMeta[p.type]?.colorDot || 'bg-slate-300'}`}></span>
                        {p.qname}
                      </a>
                    ))}
                  </div>
                </div>
              )}

              {/* Grouped usage table (Ontospy-style) */}
              {groupedUsage.length > 0 && (
                <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4">
                  <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">
                    Properties by Class ({relatedProperties.domain.length})
                  </h3>
                  <div class="space-y-4">
                    {groupedUsage.map((group) => (
                      <div>
                        <div class="flex items-center gap-2 mb-2">
                          <span class="text-xs font-semibold text-slate-700 dark:text-slate-300">From</span>
                          <a href={`/ontology/${group.source.slug}`} class="text-xs font-mono text-blue-600 hover:underline">{group.source.qname}</a>
                          <span class="text-xs text-slate-400">({group.props.length})</span>
                        </div>
                        <div class="overflow-x-auto rounded-lg border border-slate-200/60">
                          <table class="w-full text-xs">
                            <thead>
                              <tr class="bg-slate-50/80 border-b border-slate-200/60">
                                <th class="text-left px-3 py-1.5 font-semibold text-slate-500">Property</th>
                                <th class="text-left px-3 py-1.5 font-semibold text-slate-500">Description</th>
                                <th class="text-left px-3 py-1.5 font-semibold text-slate-500">Range</th>
                                <th class="text-center px-3 py-1.5 font-semibold text-slate-500">Type</th>
                              </tr>
                            </thead>
                            <tbody>
                              {group.props.map((p) => (
                                <tr class="border-b border-slate-100 dark:border-dark-700/60 last:border-0">
                                  <td class="px-3 py-1.5">
                                    <a href={`/ontology/${p.slug}`} class="text-green-700 hover:underline font-medium">{p.qname}</a>
                                  </td>
                                  <td class="px-3 py-1.5 text-slate-600 dark:text-slate-400 max-w-xs truncate">{p.description || '—'}</td>
                                  <td class="px-3 py-1.5">
                                    {p.range?.length ? p.range.map((r, i) => (
                                      <Fragment>
                                        <OntologyLink qname={r} spanClass="text-slate-600 dark:text-slate-400" />
                                        {i < p.range!.length - 1 && <span>, </span>}
                                      </Fragment>
                                    )) : <span class="text-slate-400">—</span>}
                                  </td>
                                  <td class="px-3 py-1.5 text-center">
                                    <span class={`text-xs font-semibold px-1.5 py-0.5 rounded ${typeMeta[p.type]?.color || 'bg-slate-100 text-slate-600'}`}>{typeMeta[p.type]?.label || p.type}</span>
                                  </td>
                                </tr>
                              ))}
                            </tbody>
                          </table>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {/* Direct subclasses */}
              {subclasses.length > 0 && (
                <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4">
                  <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Direct Subclasses ({subclasses.length})</h3>
                  <ul class="space-y-1">
                    {subclasses.map((sc) => (
                      <li>
                        <a href={`/ontology/${sc.slug}`} class="text-blue-600 hover:underline">{sc.qname}</a>
                        {sc.description && <span class="text-gray-400 text-sm ml-2">— {truncate(sc.description, 80)}</span>}
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {/* All descendants */}
              {allDescendants.length > subclasses.length && (
                <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4">
                  <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">All Descendants ({allDescendants.length})</h3>
                  <ul class="space-y-1">
                    {allDescendants.map((d) => (
                      <li>
                        <a href={`/ontology/${d.slug}`} class="text-blue-600 hover:underline">{d.qname}</a>
                        {d.description && <span class="text-gray-400 text-sm ml-2">— {truncate(d.description, 60)}</span>}
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {/* SHACL Shapes targeting this class */}
              {targetingShapes.length > 0 && (
                <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4">
                  <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">
                    SHACL Constraints ({targetingShapes.length})
                  </h3>
                  {targetingShapes.map((s) => (
                    <div class="mb-4 last:mb-0">
                      <div class="flex items-center gap-2 mb-2">
                        <span class="text-xs font-semibold px-1.5 py-0.5 rounded bg-purple-50 text-purple-600">Shape</span>
                        <a href={`/ontology/${s.slug}`} class="text-sm font-bold text-brand-600 hover:underline">{s.qname}</a>
                      </div>
                      {s.constraints?.length ? (
                        <div class="overflow-x-auto rounded-lg border border-slate-200/60">
                          <table class="w-full text-xs">
                            <thead>
                              <tr class="bg-slate-50/80 border-b border-slate-200/60">
                                <th class="text-left px-3 py-1.5 font-semibold text-slate-500">Property</th>
                                <th class="text-center px-3 py-1.5 font-semibold text-slate-500">Min</th>
                                <th class="text-center px-3 py-1.5 font-semibold text-slate-500">Max</th>
                                <th class="text-left px-3 py-1.5 font-semibold text-slate-500">Type / Class</th>
                                <th class="text-left px-3 py-1.5 font-semibold text-slate-500">Node Kind</th>
                              </tr>
                            </thead>
                            <tbody>
                              {s.constraints.map((c, i) => (
                                <tr class="border-b border-slate-100 dark:border-dark-700/60 last:border-0">
                                  <td class="px-3 py-1.5">
                                    <OntologyLink qname={c.path} spanClass="font-mono" />
                                  </td>
                                  <td class="px-3 py-1.5 text-center">{c.minCount ?? '—'}</td>
                                  <td class="px-3 py-1.5 text-center">{c.maxCount ?? '—'}</td>
                                  <td class="px-3 py-1.5">
                                    {c.datatype && <span class="italic">{c.datatype}</span>}
                                    {!c.datatype && c.classValue && <OntologyLink qname={c.classValue} />}
                                    {c.hasValue && <span class="text-slate-400 ml-1">= {c.hasValue}</span>}
                                    {c.uniqueLang && <span class="text-xs text-amber-600 bg-amber-50 px-1 py-0.5 rounded ml-1">uniqueLang</span>}
                                  </td>
                                  <td class="px-3 py-1.5">{c.nodeKind || '—'}</td>
                                </tr>
                              ))}
                            </tbody>
                          </table>
                        </div>
                      ) : null}
                    </div>
                  ))}
                </div>
              )}

              {/* Range usage */}
              {relatedProperties.range.length > 0 && (
                <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4">
                  <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">In Range Of</h3>
                  <ul class="space-y-1">
                    {relatedProperties.range.map((p) => (
                      <li>
                        <a href={`/ontology/${p.slug}`} class="text-blue-600 hover:underline">{p.qname}</a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {/* Instances */}
              {instances.length > 0 && (
                <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4">
                  <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Instances ({instances.length})</h3>
                  <div class="flex flex-wrap gap-1.5">
                    {instances.map((inst) => (
                      <a href={`/ontology/${inst.slug}`} class="text-xs font-medium px-2 py-1 rounded-lg border border-slate-200/60 dark:border-dark-600/60 bg-slate-50/50 dark:bg-dark-700/50 text-slate-600 dark:text-slate-400 hover:border-brand-200 hover:text-brand-600 transition-colors inline-flex items-center gap-1">
                        <span class={`w-1.5 h-1.5 rounded-full ${typeMeta[inst.type]?.colorDot || 'bg-slate-300'}`}></span>
                        {inst.label}
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </Fragment>
          )}

          {/* ─── Property-specific ─────────────────────────────────────── */}
          {(entity.type === 'objectProperty' || entity.type === 'datatypeProperty') && (
            <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4">
              <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Property Characteristics</h3>
              <table class="w-full text-sm">
                {entity.domain?.length ? (
                  <tr>
                    <td class="py-1 pr-4 font-medium text-gray-600 align-top w-32">Domain</td>
                    <td>
                      {entity.domain.map((d, i) => (
                        <Fragment>
                          <OntologyLink qname={d} spanClass="text-gray-700" />
                          {i < entity.domain!.length - 1 && <span>, </span>}
                        </Fragment>
                      ))}
                    </td>
                  </tr>
                ) : null}
                {entity.range?.length ? (
                  <tr>
                    <td class="py-1 pr-4 font-medium text-gray-600 align-top w-32">Range</td>
                    <td>
                      {entity.range.map((r, i) => (
                        <Fragment>
                          <OntologyLink qname={r} spanClass="text-gray-700" />
                          {i < entity.range!.length - 1 && <span>, </span>}
                        </Fragment>
                      ))}
                    </td>
                  </tr>
                ) : null}
                {entity.type === 'objectProperty' && (
                  <tr>
                    <td class="py-1 pr-4 font-medium text-gray-600 w-32">Functional</td>
                    <td>{entity.functional ? 'Yes' : 'No'}</td>
                  </tr>
                )}
              </table>
            </div>
          )}

          {/* ─── Shape-specific ────────────────────────────────────────── */}
          {entity.type === 'shape' && (
            <Fragment>
              {entity.targetClass && (
                <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4">
                  <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Target Class</h3>
                  <OntologyLink qname={entity.targetClass} spanClass="text-gray-700" />
                </div>
              )}

              {entity.targetSubjectsOf && (
                <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4">
                  <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Target Subjects Of</h3>
                  <OntologyLink qname={entity.targetSubjectsOf} spanClass="text-gray-700" />
                </div>
              )}

              {entity.targetObjectsOf && (
                <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4">
                  <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Target Objects Of</h3>
                  <OntologyLink qname={entity.targetObjectsOf} spanClass="text-gray-700" />
                </div>
              )}

              {entity.constraints?.length ? (
                <div class="bg-white dark:bg-dark-800 border border-slate-200/60 dark:border-dark-600/60 rounded-lg p-4">
                  <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">
                    Shape Properties ({entity.constraints.length})
                  </h3>
                  <div class="overflow-x-auto">
                    <table class="w-full text-sm border-collapse">
                      <thead>
                        <tr class="border-b bg-gray-50">
                          <th class="text-left py-2 px-3 font-semibold text-gray-600">Property</th>
