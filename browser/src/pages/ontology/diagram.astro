---
import DefaultLayout from '../../layouts/DefaultLayout.astro'
import MermaidDiagram from '../../components/MermaidDiagram.vue'
import { ontologyEntities } from '../../data/generated/ontology'
import { generateClassDiagram, generatePropertyDiagram } from '../../lib/mermaidDiagram'
import type { OntologyEntityData } from '../../data/ontologyViewModel'

const allEntities = ontologyEntities as unknown as readonly OntologyEntityData[]

// Generate Mermaid class diagram text (ISQ + SMART only, exclude external)
const definedEntities = allEntities.filter(e => e.ontology !== 'external')
const classDiagramText = generateClassDiagram(definedEntities)
const propertyDiagramText = generatePropertyDiagram(definedEntities)

const classCount = definedEntities.filter(e => e.type === 'class').length
const propertyCount = definedEntities.filter(e => e.type === 'objectProperty' || e.type === 'datatypeProperty' || e.type === 'annotationProperty').length
---

<DefaultLayout title="Ontology Class Diagram — ISQ Browser" description="Visual RDF class hierarchy diagram of the ISO & IEC 80000 and SMART Core ontologies.">
  <div>
    <!-- Hero -->
    <section class="relative overflow-hidden bg-gradient-to-br from-emerald-950 via-emerald-900 to-teal-950">
      <div class="absolute inset-0 hero-pattern"></div>
      <div class="grain-overlay absolute inset-0"></div>
      <div class="absolute top-0 right-0 w-[800px] h-[800px] rounded-full blur-[120px] -translate-y-1/2 translate-x-1/3 bg-emerald-500/10"></div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
        <div class="max-w-3xl page-enter">
          <div class="flex items-center gap-2 text-xs text-emerald-300/60 mb-4">
            <a href="/isq-smart/ontology" class="hover:text-emerald-200 transition-colors">Ontology</a>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
            <span>Class Diagram</span>
          </div>
          <h1 class="text-3xl sm:text-4xl font-bold text-white tracking-tight heading-serif">Ontology Class Diagram</h1>
          <p class="mt-3 text-sm text-emerald-300/70 leading-relaxed max-w-2xl">
            Visual RDF class hierarchy of the ISQ domain ontology (ISO &amp; IEC 80000) built on the SMART Core Ontology.
            Each node is an OWL class; arrows show rdfs:subClassOf inheritance.
          </p>
          <div class="mt-4 flex gap-3 text-xs">
            <span class="px-2.5 py-1 rounded-lg bg-white/[0.06] border border-white/[0.08] text-white">
              <span class="font-bold">{classCount}</span> <span class="text-emerald-300/60">classes</span>
            </span>
            <span class="px-2.5 py-1 rounded-lg bg-white/[0.06] border border-white/[0.08] text-white">
              <span class="font-bold">{propertyCount}</span> <span class="text-emerald-300/60">properties</span>
            </span>
          </div>
        </div>
      </div>
      <div class="absolute bottom-0 inset-x-0 h-12 bg-gradient-to-t from-slate-50 dark:from-dark-950 to-transparent z-10"></div>
    </section>

    <!-- Legend -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex items-center gap-4 text-xs text-slate-500 dark:text-slate-400">
        <span class="flex items-center gap-1.5">
          <span class="w-3 h-3 rounded border-2 border-red-400 bg-red-50"></span>
          ISQ domain
        </span>
        <span class="flex items-center gap-1.5">
          <span class="w-3 h-3 rounded border-2 border-emerald-400 bg-emerald-50"></span>
          SMART Core
        </span>
        <span class="text-slate-300 dark:text-slate-600">·</span>
        <span>Click a node to view its entity detail page</span>
      </div>
    </section>

    <!-- Class Diagram -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-8">
      <div class="rounded-2xl border border-slate-200/60 dark:border-dark-600/60 bg-white dark:bg-dark-800 overflow-hidden">
        <div class="px-5 py-3 border-b border-slate-200/60 dark:border-dark-600/60 bg-slate-50/50 dark:bg-dark-700/30">
          <h2 class="text-sm font-bold text-slate-900 dark:text-slate-100 heading-serif">Class Hierarchy</h2>
          <p class="text-[11px] text-slate-500 dark:text-slate-400 mt-0.5">OWL classes with rdfs:subClassOf relationships</p>
        </div>
        <div class="p-4 sm:p-6">
          <MermaidDiagram client:visible chart={classDiagramText} />
        </div>
      </div>
    </section>

    <!-- Property Diagram -->
    {propertyCount > 0 && (
      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-8">
        <div class="rounded-2xl border border-slate-200/60 dark:border-dark-600/60 bg-white dark:bg-dark-800 overflow-hidden">
          <div class="px-5 py-3 border-b border-slate-200/60 dark:border-dark-600/60 bg-slate-50/50 dark:bg-dark-700/30">
            <h2 class="text-sm font-bold text-slate-900 dark:text-slate-100 heading-serif">Property Relationships</h2>
            <p class="text-[11px] text-slate-500 dark:text-slate-400 mt-0.5">Domain-range relationships of object properties</p>
          </div>
          <div class="p-4 sm:p-6">
            <MermaidDiagram client:visible chart={propertyDiagramText} />
          </div>
        </div>
      </section>
    )}

    <!-- Download -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
      <div class="flex gap-3">
        <a href="/isq-smart/ontology/full.ttl" class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-emerald-50 dark:bg-emerald-950/30 border border-emerald-200/60 dark:border-emerald-800/40 text-emerald-700 dark:text-emerald-400 text-sm font-medium hover:bg-emerald-100 dark:hover:bg-emerald-950/50 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3"/></svg>
          Download full ontology (Turtle)
        </a>
      </div>
    </section>
  </div>
</DefaultLayout>
