---
import DefaultLayout from '../../layouts/DefaultLayout.astro'
import { asset } from '../../lib/asset'
import OntologyDiagram from '../../components/OntologyDiagram.vue'
import { ontologyEntities } from '../../data/generated/ontology'

interface Entity {
  uri: string
  qname: string
  slug: string
  label: string
  description: string
  ontology: string
  type: string
  parent?: string
}

const allEntities = ontologyEntities as readonly Entity[]

const allClasses = allEntities.filter(e => e.type === 'class' && e.ontology !== 'external')
const rootClasses = allClasses.filter(c => !c.parent)
---

<DefaultLayout title="Ontology Class Hierarchy Diagram — ISQ Browser" description="Visual class hierarchy diagram of the ISO & IEC 80000 and SMART Core ontologies.">
  <div>
    <!-- Hero -->
    <section class="relative overflow-hidden bg-gradient-to-br from-emerald-950 via-emerald-900 to-teal-950">
      <div class="absolute inset-0 hero-pattern"></div>
      <div class="grain-overlay absolute inset-0"></div>
      <div class="absolute top-0 right-0 w-[800px] h-[800px] rounded-full blur-[120px] -translate-y-1/2 translate-x-1/3 bg-emerald-500/10"></div>
      <div class="hero-float-1 absolute top-[15%] right-[18%] w-3 h-3 rounded-full bg-emerald-400/20"></div>
      <div class="hero-float-2 absolute top-[30%] right-[8%] w-2 h-2 rounded-full bg-white/10"></div>
      <div class="hero-float-4 absolute top-[20%] left-[5%] w-16 h-16 rounded-full border border-white/[0.04]"></div>
      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
        <div class="max-w-3xl page-enter">
          <!-- Breadcrumb -->
          <div class="flex items-center gap-2 text-xs text-emerald-300/60 mb-5">
            <a href={asset("/")} class="hover:text-emerald-200 transition-colors">Home</a>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
            <a href={asset("/ontology")} class="hover:text-emerald-200 transition-colors">Ontology</a>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
            <span class="text-emerald-200">Class Diagram</span>
          </div>

          <h1 class="text-3xl sm:text-4xl font-bold text-white tracking-tight heading-serif">Ontology Class Hierarchy</h1>
          <p class="mt-2 text-sm leading-relaxed max-w-xl text-emerald-300/80">
            The full class tree of the ISO &amp; IEC 80000 domain ontology and the SMART Core ontology it extends. Click any node to expand or collapse subclasses.
          </p>

          <!-- Quick stats -->
          <div class="flex gap-2 mt-4">
            <div class="px-3 py-1.5 rounded-lg bg-white/[0.06] border border-white/[0.08]">
              <span class="text-lg font-bold text-white heading-serif tabular-nums">{rootClasses.length}</span>
              <span class="text-xs ml-1 text-emerald-300/70">root class{rootClasses.length !== 1 ? 'es' : ''}</span>
            </div>
            <div class="px-3 py-1.5 rounded-lg bg-white/[0.06] border border-white/[0.08]">
              <span class="text-lg font-bold text-white heading-serif tabular-nums">{allClasses.length}</span>
              <span class="text-xs ml-1 text-emerald-300/70">total classes</span>
            </div>
          </div>
        </div>
      </div>
      <div class="absolute bottom-0 inset-x-0 h-12 bg-gradient-to-t from-slate-50 dark:from-dark-950 to-transparent z-10"></div>
    </section>

    <!-- Diagram -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <!-- Namespace legend -->
      <div class="rounded-2xl border border-slate-200/80 dark:border-dark-600/80 bg-white dark:bg-dark-800 p-6 mb-6">
        <div class="flex flex-wrap items-center gap-4">
          <div class="flex items-center gap-1.5">
            <span class="w-3 h-3 rounded-sm border-l-2 border-brand-400 dark:border-brand-500 bg-brand-50/50 dark:bg-brand-950/20"></span>
            <span class="text-[11px] text-slate-500">ISO &amp; IEC 80000 (isq)</span>
          </div>
          <div class="flex items-center gap-1.5">
            <span class="w-3 h-3 rounded-sm border-l-2 border-emerald-400 dark:border-emerald-500 bg-emerald-50/50 dark:bg-emerald-950/20"></span>
            <span class="text-[11px] text-slate-500">SMART Core (smart)</span>
          </div>
          <div class="flex items-center gap-1.5">
            <span class="w-3 h-3 rounded-sm border-l-2 border-slate-300 dark:border-dark-500 bg-slate-50/50 dark:bg-dark-700/40"></span>
            <span class="text-[11px] text-slate-500">External</span>
          </div>
        </div>
      </div>

      <!-- The class tree (primary content) -->
      <div class="rounded-2xl border border-slate-200/80 dark:border-dark-600/80 bg-white dark:bg-dark-800 p-6">
        <OntologyDiagram
          client:idle
          rootClasses={rootClasses}
          allClasses={allClasses}
        />
      </div>
    </section>
  </div>
</DefaultLayout>
