---
import DefaultLayout from '../layouts/DefaultLayout.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import SectionHead from '../components/SectionHead.astro'
import { asset } from '../lib/asset'

const navModes = [
  {
    icon: '📚',
    title: 'By Part',
    href: '/quantities',
    color: 'brand',
    desc: 'Browse the traditional ISO 80000 & IEC 80000 structure — Part 3 (Space & Time), Part 4 (Mechanics), through Part 13 (Information Science). Each part is a published standard document.',
    example: 'ISO 80000-3 → 42 entries on space and time',
  },
  {
    icon: '📐',
    title: 'By Kind',
    href: '/kinds',
    color: 'indigo',
    desc: 'Browse quantities grouped by their physical dimension. All quantities sharing the same dimension vector (e.g., L for length-type) form a kind of quantity — they can be compared and converted.',
    example: 'Kind L → length, width, height, wavelength, altitude',
  },
  {
    icon: '🔤',
    title: 'By Dimension',
    href: '/dimensions',
    color: 'indigo',
    desc: 'Browse by dimensional composition — the fundamental building blocks L, M, T, I, Θ, N, J. Cross-referenced with the UnitsML database for machine-readable unit definitions.',
    example: 'L T⁻¹ → all velocity-type quantities',
  },
  {
    icon: '⚖️',
    title: 'By Unit',
    href: '/units',
    color: 'teal',
    desc: 'Browse the complete catalog of measurement units — SI base units, derived units, accepted non-SI units, and their symbols. Linked to UnitsDB for canonical definitions.',
    example: 'metre (m) → used by 28+ quantities',
  },
  {
    icon: '🔗',
    title: 'By Concept',
    href: '/ontology',
    color: 'emerald',
    desc: 'Browse the ontology — SKOS concept scheme with broader/narrower relationships, entity characterization, and RDF/JSON-LD exports for machine consumption.',
    example: 'speed → broader → phase speed, group speed',
  },
]

const levels = [
  {
    level: 0,
    name: 'Kind of Quantity',
    axis: 'quantity',
    color: 'indigo',
    icon: '◇',
    quantity: { term: 'kind of quantity', example: 'space', note: 'Abstract category — all quantities of dimension L' },
    entity: null,
    measurement: null,
    impl: 'Derived automatically from unit dimension analysis. Every quantity whose primary unit reduces to the same dimension vector belongs to the same kind.',
  },
  {
    level: 1,
    name: 'Quantity',
    axis: 'quantity',
    color: 'brand',
    icon: '○',
    quantity: { term: 'quantity, Q = X', example: 'length (X₁ − X₂)', note: 'Named, defined concept — this is what ISO 80000 defines' },
    entity: { term: 'kind of entity', example: 'physical body', note: 'Category of thing being characterized' },
    measurement: null,
    impl: 'The primary content of the dataset. Each ISO 80000 entry (e.g., t3-1.1 "length") is a Level 1 quantity concept.',
  },
  {
    level: 2,
    name: 'Dedicated Quantity',
    axis: 'quantity',
    color: 'amber',
    icon: '◆',
    quantity: { term: 'entity quantity (Sachgrösse)', example: 'length of rod', note: 'Quantity bound to a specific kind of entity' },
    entity: { term: 'entity', example: 'rod', note: 'A specific type of physical thing' },
    measurement: null,
    impl: 'Derived semi-automatically. The quantity "sound particle displacement" is the "displacement" quantity bound to the "particle" entity. Pattern matching on designations and definitions.',
  },
  {
    level: 3,
    name: 'Measured Quantity',
    axis: 'measurement',
    color: 'rose',
    icon: '●',
    quantity: { term: 'instantiation', example: 'length of rod AB, today at 09:15', note: 'A specific quantity of a specific entity instance' },
    entity: { term: 'entity instance', example: 'rod AB, today at 09:15', note: 'A particular physical object at a particular time' },
    measurement: { term: 'quantity as measured', example: '1.234 m', note: 'A measurement result with a value and unit' },
    impl: 'Out of scope for a standards browser. This level belongs to measurement databases and laboratory information systems.',
  },
]

const references = [
  {
    citation: 'Pendrill, L. R. (2024)',
    title: 'Quantities and units: order amongst complexity',
    source: 'Chapter 2 in Models, Measurement, and Metrology extending the SI — Trust and Quality Assured Knowledge Infrastructures (W. P. Fisher Jr. & L. R. Pendrill, eds.). De Gruyter.',
    doi: '10.1515/9783111036496-002',
    note: 'Source of the concept system hierarchy with four levels (0–3) across three axes (quantity, entity, measurement) implemented on this site.',
  },
  {
    citation: 'Dybkaer, R. (2010)',
    title: 'An ontology on property for physical, chemical, and biological quantities',
    source: 'Metrologia, 47(3), 80–93.',
    doi: '10.1088/0026-1394/47/3/001',
    note: 'Foundation for the "systematic quantity term" column in Pendrill\'s hierarchy.',
  },
  {
    citation: 'Fleischman, E. (1960)',
    title: 'Sachgrösse und Grössenwert',
    source: 'Zeitschrift für Physik, 159, 1–12. (In German)',
    doi: null,
    note: 'Origin of the "Sachgrösse" (entity quantity) concept at Level 2 — the binding between a quantity and the entity it characterizes.',
  },
  {
    citation: 'Maxwell, J. C. (1873)',
    title: 'A Treatise on Electricity and Magnetism',
    source: 'Oxford: Clarendon Press. Vol. 1, §3.',
    doi: null,
    note: 'Established the quantity value equation Q = {Q} · [Q] — a quantity equals its numerical value times its unit.',
  },
  {
    citation: 'ISO/IEC (2008)',
    title: 'ISO/IEC Guide 99:2008 — International Vocabulary of Metrology (VIM)',
    source: 'Geneva: ISO/IEC.',
    doi: null,
    note: 'Normative reference for the ISO 80000 & IEC 80000 series — defines core concepts including "kind of quantity," "quantity," and "measurement."',
  },
]

const colorClasses: Record<string, { bg: string; text: string; border: string; dot: string }> = {
  brand: { bg: 'bg-brand-50 dark:bg-brand-950/40', text: 'text-brand-700 dark:text-brand-400', border: 'border-brand-200/60 dark:border-brand-800/40', dot: 'bg-brand-500' },
  indigo: { bg: 'bg-indigo-50 dark:bg-indigo-950/40', text: 'text-indigo-700 dark:text-indigo-400', border: 'border-indigo-200/60 dark:border-indigo-800/40', dot: 'bg-indigo-500' },
  teal: { bg: 'bg-teal-50 dark:bg-teal-950/40', text: 'text-teal-700 dark:text-teal-400', border: 'border-teal-200/60 dark:border-teal-800/40', dot: 'bg-teal-500' },
  amber: { bg: 'bg-amber-50 dark:bg-amber-950/40', text: 'text-amber-700 dark:text-amber-400', border: 'border-amber-200/60 dark:border-amber-800/40', dot: 'bg-amber-500' },
  rose: { bg: 'bg-rose-50 dark:bg-rose-950/40', text: 'text-rose-700 dark:text-rose-400', border: 'border-rose-200/60 dark:border-rose-800/40', dot: 'bg-rose-500' },
  emerald: { bg: 'bg-emerald-50 dark:bg-emerald-950/40', text: 'text-emerald-700 dark:text-emerald-400', border: 'border-emerald-200/60 dark:border-emerald-800/40', dot: 'bg-emerald-500' },
}
---

<DefaultLayout title="Methodology — ISQ Browser" description="How the ISQ Browser works: concept system hierarchy, navigation modes, data pipeline, and methodology.">
  <div>
    {/* Hero */}
    <section class="relative overflow-hidden bg-gradient-to-br from-slate-950 via-brand-950 to-indigo-950">
      <div class="absolute inset-0 hero-pattern"></div>
      <div class="grain-overlay absolute inset-0"></div>
      <div class="absolute top-0 right-0 w-[800px] h-[800px] rounded-full blur-[120px] -translate-y-1/2 translate-x-1/3 bg-indigo-500/10"></div>
      <div class="absolute bottom-0 left-0 w-[600px] h-[600px] rounded-full blur-[100px] translate-y-1/3 -translate-x-1/4 bg-rose-500/5"></div>

      <div class="hero-float-1 absolute top-[15%] right-[18%] w-3 h-3 rounded-full bg-indigo-400/20"></div>
      <div class="hero-float-2 absolute top-[30%] right-[8%] w-2 h-2 rounded-full bg-white/10"></div>
      <div class="hero-float-4 absolute top-[20%] left-[5%] w-16 h-16 rounded-full border border-white/[0.04]"></div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
        <div class="max-w-3xl page-enter">
          <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Methodology' }]} variant="dark" />
          <div class="flex items-center gap-2 mb-4">
            <span class="text-[10px] font-bold uppercase tracking-[0.15em] text-indigo-300/70">How this site works</span>
          </div>
          <h1 class="text-4xl sm:text-5xl font-bold text-white tracking-tight heading-serif leading-[1.1]">Methodology</h1>
          <p class="mt-4 text-lg text-slate-300/80 heading-serif leading-relaxed">
            The concept system, data pipeline, and design principles behind the ISQ Browser.
          </p>
          <p class="mt-3 text-sm text-slate-400/60 leading-relaxed max-w-2xl">
            Built on a four-level concept hierarchy adapted from Pendrill (2024), with automatic derivation of kinds, relationships, and entity bindings from the ISO 80000 & IEC 80000 dataset.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="#concept-system" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white/[0.06] border border-white/[0.08] text-xs font-medium text-white hover:bg-white/[0.1] transition-colors">
              <span>Concept System</span>
            </a>
            <a href="#navigation" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white/[0.06] border border-white/[0.08] text-xs font-medium text-white hover:bg-white/[0.1] transition-colors">
              <span>Navigation</span>
            </a>
            <a href="#pipeline" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white/[0.06] border border-white/[0.08] text-xs font-medium text-white hover:bg-white/[0.1] transition-colors">
              <span>Data Pipeline</span>
            </a>
            <a href="#references" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white/[0.06] border border-white/[0.08] text-xs font-medium text-white hover:bg-white/[0.1] transition-colors">
              <span>References</span>
            </a>
          </div>
        </div>
      </div>
      <div class="absolute bottom-0 inset-x-0 h-16 bg-gradient-to-t from-slate-50 dark:from-dark-950 to-transparent z-10"></div>
    </section>

    {/* The Concept System */}
    <section id="concept-system" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
      <div class="text-center mb-12">
        <SectionHead
          eyebrow="Pendrill (2024)"
          title="The Concept System"
          subtitle="A four-level hierarchy across three parallel axes — quantity, entity, and measurement. Each cell below is illustrated with a concrete example."
        />
      </div>

      {/* Matrix SVG */}
      <div class="max-w-5xl mx-auto mb-10">
        <div class="rounded-2xl border border-slate-200/60 dark:border-dark-600/60 bg-white dark:bg-dark-800 p-6 sm:p-8 shadow-sm">
          <svg viewBox="0 0 800 520" class="w-full h-auto" role="img" aria-label="Concept hierarchy matrix">
            <title>Concept Hierarchy Matrix — Pendrill (2024)</title>
            <desc>A 4×3 grid showing four levels of abstraction (0=kind, 1=generic, 2=dedicated, 3=instance) across three axes (quantity, entity, measurement), each cell containing an example.</desc>

            <defs>
              <linearGradient id="qGrad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#6366f1" stop-opacity="0.12"/>
                <stop offset="100%" stop-color="#6366f1" stop-opacity="0.04"/>
              </linearGradient>
              <linearGradient id="eGrad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#f43f5e" stop-opacity="0.10"/>
                <stop offset="100%" stop-color="#f43f5e" stop-opacity="0.03"/>
              </linearGradient>
              <linearGradient id="mGrad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#f59e0b" stop-opacity="0.10"/>
                <stop offset="100%" stop-color="#f59e0b" stop-opacity="0.03"/>
              </linearGradient>
            </defs>

            {/* Header row */}
            <text x="20" y="30" font-size="11" font-weight="700" fill="#94a3b8" font-family="monospace" text-transform="uppercase" letter-spacing="0.1em">LEVEL</text>
            <text x="200" y="30" font-size="13" font-weight="700" fill="#6366f1" font-family="sans-serif">QUANTITY AXIS</text>
            <text x="460" y="30" font-size="13" font-weight="700" fill="#f43f5e" font-family="sans-serif">ENTITY AXIS</text>
            <text x="660" y="30" font-size="13" font-weight="700" fill="#f59e0b" font-family="sans-serif">MEASUREMENT</text>

            {/* Header underline */}
            <line x1="20" y1="40" x2="780" y2="40" stroke="#cbd5e1" stroke-width="0.5"/>

            {/* Column backgrounds */}
            <rect x="180" y="45" width="260" height="420" fill="url(#qGrad)" rx="4"/>
            <rect x="445" y="45" width="210" height="420" fill="url(#eGrad)" rx="4"/>
            <rect x="660" y="45" width="120" height="420" fill="url(#mGrad)" rx="4"/>

            {/* Level 0 */}
            <text x="40" y="80" font-size="14" font-weight="700" fill="#6366f1" font-family="monospace">0</text>
            <text x="70" y="80" font-size="9" fill="#94a3b8" font-family="monospace">KIND</text>
            <text x="200" y="75" font-size="11" font-weight="600" fill="#1e293b">kind of quantity</text>
            <text x="200" y="92" font-size="11" fill="#6366f1" font-style="italic">"space"</text>
            <text x="460" y="84" font-size="11" fill="#cbd5e1">—</text>
            <text x="665" y="84" font-size="11" fill="#cbd5e1">—</text>

            <line x1="20" y1="105" x2="780" y2="105" stroke="#e2e8f0" stroke-width="0.5" stroke-dasharray="2 3"/>

            {/* Level 1 */}
            <text x="40" y="145" font-size="14" font-weight="700" fill="#6366f1" font-family="monospace">1</text>
            <text x="70" y="145" font-size="9" fill="#94a3b8" font-family="monospace">GENERIC</text>
            <text x="200" y="135" font-size="11" font-weight="600" fill="#1e293b">quantity, Q = X</text>
            <text x="200" y="152" font-size="11" fill="#6366f1" font-style="italic">"length" (X₁ − X₂)</text>
            <text x="460" y="135" font-size="11" font-weight="600" fill="#1e293b">kind of entity</text>
            <text x="460" y="152" font-size="11" fill="#f43f5e" font-style="italic">"physical body"</text>
            <text x="665" y="145" font-size="11" fill="#cbd5e1">—</text>

            <line x1="20" y1="170" x2="780" y2="170" stroke="#e2e8f0" stroke-width="0.5" stroke-dasharray="2 3"/>

            {/* Level 2 */}
            <text x="40" y="215" font-size="14" font-weight="700" fill="#6366f1" font-family="monospace">2</text>
            <text x="70" y="215" font-size="9" fill="#94a3b8" font-family="monospace">DEDICATED</text>
            <text x="200" y="200" font-size="11" font-weight="600" fill="#1e293b">entity quantity</text>
            <text x="200" y="215" font-size="9" fill="#94a3b8" font-family="monospace">[Sachgrösse]</text>
            <text x="200" y="232" font-size="11" fill="#6366f1" font-style="italic">"length of rod"</text>
            <text x="460" y="215" font-size="11" font-weight="600" fill="#1e293b">entity</text>
            <text x="460" y="232" font-size="11" fill="#f43f5e" font-style="italic">"rod"</text>
            <text x="665" y="222" font-size="11" fill="#cbd5e1">—</text>

            <line x1="20" y1="255" x2="780" y2="255" stroke="#e2e8f0" stroke-width="0.5" stroke-dasharray="2 3"/>

            {/* Level 3 */}
            <text x="40" y="310" font-size="14" font-weight="700" fill="#6366f1" font-family="monospace">3</text>
            <text x="70" y="310" font-size="9" fill="#94a3b8" font-family="monospace">INSTANCE</text>
            <text x="200" y="290" font-size="11" font-weight="600" fill="#1e293b">instantiation</text>
            <text x="200" y="307" font-size="11" fill="#6366f1" font-style="italic">"length of rod AB,"</text>
            <text x="200" y="322" font-size="11" fill="#6366f1" font-style="italic">"today at 09:15"</text>
            <text x="460" y="290" font-size="11" font-weight="600" fill="#1e293b">entity instance</text>
            <text x="460" y="307" font-size="11" fill="#f43f5e" font-style="italic">"rod AB,"</text>
            <text x="460" y="322" font-size="11" fill="#f43f5e" font-style="italic">"today at 09:15"</text>
            <text x="660" y="290" font-size="11" font-weight="600" fill="#1e293b">measured</text>
            <text x="660" y="307" font-size="11" fill="#f59e0b" font-style="italic">"1.234 m"</text>

            {/* Bottom arrows: generic → specific */}
            <line x1="100" y1="390" x2="700" y2="390" stroke="#94a3b8" stroke-width="1" stroke-dasharray="4 4"/>
            <polygon points="700,390 692,386 692,394" fill="#94a3b8"/>
            <text x="100" y="410" font-size="10" fill="#94a3b8" font-family="monospace">GENERIC</text>
            <text x="650" y="410" font-size="10" fill="#94a3b8" font-family="monospace" text-anchor="end">SPECIFIC</text>

            {/* Legend */}
            <rect x="180" y="445" width="14" height="14" fill="url(#qGrad)" stroke="#6366f1" stroke-width="0.5" rx="2"/>
            <text x="200" y="456" font-size="10" fill="#64748b">Quantity — what is measured</text>
            <rect x="445" y="445" width="14" height="14" fill="url(#eGrad)" stroke="#f43f5e" stroke-width="0.5" rx="2"/>
            <text x="465" y="456" font-size="10" fill="#64748b">Entity — what is characterized</text>
            <rect x="660" y="445" width="14" height="14" fill="url(#mGrad)" stroke="#f59e0b" stroke-width="0.5" rx="2"/>
            <text x="680" y="456" font-size="10" fill="#64748b">Measurement — the result</text>

            {/* Caption */}
            <text x="400" y="500" font-size="10" fill="#94a3b8" font-family="sans-serif" text-anchor="middle" font-style="italic">
              Adapted from Pendrill (2024), Table 1.1. Level numbers indicate abstraction: 0 = most generic, 3 = most specific.
            </text>
          </svg>
        </div>
      </div>

      {/* Original table reproduction */}
      <div class="max-w-5xl mx-auto mb-10">
        <div class="text-center mb-4">
          <p class="text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400 mb-1">Source table</p>
          <h3 class="text-lg font-bold text-slate-900 dark:text-slate-100 heading-serif">Table 1.1 — Hierarchy of Quantity, Entity and Measurement concepts</h3>
          <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Reproduced from Pendrill (2024), Table 1.1. The original 7-column layout showing how each level of abstraction applies across the three concept axes.</p>
        </div>

        <div class="rounded-2xl border border-slate-200/60 dark:border-dark-600/60 bg-white dark:bg-dark-800 overflow-hidden overflow-x-auto shadow-sm">
          <table class="w-full text-xs">
            <thead>
              <tr class="border-b-2 border-slate-300 dark:border-dark-500 bg-slate-50/50 dark:bg-dark-700/50">
                <th class="py-3 px-3 text-left font-bold text-slate-700 dark:text-slate-200 align-bottom w-12">Level</th>
                <th class="py-3 px-3 text-left font-bold text-indigo-700 dark:text-indigo-400 align-bottom">Systematic (quantity) term<br/><span class="text-[9px] font-normal text-slate-400">adapted from Dybkaer (2010)</span></th>
                <th class="py-3 px-3 text-left font-bold text-slate-700 dark:text-slate-200 align-bottom">Example</th>
                <th class="py-3 px-3 text-left font-bold text-rose-700 dark:text-rose-400 align-bottom">Systematic (entity) term<br/><span class="text-[9px] font-normal text-slate-400">phenomena, bodies, substances</span></th>
                <th class="py-3 px-3 text-left font-bold text-slate-700 dark:text-slate-200 align-bottom">Example</th>
                <th class="py-3 px-3 text-left font-bold text-amber-700 dark:text-amber-400 align-bottom">Systematic (measurement) term<br/><span class="text-[9px] font-normal text-slate-400">Pendrill (2019)</span></th>
                <th class="py-3 px-3 text-left font-bold text-slate-700 dark:text-slate-200 align-bottom">Example</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 dark:divide-dark-600">
              <tr class="hover:bg-indigo-50/30 dark:hover:bg-indigo-950/20 transition-colors">
                <td class="py-3 px-3 font-mono font-bold text-indigo-600 dark:text-indigo-400">0</td>
                <td class="py-3 px-3 text-slate-600 dark:text-slate-300">kind of quantity</td>
                <td class="py-3 px-3 text-slate-600 dark:text-slate-300 italic">space</td>
                <td class="py-3 px-3 text-slate-300 dark:text-slate-600">—</td>
                <td class="py-3 px-3 text-slate-300 dark:text-slate-600">—</td>
                <td class="py-3 px-3 text-slate-300 dark:text-slate-600">—</td>
                <td class="py-3 px-3 text-slate-300 dark:text-slate-600">—</td>
              </tr>
              <tr class="hover:bg-indigo-50/30 dark:hover:bg-indigo-950/20 transition-colors">
                <td class="py-3 px-3 font-mono font-bold text-indigo-600 dark:text-indigo-400">1</td>
                <td class="py-3 px-3 text-slate-600 dark:text-slate-300">quantity, Q = X</td>
                <td class="py-3 px-3 text-slate-600 dark:text-slate-300 italic">length (X₁ − X₂)</td>
                <td class="py-3 px-3 text-slate-600 dark:text-slate-300">kind of entity</td>
                <td class="py-3 px-3 text-slate-600 dark:text-slate-300 italic">physical body</td>
                <td class="py-3 px-3 text-slate-300 dark:text-slate-600">—</td>
                <td class="py-3 px-3 text-slate-300 dark:text-slate-600">—</td>
              </tr>
              <tr class="hover:bg-amber-50/30 dark:hover:bg-amber-950/20 transition-colors">
                <td class="py-3 px-3 font-mono font-bold text-amber-600 dark:text-amber-400">2</td>
                <td class="py-3 px-3 text-slate-600 dark:text-slate-300">dedicated quantity = entity quantity<br/><span class="text-[9px] text-slate-400">[Sachgrösse, Fleischman 1960]</span></td>
                <td class="py-3 px-3 text-slate-600 dark:text-slate-300 italic">length of rod</td>
                <td class="py-3 px-3 text-slate-600 dark:text-slate-300">entity</td>
                <td class="py-3 px-3 text-slate-600 dark:text-slate-300 italic">rod</td>
                <td class="py-3 px-3 text-slate-300 dark:text-slate-600">—</td>
                <td class="py-3 px-3 text-slate-300 dark:text-slate-600">—</td>
              </tr>
              <tr class="hover:bg-rose-50/30 dark:hover:bg-rose-950/20 transition-colors">
                <td class="py-3 px-3 font-mono font-bold text-rose-600 dark:text-rose-400">3</td>
                <td class="py-3 px-3 text-slate-600 dark:text-slate-300">instantiation of an entity quantity</td>
                <td class="py-3 px-3 text-slate-600 dark:text-slate-300 italic">length of rod AB,<br/>today at 09:15</td>
                <td class="py-3 px-3 text-slate-600 dark:text-slate-300">instantiation of an entity</td>
                <td class="py-3 px-3 text-slate-600 dark:text-slate-300 italic">rod AB,<br/>today at 09:15</td>
                <td class="py-3 px-3 text-slate-600 dark:text-slate-300">quantity as measured</td>
                <td class="py-3 px-3 text-slate-600 dark:text-slate-300 italic">measured length of rod AB,<br/>today at 09:15,<br/>1.234 m</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-[11px] text-slate-400 dark:text-slate-500 mt-3 text-center italic">
          Source: Pendrill, L. R. (2024). "Quantities and units: order amongst complexity." Chapter 2 in <em>Models, Measurement, and Metrology extending the SI</em>, De Gruyter. <a href="https://doi.org/10.1515/9783111036496-002" target="_blank" rel="noopener" class="text-brand-600 dark:text-brand-400 hover:underline">doi:10.1515/9783111036496-002</a>. Table 1.1, p. 22. Reproduced for educational commentary; all rights reserved by the publisher.
        </p>
      </div>

      {/* Mapping: Table → ISQ Browser */}
      <div class="max-w-5xl mx-auto mb-10">
        <div class="text-center mb-6">
          <p class="text-[10px] font-bold uppercase tracking-[0.15em] text-brand-500 mb-1">Mapping</p>
          <h3 class="text-lg font-bold text-slate-900 dark:text-slate-100 heading-serif">How the table maps to the ISQ Browser</h3>
          <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Each cell in the concept hierarchy informs a specific feature of this site.</p>
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          <div class="p-5 rounded-xl bg-indigo-50/50 dark:bg-indigo-950/20 border border-indigo-200/50 dark:border-indigo-800/30">
            <div class="flex items-center gap-2 mb-2">
              <div class="w-7 h-7 rounded-lg bg-indigo-100 dark:bg-indigo-900/40 flex items-center justify-center font-mono text-sm font-bold text-indigo-600 dark:text-indigo-400">0</div>
              <span class="text-sm font-bold text-indigo-700 dark:text-indigo-400">Kind of Quantity → /kinds</span>
            </div>
            <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed">
              <strong>Why applied:</strong> ISO 80000 defines individual quantities but never groups them by kind. Without this level, "length" in Part 3 and "wavelength" in Part 7 appear unrelated — even though they share dimension L and can be converted. Grouping by kind reveals these cross-part connections automatically.
            </p>
            <div class="mt-2 text-[10px] font-mono text-indigo-600 dark:text-indigo-400">
              kind-L → length, width, height, wavelength, altitude, distance…
            </div>
          </div>

          <div class="p-5 rounded-xl bg-brand-50/50 dark:bg-brand-950/20 border border-brand-200/50 dark:border-brand-800/30">
            <div class="flex items-center gap-2 mb-2">
              <div class="w-7 h-7 rounded-lg bg-brand-100 dark:bg-brand-900/40 flex items-center justify-center font-mono text-sm font-bold text-brand-600 dark:text-brand-400">1</div>
              <span class="text-sm font-bold text-brand-700 dark:text-brand-400">Quantity → /quantities</span>
            </div>
            <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed">
              <strong>Why applied:</strong> This is the authoritative level — what ISO/TC 12 and IEC/TC 25 actually define. Each entry has a normative name, symbol, definition, and units. The browser treats these as the primary content; all other levels are derived context.
            </p>
            <div class="mt-2 text-[10px] font-mono text-brand-600 dark:text-brand-400">
              t3-1.1 → length | symbol: l, L | unit: metre (m)
            </div>
          </div>

          <div class="p-5 rounded-xl bg-amber-50/50 dark:bg-amber-950/20 border border-amber-200/50 dark:border-amber-800/30">
            <div class="flex items-center gap-2 mb-2">
              <div class="w-7 h-7 rounded-lg bg-amber-100 dark:bg-amber-900/40 flex items-center justify-center font-mono text-sm font-bold text-amber-600 dark:text-amber-400">2</div>
              <span class="text-sm font-bold text-amber-700 dark:text-amber-400">Entity Quantity → Entry context</span>
            </div>
            <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed">
              <strong>Why applied:</strong> Pendrill's insight is that quantities characterize entities — "length" is abstract, "length of a rod" is meaningful. ISO 80000 encodes these bindings implicitly in names like "sound particle displacement" (entity: particle). Extracting them enables entity-based navigation and makes the quantity's scope explicit.
            </p>
            <div class="mt-2 text-[10px] font-mono text-amber-600 dark:text-amber-400">
              t8-3 → displacement + entity:particle → "particle displacement"
            </div>
          </div>

          <div class="p-5 rounded-xl bg-rose-50/50 dark:bg-rose-950/20 border border-rose-200/50 dark:border-rose-800/30">
            <div class="flex items-center gap-2 mb-2">
              <div class="w-7 h-7 rounded-lg bg-rose-100 dark:bg-rose-900/40 flex items-center justify-center font-mono text-sm font-bold text-rose-600 dark:text-rose-400">3</div>
              <span class="text-sm font-bold text-rose-700 dark:text-rose-400">Measured Quantity → Out of scope</span>
            </div>
            <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed">
              <strong>Why not applied:</strong> Individual measurements ("1.234 m for rod AB at 09:15") are data points, not concepts. They belong to laboratory information systems and measurement databases — not a standards browser. Including them would require runtime data fetching, breaking the static-site principle and the conceptual clarity of the browser.
            </p>
            <div class="mt-2 text-[10px] font-mono text-rose-600 dark:text-rose-400">
              Out of scope — handled by LIMS, measurement DBs
            </div>
          </div>
        </div>
      </div>

      {/* Why this matters */}
      <div class="max-w-3xl mx-auto mt-12 p-6 rounded-2xl bg-gradient-to-br from-brand-50/60 to-indigo-50/40 dark:from-brand-950/30 dark:to-indigo-950/20 border border-brand-200/40 dark:border-brand-800/30">
        <h3 class="text-base font-bold text-brand-700 dark:text-brand-400 mb-3 heading-serif">Why a hierarchy matters</h3>
        <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-3">
          A flat list of 765 quantities is overwhelming. Without structure, a user looking for "all the ways to express length-type quantities" must manually scan every part. The Pendrill hierarchy provides three organizing dimensions:
        </p>
        <ul class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed space-y-2 ml-4">
          <li class="list-disc"><strong>Generic to specific</strong> (Level 0→3): start from an abstract kind ("length-type") and drill down to a specific quantity ("wavelength"). Each level adds constraints.</li>
          <li class="list-disc"><strong>Quantity vs entity</strong> (Axis): separate "what is measured" (quantity) from "what is characterized" (entity). This prevents the common confusion between a quantity and the thing it describes.</li>
          <li class="list-disc"><strong>Concept vs measurement</strong> (Level 3): clearly delineate the standard's scope (what quantities ARE) from the application scope (what a specific measurement FOUND).</li>
        </ul>
        <p class="text-xs text-slate-500 dark:text-slate-500 italic mt-4 leading-relaxed">
          The result: every entry page on this site shows not just the quantity definition, but its kind, its broader/narrower concepts, and the entities it characterizes — all derived automatically from the ISO 80000 source data.
        </p>
      </div>

      {/* Level cards */}
      <div class="space-y-6">
        {levels.map((lvl) => {
          const c = colorClasses[lvl.color]
          return (
            <div class={`relative p-6 rounded-2xl border ${c.border} ${c.bg} overflow-hidden`}>
              <div class="flex items-start gap-4 flex-wrap">
                <div class="flex items-center gap-3 flex-shrink-0">
                  <div class={`w-12 h-12 rounded-xl ${c.bg} border ${c.border} flex items-center justify-center font-mono text-xl font-bold ${c.text}`}>
                    {lvl.level}
                  </div>
                  <div>
                    <div class="text-[9px] font-bold uppercase tracking-wider text-slate-400">Level {lvl.level}</div>
                    <div class={`text-sm font-bold ${c.text}`}>{lvl.name}</div>
                  </div>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="grid sm:grid-cols-3 gap-3 mb-3">
                    {lvl.quantity && (
                      <div class="p-3 rounded-lg bg-white/60 dark:bg-dark-800/40 border border-slate-200/40 dark:border-dark-600/40">
                        <div class="text-[9px] font-bold uppercase tracking-wider text-indigo-500 mb-1">Quantity</div>
                        <div class="text-xs font-semibold text-slate-700 dark:text-slate-200">{lvl.quantity.term}</div>
                        <div class="text-xs italic text-indigo-600 dark:text-indigo-400 mt-0.5">{lvl.quantity.example}</div>
                      </div>
                    )}
                    {lvl.entity && (
                      <div class="p-3 rounded-lg bg-white/60 dark:bg-dark-800/40 border border-slate-200/40 dark:border-dark-600/40">
                        <div class="text-[9px] font-bold uppercase tracking-wider text-rose-500 mb-1">Entity</div>
                        <div class="text-xs font-semibold text-slate-700 dark:text-slate-200">{lvl.entity.term}</div>
                        <div class="text-xs italic text-rose-600 dark:text-rose-400 mt-0.5">{lvl.entity.example}</div>
                      </div>
                    )}
                    {lvl.measurement && (
                      <div class="p-3 rounded-lg bg-white/60 dark:bg-dark-800/40 border border-slate-200/40 dark:border-dark-600/40">
                        <div class="text-[9px] font-bold uppercase tracking-wider text-amber-500 mb-1">Measurement</div>
                        <div class="text-xs font-semibold text-slate-700 dark:text-slate-200">{lvl.measurement.term}</div>
                        <div class="text-xs italic text-amber-600 dark:text-amber-400 mt-0.5">{lvl.measurement.example}</div>
                      </div>
                    )}
                  </div>
                  <div class="flex items-start gap-2">
                    <span class="text-[9px] font-bold uppercase tracking-wider text-slate-400 flex-shrink-0 mt-0.5">How derived</span>
                    <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">{lvl.impl}</p>
                  </div>
                </div>
              </div>
            </div>
          )
        })}
      </div>
    </section>

    {/* Derivation example */}
