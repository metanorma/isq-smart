---
import DefaultLayout from '../layouts/DefaultLayout.astro'
---

<DefaultLayout title="Not Found — ISQ Browser" description="The requested page was not found.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
    <div class="text-6xl mb-4">404</div>
    <h1 class="text-2xl font-bold text-slate-900 dark:text-slate-100 heading-serif">Page not found</h1>
    <p class="mt-2 text-slate-500 dark:text-slate-400 text-sm">The page you are looking for does not exist or has been moved.</p>
    <a href="/" class="mt-6 inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-brand-600 text-white text-sm font-medium hover:bg-brand-700 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      Back to Home
    </a>
  </div>
</DefaultLayout>
