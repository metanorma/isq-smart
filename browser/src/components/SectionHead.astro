---
interface Props {
  eyebrow?: string
  title: string
  subtitle?: string
  align?: 'left' | 'center'
  class?: string
}
const { eyebrow, title, subtitle, align = 'center', class: className = '' } = Astro.props
---

<div class={`${align === 'center' ? 'text-center' : ''} ${className}`}>
  {eyebrow && <p class="text-xs font-bold uppercase tracking-[0.15em] text-brand-500 mb-2">{eyebrow}</p>}
  <h2 class="text-3xl font-bold text-slate-900 dark:text-slate-100 tracking-tight heading-serif">{title}</h2>
  {subtitle && <p class="text-slate-500 dark:text-slate-400 text-sm max-w-2xl mt-2 leading-relaxed">{subtitle}</p>}
</div>
