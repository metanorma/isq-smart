---
import Breadcrumb from './Breadcrumb.astro'

interface Crumb {
  label: string
  href?: string
}

interface Stat {
  value: string | number
  label: string
}

interface Props {
  variant?: 'brand' | 'violet' | 'teal'
  crumbs?: Crumb[]
  title: string
  subtitle?: string
  description?: string
  stats?: Stat[]
}

const {
  variant = 'brand',
  crumbs = [],
  title,
  subtitle,
  description,
  stats = [],
} = Astro.props

const gradients: Record<string, string> = {
  brand: 'bg-gradient-to-br from-brand-950 via-[#351a38] to-iec-900',
  violet: 'bg-gradient-to-br from-violet-950 via-violet-900 to-indigo-950',
  teal: 'bg-gradient-to-br from-teal-950 via-cyan-900 to-blue-950',
}

const blobColors: Record<string, { primary: string; secondary?: string }> = {
  brand: { primary: 'bg-brand-500/10', secondary: 'bg-iec-500/10' },
  violet: { primary: 'bg-violet-500/10' },
  teal: { primary: 'bg-teal-500/10' },
}

const textColors: Record<string, { desc: string; crumb: string }> = {
  brand: { desc: 'text-brand-300/80', crumb: 'text-brand-300/60' },
  violet: { desc: 'text-violet-300/80', crumb: 'text-violet-300/60' },
  teal: { desc: 'text-teal-300/80', crumb: 'text-teal-300/60' },
}

const blob = blobColors[variant]
const text = textColors[variant]
---

<section class="relative overflow-hidden {gradients[variant]}">
  <div class="absolute inset-0 hero-pattern"></div>
  <div class="grain-overlay absolute inset-0"></div>
  <div class={`absolute top-0 right-0 w-[800px] h-[800px] ${blob.primary} rounded-full blur-[120px] -translate-y-1/2 translate-x-1/3`}></div>
  {blob.secondary && <div class={`absolute bottom-0 left-0 w-[600px] h-[600px] ${blob.secondary} rounded-full blur-[100px] translate-y-1/3 -translate-x-1/4`}></div>}

  <div class="hero-float-1 absolute top-[15%] right-[18%] w-3 h-3 rounded-full bg-white/10"></div>
  <div class="hero-float-2 absolute top-[30%] right-[8%] w-2 h-2 rounded-full bg-white/5"></div>
  <div class="hero-float-4 absolute top-[20%] left-[5%] w-16 h-16 rounded-full border border-white/[0.04]"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="max-w-3xl page-enter">
      {crumbs.length > 0 && <Breadcrumb items={crumbs} variant="dark" />}
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white tracking-tight heading-serif leading-[1.1]">
        {title}
      </h1>
      {subtitle && <p class={`mt-3 text-lg ${text.desc} heading-serif`}>{subtitle}</p>}
      {description && <p class={`mt-3 text-sm ${text.desc} leading-relaxed max-w-2xl`}>{description}</p>}
      {stats.length > 0 && (
        <div class="mt-6 flex gap-2">
          {stats.map((stat) => (
            <div class="px-3 py-1.5 rounded-lg bg-white/[0.06] border border-white/[0.08]">
              <span class="text-lg font-bold text-white heading-serif tabular-nums">{stat.value}</span>
              <span class={`text-xs ml-1 ${text.desc}`}>{stat.label}</span>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
  <div class="absolute bottom-0 inset-x-0 h-16 bg-gradient-to-t from-slate-50 dark:from-dark-950 to-transparent z-10"></div>
</section>
