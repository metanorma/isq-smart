---
import DefaultLayout from './DefaultLayout.astro'
import OntologySidebar from '../components/OntologySidebar.vue'
import { ontologyEntities } from '../data/generated/ontology'
import { buildOntologyTree } from '../data/ontology/OntologyTree'
import { asset } from '../lib/asset'

interface Props {
  title: string
  description?: string
  activeSlug?: string
}

const { title, description, activeSlug } = Astro.props
const tree = buildOntologyTree(ontologyEntities as any)
const pathname = Astro.url.pathname
---

<DefaultLayout title={title} description={description}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="flex gap-6">
      <!-- Sidebar (desktop) -->
      <aside class="hidden lg:block w-72 flex-shrink-0">
        <div class="sticky top-20 h-[calc(100vh-6rem)] rounded-xl border border-slate-200/60 dark:border-dark-600/60 bg-white dark:bg-dark-800 overflow-hidden">
          <OntologySidebar client:load tree={tree} activeSlug={activeSlug} />
        </div>
      </aside>

      <!-- Mobile sidebar toggle -->
      <div class="lg:hidden mb-4">
        <button
          id="ontology-sidebar-toggle"
          class="flex items-center gap-2 px-4 py-2 rounded-lg border border-slate-200/60 dark:border-dark-600/60 bg-white dark:bg-dark-800 text-sm font-medium text-slate-600 dark:text-slate-300"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
          Browse Ontology
        </button>
      </div>

      <!-- Mobile sidebar drawer -->
      <div id="ontology-sidebar-drawer" class="hidden fixed inset-0 z-50 lg:hidden">
        <div class="absolute inset-0 bg-black/30" data-close-drawer></div>
        <div class="absolute left-0 top-0 bottom-0 w-80 max-w-[85vw] bg-white dark:bg-dark-900 shadow-xl">
          <div class="flex items-center justify-between p-3 border-b border-slate-200/60 dark:border-dark-600/60">
            <span class="text-sm font-bold text-slate-700 dark:text-slate-200">Ontology Browser</span>
            <button data-close-drawer class="p-1 rounded-lg hover:bg-slate-100 dark:hover:bg-dark-700">
              <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          </div>
          <div class="h-[calc(100%-3rem)]">
            <OntologySidebar client:load tree={tree} activeSlug={activeSlug} />
          </div>
        </div>
      </div>

      <!-- Content -->
      <main class="flex-1 min-w-0">
        <slot />
      </main>
    </div>
  </div>

  <script>
    const toggle = document.getElementById('ontology-sidebar-toggle')
    const drawer = document.getElementById('ontology-sidebar-drawer')
    toggle?.addEventListener('click', () => drawer?.classList.remove('hidden'))
    drawer?.querySelectorAll('[data-close-drawer]').forEach(el => {
      el.addEventListener('click', () => drawer?.classList.add('hidden'))
    })
  </script>
</DefaultLayout>
