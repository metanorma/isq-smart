        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "B sub A",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t2-6.8",
      "@type": [
        "isoiec80000:MathConcept",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "2-6.8",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-6.8-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-6.8-0"
        }
      ],
      "skos:definition": {
        "@value": "stem:[B] is properly included in stem:[A],\n\nstem:[B] is a proper subset of stem:[A]\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Every element of stem:[B] belongs to stem:[A], but at least one element of stem:[A] does not belong to stem:[B].\n\nIf stem:[sub] is used for <<t2-6.7>>, then &#x228A; shall be used for <<t2-6.8>>.\n\nstem:[A sup B] has the same meaning as stem:[B sub A].\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-2-6"
      }
    }
  ]
