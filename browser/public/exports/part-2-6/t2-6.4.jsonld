        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "{x in A &#x2223; p(x)}",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t2-6.4",
      "@type": [
        "isoiec80000:MathConcept",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "2-6.4",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-6.4-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-6.4-0"
        }
      ],
      "skos:definition": {
        "@value": "set of those elements of stem:[A] for which the proposition stem:[p(x)] is true",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[example]\n====\n[stem]\n++++\n{x in bb(sf(R)) &#x2223; x >= 5}\n++++\n\nIf it is clear from the context which set stem:[A] is considered, the notation stem:[{x &#x2223; p(x)}] can be used (for example stem:[{x &#x2223; x >= 5}], if it is clear that real numbers are considered).\n\nInstead of the vertical line often a colon is used as separator:\n\nstem:[{x in A : p(x)}].\n====\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-2-6"
      }
    }
  ]
