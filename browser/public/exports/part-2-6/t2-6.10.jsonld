      "skos:definition": {
        "@value": "intersection of stem:[A] and stem:[B]",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The set of elements which belong to both sets stem:[A] and stem:[B].\n\nstem:[A nn B = {x &#x2223; x in A ^^ x in B}]\n",
