isoiec80000:term-t2-6.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "ordered pair"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-6.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "(a, b)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-6.14 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-6.14" ;
  skosxl:prefLabel isoiec80000:term-t2-6.14-0 ;
  skosxl:altLabel isoiec80000:sym-t2-6.14-0 ;
  skos:definition """ordered pair stem:[a, b], +
couple stem:[a, b]
"""@en ;
  skos:note """stem:[(a, b) = (c, d)] if and only if stem:[a = c] and stem:[b = d].

If the comma can be mistaken as the decimal sign, then the semicolon (;) or a stroke (&#x2223;) may be used as separator.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-6 .