isoiec80000:term-t2-6.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "not belong to"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-6.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "y !in A"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-6.2 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-6.2" ;
  skosxl:prefLabel isoiec80000:term-t2-6.2-0 ;
  skosxl:altLabel isoiec80000:sym-t2-6.2-0 ;
  skos:definition """stem:[y] does not belong to stem:[A], stem:[y] is not an element of the set stem:[A]"""@en ;
  skos:note """stem:[A\" \"&#x220C;\" \"y] has the same meaning as latexmath:[y \\notin A].

The negating stroke may also be vertical.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-6 .