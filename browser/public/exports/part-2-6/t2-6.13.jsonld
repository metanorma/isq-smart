        "smart:TermEntry"
      ],
      "dcterms:identifier": "2-6.13",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-6.13-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-6.13-0"
        }
      ],
      "skos:definition": {
        "@value": "difference of stem:[A] and stem:[B], +\nstem:[A] minus stem:[B]\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The set of elements which belong to stem:[A] but not to stem:[B].\n\nstem:[A \\\\ B = {x &#x2223; x in A ^^ x !in B}]\n\nThe notation stem:[A - B] should not be used.\n\nstem:[C_A B] is also used. stem:[C_A B] is mainly used when stem:[B] is a subset of stem:[A], and the symbol stem:[A] may be omitted if it is clear from the context which set stem:[A] is considered.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-2-6"
      }
    }
  ]
