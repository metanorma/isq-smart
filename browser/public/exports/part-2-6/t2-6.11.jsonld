      "skosxl:literalForm": {
        "@value": "uuu_(i=1)^n A_i",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t2-6.11",
      "@type": [
        "isoiec80000:MathConcept",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "2-6.11",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-6.11-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-6.11-0"
        }
      ],
      "skos:definition": {
        "@value": "union of the sets stem:[A_1, A_2, ..., A_n]\n\nstem:[uuu_(i=1)^n A_i = A_1 uu ... uu A_n]\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The set of elements belonging to at least one of the sets stem:[A_1, A_2, ..., A_n]\n\nstem:[uuu_(i=1)^n], stem:[uuu_(i in I)] and stem:[uuu_(i in I)] are also used,\n\nwhere stem:[I] denotes a set of subscripts.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-2-6"
      }
    }
