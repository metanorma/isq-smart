  dcterms:identifier "2-18.25" ;
  skosxl:prefLabel isoiec80000:term-t2-18.25-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.25-0 ;
  skos:definition """scalar product of two tensors stem:[sf(bb(ii(T)))] and stem:[sf(bb(ii(S)))] of the second order"""@en ;
  skos:note """scalar quantity +
stem:[sf(bb(ii(T:S))) = sum_i sum_j T_(ij) S_(ij)]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .
