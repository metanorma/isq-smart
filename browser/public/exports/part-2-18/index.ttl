  skosxl:literalForm "sf(bb(ii(T)))* bb(ii(a))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.24 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.24" ;
  skosxl:prefLabel isoiec80000:term-t2-18.24-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.24-0 ;
  skos:definition """inner product of a tensor stem:[sf(bb(ii(T)))] of the second order and a vector stem:[bb(ii(a))]"""@en ;
  skos:note """vector with coordinates

stem:[(sf(bb(ii(T)))* bb(ii(a)))_i = sum_j T_(ij) a_j]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

