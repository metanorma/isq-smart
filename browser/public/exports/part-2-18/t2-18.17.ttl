  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.17 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.17" ;
  skosxl:prefLabel isoiec80000:term-t2-18.17-0 ;
