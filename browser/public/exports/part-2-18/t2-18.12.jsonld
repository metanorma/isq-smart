      ],
      "dcterms:identifier": "2-18.12",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-18.12-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-18.12-0"
        }
      ],
      "skos:definition": {
        "@value": "vector product of stem:[bb(ii(a))] and stem:[bb(ii(b))]",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The coordinates, in a right-handed Cartesian coordinate system, are\n\nstem:[(bb(ii(a)) xx bb(ii(b)))_x = a_y b_z - a_z b_y]\n\nstem:[(bb(ii(a)) xx bb(ii(b)))_y = a_z b_x - a_x b_z]\n\nstem:[(bb(ii(a)) xx bb(ii(b)))_z = a_x b_y - a_y b_x]\n\nstem:[(bb(ii(a)) xx bb(ii(b)))_i = sum_j sum_k varepsilon_(ijk) a_j b_k]\n\nSee <<t2-18.10>>.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-2-18"
      }
    }
  ]
