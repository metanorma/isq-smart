        }
      ],
      "skos:definition": {
        "@value": "zero vector",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The zero vector has magnitude stem:[0].",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
