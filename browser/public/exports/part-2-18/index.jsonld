      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-18.7-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "bb(e)_1, bb(e)_2, bb(e)_3",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t2-18.7",
      "@type": [
        "isoiec80000:MathConcept",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "2-18.7",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-18.7-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-18.7-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-18.7-1"
        }
      ],
      "skos:definition": {
        "@value": "unit vectors in the directions of the Cartesian coordinate axes",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[bb(i), bb(j), bb(k)] are also used.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-2-18"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-18.8-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Cartesian coordinates of vector",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-18.8-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "a_x, a_y, a_z",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-18.8-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "a_i",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t2-18.8",
      "@type": [
        "isoiec80000:MathConcept",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "2-18.8",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-18.8-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-18.8-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-18.8-1"
        }
      ],
      "skos:definition": {
        "@value": "Cartesian coordinates of vector stem:[bb(ii(a))], +\nCartesian components of vector stem:[bb(ii(a))]\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[bb(ii(a)) = a_x\" \"bb(e)_x + a_y\" \"bb(e)_y + a_z\" \"bb(e)_z]\n\nstem:[a_1\" \"bb(e)_1, a_2\" \"bb(e)_2, a_3\" \"bb(e)_3] are the component vectors. If it is clear from the context which are the base vectors, the vector can be written\n\nstem:[bb(ii(a)) = (a_x, a_y, a_z)].\n\nstem:[a_x = bb(ii(a))*bb(e)_x, a_y = bb(ii(a))*bb(e)_y, a_z = bb(ii(a))*bb(e)_z]\n\nstem:[bb(r) = x bb(e)_x + y bb(e)_y + z bb(e)_z] is the position vector (radius vector) of the point with coordinates stem:[x, y, z].\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-2-18"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-18.9-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Kronecker delta symbol",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-18.9-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "delta_(ik)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t2-18.9",
      "@type": [
        "isoiec80000:MathConcept",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "2-18.9",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-18.9-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-18.9-0"
        }
      ],
      "skos:definition": {
        "@value": "Kronecker delta symbol",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[delta_(ik)={(1,\"for\",i=k),(0,\"for\",i!=k):}]",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-2-18"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-18.10-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Levi-Civita symbol",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-18.10-0",
      "@type": [
        "smart:Term",
