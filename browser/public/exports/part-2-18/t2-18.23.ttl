isoiec80000:term-t2-18.23-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "inner product of tensors"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.23-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sf(bb(ii(T))) * sf(bb(ii(S)))"@en ;
