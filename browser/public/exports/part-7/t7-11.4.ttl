isoiec80000:term-t7-11.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "luminous efficacy of a source"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t7-11.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "eta_\"v\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t7-11.4-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "(eta)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t7-11.4 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "7-11.4" ;
  skosxl:prefLabel isoiec80000:term-t7-11.4-0 ;
  skosxl:altLabel isoiec80000:sym-t7-11.4-0 ;
  skosxl:altLabel isoiec80000:sym-t7-11.4-1 ;
  skos:definition """quotient of the luminous flux emitted and the power consumed by the source, expressed by

[stem%unnumbered]
++++
eta_\"v\" = (Phi_\"v\")/P
++++

where stem:[Phi_\"v\"] is luminous flux (<<t7-13>>) and stem:[P] is the power (<<iso80000-4>>) consumed by the source
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-lm/W ;
  isoiec80000:hasUnit isoiec80000:unit-cd*sr*kg^(-1)*m^(-2)*s^3 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-7 .