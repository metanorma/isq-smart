isoiec80000:term-t7-22-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "photon radiance"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t7-22-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "L_\"p\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t7-22-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "(L)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t7-22 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "7-22" ;
  skosxl:prefLabel isoiec80000:term-t7-22-0 ;
  skosxl:altLabel isoiec80000:sym-t7-22-0 ;
  skosxl:altLabel isoiec80000:sym-t7-22-1 ;
  skos:definition """density of photon intensity with respect to projected area in a specified direction at a specified point on a real or imaginary surface, expressed by

[stem%unnumbered]
++++
L_\"p\" = (\"d\"I_\"p\")/(\"d\"A) 1/(\"cos\"alpha)
++++

where stem:[I_\"p\"] is photon intensity (<<t7-21>>), stem:[A] is area (<<iso80000-3>>) and stem:[alpha] the angle between the normal to the surface at the specified point and the specified direction
"""@en ;
  skos:note """The corresponding radiometric quantity is \"radiance\" (<<t7-6.1>>). The corresponding photometric quantity is \"luminance\" (<<t7-15>>)."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-m^(-2)*s^(-1)*sr^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-7 .