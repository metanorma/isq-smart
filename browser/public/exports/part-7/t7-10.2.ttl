isoiec80000:term-t7-10.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "spectral luminous efficiency <specified photometric condition>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t7-10.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "V(lambda)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t7-10.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "7-10.2" ;
  skosxl:prefLabel isoiec80000:term-t7-10.2-0 ;
  skosxl:altLabel isoiec80000:sym-t7-10.2-0 ;
  skos:definition """quotient of the radiant flux (<<t7-4.1>>) at wavelength stem:[lambda_\"m\"] and that at wavelength stem:[lambda], such that both produce equally intense luminous sensations for a specified photometric condition and stem:[lambda_\"m\"] is chosen so that the maximum value of this quotient is equal to 1"""@en ;
  skos:note """The spectral luminous efficiency of the human eye depends on a number of factors, particularly the state of visual adaptation and the size and position of the source in the visual field. The photometric condition should be specified (e.g. photopic, scotopic, mesopic). If it is not specified, photopic vision is assumed and the symbol stem:[V(lambda)] is used.

For scotopic and mesopic vision see <<cls-0.4>> and <<cls-0.5>>.

Symbols for different photometric conditions:

stem:[V(lambda)], <for photopic vision>; stem:[V'(lambda)], <for scotopic vision>; stem:[V_\"mes;m\"(lambda)], <for mesopic vision>; stem:[V_(10)(lambda)], <for the CIE 10&deg; photopic photometric observer>; stem:[V_\"M\"(lambda)], <for the CIE 1988 modified 2&deg; spectral luminous efficiency function for photopic vision>.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-7 .