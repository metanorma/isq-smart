isoiec80000:term-t7-37-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "molar absorption coefficient <radiometry>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t7-37-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "chi"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t7-37 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "7-37" ;
  skosxl:prefLabel isoiec80000:term-t7-37-0 ;
  skosxl:altLabel isoiec80000:sym-t7-37-0 ;
  skos:definition """product of linear absorption coefficient and molar volume, expressed by

[stem%unnumbered]
++++
chi = alpha V_\"m\"
++++

where stem:[alpha] is linear absorption coefficient (<<t7-35.2>>) and stem:[V_\"m\"] is molar volume (<<iso80000-9>>)
"""@en ;
  skos:note """The molar absorption coefficient can also be expressed by

[stem%unnumbered]
++++
chi=alpha c
++++

where stem:[c] is amount-of-substance concentration (<<iso80000-9>>).

Similarly, luminous and photon quantities can be defined.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-m^2*mol^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-7 .