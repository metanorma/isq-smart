isoiec80000:term-t7-9.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "radiant exposure"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t7-9.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "H_\"e\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t7-9.1-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "(H)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t7-9.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "7-9.1" ;
  skosxl:prefLabel isoiec80000:term-t7-9.1-0 ;
  skosxl:altLabel isoiec80000:sym-t7-9.1-0 ;
  skosxl:altLabel isoiec80000:sym-t7-9.1-1 ;
  skos:definition """density of incident radiant energy with respect to area at a point on a real or imaginary surface, expressed by

[stem%unnumbered]
++++
H_\"e\" = (\"d\"Q_\"e\")/(\"d\"A)
++++

where stem:[Q_\"e\"] is radiant energy (<<t7-2.1>>) and stem:[A] is the area on which the radiant energy is incident (<<iso80000-3>>)
"""@en ;
  skos:note """The corresponding photometric quantity is \"luminous exposure\" (<<t7-18>>). The corresponding quantity for photons is \"photon exposure\" (<<t7-25>>)."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-J/m^2 ;
  isoiec80000:hasUnit isoiec80000:unit-kg*s^(-2) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-7 .