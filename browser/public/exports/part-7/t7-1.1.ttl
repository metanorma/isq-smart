isoiec80000:term-t7-1.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "speed of light in a medium"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t7-1.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "c"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t7-1.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "7-1.1" ;
  skosxl:prefLabel isoiec80000:term-t7-1.1-0 ;
  skosxl:altLabel isoiec80000:sym-t7-1.1-0 ;
  skos:definition """phase speed of an electromagnetic wave at a given point in a medium"""@en ;
  skos:note """See also <<iso80000-3>>.

The value of the speed of light in a medium can depend on the frequency, polarization, and direction.

For the definition of the speed of electromagnetic waves in vacuum, stem:[c_0], see <<iso80000-1>>.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-m*s^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-7 .