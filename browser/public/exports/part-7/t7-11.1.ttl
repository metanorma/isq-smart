isoiec80000:term-t7-11.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "luminous efficacy of radiation <specified photometric condition>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t7-11.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "K"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t7-11.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "7-11.1" ;
  skosxl:prefLabel isoiec80000:term-t7-11.1-0 ;
  skosxl:altLabel isoiec80000:sym-t7-11.1-0 ;
  skos:definition """quotient of luminous flux (<<t7-13>>) and the corresponding radiant flux (<<t7-4.1>>) for a specified photometric condition"""@en ;
  skos:note """Luminous efficacy of radiation for photopic vision is expressed by

[stem%unnumbered]
++++
K = (Phi_\"v\")/(Phi_\"e\")
++++

where stem:[Phi_\"v\"] is luminous flux (<<t7-13>>) and stem:[Phi_\"e\"] is radiant flux (<<t7-4.1>>).

For scotopic and mesopic vision see <<cls-0.4>> and <<cls-0.5>>.

Symbols for different photometric conditions:

stem:[K], <for photopic vision>; stem:[K'], <for scotopic vision>; stem:[K_(\"mes\";m)], <for mesopic vision>; stem:[K_(10)], <for the CIE 10&deg; photopic photometric observer>; stem:[K_\"M\"], <for the CIE 1988 modified 2&deg; spectral luminous efficiency function for photopic vision>.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-lm/W ;
  isoiec80000:hasUnit isoiec80000:unit-cd*sr*kg^(-1)*m^(-2)*s^3 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-7 .