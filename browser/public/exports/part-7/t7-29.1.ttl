isoiec80000:term-t7-29.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "colour temperature"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t7-29.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "T_\"c\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t7-29.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "7-29.1" ;
  skosxl:prefLabel isoiec80000:term-t7-29.1-0 ;
  skosxl:altLabel isoiec80000:sym-t7-29.1-0 ;
  skos:definition """temperature of a Planckian radiator whose radiation has the same chromaticity as that of a given stimulus"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-K ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-7 .