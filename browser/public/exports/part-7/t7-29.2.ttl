isoiec80000:term-t7-29.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "correlated colour temperature"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t7-29.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "T_\"cp\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t7-29.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "7-29.2" ;
  skosxl:prefLabel isoiec80000:term-t7-29.2-0 ;
  skosxl:altLabel isoiec80000:sym-t7-29.2-0 ;
  skos:definition """temperature of a Planckian radiator having the chromaticity nearest the chromaticity associated with the given spectral distribution on a modified 1976 CIE Uniform Chromaticity Scale (UCS) diagram where

stem:[u'], stem:[2/3 v'] are the coordinates of the Planckian locus and the test stimulus
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-K ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-7 .