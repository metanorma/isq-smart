isoiec80000:term-t7-36.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "mass attenuation coefficient <radiometry>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t7-36.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "mu_\"m\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t7-36.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "7-36.1" ;
  skosxl:prefLabel isoiec80000:term-t7-36.1-0 ;
  skosxl:altLabel isoiec80000:sym-t7-36.1-0 ;
  skos:definition """quotient of the linear attenuation coefficient (<<t7-35.1>>), stem:[mu], and the mass density (<<iso80000-4>>), stem:[rho], of the medium"""@en ;
  skos:note """This quantity is also defined spectrally in terms of wavelength, in which case, \"spectral\" is added before this quantity name, which can be expressed by

[stem%unnumbered]
++++
mu_\"m\"(lambda) = (mu(lambda))/rho_\"m\"
++++

Similarly, luminous and photon quantities can be defined.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-kg^(-1)*m^2 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-7 .