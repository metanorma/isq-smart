      ],
      "dcterms:identifier": "7-4.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t7-4.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t7-4.1-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t7-4.1-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t7-4.1-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t7-4.1-2"
        }
      ],
      "skos:definition": {
        "@value": "change in radiant energy with time, expressed by\n\n[stem%unnumbered]\n++++\nPhi_\"e\" = (\"d\"Q_\"e\")/(\"d\"t)\n++++\n\nwhere stem:[Q_\"e\"] is the radiant energy (<<t7-2.1>>) emitted, transferred or received and stem:[t] is time (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The corresponding photometric quantity is \"luminous flux\" (<<t7-13>>). The corresponding quantity for photons is \"photon flux\" (<<t7-20>>).",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-W"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-3)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-7"
      }
    }
  ]
