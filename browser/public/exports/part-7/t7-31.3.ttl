isoiec80000:term-t7-31.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "reflectance"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t7-31.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "rho"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t7-31.3 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "7-31.3" ;
  skosxl:prefLabel isoiec80000:term-t7-31.3-0 ;
  skosxl:altLabel isoiec80000:sym-t7-31.3-0 ;
  skos:definition """quotient of reflected radiant flux and incident radiant flux, expressed by

[stem%unnumbered]
++++
rho = Phi_\"r\"/Phi_\"m\"
++++

where stem:[Phi_\"r\"] is reflected radiant flux (<<t7-4.1>>) and stem:[Phi_\"m\"] is incident radiant flux
"""@en ;
  skos:note """This quantity is also defined spectrally in terms of wavelength, in which case, \"spectral\" is added before the quantity name.

Due to energy conservation, stem:[alpha + rho + tau = 1] except when polarized radiation is observed, where stem:[alpha] is absorptance (<<t7-31.1>>) and stem:[tau] is transmittance (<<t7-31.5>>).
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-7 .