isoiec80000:term-t7-36.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "mass absorption coefficient <radiometry>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t7-36.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "alpha_\"m\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t7-36.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "7-36.2" ;
  skosxl:prefLabel isoiec80000:term-t7-36.2-0 ;
  skosxl:altLabel isoiec80000:sym-t7-36.2-0 ;
  skos:definition """quotient of the linear absorption coefficient (<<t7-35.2>>), stem:[alpha], and the mass density (<<iso80000-4>>), stem:[rho], of the medium"""@en ;
  skos:note """This quantity is also defined spectrally in terms of wavelength, in which case, \"spectral\" is added before this quantity name, which can be expressed by

[stem%unnumbered]
++++
alpha_\"m\"(lambda) = (alpha(lambda))/rho_\"m\"
++++

Similarly, luminous and photon quantities can be defined.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-7 .