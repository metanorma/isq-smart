isoiec80000:term-t7-8.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "spectral radiant exitance"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t7-8.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "M_(\"e\",lambda)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t7-8.2-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "(M_(lambda))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t7-8.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "7-8.2" ;
  skosxl:prefLabel isoiec80000:term-t7-8.2-0 ;
  skosxl:altLabel isoiec80000:sym-t7-8.2-0 ;
  skosxl:altLabel isoiec80000:sym-t7-8.2-1 ;
  skos:definition """density of radiant exitance with respect to wavelength, expressed by

[stem%unnumbered]
++++
M_(\"e\",lambda) = (\"d\"M_\"e\")/(\"d\"lambda)
++++

where stem:[M_\"e\"] is radiant exitance (<<t7-8.1>>) in terms of wavelength stem:[lambda] (<<iso80000-3>>)
"""@en ;
  skos:note """The integral of (total) radiant exitance is determined by the wavelength interval stem:[(lambda_1, lambda_2)] under consideration:

[stem%unnumbered]
++++
M_\"e\" = int_(lambda_1)^(lambda_2) M_(\"e\",lambda)\"d\"lambda
++++
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-W/(m^2*nm) ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^(-1)*s^(-3) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-7 .