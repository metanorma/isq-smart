isoiec80000:term-t7-32.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "transmittance optical density"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t7-32.1-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "optical density"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t7-32.1-2 a smart:Term, skosxl:Label ;
  skosxl:literalForm "transmittance density"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t7-32.1-3 a smart:Term, skosxl:Label ;
  skosxl:literalForm "decadic absorbance"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t7-32.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "D"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t7-32.1-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "A_(10)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t7-32.1-2 a smart:Term, skosxl:Label ;
  skosxl:literalForm "D_tau"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t7-32.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "7-32.1" ;
  skosxl:prefLabel isoiec80000:term-t7-32.1-0 ;
  skosxl:altLabel isoiec80000:term-t7-32.1-1 ;
  skosxl:altLabel isoiec80000:term-t7-32.1-2 ;
  skosxl:altLabel isoiec80000:term-t7-32.1-3 ;
  skosxl:altLabel isoiec80000:sym-t7-32.1-0 ;
  skosxl:altLabel isoiec80000:sym-t7-32.1-1 ;
  skosxl:altLabel isoiec80000:sym-t7-32.1-2 ;
  skos:definition """logarithm to base 10 of the reciprocal of the transmittance, stem:[tau] (<<t7-31.5>>)"""@en ;
  skos:note """If defined in terms of wavelength, the optical density can be expressed by

[stem%unnumbered]
++++
A_(10)(lambda) = -\"lg\"[tau(lambda)\\]
++++

where stem:[tau(lambda)] is the transmittance (<<t7-31.5>>) in terms of wavelength.

In spectroscopy, the name \"absorbance stem:[A_(10)]\" is generally used.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-7 .