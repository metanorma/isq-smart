isoiec80000:term-t7-11.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "spectral luminous efficacy <specified photometric condition>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t7-11.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "K(lambda)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t7-11.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "7-11.2" ;
  skosxl:prefLabel isoiec80000:term-t7-11.2-0 ;
  skosxl:altLabel isoiec80000:sym-t7-11.2-0 ;
  skos:definition """product of spectral luminous efficiency (<<t7-10.2>>) and maximum luminous efficacy (<<t7-11.3>>) for a specified photometric condition"""@en ;
  skos:note """Spectral luminous efficacy for photopic vision is expressed by

[stem%unnumbered]
++++
K(lambda) = K_\"m\" V(lambda)
++++

where stem:[K_\"m\"] is maximum luminous efficacy (<<t7-11.3>>), stem:[V(lambda)] is spectral luminous efficiency (<<t7-10.2>>) and stem:[lambda] is wavelength.

For scotopic and mesopic vision see <<cls-0.4>> and <<cls-0.5>>.

Symbols for different photometric conditions:

stem:[K(lambda)], <for photopic vision>; stem:[K'(lambda)], <for scotopic vision>; stem:[K_\"mes;m\"(lambda)], <for mesopic vision>; stem:[K_(10)(lambda)], <for the CIE 10&deg; photopic photometric observer>; stem:[K_\"M\"(lambda)], <for the CIE 1988 modified 2&deg; spectral luminous efficiency function for photopic vision>.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-lm/W ;
  isoiec80000:hasUnit isoiec80000:unit-cd*sr*kg^(-1)*m^(-2)*s^3 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-7 .