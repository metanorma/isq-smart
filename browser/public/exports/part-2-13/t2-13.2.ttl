isoiec80000:term-t2-13.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "exponential function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-13.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a^x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-13.2 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-13.2" ;
  skosxl:prefLabel isoiec80000:term-t2-13.2-0 ;
  skosxl:altLabel isoiec80000:sym-t2-13.2-0 ;
  skos:definition """stem:[a] to the power of stem:[x], +
exponential function to the base stem:[a] of argument stem:[x]
"""@en ;
  skos:note """See also <<t2-10.9>>."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-13 .