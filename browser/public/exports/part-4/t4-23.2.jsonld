      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t4-23.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "4-23.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t4-23.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t4-23.2-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t4-23.2-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t4-23.2-1"
        }
      ],
      "skos:definition": {
        "@value": "proportionality factor between the magnitudes of the kinetic friction force,\nstem:[F_(rm(mu))] (<<t4-9.4>>) and the normal component stem:[N] of the\ncontact force (<<t4-9.1>>):\n\nstem:[F_(rm(mu)) = mu N]\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "When it is not necessary to distinguish between dynamic friction factor and\nstatic friction factor, the name friction factor may be used for both.\n\nThe dynamic friction factor stem:[mu] is independent in first approximation\nof the contact surface.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-4"
      }
    }
