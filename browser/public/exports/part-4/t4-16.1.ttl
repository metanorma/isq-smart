isoiec80000:term-t4-16.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "normal stress"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t4-16.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sigma_\"n\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t4-16.1-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sigma"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t4-16.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "4-16.1" ;
  skosxl:prefLabel isoiec80000:term-t4-16.1-0 ;
  skosxl:altLabel isoiec80000:sym-t4-16.1-0 ;
  skosxl:altLabel isoiec80000:sym-t4-16.1-1 ;
  skos:definition """scalar (<<iso80000-2>>) quantity describing surface action of a force into a
body equal to:

stem:[sigma_\"n\" = (\"d\"F_\"n\")/(\"d\"A)]

where stem:[F_\"n\"] is the normal component of force (<<t4-9.1>>) and
stem:[A] is the area (<<iso80000-3>>) of the surface element
"""@en ;
  skos:note """A couple of mutually opposite forces of magnitude F acting on the opposite
surfaces of a slice (layer) of homogenous solid matter normal to it, and
evenly distributed, cause a constant normal stress stem:[sigma_\"n\"=FA] in
the slice (layer).
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Pa ;
  isoiec80000:hasUnit isoiec80000:unit-N*m^(-2) ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^(-1)*s^(-2) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-4 .