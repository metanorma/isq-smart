  "@graph": [
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t4-21.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "second axial moment of area",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t4-21.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "I_\"a\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t4-21.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "4-21.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t4-21.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t4-21.1-0"
        }
      ],
      "skos:definition": {
        "@value": "geometrical characteristic of a shape of a body equal to:\n\nstem:[I_\"a\" = &#8748;_\"M\" r_\"Q\"^2 \"d\"A]\n\nwhere stem:[\"M\"] is the two-dimensional domain of the cross-section of a\nplane and considered body, stem:[r_\"Q\"] is radial distance (<<iso80000-3>>)\nfrom a stem:[\"Q\"]-axis in the plane of the surface considered and stem:[A]\nis area (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "This quantity is often referred to wrongly as \"moment of inertia\" (<<t4-7>>).\n\nThe subscript, stem:[\"a\"], may be omitted when there is no risk of confusion.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^4"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-4"
      }
    }
  ]
}