isoiec80000:term-t4-11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "angular momentum"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t4-11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(L))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t4-11 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "4-11" ;
  skosxl:prefLabel isoiec80000:term-t4-11-0 ;
  skosxl:altLabel isoiec80000:sym-t4-11-0 ;
  skos:definition """vector (<<iso80000-2>>) quantity described by the vector product:

stem:[bb(ii(L)) = bb(ii(r)) xx bb(ii(p))]

where stem:[bb(ii(r))] is position vector (<<iso80000-3>>) with respect to
the axis of rotation and stem:[bb(ii(p))] is momentum (<<t4-8>>)
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^2*s^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-4 .