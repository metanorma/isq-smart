          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t4-23.1-1"
        }
      ],
      "skos:definition": {
        "@value": "proportionality factor between the maximum magnitude of the tangential\ncomponent stem:[F_\"max\"] of the static friction force (<<t4-9.3>>) and the\nmagnitude of the normal component stem:[N] of the contact force (<<t4-9.1>>)\nbetween two bodies at relative rest with respect to each other:\n\nstem:[F_\"max\" = mu_\"s\"N]\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "When it is not necessary to distinguish between dynamic friction factor and\nstatic friction factor, the name friction factor may be used for both.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-4"
      }
    }
