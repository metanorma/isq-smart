      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t4-31",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "4-31",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t4-31-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t4-31-0"
        }
      ],
      "skos:definition": {
        "@value": "scalar (<<iso80000-2>>) quantity characterizing the total flow through the\ntwo-dimensional domain stem:[\"A\"] with the normal vector\nstem:[bb(ii(e))_\"n\"] of a flowing fluid with velocity stem:[v]\n(<<iso80000-3>>) as an integral:\n\nstem:[q_V = &#8748;_\"A\" v * bb(ii(e))_\"n\" \"d\"A]\n\nwhere stem:[\"d\"A] is the area (<<iso80000-3>>) of an element of the\ntwo-dimensional domain stem:[\"A\"]\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^3*s^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t4-32-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "action",
        "@language": "en"
      },
