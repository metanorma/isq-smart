      "skos:definition": {
        "@value": "scalar (<<iso80000-2>>) quantity characterizing a moving body expressed by:\n\nstem:[T = 1/2 mv^2]\n\nwhere stem:[m] is mass (<<t4-1>>) of the body and vis its speed\n(<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For the definition of energy, see <<iso80000-5>>.",
        "@language": "en"
      },
