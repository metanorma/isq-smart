isoiec80000:term-t4-31-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "volume flow rate"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t4-31-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "q_V"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t4-31 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "4-31" ;
  skosxl:prefLabel isoiec80000:term-t4-31-0 ;
  skosxl:altLabel isoiec80000:sym-t4-31-0 ;
  skos:definition """scalar (<<iso80000-2>>) quantity characterizing the total flow through the
two-dimensional domain stem:[\"A\"] with the normal vector
stem:[bb(ii(e))_\"n\"] of a flowing fluid with velocity stem:[v]
(<<iso80000-3>>) as an integral:

stem:[q_V = &#8748;_\"A\" v * bb(ii(e))_\"n\" \"d\"A]

where stem:[\"d\"A] is the area (<<iso80000-3>>) of an element of the
two-dimensional domain stem:[\"A\"]
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-m^3*s^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-4 .