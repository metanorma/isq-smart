isoiec80000:term-t4-17.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "strain"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t4-17.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(epsilon))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t4-17.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "4-17.1" ;
  skosxl:prefLabel isoiec80000:term-t4-17.1-0 ;
  skosxl:altLabel isoiec80000:sym-t4-17.1-0 ;
  skos:definition """tensor (<<iso80000-2>>) quantity representing the deformation of matter
caused by stress
"""@en ;
  skos:note """Strain tensor is symmetric and has three linear-strain and three shear
strain (Cartesian) components.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-4 .