          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t4-28.3-1"
        }
      ],
      "skos:definition": {
        "@value": "sum of kinetic energy stem:[T] (<<t4-28.2>>) and potential energy stem:[V]\n(<<t4-28.1>>):\n\nstem:[E = T + V]\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The symbols stem:[E] and stem:[W] are also used for other kinds of energy.\n\nThis definition is understood in a classical way and it does not include\nthermal motion.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-J"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-2)"
        }
      ],
