      ],
      "skos:definition": {
        "@value": "proportionality factor between the magnitude of the tangential component\nstem:[F] and the magnitude of the normal component stem:[N] of the force\napplied to a body rolling on a surface at constant speed:\n\nstem:[F = C_\"rr\"N]\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Also known as rolling resistance coefficient, ((RRC)).",
        "@language": "en"
      },
