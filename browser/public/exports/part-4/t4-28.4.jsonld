        "smart:TermEntry"
      ],
      "dcterms:identifier": "4-28.4",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t4-28.4-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t4-28.4-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t4-28.4-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t4-28.4-1"
        }
      ],
      "skos:definition": {
        "@value": "process quantity describing the total action of a force stem:[bb(ii(F))]\n(<<t4-9.1>>) along a continuous curve stem:[Gamma] in three-dimensional\nspace with infinitesimal displacement (<<iso80000-3>>) stem:[\"d\"r], as a\nline integral of their scalar product:\n\nstem:[A = int_Gamma bb(ii(F)) * \"d\"r]\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The definition covers the case\n\nstem:[A = - int_Gamma p * \"d\"V]\n\nwhere stem:[Gamma] is a curve in the phase space and implies that work\ngenerally depends upon stem:[Gamma], and that type of process must be\ndefined (e.g. isentropic or isothermic).\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-J"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-4"
      }
