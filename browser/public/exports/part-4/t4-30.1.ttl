isoiec80000:term-t4-30.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "mass flow"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t4-30.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(j))_m"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t4-30.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "4-30.1" ;
  skosxl:prefLabel isoiec80000:term-t4-30.1-0 ;
  skosxl:altLabel isoiec80000:sym-t4-30.1-0 ;
  skos:definition """vector (<<iso80000-2>>) quantity characterizing a flowing fluid by the
product of its local mass density stem:[rho] (<<t4-2>>) and local velocity
stem:[v] (<<iso80000-3>>):

stem:[bb(ii(j))_m = rho v]
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^(-2)*s^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-4 .