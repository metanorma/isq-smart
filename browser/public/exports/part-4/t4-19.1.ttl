isoiec80000:term-t4-19.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "modulus of elasticity"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t4-19.1-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Young modulus"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t4-19.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "E"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t4-19.1-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "E_\"m\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t4-19.1-2 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Y"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t4-19.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "4-19.1" ;
  skosxl:prefLabel isoiec80000:term-t4-19.1-0 ;
  skosxl:altLabel isoiec80000:term-t4-19.1-1 ;
  skosxl:altLabel isoiec80000:sym-t4-19.1-0 ;
  skosxl:altLabel isoiec80000:sym-t4-19.1-1 ;
  skosxl:altLabel isoiec80000:sym-t4-19.1-2 ;
  skos:definition """quotient of normal stress stem:[sigma] (<<t4-16.1>>) and relative linear
strain stem:[epsilon] (<<t4-17.2>>):

stem:[E = sigma/epsilon]
"""@en ;
  skos:note """Conditions should be specified (e.g. adiabatic or isothermal process)."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Pa ;
  isoiec80000:hasUnit isoiec80000:unit-N*m^(-2) ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^(-1)*s^(-2) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-4 .