      ],
      "skos:definition": {
        "@value": "geometrical characteristic of a shape of a body equal to:\n\nstem:[Z = I_\"a\"//r_\"Q,max\"]\n\nwhere stem:[I_\"a\"] is the second axial moment of area (<<t4-21.1>>) and\nstem:[r_\"Q,max\"] is the maximum radial distance (<<iso80000-3>>) of any\npoint in the surface considered from the stem:[\"Q\"]-axis with respect to\nwhich stem:[I_\"a\"] is defined\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^3"
        }
      ],
