isoiec80000:term-t4-4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "relative mass density"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t4-4-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "relative density"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t4-4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "d"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t4-4 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "4-4" ;
  skosxl:prefLabel isoiec80000:term-t4-4-0 ;
  skosxl:altLabel isoiec80000:term-t4-4-1 ;
  skosxl:altLabel isoiec80000:sym-t4-4-0 ;
  skos:definition """quotient of mass density of a substance stem:[rho] and mass density of a
reference substance stem:[rho_0]:

stem:[d = rho/rho_0]
"""@en ;
  skos:note """Conditions and material should be specified for the reference substance."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-4 .