isoiec80000:term-t4-13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "angular impulse"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t4-13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(H))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t4-13 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "4-13" ;
  skosxl:prefLabel isoiec80000:term-t4-13-0 ;
  skosxl:altLabel isoiec80000:sym-t4-13-0 ;
  skos:definition """vector (<<iso80000-2>>) quantity describing the effect of moment of force
during a time interval:

stem:[bb(ii(H))(t_1;t_2) = int_(t_1)^(t_2) bb(ii(M)) \"d\"t]

where stem:[bb(ii(M))] is moment of force (<<t4-12.1>>), stem:[t] is time
(<<iso80000-3>>) and stem:[[t_1, t_2\\]] is considered time interval
"""@en ;
  skos:note """For a time interval stem:[[t_1, t_2\\]],

stem:[bb(ii(H))(t_1,t_2) = bb(ii(L))(t_2) - bb(ii(L))(t_1) = Delta bb(ii(L))]

where stem:[bb(ii(L))] is angular momentum.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-N*m*s ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^2*s^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-4 .