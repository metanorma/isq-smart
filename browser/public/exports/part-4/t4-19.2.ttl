  smart:hasTermFormType smart:symbol .

isoiec80000:t4-19.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "4-19.2" ;
  skosxl:prefLabel isoiec80000:term-t4-19.2-0 ;
  skosxl:altLabel isoiec80000:term-t4-19.2-1 ;
  skosxl:altLabel isoiec80000:sym-t4-19.2-0 ;
  skos:definition """quotient of shear stress stem:[tau] (<<t4-16.2>>) and shear strain
