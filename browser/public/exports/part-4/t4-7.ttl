isoiec80000:term-t4-7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "moment of inertia"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t4-7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(J))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t4-7 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "4-7" ;
  skosxl:prefLabel isoiec80000:term-t4-7-0 ;
  skosxl:altLabel isoiec80000:sym-t4-7-0 ;
  skos:definition """tensor (<<iso80000-2>>) quantity representing rotational inertia of a rigid
body relative to a fixed centre of rotation expressed by the tensor product:

stem:[bb(ii(L)) = bb(ii(J)) omega]

where stem:[bb(ii(L))] is angular momentum (<<iso80000-3>>) of the body
relative to the reference point and stem:[omega] is its angular velocity
(<<iso80000-3>>)
"""@en ;
  skos:note """The calculation of the value requires an integration."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^2 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-4 .