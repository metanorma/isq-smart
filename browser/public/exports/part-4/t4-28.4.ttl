isoiec80000:term-t4-28.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "mechanical work"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t4-28.4-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "work"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t4-28.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "A"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t4-28.4-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "W"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t4-28.4 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "4-28.4" ;
  skosxl:prefLabel isoiec80000:term-t4-28.4-0 ;
  skosxl:altLabel isoiec80000:term-t4-28.4-1 ;
  skosxl:altLabel isoiec80000:sym-t4-28.4-0 ;
  skosxl:altLabel isoiec80000:sym-t4-28.4-1 ;
  skos:definition """process quantity describing the total action of a force stem:[bb(ii(F))]
(<<t4-9.1>>) along a continuous curve stem:[Gamma] in three-dimensional
space with infinitesimal displacement (<<iso80000-3>>) stem:[\"d\"r], as a
line integral of their scalar product:

stem:[A = int_Gamma bb(ii(F)) * \"d\"r]
"""@en ;
  skos:note """The definition covers the case

stem:[A = - int_Gamma p * \"d\"V]

where stem:[Gamma] is a curve in the phase space and implies that work
generally depends upon stem:[Gamma], and that type of process must be
defined (e.g. isentropic or isothermic).
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-J ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^2*s^(-2) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-4 .