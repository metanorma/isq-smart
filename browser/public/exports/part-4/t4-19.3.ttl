isoiec80000:term-t4-19.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "modulus of compression"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t4-19.3-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bulk modulus"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t4-19.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "K"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t4-19.3-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "K_\"m\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t4-19.3-2 a smart:Term, skosxl:Label ;
  skosxl:literalForm "B"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t4-19.3 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "4-19.3" ;
  skosxl:prefLabel isoiec80000:term-t4-19.3-0 ;
  skosxl:altLabel isoiec80000:term-t4-19.3-1 ;
  skosxl:altLabel isoiec80000:sym-t4-19.3-0 ;
  skosxl:altLabel isoiec80000:sym-t4-19.3-1 ;
  skosxl:altLabel isoiec80000:sym-t4-19.3-2 ;
  skos:definition """negative of the quotient of pressure stem:[p] (<<t4-14.1>>) and relative
volume strain stem:[vartheta] (<<t4-17.4>>):

stem:[K = p/vartheta]
"""@en ;
  skos:note """Conditions should be specified (e.g. isentropic or isothermal process)."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Pa ;
  isoiec80000:hasUnit isoiec80000:unit-N*m^(-2) ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^(-1)*s^(-2) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-4 .