isoiec80000:term-t4-9.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "kinetic friction force"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t4-9.4-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "dynamic friction force"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t4-9.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(F))_(rm(mu))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t4-9.4 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "4-9.4" ;
  skosxl:prefLabel isoiec80000:term-t4-9.4-0 ;
  skosxl:altLabel isoiec80000:term-t4-9.4-1 ;
  skosxl:altLabel isoiec80000:sym-t4-9.4-0 ;
  skos:definition """force (<<t4-9.1>>) resisting the motion when a body slides on a surface"""@en ;
  skos:note """For the kinetic friction factor, see <<t4-23.2>>."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-N ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m*s^(-2) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-4 .