isoiec80000:term-t4-8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "momentum"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t4-8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "p"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t4-8 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "4-8" ;
  skosxl:prefLabel isoiec80000:term-t4-8-0 ;
  skosxl:altLabel isoiec80000:sym-t4-8-0 ;
  skos:definition """product of mass stem:[m] (<<t4-1>>) of a body and velocity stem:[v]
(<<iso80000-3>>) of its centre of mass:

stem:[p=mv]
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m*s^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-4 .