      "skos:definition": {
        "@value": "for laminar flows, proportionality constant between shear stress\nstem:[tau_(xz)] (<<t4-16.2>>) in a fluid moving with a velocity stem:[v_x]\n(<<iso80000-3>>) and gradient stem:[\"d\"v_x//\"d\"z] perpendicular to the plane\nof shear:\n\nstem:[tau_(xz) = eta (\"d\"v_x)/(\"d\"z)]\n",
        "@language": "en"
      },
