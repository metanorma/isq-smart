        }
      ],
      "skos:definition": {
        "@value": "determinant of a square matrix stem:[bb(ii(A))]",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Sometimes stem:[abs(bb(ii(A)))] is used.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
