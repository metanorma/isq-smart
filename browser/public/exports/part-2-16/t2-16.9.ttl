isoiec80000:term-t2-16.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Hermitian conjugate matrix"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-16.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(A))^(\"H\")"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-16.9 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-16.9" ;
  skosxl:prefLabel isoiec80000:term-t2-16.9-0 ;
  skosxl:altLabel isoiec80000:sym-t2-16.9-0 ;
  skos:definition """Hermitian conjugate matrix of stem:[bb(ii(A))]"""@en ;
  skos:note """stem:[bb(ii(A))^(\"H\") = (bb(bar A))^(\"T\")]

The term \"adjoint matrix\" is also used.

stem:[bb(ii(A))**] and stem:[bb(ii(A))^(+)] are also used for stem:[bb(ii(A))^(\"H\")].
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-16 .