      ],
      "skos:definition": {
        "@value": "norm of matrix stem:[bb(ii(A))]",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The norm of matrix stem:[bb(ii(A))] is a number characterizing this matrix and satisfying the triangle inequality:\n\nif stem:[bb(ii(A)) + bb(ii(B)) = bb(ii(C))], then stem:[norm(bb(ii(A))) + norm(bb(ii(B))) >= norm(bb(ii(C)))].\n\nDifferent matrix norms are used.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-2-16"
      }
    }
  ]
