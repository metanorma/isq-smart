isoiec80000:term-t3-11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "acceleration"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t3-11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "ii(bb(sf(a)))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t3-11 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "3-11" ;
  skosxl:prefLabel isoiec80000:term-t3-11-0 ;
  skosxl:altLabel isoiec80000:sym-t3-11-0 ;
  skos:definition """vector (<<iso80000-2>>) quantity giving the rate of change of velocity (<<t3-10.1>>)"""@en ;
  skos:note """The acceleration vector is given by:

[stem%unnumbered]
++++
ii(bb(sf(a))) = (\"d\"ii(bb(sf(v))))/(\"d\"t)
++++

where stem:[ii(bb(sf(v)))] denotes the velocity (<<t3-10.1>>) and stem:[t] the duration (<<t3-9>>).

The magnitude (<<iso80000-2>>) of the acceleration of free fall is usually denoted by stem:[g].
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-m*s^-2 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-3 .