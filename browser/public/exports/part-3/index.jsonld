      "skos:definition": {
        "@value": "rate of change of rotation (<<t3-16>>)",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The rotational frequency is given by:\n\n[stem%unnumbered]\n++++\nn=(\"d\"N)/(\"d\"t)\n++++\n\nwhere stem:[N] denotes the rotation (<<t3-16>>) and stem:[t] is the duration (<<t3-9>>).\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-s^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-3"
      }
    },
