        "@value": "inverse of period duration (<<t3-14>>)",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The frequency is given by:\n\n[stem%unnumbered]\n++++\nf=1/T\n++++\n\nwhere stem:[T] denotes the period duration (<<t3-14>>).\n",
        "@language": "en"
      },
