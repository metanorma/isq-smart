        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t3-1.7-0"
        }
      ],
      "skos:definition": {
        "@value": "length of a rectifiable curve between two of its points",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The differential path length at a given point of a curve is:\n\n[stem%unnumbered]\n++++\n\"d\"x = sqrt((\"d\"x)^2 + (\"d\"y)^2 + (\"d\"z)^2)\n++++\n\nwhere stem:[x], stem:[y], and stem:[z] denote the Cartesian coordinates (<<iso80000-2>>) of the particular point.\n\nThere are curves which are not rectifiable, for example fractal curves.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m"
        }
      ],
