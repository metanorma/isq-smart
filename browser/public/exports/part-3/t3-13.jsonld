      "skos:definition": {
        "@value": "vector (<<iso80000-2>>) quantity giving the rate of change of angular velocity (<<t3-12>>)",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The angular acceleration vector is given by:\n\n[stem%unnumbered]\n++++\nbb(alpha) = (\"d\"bb(omega))/(\"d\"t)\n++++\n\nWhere stem:[bb(omega)] denotes the angular velocity (<<t3-12>>) and stem:[t] the duration (<<t3-9>>).\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-rad*s^(-2)"
        },
        {
          "@id": "isoiec80000:unit-s^(-2)"
        }
      ],
