        }
      ],
      "skos:definition": {
        "@value": "speed with which the envelope of a wave propagates in space",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The group velocity is given by:\n\n[stem%unnumbered]\n++++\nc_\"g\" = (\"d\"omega)/(\"d\"k)\n++++\n\nwhere stem:[omega] denotes the angular frequency (<<t3-18>>) and stem:[k] the angular repetency (<<t3-22>>).\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m*s^-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-3"
      }
    }
