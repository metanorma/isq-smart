  "@graph": [
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t3-12-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "angular velocity",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t3-12-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "bb(omega)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t3-12",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "3-12",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t3-12-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t3-12-0"
        }
      ],
      "skos:definition": {
        "@value": "vector (<<iso80000-2>>) quantity giving the rate of change of the rotational displacement (<<t3-6>>) as its magnitude (<<iso80000-2>>) and with a direction equal to the direction of the axis of rotation",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The angular velocity vector is given by:\n\n[stem%unnumbered]\n++++\nbb(omega)=(\"d\"varphi)/(\"d\"t)bb(ii(u))\n++++\n\nwhere stem:[varphi] denotes the angular displacement (<<t3-6>>), stem:[t] the duration (<<t3-9>>), and stem:[bb(ii(u))] the unit vector (<<iso80000-2>>) along the axis of rotation in the direction for which the rotation corresponds to a right-hand spiral.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-rad*s^(-1)"
        },
        {
          "@id": "isoiec80000:unit-s^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-3"
      }
    }
  ]
}