        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t3-23.1-1"
        }
      ],
      "skos:definition": {
        "@value": "speed with which the phase angle (<<t3-7>>) of a wave propagates in space",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The phase velocity is given by:\n\n[stem%unnumbered]\n++++\nc = omega/k\n++++\n\nwhere stem:[omega] denotes the angular frequency (<<t3-18>>) and stem:[k] the angular repetency (<<t3-22>>).\n\nIf phase velocities of electromagnetic waves and other phase velocities are both involved, then stem:[c] should be used for the former and stem:[v] for the latter.\n\nPhase velocity can also be written as stem:[c = lambda f].\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m*s^-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-3"
      }
    }
