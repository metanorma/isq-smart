isoiec80000:term-t2-20.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "gamma function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Gamma(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.2 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.2" ;
  skosxl:prefLabel isoiec80000:term-t2-20.2-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.2-0 ;
  skos:definition """gamma function"""@en ;
  skos:note """stem:[Gamma(z)] is a meromorphic function with poles at stem:[0, -1, -2, -3, ...]

stem:[Gamma(z) = int_0^(oo) t^(z-1) e^(-t) \"d\"t] (for stem:[\"Re \"z>0])

stem:[Gamma(n+1) = n!] (for stem:[n in bb(sf(N))])
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .