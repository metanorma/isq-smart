isoiec80000:t2-20.28 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.28" ;
  skosxl:prefLabel isoiec80000:term-t2-20.28-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.28-0 ;
  skos:definition """spherical Neumann function"""@en ;
  skos:note """stem:[\"n\"_l(z) = (pi/(2z))^(1/2) \"N\"_(l+1//2)(z)]

(for stem:[l in bb(sf(N))])

stem:[y_l(z)] is also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .