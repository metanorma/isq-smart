  skos:definition """Hermite polynomial"""@en ;
  skos:note """stem:[\"H\"_n(z) = (-1)^n \"e\"^(z^2) (\"d\"^n)/(\"d\"z^n) \"e\"^(-z^2)]

(for stem:[n in bb(sf(N))])

Solution of stem:[y'' - 2zy' + 2ny =0]
"""@en ;
