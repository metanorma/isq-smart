isoiec80000:term-t2-20.20-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "associated Laguerre polynomial"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.20-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"L\"_n^m(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.20 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.20" ;
  skosxl:prefLabel isoiec80000:term-t2-20.20-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.20-0 ;
  skos:definition """associated Laguerre polynomial"""@en ;
  skos:note """stem:[\"L\"_n^m(z) = (-1)^m (\"d\"^m)/(\"d\"z^m) \"L\"_n (z)]

(for stem:[m in bb(sf(N))], stem:[m <= n])

Solution of

stem:[zy'' + (m+1-z)y' + (n-m)y =0]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .