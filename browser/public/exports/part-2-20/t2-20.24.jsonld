      "skos:definition": {
        "@value": "Neumann function, +\ncylinder Bessel function of the second kind\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[\"N\"_nu(z) = (\"J\"_nu (z)\"cos\"(nu pi)-\"J\"_(-nu)(z))/(\"sin\"(nu pi))]\n\n(for stem:[nu in bb(sf(C))])\n\nThe right-hand side of this equation is replaced by its limiting value if stem:[nu in bb(sf(Z))].\n\nstem:[\"Y\"_nu(z)] is also used.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
