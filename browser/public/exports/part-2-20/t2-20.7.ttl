isoiec80000:t2-20.7 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.7" ;
  skosxl:prefLabel isoiec80000:term-t2-20.7-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.7-0 ;
  skos:definition """sine integral"""@en ;
  skos:note """stem:[\"Si \"z= int_0^z (\"sin \"t)/t \"d\"t]

stem:[\"si \"z = - pi/2 + \"Si \"z]

is called the complementary sine integral.
"""@en ;
  smart:hasBindingnessType smart:normative ;
