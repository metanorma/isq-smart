      "skos:definition": {
        "@value": "Riemann zeta function",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[rm(zeta)(z)] is a meromorphic function with one pole at stem:[z=1].\n\nstem:[rm(zeta)(z) = sum_(n=1)^(oo) 1/(n^2)] (for stem:[\"Re \"z > 1])\n",
        "@language": "en"
      },
