      "skos:note": {
        "@value": "stem:[\"H\"_nu^((1))(z) = \"J\"_nu (z) + \"iN\"_nu(z)]\n\nstem:[\"H\"_nu^((2))(z) = \"J\"_nu (z) + \"iN\"_nu(z)]\n\n(for stem:[nu in bb(sf(C))])\n",
