      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.30-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of potential energy and kinetic energy for a falling body, expressed by\n\nstem:[Ri = gh//v^2]; where\n\nstem:[g]:: is acceleration of free fall (<<iso80000-3>>),\nstem:[h]:: is characteristic height (<<iso80000-3>>), and\nstem:[v]:: is characteristic speed (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "In geophysics differences of these quantities are of interest.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    }
  ]
