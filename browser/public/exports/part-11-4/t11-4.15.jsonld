      ],
      "skosxl:literalForm": {
        "@value": "Bejan number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.15-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Be",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.15",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.15",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.15-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.15-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of mechanical work and frictional energy loss in fluid dynamics in a pipe, expressed by\n\nstem:[Be = (Delta p l^2)/(eta sf(ii(v))) = (rho Delta p l^2)/eta^2]; where\n\nstem:[Delta p]:: is drop of pressure (<<iso80000-4>>) along the pipe,\nstem:[l]:: is characteristic length (<<iso80000-3>>),\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>),\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>), and\nstem:[rho]:: is mass density (<<iso80000-4>>).\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "A similar number exists for heat transfer (<<t11-5.9>>).\n\nThe kinematic viscosity is also called momentum diffusivity.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    }
  ]
}