  "@graph": [
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Reynolds number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Re",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.1-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of inertial forces and viscous forces in a fluid flow, expressed by\n\nstem:[Re = (rho v l)/eta = (v l)/sf(ii(v))]; where\n\nstem:[rho]:: is mass density (<<iso80000-4>>),\nstem:[v]:: is speed (<<iso80000-3>>),\nstem:[l]:: is characteristic length (<<iso80000-3>>),\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>), and\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The value of the Reynolds number gives an estimate on the flow state: laminar flow or turbulent flow.\n\nIn rotating movement, the speed stem:[v= omega l], where stem:[l] is the distance from the rotation axis and stem:[omega] is the angular velocity.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    }
  ]
}