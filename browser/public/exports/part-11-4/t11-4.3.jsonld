        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Fr",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.3",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.3",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.3-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.3-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of a body's inertial forces and its gravitational forces for flow of fluids, expressed by\n\nstem:[Fr = v/(sqrt(lg))]; where\n\nstem:[v]:: is speed (<<iso80000-3>>) of flow,\nstem:[l]:: is characteristic length (<<iso80000-3>>), and\nstem:[g]:: is acceleration of free fall (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Froude number can be modified by buoyancy.\n\nSometimes the square and sometimes the inverse of the Froude number as defined here is wrongly used.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    }
  ]
}