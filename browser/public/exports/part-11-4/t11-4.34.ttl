isoiec80000:term-t11-4.34-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Stokes number <rotameter>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t11-4.34-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "power coefficient <rotameter>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.34-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Stk_2"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.34 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.34" ;
  skosxl:prefLabel isoiec80000:term-t11-4.34-0 ;
  skosxl:altLabel isoiec80000:term-t11-4.34-1 ;
  skosxl:altLabel isoiec80000:sym-t11-4.34-0 ;
  skos:definition """Stokes number for calibration of rotameters metering vertical flows of fluids by means of a floating body, expressed by

stem:[Stk_2 = {r^3 g m rho}/{eta^2} {(rho_{\"b\"} - rho)}/{rho_{\"b\"}} = {r^3 g m}/{v^2} (1/{rho} - 1/{rho_{\"b\"}})]; where

stem:[r]:: is ratio of pipe and float radii,
stem:[g]:: is acceleration of free fall (<<iso80000-3>>),
stem:[m]:: is mass (<<iso80000-4>>) of the body,
stem:[rho]:: is mass density (<<iso80000-4>>) of the fluid,
stem:[eta]:: is dynamic viscosity (<<iso80000-4>>) of the fluid,
stem:[rho_\"b\"]:: is mass density (<<iso80000-4>>) of the body, and
stem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>) of the fluid
"""@en ;
  skos:note """In general use, this value is multiplied by stem:[1.042].

See also the Archimedes number (<<t11-6.12>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .