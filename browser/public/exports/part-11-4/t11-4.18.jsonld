          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.18-1"
        }
      ],
      "skos:definition": {
        "@value": "quotient of yield stress and viscous stress of a viscous material at flow limit for visco-plastic material in a channel, expressed by\n\nstem:[He = (tau_0 d^2 rho)/eta^2]; where\n\nstem:[tau_0]:: is shear stress (<<iso80000-4>>) at flow limit,\nstem:[d]:: is characteristic diameter (<<iso80000-3>>), e.g. effective channel width,\nstem:[rho]:: is mass density (<<iso80000-4>>), and\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>)\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    }
  ]
