      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.4",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.4",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.4-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.4-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of buoyancy forces due to thermal expansion which results in a change of mass density and viscous forces for free convection due to temperature differences, expressed by\n\nstem:[Gr = l^3 g alpha_V Delta T // sf(ii(v))^2]; where\n\nstem:[l]:: is characteristic length (<<iso80000-3>>),\nstem:[g]:: is acceleration of free fall (<<iso80000-3>>),\nstem:[alpha_V]:: is thermal cubic expansion coefficient (<<iso80000-5>>),\nstem:[Delta T]:: is difference of thermodynamic temperature stem:[T] (<<iso80000-5>>) between surface of the body and the fluid far away from the body, and\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Heating can occur near hot vertical walls, in pipes, or by a bluff body.\n\nThe characteristic length can be the vertical height of a hot plate, the diameter of a pipe, or the effective length of a body.\n\nSee also Rayleigh number (<<t11-5.3>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    }
  ]
}