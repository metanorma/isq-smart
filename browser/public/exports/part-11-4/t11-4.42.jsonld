    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.42",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.42",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.42-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.42-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.42-1"
        }
      ],
      "skos:definition": {
        "@value": "relation between inertial forces and viscous forces in oscillating flows of fluids in pipes, expressed by\n\nstem:[Wo = R sqrt(omega//sf(ii(v)))]; where\n\nstem:[R]:: is (effective) radius (<<iso80000-3>>) of the pipe,\nstem:[omega]:: is angular frequency (<<iso80000-3>>) of oscillations, and\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Womersley number is used for pulsating flows e.g. in blood flow.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    }
  ]
