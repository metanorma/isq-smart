isoiec80000:term-t11-4.19-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bodenstein number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.19-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bd"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.19 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.19" ;
  skosxl:prefLabel isoiec80000:term-t11-4.19-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.19-0 ;
  skos:definition """mathematical expression of the transfer of matter by convection in reactors with respect to diffusion,

stem:[Bd = vl//D]; where

stem:[v]:: is speed (<<iso80000-3>>),
stem:[l]:: is length (<<iso80000-3>>) of the reactor, and
stem:[D]:: is diffusion coefficient (<<iso80000-9>>)
"""@en ;
  skos:note """The Bodenstein number is also given by

stem:[Bd = Pe** = Re * Sc]; where

stem:[Pe**]:: is the Péclet number for mass transfer (<<t11-6.2>>),
stem:[Re]:: is the Reynolds number (<<t11-4.1>>), and
stem:[Sc = eta//(rho D) = v//D]:: is Schmidt number (<<t11-7.2>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .