      ],
      "skosxl:literalForm": {
        "@value": "Bl",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.38",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.38",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.38-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.38-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between inertial forces and viscous forces in a porous material, expressed by\n\nstem:[Bl = (vpl)/(eta(1-epsilon))]; where\n\nstem:[v]:: is speed (<<iso80000-3>>) of the fluid,\nstem:[rho]:: is mass density (<<iso80000-4>>) of the fluid,\nstem:[l]:: is characteristic length (<<iso80000-3>>) defined as the volume of a particle divided by its surface area,\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>) of the fluid, and\nstem:[epsilon]:: is porosity of the material (=void fraction)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Blake number can be interpreted as a Reynolds number for flow in porous material.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    }
  ]
