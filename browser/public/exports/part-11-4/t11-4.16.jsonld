        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Lagrange number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.16-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Lg",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.16",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.16",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.16-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.16-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of mechanical work and frictional energy loss in fluid dynamics in a pipe, expressed by\n\nstem:[Lg = (l Delta p)/(eta v)]; where\n\nstem:[l]:: is length (<<iso80000-3>>) of the pipe,\nstem:[Delta p]:: is drop of pressure (<<iso80000-4>>) along the pipe,\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>), and\nstem:[v]:: is speed (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Lagrange number is also given by\n\nstem:[La = Re * Eu]; where\n\nstem:[Re]:: is the Reynolds number (<<t11-4.1>>), and\nstem:[Eu]:: is the Euler number (<<t11-4.2>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    }
  ]
}