      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.6-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Mach number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.6-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ma",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.6",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.6",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.6-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.6-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the speed of flow and the speed of sound, expressed by\n\nstem:[Ma = v//c]; where\n\nstem:[v]:: is speed (<<iso80000-3>>) of the body, and\nstem:[c]:: is speed of sound (<<iso80000-8>>) in the fluid\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Mach number represents the relationship of inertial forces compared to compression forces.\n\nFor an ideal gas\n\nstem:[c = sqrt(gamma p/rho) = sqrt(gamma (RT)/M) = sqrt(gamma (kT)/m)]; where stem:[gamma] is ratio of the specific heat capacity (<<iso80000-5>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    }
  ]
}