isoiec80000:term-t11-4.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Euler number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Eu"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.2" ;
  skosxl:prefLabel isoiec80000:term-t11-4.2-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.2-0 ;
  skos:definition """relationship between pressure drop in a flow and the kinetic energy per volume for flow of fluids in a pipe, expressed by

stem:[Eu = (Delta p)/(rho v^2)]; where

stem:[Delta p]:: is drop of pressure (<<iso80000-4>>),
stem:[rho]:: is mass density (<<iso80000-4>>), and
stem:[v]:: is speed (<<iso80000-3>>)
"""@en ;
  skos:note """The Euler number is used to characterize losses in the flow.

A modification of the Euler number is considering the dimensions of the containment (pipe):

stem:[Eu' = d/l Eu]; where

stem:[d]:: is inner diameter (<<iso80000-3>>) of the pipe, and
stem:[l]:: is length (<<iso80000-3>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .