        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bd",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.19",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.19",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.19-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.19-0"
        }
      ],
      "skos:definition": {
        "@value": "mathematical expression of the transfer of matter by convection in reactors with respect to diffusion,\n\nstem:[Bd = vl//D]; where\n\nstem:[v]:: is speed (<<iso80000-3>>),\nstem:[l]:: is length (<<iso80000-3>>) of the reactor, and\nstem:[D]:: is diffusion coefficient (<<iso80000-9>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Bodenstein number is also given by\n\nstem:[Bd = Pe** = Re * Sc]; where\n\nstem:[Pe**]:: is the Péclet number for mass transfer (<<t11-6.2>>),\nstem:[Re]:: is the Reynolds number (<<t11-4.1>>), and\nstem:[Sc = eta//(rho D) = v//D]:: is Schmidt number (<<t11-7.2>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    }
  ]
