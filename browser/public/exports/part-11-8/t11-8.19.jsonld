      "skosxl:literalForm": {
        "@value": "Na",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-8.19",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-8.19",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.19-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.19-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of velocity of Alfvén waves and velocity of sound in a plasma, expressed by\n\nstem:[Na = B // (c sqrt(rho mu))]; where\n\nstem:[B]:: is magnetic flux density (<<iec80000-6>>),\nstem:[c]:: is speed of sound (<<iso80000-8>>),\nstem:[rho]:: is mass density (<<iso80000-4>>), and\nstem:[mu]:: is magnetic permeability (<<iec80000-6>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The quantity stem:[v_\"A\" = B // sqrt(rho mu)] is called Alfvén wave speed. See <<t11-8.4>>.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-8"
      }
    }
  ]
