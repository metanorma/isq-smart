        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Se",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-8.7",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-8.7",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.7-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.7-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of electric energy density and kinematic energy density in a plasma, expressed by\n\nstem:[Se = epsilon E^2 // (rho v^2)]; where\n\nstem:[epsilon]:: is electric permittivity (<<iec80000-6>>),\nstem:[E]:: is electric field strength (<<iec80000-6>>),\nstem:[rho]:: is mass density (<<iso80000-4>>), and\nstem:[v]:: is speed (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Stuart electrical number is the electrical counterpart of the Cowling number (<<t11-8.6>>).",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-8"
      }
    }
  ]
