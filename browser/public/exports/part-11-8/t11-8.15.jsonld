    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-8.15",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-8.15",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.15-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.15-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.15-1"
        }
      ],
      "skos:definition": {
        "@value": "quotient of gyro frequency and collision frequency in a plasma, expressed by\n\nstem:[H_\"c\" = (omega_\"c\")/(2pi) lambda/v]; where\n\nstem:[omega_\"c\"]:: is cyclotron angular frequency (<<iso80000-10>>),\nstem:[lambda]:: is mean free path (<<iso80000-9>>), and\nstem:[v]:: is average speed (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Sometimes the inverse of this number is wrongly used.\n\nstem:[2pi] times this quantity is called the Hall parameter.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-8"
      }
    }
  ]
