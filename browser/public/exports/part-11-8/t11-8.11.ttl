isoiec80000:term-t11-8.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Roberts number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-8.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ro"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-8.11 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-8.11" ;
  skosxl:prefLabel isoiec80000:term-t11-8.11-0 ;
  skosxl:altLabel isoiec80000:sym-t11-8.11-0 ;
  skos:definition """quotient of thermal diffusivity and magnetic viscosity in an electrically conducting liquid, expressed by

stem:[Ro = alpha sigma mu]; where

stem:[alpha]:: is thermal diffusivity (<<iso80000-5>>),
stem:[sigma]:: is electrical conductivity (<<iec80000-6>>), and
stem:[mu]:: is magnetic permeability (<<iec80000-6>>)
"""@en ;
  skos:note """The quantity stem:[v_\"m\" = 1//(mu sigma)] is called magnetic viscosity or magnetic diffusivity; where

stem:[mu]:: is magnetic permeability (<<iec80000-6>>), and
stem:[sigma]:: is electrical conductivity (<<iec80000-6>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-8 .