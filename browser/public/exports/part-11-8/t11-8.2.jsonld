      "dcterms:identifier": "11-8.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.2-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between inertia and magneto-dynamic diffusion in an electrically conducting liquid, expressed by\n\nstem:[Bt = v l sigma mu // (epsilon_\"r\" mu_\"r\")]; where\n\nstem:[v]:: is speed (<<iso80000-3>>),\nstem:[l]:: is characteristic length (<<iso80000-3>>),\nstem:[sigma]:: is electrical conductivity (<<iec80000-6>>),\nstem:[mu]:: is magnetic permeability (<<iec80000-6>>),\nstem:[epsilon_\"r\"]:: is relative permittivity (<<iec80000-6>>), and\nstem:[mu_\"r\"]:: is relative permeability (<<iec80000-6>>)\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-8"
      }
    }
  ]
