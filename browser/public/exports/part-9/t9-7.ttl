isoiec80000:term-t9-7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "molar heat capacity"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t9-7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "C_\"m\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t9-7 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "9-7" ;
  skosxl:prefLabel isoiec80000:term-t9-7-0 ;
  skosxl:altLabel isoiec80000:sym-t9-7-0 ;
  skos:definition """quotient of heat capacity stem:[C] (<<iso80000-5>>) and amount of substance stem:[n] (<<t9-2>>):

[stem%unnumbered]
++++
C_\"m\" = C//n
++++
"""@en ;
  skos:note """Conditions (constant pressure or volume etc.) must be specified."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-J/(mol*K) ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^2*s^(-2)*K^(-1)*mol^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-9 .