isoiec80000:term-t9-6.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "molar enthalpy"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t9-6.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "H_\"m\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t9-6.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "9-6.2" ;
  skosxl:prefLabel isoiec80000:term-t9-6.2-0 ;
  skosxl:altLabel isoiec80000:sym-t9-6.2-0 ;
  skos:definition """quotient of enthalpy stem:[H] (<<iso80000-5>>) and amount stem:[n] of substance (<<t9-2>>):

[stem%unnumbered]
++++
H_\"m\" = H//n
++++
"""@en ;
  skos:note """Molar quantities are normally only used with reference to pure substances."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-J/mol ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^2*s^(-2)*mol^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-9 .