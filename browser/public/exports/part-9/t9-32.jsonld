          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-32-0"
        }
      ],
      "skos:definition": {
        "@value": "for a chemical reaction, product for all substances stem:[\"B\"] of standard absolute activity stem:[lambda_\"B\"^(&#8854;)] of substance stem:[\"B\"] (<<t9-26>>) in power of minus stoichiometric number stem:[nu_\"B\"] of substance stem:[\"B\"] (<<t9-29>>):\n\n[stem%unnumbered]\n++++\nK^(&#8854;) = Pi_\"B\" (lambda_\"B\"^(&#8854;))^(-nu_\"B\")\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "This quantity is a function of temperature only. Others depend on temperature, pressure, and composition.\n\nOne can define in an analogous way an equilibrium constant in terms of fugacity, stem:[K_\"f\"], molality, stem:[K_\"m\"], etc.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
