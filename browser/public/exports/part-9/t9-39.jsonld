      "skos:definition": {
        "@value": "proportionality coefficient of local molecular concentration stem:[C_\"B\"] (<<t9-9.2>>) of substance stem:[\"B\"] in the mixture multiplied by the local average velocity (<<iso80000-3>>) stem:[v_\"B\"] of the molecules of stem:[\"B\"], and minus the gradient of the local molecular concentration stem:[C_\"B\"] (<<t9-9.2>>) of substance stem:[\"B\"] in the mixture, expressed by:\n\n[stem%unnumbered]\n++++\nC_\"B\" << v_\"B\" >> = -D bb(\"grad\") C_\"B\"\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^2*s^(-1)"
        }
      ],
