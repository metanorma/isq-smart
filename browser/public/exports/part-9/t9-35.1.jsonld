      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-35.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-35.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-35.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-35.1-0"
        }
      ],
      "skos:definition": {
        "@value": "number of all quantum states stem:[r] consistent with given energy stem:[E] (<<iso80000-4>>), volume (<<iso80000-3>>), and external fields:\n\n[stem%unnumbered]\n++++\nii(Omega) = sum_r 1\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[stem%unnumbered]\n++++\nS = k\"ln\" ii(Omega)\n++++\n\nwhere stem:[S] is entropy (<<iso80000-5>>) and stem:[k] is the Boltzmann constant (<<iso80000-1>>).\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    }
