++++
"""@en ;
  skos:note """Molar quantities are normally only used with reference to pure substances."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-J/mol ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^2*s^(-2)*mol^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-9 .

isoiec80000:term-t9-6.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "molar Gibbs energy"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t9-6.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "G_\"m\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t9-6.4 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "9-6.4" ;
  skosxl:prefLabel isoiec80000:term-t9-6.4-0 ;
  skosxl:altLabel isoiec80000:sym-t9-6.4-0 ;
