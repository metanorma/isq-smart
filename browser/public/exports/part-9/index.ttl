isoiec80000:unit-kg^(-1)*m^(-3)*s^3*A^2 a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "second cubed ampere squared per kilogram cubic metre"@en ;
  skos:notation "kg^(-1)*m^(-3)*s^3*A^2" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-S*m^2/mol a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "siemens square metre per mole"@en ;
