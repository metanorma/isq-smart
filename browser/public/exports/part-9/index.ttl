isoiec80000:unit-rad*m^2/mol a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "radian square metre per mole"@en ;
  skos:notation "rad*m^2/mol" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-m^2*mol^(-1) a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "square metre per mole"@en ;
  skos:notation "m^2*mol^(-1)" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-rad*m^2/kg^1 a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "radian square metre per kilogram"@en ;
  skos:notation "rad*m^2/kg^1" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-kg^(-1)*m^2 a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "square metre per kilogram"@en ;
  skos:notation "kg^(-1)*m^2" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:term-t9-1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "number of entities"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t9-1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "N(X)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t9-1-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "N_\"X\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t9-1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "9-1" ;
  skosxl:prefLabel isoiec80000:term-t9-1-0 ;
  skosxl:altLabel isoiec80000:sym-t9-1-0 ;
  skosxl:altLabel isoiec80000:sym-t9-1-1 ;
  skos:definition """number of elementary entities of kind stem:[\"X\"] in a system"""@en ;
  skos:note """The elementary entities must be specified and can be atoms, molecules, ions, electrons, other particle, or a specified group of such particles. It is important to always give a precise specification of the entity involved; this should preferably be done by the empirical chemical formula of the material involved."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-9 .

isoiec80000:term-t9-2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "amount of substance"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t9-2-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "DEPRECATED: number of moles"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t9-2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "n(X)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t9-2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "9-2" ;
  skosxl:prefLabel isoiec80000:term-t9-2-0 ;
  skosxl:altLabel isoiec80000:term-t9-2-1 ;
  skosxl:altLabel isoiec80000:sym-t9-2-0 ;
  skos:definition """quotient of number stem:[N] of specified elementary entities of kind stem:[\"X\"] (<<t9-1>>) in a sample, and the Avogadro constant stem:[N_\"A\"] (<<iso80000-1>>):

[stem%unnumbered]
++++
n(\"X\") = (N(\"X\"))/N_\"A\"
++++
"""@en ;
  skos:note """Amount of substance is one of the seven base quantities in the International System of Quantities, ISQ (see <<iso80000-1>>).

Elementary entities, such as molecules, atoms, ions, electrons, holes and other quasi-particles, double bonds can be used. It is necessary to specify precisely the entity involved, e.g. atoms of hydrogen stem:[\"H\"] vs. molecules of hydrogen stem:[\"H\"_2], preferably by giving the molecular chemical formula of the material involved.

In the name \"amount of substance\", the words \"of substance\" could be replaced by words specifying the substance concerned, e.g. \"amount of hydrogen chloride, stem:[\"HCl\"]\", or \"amount of benzene, stem:[\"C\"_6\"H\"_6]\".

The name \"number of moles\" is often used for \"amount of substance\", but this is deprecated because the name of a quantity should be distinguished from the name of the unit.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-mol ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-9 .

isoiec80000:term-t9-3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "relative atomic mass"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t9-3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "A_\"r\"(\"X\")"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t9-3 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "9-3" ;
  skosxl:prefLabel isoiec80000:term-t9-3-0 ;
  skosxl:altLabel isoiec80000:sym-t9-3-0 ;
  skos:definition """quotient of the average mass (<<iso80000-4>>) of atom stem:[\"X\"] and the unified atomic mass (<<iso80000-10>>)"""@en ;
  skos:note """A similar quantity \"relative molecular mass\" can be defined for molecules.

[example]
====
stem:[A_\"r\"(\"Cl\") ~~ 35.453],

stem:[A_\"r\"(\"CO\"_2) ~~ 44].
====

The relative atomic or relative molecular mass depends on the nuclidic composition.

The International Union of Pure and Applied Chemistry (IUPAC) accepts the use of the special names \"atomic weight\" and \"molecular weight\" for the quantities \"relative atomic mass\" and \"relative molecular mass\", respectively. The use of these traditional names is deprecated.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-9 .

isoiec80000:term-t9-4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "molar mass"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t9-4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "M(\"X\")"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t9-4 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "9-4" ;
  skosxl:prefLabel isoiec80000:term-t9-4-0 ;
  skosxl:altLabel isoiec80000:sym-t9-4-0 ;
  skos:definition """for a pure substance stem:[\"X\"], quotient of mass stem:[m(\"X\")] (<<iso80000-4>>) and amount stem:[n] of substance (<<t9-2>>):

[stem%unnumbered]
++++
M = m//n
++++
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-g/mol ;
  isoiec80000:hasUnit isoiec80000:unit-kg*mol^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-9 .

isoiec80000:term-t9-5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "molar volume"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t9-5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "V_\"m\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t9-5 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "9-5" ;
  skosxl:prefLabel isoiec80000:term-t9-5-0 ;
  skosxl:altLabel isoiec80000:sym-t9-5-0 ;
  skos:definition """for a pure substance, quotient of its volume stem:[V] (<<iso80000-3>>) and amount stem:[n] of substance (<<t9-2>>):

[stem%unnumbered]
++++
V_\"m\" = V//n
++++
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-m^3*mol^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-9 .

isoiec80000:term-t9-6.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "molar internal energy"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t9-6.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "U_\"m\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t9-6.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "9-6.1" ;
  skosxl:prefLabel isoiec80000:term-t9-6.1-0 ;
  skosxl:altLabel isoiec80000:sym-t9-6.1-0 ;
  skos:definition """quotient of internal energy stem:[U] (<<iso80000-5>>) and amount stem:[n] of substance (<<t9-2>>):

[stem%unnumbered]
++++
U_\"m\" = U//n
++++
"""@en ;
  skos:note """Molar quantities are normally only used with reference to pure substances."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-J/mol ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^2*s^(-2)*mol^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-9 .

isoiec80000:term-t9-6.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "molar enthalpy"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t9-6.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "H_\"m\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t9-6.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "9-6.2" ;
  skosxl:prefLabel isoiec80000:term-t9-6.2-0 ;
  skosxl:altLabel isoiec80000:sym-t9-6.2-0 ;
  skos:definition """quotient of enthalpy stem:[H] (<<iso80000-5>>) and amount stem:[n] of substance (<<t9-2>>):

[stem%unnumbered]
++++
H_\"m\" = H//n
++++
"""@en ;
  skos:note """Molar quantities are normally only used with reference to pure substances."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-J/mol ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^2*s^(-2)*mol^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-9 .

isoiec80000:term-t9-6.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "molar Helmholtz energy"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t9-6.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "F_\"m\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t9-6.3 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "9-6.3" ;
  skosxl:prefLabel isoiec80000:term-t9-6.3-0 ;
  skosxl:altLabel isoiec80000:sym-t9-6.3-0 ;
  skos:definition """quotient of the Helmholtz energy stem:[F] (<<iso80000-5>>) and amount stem:[n] of substance (<<t9-2>>):

[stem%unnumbered]
