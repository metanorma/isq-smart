  smart:hasBindingnessType smart:normative .

isoiec80000:unit-kg^(-1)*s^3*A^2*mol^(-1) a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "second cubed ampere squared per kilogram mole"@en ;
  skos:notation "kg^(-1)*s^3*A^2*mol^(-1)" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-rad a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "radian"@en ;
  skos:notation "rad" ;
