isoiec80000:unit-stem:[("unitsml(mol/m^3)")^(sum nu_"B")] a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "mole per cubic metre to the power of sum of stoichiometric numbers"@en ;
  skos:notation "stem:[("unitsml(mol/m^3)")^(sum nu_"B")]" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-J/(kg*K) a isoiec80000:Unit, smart:TermEntry ;
