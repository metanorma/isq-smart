[stem%unnumbered]
++++
G_\"m\" = G//n
++++
"""@en ;
  skos:note """Molar quantities are normally only used with reference to pure substances."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-J/mol ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^2*s^(-2)*mol^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-9 .

isoiec80000:term-t9-7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "molar heat capacity"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t9-7-0 a smart:Term, skosxl:Label ;
