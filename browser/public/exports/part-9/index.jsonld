      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-14-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "volume fraction",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-14-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "varphi_\"X\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-14",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-14",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-14-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-14-0"
        }
      ],
      "skos:definition": {
        "@value": "for substance stem:[\"X\"], quotient of product of amount of substance fraction stem:[x_\"X\"] (<<t9-13>>) of stem:[\"X\"] and molar volume stem:[V_\"m,X\"] (<<t9-5>>) of the pure substance stem:[\"X\"] at the same temperature (<<iso80000-5>>) and pressure (<<iso80000-4>>), and sum over all substances stem:[i] of products of amount-of-substance fractions stem:[x_i] (<<t9-13>>) of substance stem:[i] and their molar volumes stem:[V_\"m,i\"] (<<t9-5>>):\n\n[stem%unnumbered]\n++++\nvarphi_\"X\" = (x_\"X\"V_\"m,X\")/(sum_i x_i V_(\"m\",i))\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Generally, the volume fraction is temperature dependent.\n\nDecided by the 16^th^ CGPM (1979), both \"l\" and \"L\" are allowed for the symbols for the litre.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-ml/l"
        },
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-15-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "molality",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-15-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "b_\"B\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-15-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "m_\"B\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-15",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-15",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-15-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-15-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-15-1"
        }
      ],
      "skos:definition": {
        "@value": "quotient of amount of substance (<<t9-2>>) of solute stem:[\"B\"] and mass stem:[m_\"A\"] (<<iso80000-4>>) of the solvent substance stem:[\"A\"]\n\n[stem%unnumbered]\n++++\nb_\"B\" = n_\"B\"//m_\"A\"\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The alternative symbol stem:[m_\"B\"] should be avoided in situations where it might be mistaken for the mass of substance stem:[\"B\"]. However, the symbol stem:[m_\"B\"] is much more commonly used than the symbol stem:[b_\"B\"] for molality, despite the possible confusion with mass.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-mol/kg"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-16-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "latent heat of phase transition",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-16-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "enthalpy of phase transition",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-16-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "C_\"pt\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-16",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-16",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-16-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-16-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-16-0"
        }
      ],
      "skos:definition": {
        "@value": "energy (<<iso80000-5>>) necessary to be added or subtracted isothermally and isobarically to a system to completely undergo the phase transition",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Mostly, molar or specific quantity is used and phase transition is expressed explicitly, e.g. molar latent heat of evaporation.\n\nThe subscript \"pt\" is the qualifier for the phase transition, which may be changed to e.g. \"l-g\".\n\nThe term \"enthalpy of phase transition\" is mainly used in theory.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-J"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-17-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "chemical potential <chemistry>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-17-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "mu_\"X\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-17",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-17",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-17-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-17-0"
        }
      ],
      "skos:definition": {
        "@value": "partial derivative of the Gibbs energy (<<iso80000-5>>) with respect to amount stem:[n_\"X\"] of substance stem:[\"X\"] (<<t9-2>>) at constant temperature stem:[T] (<<iso80000-5>>) and pressure stem:[p] (<<iso80000-4>>):\n\n[stem%unnumbered]\n++++\nmu_\"X\" = (del G//del n_\"X\")_(T,p)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For a pure substance, where stem:[G_\"m\"] is the molar Gibbs energy. In a mixture, stem:[mu_\"B\"] is the partial molar Gibbs energy.\n\nIn condensed matter physics, the chemical potential of electrons is energy.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-J/mol"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-2)*mol^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-18-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "absolute activity",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-18-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "lambda_\"X\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-18",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-18",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-18-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-18-0"
        }
      ],
      "skos:definition": {
        "@value": "for substance stem:[\"X\"], exponential of quotient of chemical potential stem:[mu_\"X\"] of substance stem:[\"B\"] (<<t9-17>>), and product of molar gas constant stem:[R] (<<t9-37.1>>) and thermodynamic temperature stem:[T] (<<iso80000-5>>):\n\n[stem%unnumbered]\n++++\nlambda_\"X\" = \"exp\"(mu_\"X\"/(RT))\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-19-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "partial pressure",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-19-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "p_\"X\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-19",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-19",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-19-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-19-0"
        }
      ],
      "skos:definition": {
        "@value": "for substance stem:[X] in a gaseous mixture, product of amount-of-substance fraction stem:[y_\"X\"] of substance stem:[\"X\"] (<<t9-13>>) and total pressure stem:[p] (<<iso80000-4>>):\n\n[stem%unnumbered]\n++++\np_\"X\" = y_\"X\"p\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Pa"
        },
        {
          "@id": "isoiec80000:unit-kg*m^(-1)*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-20-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "fugacity",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-20-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "tilde p_\"X\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-20",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-20",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-20-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-20-0"
        }
      ],
      "skos:definition": {
        "@value": "for substance stem:[\"X\"], quantity proportional to the absolute activity, stem:[lambda_\"X\"] (<<t9-18>>), the proportionality factor, which is a function of temperature (<<iso80000-5>>) only, being determined by the condition that, at constant temperature and composition, stem:[p_\"X\"//tilde p_\"X\"] tends to 1 for an indefinitely dilute gas",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[stem%unnumbered]\n++++\ntilde p_\"X\" = lambda_\"X\" * lim_(p -> 0)(p_\"X\"//lambda_\"X\")\n++++\n\nwhere stem:[p] is total pressure (<<iso80000-4>>).\n\nThe IUPAC preferred symbol for fugacity is stem:[f].\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Pa"
        },
        {
          "@id": "isoiec80000:unit-kg*m^(-1)*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-21-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "standard chemical potential",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-21-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "mu_\"B\"^(&#8854;)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-21-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "mu^(&#8854;)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-21",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-21",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-21-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-21-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-21-1"
        }
      ],
      "skos:definition": {
        "@value": "for substance stem:[\"B\"], value of the chemical potential (<<t9-17>>) at specified standard conditions",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[stem%unnumbered]\n++++\nmu_\"B\"^(&#8854;) = RT \"ln\" lambda^(&#8854;)\n++++\n\nwhere stem:[mu_\"B\"^(&#8854;)] is a function of temperature stem:[T] at the standard pressure stem:[p=p^(&#8854;)].\n\nThe standard chemical potential depends on the choice of standard state, which must be specified.\n\nIn a liquid or solid solution, the standard state is referenced to the ideal dilute behaviour of the solute (substance stem:[\"B\"]).\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-J/mol"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-2)*mol^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-22-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "activity factor",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-22-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "f_\"X\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-22",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-22",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-22-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-22-0"
        }
      ],
      "skos:definition": {
        "@value": "for substance stem:[\"X\"] in a liquid or a solid mixture, quotient of absolute activity stem:[lambda_\"X\"] (<<t9-18>>) of substance stem:[\"X\"] and the product of absolute activity stem:[lambda_\"X\"^(**)] of the pure substance stem:[\"X\"] at the same temperature (<<iso80000-5>>) and pressure (<<iso80000-4>>) and amount-of-substance fraction stem:[x_\"X\"] of substance stem:[\"X\"] (<<t9-13>>):\n\n[stem%unnumbered]\n++++\nf_\"X\" = lambda_\"X\" // (lambda_\"X\"^(**) x_\"X\")\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The systematic name is \"activity factor\", but the name \"activity coefficient\" is also commonly used (see <<t9-25>>).\n\nActivity factors can also be obtained applying Raoult's law or Henry's law.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-23-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "standard absolute activity <in a mixture>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-23-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "lambda_\"X\"^(&#8854;)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-23",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-23",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-23-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-23-0"
        }
      ],
      "skos:definition": {
        "@value": "for substance stem:[X] in a liquid or a solid mixture, absolute activity stem:[lambda_\"X\"^(**)] (<<t9-18>>) of the pure substance stem:[X] at the same temperature (<<iso80000-5>>) but at standard pressure (<<iso80000-4>>) stem:[10^5 \"unitsml(Pa)\"]:\n\n[stem%unnumbered]\n++++\nlambda_\"X\"^(&#8854;) = lambda_\"X\"^(**) (p^(&#8854;))\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "This quantity is a function of temperature only.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-24-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "activity of solute",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-24-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "relative activity of solute",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-24-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "a_\"X\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-24-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "a_\"m,X\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-24",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-24",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-24-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-24-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-24-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-24-1"
        }
      ],
      "skos:definition": {
        "@value": "for a solute stem:[\"X\"] in a solution, quantity proportional to the absolute activity, stem:[lambda_\"X\"] (<<t9-18>>), the proportionality factor, which is a function of temperature (<<iso80000-5>>) and pressure (<<iso80000-4>>) only, being determined by the condition that, at constant temperature and pressure, aX divided by the molality (<<t9-15>>) ratio, stem:[b_\"X\"//b^(&#8854;)] tends to 1 at infinite dilution; stem:[b_\"X\"] is the molality of solute stem:[\"X\"] (<<t9-15>>), and stem:[b^(&#8854;)] is standard molality:\n\n[stem%unnumbered]\n++++\na_\"X\" = lambda_\"X\" * \"lim\"_(sum b_\"x\" -> 0) (b_\"X\"//b^(&#8854;))/(lambda_\"X\")\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The quantity stem:[a_\"c,X\"], similarly defined in terms of the concentration ratio stem:[c_\"X\"//c^(&#8854;)], is also called the activity or relative activity of solute stem:[\"X\"]; stem:[c^(&#8854;)] is a standard amount-of-substance concentration (<<t9-12.2>>):\n\n[stem%unnumbered]\n++++\na_\"c,X\" = lambda_\"X\" \"lim\"_(sum c_\"x\" -> 0) (c_\"x\"//c^(&#8854;))/(lambda_\"X\")\n++++\n\nwhere stem:[sum] denotes summation over all the solute substances. This especially applies to a dilute liquid solution.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-25-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "activity coefficient",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-25-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "gamma_\"B\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-25",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-25",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-25-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-25-0"
        }
      ],
      "skos:definition": {
        "@value": "for a solute stem:[\"B\"] in a solution, quotient of activity stem:[a_\"B\"] of solute stem:[\"B\"] (<<t9-24>>), and quotient of the molality (<<t9-15>>) stem:[b_\"B\"] of substance stem:[\"B\"] and standard molality stem:[b^(&#8854;)]:\n\n[stem%unnumbered]\n++++\ngamma_\"B\" = (a_\"B\")/(b_\"B\"//b^(&#8854;))\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The name \"activity coefficient of solute stem:[\"B\"]\" is also used for the quantity stem:[gamma_\"B\"] defined as:\n\n[stem%unnumbered]\n++++\ngamma_\"B\" = (a_(c,\"B\"))/(c_\"B\"//c^(&#8854;))\n++++\n\nSee <<t9-22>>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-26-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "standard absolute activity <in a solution>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-26-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "lambda_\"B\"^(&#8854;)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-26",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-26",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-26-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-26-0"
        }
      ],
      "skos:definition": {
        "@value": "for a solute stem:[\"B\"] in a solution:\n\n[stem%unnumbered]\n++++\nlambda_\"B\"^(&#8854;) = \"lim\"_(sum b_\"B\" -> 0) [lambda_\"B\" ((p^(&#8854;))b^(&#8854;))/b_\"B\"]\n++++\n\nwhere stem:[sum] denotes summation over all solutes, stem:[p^(&#8854;)] is a standard pressure (<<iso80000-4>>), stem:[b^(&#8854;)] is standard molality, and stem:[b_\"B\"] is the molality of substance stem:[\"B\"] (<<t9-15>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "This quantity is a function of temperature only. It especially applies to a dilute liquid solution. The standard pressure is stem:[10^5 \"unitsml(Pa)\"].",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-27.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "activity of solvent",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-27.1-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "relative activity of solvent",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-27.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "a_\"A\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-27.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-27.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-27.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-27.1-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-27.1-0"
        }
      ],
      "skos:definition": {
        "@value": "for the solvent stem:[\"A\"] in a solution, quotient of the absolute activity of substance stem:[\"A\"], stem:[lambda_\"A\"] (<<t9-18>>), and that, stem:[lambda_\"A\"^(**)], of the pure solvent at the same temperature (<<iso80000-5>>) and pressure (<<iso80000-4>>):\n\n[stem%unnumbered]\n++++\na_\"A\" = lambda_\"A\"//lambda_\"A\"^(**)\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-27.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "osmotic factor of solvent",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-27.2-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "osmotic coefficient of solvent stem:[\"A\"]",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-27.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "varphi",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-27.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-27.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-27.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-27.2-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-27.2-0"
        }
      ],
      "skos:definition": {
        "@value": "quantity given by:\n\n[stem%unnumbered]\n++++\nvarphi = -(M_\"A\" sum b_\"B\")^(-1) \"ln\" a_\"A\"\n++++\n\nwhere stem:[M_\"A\"] is the molar mass (<<t9-4>>) of the solvent stem:[A], stem:[sum] denotes summation over all the solutes, stem:[b_\"B\"] is the molality of solute stem:[\"B\"] (<<t9-15>>), and stem:[a_\"A\"] is the activity of solvent stem:[\"A\"] (<<t9-27.1>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The name \"osmotic coefficient\" is generally used, although the name \"osmotic factor\" is more systematic.\n\nThis concept especially applies to a dilute liquid solution.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-27.3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "standard absolute activity of solvent <in a dilute solution>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-27.3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "lambda_\"A\"^(&#8854;)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-27.3",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-27.3",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-27.3-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-27.3-0"
        }
      ],
      "skos:definition": {
        "@value": "for solvent stem:[\"A\"], standard absolute activity (<<t9-23>>) of the pure substance stem:[\"A\"] at the same temperature (<<iso80000-5>>) and at a standard pressure stem:[p^(&#8854;)] (<<iso80000-4>>):\n\n[stem%unnumbered]\n++++\nlambda_\"A\"^(&#8854;) = lambda_\"A\"^(**) p^(&#8854;)\n++++\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-28-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "osmotic pressure",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-28-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "ii(Pi)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-28",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-28",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-28-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-28-0"
        }
      ],
      "skos:definition": {
        "@value": "excess pressure (<<iso80000-4>>) required to maintain osmotic equilibrium between a solution and the pure solvent separated by a membrane permeable to the solvent only",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Pa"
        },
        {
          "@id": "isoiec80000:unit-kg*m^(-1)*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-29-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "stoichiometric number of substance",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-29-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "nu_\"B\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-29",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-29",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-29-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-29-0"
        }
      ],
      "skos:definition": {
        "@value": "for substance stem:[\"B\"], an integer number or a simple fraction, being negative for a reactant and positive for a product, occurring in the expression for a chemical reaction:\n\n[stem%unnumbered]\n++++\n0 = sum nu_\"B\"\n++++\n\nwhere the symbol stem:[B] denotes the reactants and products involved in the reaction\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[example]\n====\nstem:[(1//2)\"N\"_2 + (3//2)\"H\"_2 = \"NH\"_3]\n\nstem:[nu (\"N\"_2) = -1//2], stem:[nu (\"H\"_2) = -3//2], stem:[nu (\"NH\"_3) = +1].\n====\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-30-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "affinity of a chemical reaction",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-30-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "A",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-30",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-30",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-30-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-30-0"
        }
      ],
      "skos:definition": {
        "@value": "negative of the sum over all substances stem:[\"B\"] of products of stoichiometric number stem:[nu_\"B\"] of substance stem:[\"B\"] (<<t9-29>>) and chemical potential stem:[mu_\"B\"] of substance stem:[\"B\"] (<<t9-17>>):\n\n[stem%unnumbered]\n++++\nA = - sum nu_\"B\" mu_\"B\"\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The affinity of a reaction is a measure of the \"driving force\" of the reaction. When it is positive, the reaction goes spontaneously from reactants to products, and when it is negative, the reaction goes in the opposite direction. Another way to write the definition is:\n\n[stem%unnumbered]\n++++\nA = (del G// del xi)_(p,T)\n++++\n\nwhere stem:[G] is Gibbs energy (<<iso80000-5>>) and stem:[xi] is the extent of the reaction (<<t9-31>>).\n\nNote that stem:[nu_\"B\"] is negative for reactants and positive for products.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-J/mol"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-2)*mol^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-31-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "extent of reaction",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-31-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "xi",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-31",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-31",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-31-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-31-0"
        }
      ],
      "skos:definition": {
        "@value": "difference of initial amount stem:[n_\"B in\"] of substance stem:[\"B\"] (<<t9-2>>) and equilibrium amount stem:[n_\"B eq\"] of substance stem:[\"B\"] (<<t9-2>>) divided by stoichiometric number stem:[nu_\"B\"] of substance stem:[\"B\"] (<<t9-29>>):\n\n[stem%unnumbered]\n++++\nxi = (n_\"B eq\" - n_\"B in\")/(nu_\"B\")\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "See remark to <<t9-30>>.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-mol"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-32-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "standard equilibrium constant",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-32-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "thermodynamic equilibrium constant",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-32-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "K^(&#8854;)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-32",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-32",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-32-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-32-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-32-0"
        }
      ],
      "skos:definition": {
        "@value": "for a chemical reaction, product for all substances stem:[\"B\"] of standard absolute activity stem:[lambda_\"B\"^(&#8854;)] of substance stem:[\"B\"] (<<t9-26>>) in power of minus stoichiometric number stem:[nu_\"B\"] of substance stem:[\"B\"] (<<t9-29>>):\n\n[stem%unnumbered]\n++++\nK^(&#8854;) = Pi_\"B\" (lambda_\"B\"^(&#8854;))^(-nu_\"B\")\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "This quantity is a function of temperature only. Others depend on temperature, pressure, and composition.\n\nOne can define in an analogous way an equilibrium constant in terms of fugacity, stem:[K_\"f\"], molality, stem:[K_\"m\"], etc.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-33-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "equilibrium constant <pressure basis>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-33-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "K_p",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-33",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-33",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-33-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-33-0"
        }
      ],
      "skos:definition": {
        "@value": "for gases, product for all substances stem:[\"B\"] of partial pressure stem:[p_\"B\"] of substance stem:[\"B\"] (<<t9-19>>) in power of its stoichiometric number stem:[nu_\"B\"] (<<t9-29>>):\n\n[stem%unnumbered]\n++++\nK_p = Pi_\"B\"(p_\"B\")^(nu_\"B\")\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-stem:[\"unitsml(Pa)\"^(sum nu_\"B\")]"
        },
        {
          "@id": "isoiec80000:unit-stem:[(\"unitsml(kg*m^(-1)*s^(-2))\")^(sum nu_\"B\")]"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-34-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "equilibrium constant <concentration basis>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-34-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "K_c",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-34",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-34",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-34-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-34-0"
        }
      ],
      "skos:definition": {
        "@value": "for solutions, product for all substances stem:[\"B\"] of concentration stem:[c_\"B\"] of substance stem:[\"B\"] (<<t9-9.1>>) in power of its stoichiometric number stem:[nu_\"B\"] (<<t9-29>>):\n\n[stem%unnumbered]\n++++\nK_c = Pi_\"B\" (c_\"B\")^(nu_\"B\")\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-stem:[(\"unitsml(mol/m^3)\")^(sum nu_\"B\")]"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-35.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "microcanonical partition function",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-35.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "ii(Omega)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-35.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-35.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-35.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-35.1-0"
        }
      ],
      "skos:definition": {
        "@value": "number of all quantum states stem:[r] consistent with given energy stem:[E] (<<iso80000-4>>), volume (<<iso80000-3>>), and external fields:\n\n[stem%unnumbered]\n++++\nii(Omega) = sum_r 1\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[stem%unnumbered]\n++++\nS = k\"ln\" ii(Omega)\n++++\n\nwhere stem:[S] is entropy (<<iso80000-5>>) and stem:[k] is the Boltzmann constant (<<iso80000-1>>).\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-35.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "canonical partition function",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-35.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Z",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-35.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-35.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-35.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-35.2-0"
        }
      ],
      "skos:definition": {
        "@value": "sum over quantum states of energy stem:[E_r] (<<iso80000-4>>), expressed by:\n\n[stem%unnumbered]\n++++\nZ = sum_r \"exp\" ((-E_r)/(kT))\n++++\n\nwhere stem:[k] is the Boltzmann constant (<<iso80000-1>>), and stem:[T] is thermodynamic temperature (<<iso80000-5>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[stem%unnumbered]\n++++\nA = -kT \"ln\" Z\n++++\n\nwhere stem:[A] is Helmholtz energy (<<iso80000-5>>).\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-35.3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "grand-canonical partition function",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-35.3-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "grand partition function",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-35.3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "ii(Xi)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-35.3",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-35.3",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-35.3-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-35.3-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-35.3-0"
        }
      ],
      "skos:definition": {
        "@value": "sum of canonical partition function stem:[Z (N_\"A\",N_\"B\",...)] for the given number of particles stem:[\"A\", \"B\"] multiplied by absolute activities (<<t9-18>>) stem:[lambda_\"A\", lambda_\"B\", ...] of particles stem:[\"A\", \"B\"]:\n\n[stem%unnumbered]\n++++\nii(Xi) = sum_(N_\"A\",N_\"B\",...) Z(N_\"A\", N_\"B\",...) * lambda_\"A\"^(N_\"A\")*lambda_\"B\"^(N_\"B\")*...\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[stem%unnumbered]\n++++\nA - sum mu_\"B\" n_\"B\" = - kT \"ln\" ii(Xi)\n++++\n\nwhere stem:[A] is Helmholtz energy (<<iso80000-5>>), stem:[mu_\"B\"] is the chemical potential of substance stem:[\"B\"], and stem:[n_\"B\"] is the amount of substance stem:[\"B\"].\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-35.4-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "molecular partition function",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-35.4-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "partition function of a molecule",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-35.4-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "q",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-35.4",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-35.4",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-35.4-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-35.4-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-35.4-0"
        }
      ],
      "skos:definition": {
        "@value": "quantity given by:\n\n[stem%unnumbered]\n++++\nq = sum_r \"exp\" ((-epsilon_r)/(kT))\n++++\n\nwhere stem:[epsilon_r] is the energy (<<iso80000-5>>) of the stem:[r]-th level of the molecule consistent with given volume (<<iso80000-3>>) and external fields, stem:[k] is the Boltzmann constant (<<iso80000-1>>), and stem:[T] is thermodynamic temperature (<<iso80000-5>>)\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-36.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "statistical weight of subsystem",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-36.1-0",
      "@type": [
        "smart:Term",
