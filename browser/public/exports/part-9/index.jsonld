      ],
      "skos:definition": {
        "@value": "for substance stem:[\"X\"] in a mixture, quotient of amount of substance stem:[n_\"X\"] (<<t9-2>>) of stem:[\"X\"] and total amount stem:[n] of substance (<<t9-2>>) in the mixture:\n\n[stem%unnumbered]\n++++\nx_\"X\" = n_\"X\"//n\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For condensed phases, stem:[x_\"X\"] is used, and for gaseous mixtures stem:[y_\"X\"] may be used.\n\nThe unsystematic name \"mole fraction\" is still used. However, the use of this name is deprecated.\n\nFor this quantity, the entity used to define the amount of substance should always be a single molecule for every species in the mixture.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
