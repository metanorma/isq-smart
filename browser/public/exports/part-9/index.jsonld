      "skos:definition": {
        "@value": "for a pure substance stem:[\"X\"], quotient of mass stem:[m(\"X\")] (<<iso80000-4>>) and amount stem:[n] of substance (<<t9-2>>):\n\n[stem%unnumbered]\n++++\nM = m//n\n++++\n",
        "@language": "en"
      },
