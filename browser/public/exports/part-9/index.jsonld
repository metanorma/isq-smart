    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-4",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-4",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-4-0"
