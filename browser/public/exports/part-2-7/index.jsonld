    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t2-7.3",
      "@type": [
        "isoiec80000:MathConcept",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "2-7.3",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-7.3-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-7.3-0"
        }
      ],
      "skos:definition": {
        "@value": "the set of rational numbers",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[bb(sf(Q))** = {r in bb(sf(Q)) &#x2223; r != 0}]\n\nOther restrictions can be indicated in an obvious way, as shown below.\n\nstem:[bb(sf(Q))_(<0) = {r in bb(sf(Q)) &#x2223; r < 0}]\n\nThe symbols stem:[rm(&#8739;Q)] and stem:[QQ] are also used.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
