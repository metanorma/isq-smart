        }
      ],
      "skos:definition": {
        "@value": "left half-open interval from stem:[a] excluded to stem:[b] included",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[(a, b\\] = {x in bb(sf(R)) &#x2223; a < x <= b}]\n\nThe notation stem:[\\]a, b\\]] is also used.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
