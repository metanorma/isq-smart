        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-7.7-0"
        }
      ],
      "skos:definition": {
        "@value": "closed interval from stem:[a] included to stem:[b] included",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[[a, b\\] = {x in bb(sf(R)) &#x2223; a <= x <= b}]",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
