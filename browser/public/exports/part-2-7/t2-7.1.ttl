isoiec80000:term-t2-7.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "natural numbers"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-7.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(N)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-7.1 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-7.1" ;
  skosxl:prefLabel isoiec80000:term-t2-7.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-7.1-0 ;
  skos:definition """the set of natural numbers, +
the set of positive integers and zero
"""@en ;
  skos:note """stem:[bb(sf(N)) = {0, 1, 2, 3, ...}]

stem:[bb(sf(N))** = {1, 2, 3, ...}]

Other restrictions can be indicated in an obvious way, as shown below.

stem:[bb(sf(N))_(>5) = {n in bb(sf(N)) &#x2223; n > 5}]

The symbols stem:[rm(&#8739;N)] and stem:[NN] are also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-7 .