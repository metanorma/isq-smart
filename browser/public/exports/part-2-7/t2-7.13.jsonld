      "skos:definition": {
        "@value": "closed unbounded interval onward from stem:[a] included",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[[a, +oo) = {x in bb(sf(R)) &#x2223; a <= x}]\n\nThe notations stem:[[a, oo), [a, +oo[] and stem:[[a, oo[] are also used.\n",
