        }
      ],
      "skos:definition": {
        "@value": "arcus cosine of stem:[x]",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[y = \"arccos \"x <=> x = \"cos \"y] (for stem:[0 <= y <= pi])\n\nThe function stem:[\"arccos\"] is the inverse of the function stem:[\"cos\"] with the restriction mentioned above.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
