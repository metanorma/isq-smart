        "@value": "sine",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-14.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "\"sin \"x",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t2-14.2",
      "@type": [
        "isoiec80000:MathConcept",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "2-14.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-14.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-14.2-0"
        }
      ],
      "skos:definition": {
        "@value": "sine of stem:[x]",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[\"sin \"x = (e^(ix)-e^(-ix))/(2i)]\n\nstem:[\"sin \"x = x - x^3//3! + x^5//5! - ...]\n\nstem:[(\"sin \"x)^n], stem:[(\"cos \"x)^n], etc. (for stem:[n >= 2]), are often written stem:[\"sin\"^n x], stem:[\"cos\"^n x], etc.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-2-14"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-14.3-0",
