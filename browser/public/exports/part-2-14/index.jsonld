      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t2-14.3",
      "@type": [
        "isoiec80000:MathConcept",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "2-14.3",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-14.3-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-14.3-0"
        }
      ],
      "skos:definition": {
        "@value": "cosine of stem:[x]",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[\"cos \"x = \"sin\"(x + pi//2)]",
        "@language": "en"
      },
