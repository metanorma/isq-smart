      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-14.1-0"
        }
      ],
      "skos:definition": {
        "@value": "ratio of the circumference of a circle to its diameter",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[pi = 3.1415926...]",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-2-14"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-14.2-0",
