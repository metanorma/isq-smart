    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t2-14.8",
      "@type": [
        "isoiec80000:MathConcept",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "2-14.8",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-14.8-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-14.8-0"
        }
      ],
      "skos:definition": {
        "@value": "arcus sine of stem:[x]",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[y = \"arcsin \"x <=> x = \"sin \"y]\n\n(for stem:[-pi//2 <= y <= pi//2])\n\nThe function stem:[\"arcsin\"] is the inverse of the function stem:[\"sin\"] with the restriction mentioned above.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-2-14"
      }
    },
