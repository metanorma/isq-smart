        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-14.4-0"
        }
      ],
      "skos:definition": {
        "@value": "tangent of stem:[x]",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[\"tan \"x = \"sin \" x//\"cos \"x]\n\nstem:[\"tg \"x] should not be used.\n",
        "@language": "en"
