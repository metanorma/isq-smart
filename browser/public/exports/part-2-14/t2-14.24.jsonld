      "skos:definition": {
        "@value": "inverse hyperbolic secant of stem:[x], +\narea hyperbolic secant of stem:[x]\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[y = \"arsech \"x <=> x = \"sech \"y] (for stem:[y >= 0])\n\nThe function stem:[\"arsech\"] is the inverse of the function stem:[\"sech\"] with the restriction mentioned above.\n",
        "@language": "en"
      },
