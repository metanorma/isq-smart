      "skos:definition": {
        "@value": "hyperbolic sine of stem:[x]",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[\"sinh \"x = (\"e\"^x-\"e\"^(-x))/2]\n\nstem:[\"sinh \"x = x + x^3//3! + ...]\n\nstem:[\"sh \"x] should be avoided.\n",
        "@language": "en"
      },
