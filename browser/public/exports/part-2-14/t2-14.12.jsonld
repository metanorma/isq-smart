      "skos:definition": {
        "@value": "arcus secant of stem:[x]",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[y = \"arcsec \"x <=> x = \"sec \"y]\n\n(for stem:[0 <= y <= pi], stem:[y != pi//2])\n\nThe function stem:[\"arcsec\"] is the inverse of the function stem:[\"sec\"] with the restriction mentioned above.\n",
        "@language": "en"
      },
