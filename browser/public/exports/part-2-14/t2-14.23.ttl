isoiec80000:term-t2-14.23-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "inverse hyperbolic cotangent"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.23-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"arcoth \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.23 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.23" ;
  skosxl:prefLabel isoiec80000:term-t2-14.23-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.23-0 ;
  skos:definition """inverse hyperbolic cotangent of stem:[x], +
area hyperbolic cotangent of stem:[x]
"""@en ;
  skos:note """stem:[y = \"arcoth \"x <=> x = \"coth \"y] (for stem:[y != 0])

The function stem:[\"arcoth\"] is the inverse of the function stem:[\"coth\"] with the restriction mentioned above.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .