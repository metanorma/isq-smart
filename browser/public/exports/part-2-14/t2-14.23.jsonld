      "skos:definition": {
        "@value": "inverse hyperbolic cotangent of stem:[x], +\narea hyperbolic cotangent of stem:[x]\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[y = \"arcoth \"x <=> x = \"coth \"y] (for stem:[y != 0])\n\nThe function stem:[\"arcoth\"] is the inverse of the function stem:[\"coth\"] with the restriction mentioned above.\n",
        "@language": "en"
      },
