isoiec80000:term-t2-8.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "equality"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a = b"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.1 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.1" ;
  skosxl:prefLabel isoiec80000:term-t2-8.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.1-0 ;
  skos:definition """stem:[a] is equal to stem:[b] +
stem:[a] equals stem:[b]
"""@en ;
  skos:note """The symbol stem:[-=] may be used to emphasize that a particular equality is an identity, i.e. holds universally.

But see <<t2-8.18>> for another meaning.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .