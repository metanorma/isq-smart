isoiec80000:term-t2-8.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "tends to"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "x -> a"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.16 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.16" ;
  skosxl:prefLabel isoiec80000:term-t2-8.16-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.16-0 ;
  skos:definition """stem:[x] tends to stem:[a]"""@en ;
  skos:note """This symbol occurs as part of various expressions dealing with limits.

stem:[a] may be also stem:[oo], stem:[+oo], or stem:[-oo].
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .