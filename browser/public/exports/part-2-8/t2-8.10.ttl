  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.10 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.10" ;
  skosxl:prefLabel isoiec80000:term-t2-8.10-0 ;
