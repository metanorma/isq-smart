isoiec80000:term-t2-8.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "proportional to"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a ~ b"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.7 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.7" ;
  skosxl:prefLabel isoiec80000:term-t2-8.7-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.7-0 ;
  skos:definition """stem:[a] is proportional to stem:[b]"""@en ;
  skos:note """The symbol stem:[~] is also used for equivalence relations.

The notation stem:[a prop b] is also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .