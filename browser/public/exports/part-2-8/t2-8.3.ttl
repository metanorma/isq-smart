isoiec80000:term-t2-8.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "equal to"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a &#x2254; b"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.3 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.3" ;
  skosxl:prefLabel isoiec80000:term-t2-8.3-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.3-0 ;
  skos:definition """stem:[a] is by definition equal to stem:[b]"""@en ;
  skos:note """[example]
====
stem:[p &#x2254; mv], where stem:[p] is momentum, stem:[m] is mass and stem:[v] is velocity.

The symbols stem:[=_(\"def\")] and stem:[&#x225D;] are also used.
====
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .