isoiec80000:term-t2-8.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "corresponds to"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a &#x2259; b"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.4 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.4" ;
  skosxl:prefLabel isoiec80000:term-t2-8.4-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.4-0 ;
  skos:definition """stem:[a] corresponds to stem:[b]"""@en ;
  skos:note """[example]
====
When stem:[E = kT], then stem:[1 \"unitsml(eV)\" &#x2259; 11604.5 \"unitsml(K)\"].

When stem:[1 \"unitsml(cm)\"] on a map corresponds to a length of stem:[10 \"unitsml(km)\"], one may write stem:[1 \"unitsml(cm)\" &#x2259; 10 \"unitsml(km)\"].

The correspondence is not symmetric.
====
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .