isoiec80000:term-t2-8.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "asymptotically equal to"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a &#x2243; b"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.6 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.6" ;
  skosxl:prefLabel isoiec80000:term-t2-8.6-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.6-0 ;
  skos:definition """stem:[a] is asymptotically equal to stem:[b]"""@en ;
  skos:note """[example]
====
stem:[1/(sin(x-a)) &#x2243; 1/(x-a)] as stem:[x -> a]

(For stem:[x -> a], see <<t2-8.16>>.)
====
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .