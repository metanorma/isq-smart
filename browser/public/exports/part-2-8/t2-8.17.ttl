isoiec80000:term-t2-8.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "divides"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "m &#x2223; n"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.17 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.17" ;
  skosxl:prefLabel isoiec80000:term-t2-8.17-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.17-0 ;
  skos:definition """stem:[m] divides stem:[n]"""@en ;
  skos:note """For integers stem:[m] and stem:[n]:

stem:[EE k in bb(sf(Z))] stem:[m*k = n]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .