isoiec80000:term-t2-8.15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "infinity"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.15-0 a smart:Term, skosxl:Label ;
