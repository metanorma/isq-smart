isoiec80000:term-t2-8.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "approximately equal to"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a ~~ b"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.5 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.5" ;
  skosxl:prefLabel isoiec80000:term-t2-8.5-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.5-0 ;
  skos:definition """stem:[a] is approximately equal to stem:[b]"""@en ;
  skos:note """It depends on the user whether an approximation is sufficiently good. Equality is not excluded."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .