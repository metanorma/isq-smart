    "skos": "http://www.w3.org/2004/02/skos/core#",
    "skosxl": "http://www.w3.org/2008/05/skos-xl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-17.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Cartesian coordinate",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-17.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "x, y, z",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t2-17.1",
      "@type": [
        "isoiec80000:MathConcept",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "2-17.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-17.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-17.1-0"
        }
      ],
      "skos:definition": {
        "@value": "stem:[bb(ii(r)) = xbb(ii(e))_x + ybb(ii(e))_y + zbb(ii(e))_z] +\nstem:[\"d\"bb(ii(r)) = \"d\"x\" \"bb(ii(e))_x + \"d\"y\" \"bb(ii(e))_y + \"d\"z\" \"bb(ii(e))_z]\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The base vectors stem:[bb(ii(e))_x, bb(ii(e))_y, bb(ii(e))_z] form an orthonormal system (i.e. the vectors are unit vectors and orthogonal) which is right-handed, see <<fig1;and!fig4>>.\n\nstem:[bb(ii(e))_1, bb(ii(e))_2, bb(ii(e))_3] or stem:[bb(ii(i)), bb(ii(j)), bb(ii(k))] are also used for the base vectors and stem:[x_1, x_2, x_3] or stem:[i, j, k] for the coordinates.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-2-17"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-17.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "cylindrical coordinate",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-17.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "rho, varphi, z",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t2-17.2",
      "@type": [
        "isoiec80000:MathConcept",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "2-17.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-17.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-17.2-0"
        }
      ],
      "skos:definition": {
        "@value": "stem:[bb(ii(r)) = rho\" \"bb(ii(e))_rho + z\" \"bb(ii(e))_z] +\nstem:[\"d\"bb(ii(r)) = \"d\"rho\" \"bb(e)_rho + rho\" d\"varphi\" \"e_varphi + \"d\"z\" \"e_z]\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[bb(ii(e))_rho (varphi), bb(ii(e))_varphi(varphi), bb(ii(e))_z] form an orthonormal right-handed system. See <<fig2>>.\n\nIf stem:[z = 0], then stem:[rho] and stem:[varphi] are polar coordinates in the plane.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-2-17"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-17.3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "spherical coordinate",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-17.3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "r, vartheta, varphi",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t2-17.3",
      "@type": [
        "isoiec80000:MathConcept",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "2-17.3",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-17.3-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-17.3-0"
        }
      ],
      "skos:definition": {
        "@value": "stem:[bb(ii(r)) = r\" \"bb(ii(e))_r] +\nstem:[\"d\"bb(ii(r)) = \"d\"r bb(ii(e))_r + r \"d\"vartheta bb(ii(e))_vartheta + r\" sin \"vartheta\" d\"varphi\" \"bb(ii(e))_varphi]\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[bb(ii(e))_r(vartheta,varphi), bb(ii(e))_vartheta(vartheta, varphi), bb(ii(e))_varphi(varphi)] form an orthonormal right-handed system.\n\nSee <<fig3>>.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-2-17"
      }
    }
  ]
}