      },
      "skos:note": {
        "@value": "stem:[bb(ii(e))_r(vartheta,varphi), bb(ii(e))_vartheta(vartheta, varphi), bb(ii(e))_varphi(varphi)] form an orthonormal right-handed system.\n\nSee <<fig3>>.\n",
