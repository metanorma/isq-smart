isoiec80000:term-t8-10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sound intensity"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t8-10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(I))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t8-10 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "8-10" ;
  skosxl:prefLabel isoiec80000:term-t8-10-0 ;
  skosxl:altLabel isoiec80000:sym-t8-10-0 ;
  skos:definition """vector (<<iso80000-2>>) quantity given by:

[stem%unnumbered]
++++
bb(ii(I)) = p bb(ii(u))
++++

where stem:[p] is sound pressure (<<t8-2.2>>) and stem:[bb(ii(u))] is sound particle velocity (<<t8-4>>)
"""@en ;
  skos:note """This definition can become inapplicable in situations with a high mean fluid flow."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-W/m^2 ;
  isoiec80000:hasUnit isoiec80000:unit-kg*s^(-3) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-8 .