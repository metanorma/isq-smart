isoiec80000:term-t8-3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sound particle displacement"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t8-3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "delta"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t8-3 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "8-3" ;
  skosxl:prefLabel isoiec80000:term-t8-3-0 ;
  skosxl:altLabel isoiec80000:sym-t8-3-0 ;
  skos:definition """vector (<<iso80000-2>>) quantity giving the instantaneous displacement (<<iso80000-3>>) of a particle in a medium from what would be its position in the absence of sound waves"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-m ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-8 .