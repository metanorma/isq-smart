isoiec80000:term-t8-2.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sound pressure"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t8-2.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "p"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t8-2.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "8-2.2" ;
  skosxl:prefLabel isoiec80000:term-t8-2.2-0 ;
  skosxl:altLabel isoiec80000:sym-t8-2.2-0 ;
  skos:definition """difference between instantaneous total pressure and static pressure (<<t8-2.1>>)"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Pa ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^(-1)*s^(-2) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-8 .