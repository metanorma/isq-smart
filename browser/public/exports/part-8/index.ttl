isoiec80000:unit-J a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "joule"@en ;
  skos:notation "J" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-kg*m^2*s^(-2) a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "kilogram square metre per second squared"@en ;
  skos:notation "kg*m^2*s^(-2)" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-W a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "watt"@en ;
  skos:notation "W" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-kg*m^2*s^(-3) a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "kilogram square metre per second cubed"@en ;
  skos:notation "kg*m^2*s^(-3)" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-W/m^2 a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "watt per square metre"@en ;
  skos:notation "W/m^2" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-kg*s^(-3) a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "kilogram per second cubed"@en ;
  skos:notation "kg*s^(-3)" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-Pa^2*s a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "pascal squared second"@en ;
  skos:notation "Pa^2*s" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-kg^2*m^(-2)*s^(-3) a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "kilogram squared per square metre second cubed"@en ;
  skos:notation "kg^2*m^(-2)*s^(-3)" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-Pa*s/m a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "pascal second per metre"@en ;
  skos:notation "Pa*s/m" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-kg*m^(-2)*s^(-1) a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "kilogram per square metre second"@en ;
  skos:notation "kg*m^(-2)*s^(-1)" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-Pa*s/m^3 a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "pascal second per cubic metre"@en ;
  skos:notation "Pa*s/m^3" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-kg*m^(-4)*s^(-1) a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "kilogram per metre to the fourth second"@en ;
  skos:notation "kg*m^(-4)*s^(-1)" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-stem:["dB"] a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "decibel"@en ;
  skos:notation "stem:["dB"]" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-s a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "second"@en ;
  skos:notation "s" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:term-t8-1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "logarithmic frequency range"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t8-1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "G"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t8-1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "8-1" ;
  skosxl:prefLabel isoiec80000:term-t8-1-0 ;
  skosxl:altLabel isoiec80000:sym-t8-1-0 ;
  skos:definition """quantity given by:

[stem%unnumbered]
++++
G = \"lb\"(f_2/f_1) \" oct\" = \"lg\" (f_2/f_1) \" dec\"
++++

where stem:[f_1] and stem:[f_2] are two frequencies (<<iso80000-3>>)
"""@en ;
  skos:note """One octave (stem:[\"oct\"]) is the logarithmic frequency range between stem:[f_1] and stem:[f_2] when stem:[f_2/f_1 = 2]. Similarly, one decade (stem:[\"dec\"]) is the logarithmic frequency range between stem:[f_1] and stem:[f_2] when stem:[f_2/f_1 = 10]; thus stem:[1 \" dec\" = (\"lb\" 10) \" oct\" ~~ 3.322 \" oct\"].

<<iso266>> specifies preferred frequencies for acoustics separated by logarithmic frequency ranges equal to one tenth of a decade (stem:[0.1 \" dec\"]). Each stem:[0.1 \" dec\"] logarithmic frequency range is referred to in <<iso266>> as a \"one-third-octave interval\" because stem:[0.1 \" dec\"] is approximately equal to stem:[1//3 \" oct\"]. Similarly, a logarithmic frequency range of stem:[0.3 \" dec\"] is referred to as a \"one-octave interval\" because stem:[0.3 \" dec\"] is approximately equal to stem:[1 \" oct\"].

A logarithmic frequency range equal to one tenth of a decade can be referred to as a decidecade.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-stem:["oct"] ;
  isoiec80000:hasUnit isoiec80000:unit-stem:["dec"] ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-8 .

isoiec80000:term-t8-2.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "static pressure"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t8-2.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "p_\"s\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t8-2.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "8-2.1" ;
  skosxl:prefLabel isoiec80000:term-t8-2.1-0 ;
  skosxl:altLabel isoiec80000:sym-t8-2.1-0 ;
  skos:definition """pressure (<<iso80000-4>>) in a medium when no sound wave is present"""@en ;
  skos:note """This definition applies to a medium with zero flow."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Pa ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^(-1)*s^(-2) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-8 .

isoiec80000:term-t8-2.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sound pressure"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t8-2.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "p"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t8-2.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "8-2.2" ;
  skosxl:prefLabel isoiec80000:term-t8-2.2-0 ;
  skosxl:altLabel isoiec80000:sym-t8-2.2-0 ;
  skos:definition """difference between instantaneous total pressure and static pressure (<<t8-2.1>>)"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Pa ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^(-1)*s^(-2) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-8 .

isoiec80000:term-t8-3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sound particle displacement"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t8-3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "delta"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t8-3 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "8-3" ;
  skosxl:prefLabel isoiec80000:term-t8-3-0 ;
  skosxl:altLabel isoiec80000:sym-t8-3-0 ;
  skos:definition """vector (<<iso80000-2>>) quantity giving the instantaneous displacement (<<iso80000-3>>) of a particle in a medium from what would be its position in the absence of sound waves"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-m ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-8 .

isoiec80000:term-t8-4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sound particle velocity"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t8-4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(u))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t8-4-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "(bb(ii(nu)))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t8-4 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "8-4" ;
  skosxl:prefLabel isoiec80000:term-t8-4-0 ;
  skosxl:altLabel isoiec80000:sym-t8-4-0 ;
  skosxl:altLabel isoiec80000:sym-t8-4-1 ;
  skos:definition """vector (<<iso80000-2>>) quantity given by:

[stem%unnumbered]
++++
bb(ii(u)) = (del bb(ii(delta)))/(del t)
++++

where stem:[delta] is sound particle displacement (<<t8-3>>) and stem:[t] is time (<<iso80000-3>>)
"""@en ;
  skos:note """The definition is limited to small-amplitude acoustic disturbances such that the magnitude of stem:[bb(ii(u))] is small relative to the phase speed (<<iso80000-3>>) of sound."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-m*s^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-8 .

isoiec80000:term-t8-5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sound particle acceleration"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t8-5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(a))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t8-5 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "8-5" ;
  skosxl:prefLabel isoiec80000:term-t8-5-0 ;
  skosxl:altLabel isoiec80000:sym-t8-5-0 ;
  skos:definition """vector (<<iso80000-2>>) quantity given by:

[stem%unnumbered]
++++
bb(ii(a)) = (del bb(ii(u)))/(del t)
++++

where stem:[bb(ii(u))] is sound particle velocity (<<t8-4>>) and stem:[t] is time
"""@en ;
  skos:note """The definition is limited to small-amplitude acoustic disturbances such that the magnitude of the sound particle velocity is small relative to the phase speed (<<iso80000-3>>) of sound."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-m*s^(-2) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-8 .

isoiec80000:term-t8-6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "volume velocity"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t8-6-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "volume flow rate"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t8-6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "q"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t8-6-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "q_nu"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t8-6 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "8-6" ;
  skosxl:prefLabel isoiec80000:term-t8-6-0 ;
  skosxl:altLabel isoiec80000:term-t8-6-1 ;
  skosxl:altLabel isoiec80000:sym-t8-6-0 ;
  skosxl:altLabel isoiec80000:sym-t8-6-1 ;
  skos:definition """surface integral of the normal component of the sound particle velocity (<<t8-4>>) over a defined surface"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-m^3*s^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-8 .

isoiec80000:term-t8-7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sound energy density"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t8-7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "w"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t8-7 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "8-7" ;
  skosxl:prefLabel isoiec80000:term-t8-7-0 ;
  skosxl:altLabel isoiec80000:sym-t8-7-0 ;
  skos:definition """quantity given by:

[stem%unnumbered]
++++
w = 1/2 rho_\"m\" u^2 + 1/2 p^2/(rho_\"m\" c^2)
++++

where stem:[rho_\"m\"] is mean density (<<iso80000-4>>), stem:[u] is the magnitude of the sound particle velocity (<<t8-4>>), stem:[p] is sound pressure (<<t8-2.2>>), and stem:[c] is the phase speed (<<iso80000-3>>) of sound
"""@en ;
  skos:note """This definition can become inapplicable in situations with a high mean fluid flow."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-J/m^3 ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^(-1)*s^(-2) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-8 .

isoiec80000:term-t8-8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sound energy"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t8-8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Q"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t8-8 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "8-8" ;
  skosxl:prefLabel isoiec80000:term-t8-8-0 ;
  skosxl:altLabel isoiec80000:sym-t8-8-0 ;
  skos:definition """integral of sound energy density (<<t8-7>>) over a specified volume"""@en ;
  skos:note """The sound energy in region stem:[\"R\"] can be expressed by:

[stem%unnumbered]
++++
Q = oint_\"R\" w(bb(ii(x)))\"d\"^3 bb(ii(x))
++++

where stem:[\"d\"^3bb(ii(x))] is an element of volume.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-J ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^2*s^(-2) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-8 .

isoiec80000:term-t8-9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sound power"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t8-9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "P"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t8-9-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "W"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t8-9 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "8-9" ;
  skosxl:prefLabel isoiec80000:term-t8-9-0 ;
  skosxl:altLabel isoiec80000:sym-t8-9-0 ;
  skosxl:altLabel isoiec80000:sym-t8-9-1 ;
  skos:definition """integral over a surface of the product of sound pressure, stem:[p] (<<t8-2.2>>), and the component stem:[u_\"n\"] of the particle velocity (<<t8-4>>) in the direction normal to the surface, at a point on the surface"""@en ;
  skos:note """This definition holds for waves in the volume of homogenous fluids or gases.

This definition can become inapplicable in situations with a high mean fluid flow.

Sound power is for example used to indicate the rate at which energy is radiated by a sound source.

Sound power is an oscillatory quantity that can be positive or negative. A positive sound power indicates that the sound power is radiated out of the surface. A negative sound power indicates that the sound power is absorbed into the surface.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-W ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^2*s^(-3) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-8 .

isoiec80000:term-t8-10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sound intensity"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t8-10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(I))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t8-10 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "8-10" ;
  skosxl:prefLabel isoiec80000:term-t8-10-0 ;
  skosxl:altLabel isoiec80000:sym-t8-10-0 ;
  skos:definition """vector (<<iso80000-2>>) quantity given by:

[stem%unnumbered]
++++
bb(ii(I)) = p bb(ii(u))
++++

where stem:[p] is sound pressure (<<t8-2.2>>) and stem:[bb(ii(u))] is sound particle velocity (<<t8-4>>)
"""@en ;
  skos:note """This definition can become inapplicable in situations with a high mean fluid flow."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-W/m^2 ;
  isoiec80000:hasUnit isoiec80000:unit-kg*s^(-3) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-8 .

isoiec80000:term-t8-11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sound exposure"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t8-11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "E"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t8-11 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "8-11" ;
  skosxl:prefLabel isoiec80000:term-t8-11-0 ;
  skosxl:altLabel isoiec80000:sym-t8-11-0 ;
  skos:definition """time-integrated squared sound pressure (<<t8-2.2>>)"""@en ;
  skos:note """In formula form:

stem:[E = int_(t_1)^(t_2) p^2 \"d\"t] where stem:[t_1] and stem:[t_2] are the starting and ending times for the integral and stem:[p] is sound pressure (<<t8-2.2>>).

In airborne acoustics, the sound pressure is frequency-weighted and frequency-band-limited. If frequency weightings as specified in <<iec61672-1>> are applied, this should be indicated by appropriate subscripts to the symbol stem:[E].

In underwater acoustics, the term \"sound exposure\" indicates an unweighted quantity unless indicated otherwise.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Pa^2*s ;
  isoiec80000:hasUnit isoiec80000:unit-kg^2*m^(-2)*s^(-3) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-8 .

isoiec80000:term-t8-12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "characteristic impedance of a medium for longitudinal waves"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t8-12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Z_\"c\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t8-12 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "8-12" ;
  skosxl:prefLabel isoiec80000:term-t8-12-0 ;
  skosxl:altLabel isoiec80000:sym-t8-12-0 ;
  skos:definition """quotient of sound pressure (<<t8-2.2>>) and the component of the sound particle velocity (<<t8-4>>) in the direction of the wave propagation"""@en ;
  skos:note """The definition is limited to a progressive plane wave in a non-dissipative homogenous gas or fluid.

Characteristic impedance is a property of the medium and is equal to stem:[rho c] where stem:[rho] is the time-averaged density (<<iso80000-4>>) of the medium and stem:[c] the phase speed of sound (<<iso80000-3>>).

Longitudinal waves are waves in which the displacement of the medium is in the same direction as, or the opposite direction to, the direction of propagation of the wave.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Pa*s/m ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^(-2)*s^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-8 .

isoiec80000:term-t8-13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "acoustic impedance"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t8-13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Z_\"a\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t8-13 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "8-13" ;
  skosxl:prefLabel isoiec80000:term-t8-13-0 ;
  skosxl:altLabel isoiec80000:sym-t8-13-0 ;
  skos:definition """at a surface, quotient of the average sound pressure (<<t8-2.2>>) over that surface and the sound volume flow rate (<<t8-6>>) through that surface"""@en ;
  skos:note """This definition applies to a sound pressure that is in phase with the volume flow rate. In this situation, the acoustic impedance is real.

Both the sound pressure, stem:[p], and sound volume flow rate, stem:[q], are real quantities that fluctuate with time. If the fluctuations are in phase (phase difference equal to zero), the quotient stem:[p//q] is a constant. If they are out of phase (phase difference not equal to zero), they can be represented by complex quantities in the frequency domain, the quotient of which is also complex.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Pa*s/m^3 ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^(-4)*s^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-8 .

isoiec80000:term-t8-14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sound pressure level"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t8-14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "L_p"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t8-14 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "8-14" ;
  skosxl:prefLabel isoiec80000:term-t8-14-0 ;
  skosxl:altLabel isoiec80000:sym-t8-14-0 ;
  skos:definition """quantity given by:

[stem%unnumbered]
++++
L_p = 10 \"lg\" (p_\"RMS\"^2)/(p_0^2) \" dB\"
++++

where stem:[p_\"RMS\"] is the root-mean-square sound pressure in the time domain and stem:[p_0] is the reference value of sound pressure
"""@en ;
  skos:note """For sound in air and other gases, the reference value of sound pressure is given by stem:[p_0 = 20 \"unitsml(uPa)\"]. For sound in water and other liquids, the reference value of sound pressure is given by stem:[p_0 = 1 \"unitsml(uPa)\"]. When stating a value of sound pressure level, the reference value shall be specified.

The value of sound pressure level depends on the selected frequency range and time duration. When stating a value of sound pressure level, the frequency range and time duration shall be specified.

In accordance with <<iso80000-1>>, any attachment to the unit symbol as a means of giving information about the special nature of the quantity or context of measurement under consideration is not permitted. If specific frequency and time weightings as specified in <<iec61672-1>> or specific frequency bands or time duration are applied, this should be indicated by appropriate subscripts to the quantity symbol.

In some applications the level of the peak sound pressure is required. This is obtained by replacing the root-mean-square sound pressure, with the instantaneous sound pressure having the greatest absolute value during a stated time interval, in the definition of sound pressure level.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-stem:["dB"] ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-8 .

isoiec80000:term-t8-15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sound power level"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t8-15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "L_P"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t8-15-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "L_W"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t8-15 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "8-15" ;
  skosxl:prefLabel isoiec80000:term-t8-15-0 ;
  skosxl:altLabel isoiec80000:sym-t8-15-0 ;
  skosxl:altLabel isoiec80000:sym-t8-15-1 ;
  skos:definition """quantity given by:

[stem%unnumbered]
++++
L_P = 10 \"lg\" P_\"m\"/P_0 \" dB\"
++++

where stem:[P_\"m\"] is the magnitude of the time-averaged sound power (<<t8-9>>) and stem:[P_0] is the reference value of sound power
"""@en ;
  skos:note """The reference value of sound power is given by stem:[P_0 = 1 \"unitsml(pW)\"]. When stating a value of sound power level, the reference value shall be specified.

The value of sound power level depends on the selected frequency range and time duration. When stating a value of sound power level, the frequency range and time duration shall be specified.

In accordance with <<iso80000-1>>, any attachment to the unit symbol as a means of giving information about the special nature of the quantity or context of measurement under consideration is not permitted. If specific frequency and time weightings as specified in <<iec61672-1>> or specific frequency bands or time duration are applied, this should be indicated by appropriate subscripts to the quantity symbol.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-stem:["dB"] ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-8 .

isoiec80000:term-t8-16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sound exposure level"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t8-16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "L_E"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t8-16 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "8-16" ;
  skosxl:prefLabel isoiec80000:term-t8-16-0 ;
  skosxl:altLabel isoiec80000:sym-t8-16-0 ;
  skos:definition """quantity given by:

[stem%unnumbered]
++++
L_E = 10 \"lg\" E/E_0 \" dB\"
++++

where stem:[E] is sound exposure (<<t8-11>>) and stem:[E_0] is the reference value of sound exposure
"""@en ;
  skos:note """For sound in air and other gases, the reference value of sound exposure is given by stem:[E_0 = 400 \"unitsml(uPa^2*s)\"]. For sound in water and other liquids, the reference value of sound exposure is given by stem:[E_0 = 1 \"unitsml(uPa^2*s)\"]. When stating a value of sound exposure level, the reference value shall be specified.

The value of sound exposure level depends on the selected frequency range and time duration. When stating a value of sound exposure level, the frequency range and time duration shall be specified.

In accordance with <<iso80000-1>>, any attachment to the unit symbol as a means of giving information about the special nature of the quantity or context of measurement under consideration is not permitted. If specific frequency and time weightings as specified in <<iec61672-1>> or specific frequency bands or time duration are applied, this should be indicated by appropriate subscripts to the quantity symbol.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-stem:["dB"] ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-8 .

isoiec80000:term-t8-17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "reverberation time"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t8-17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "T"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t8-17 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "8-17" ;
  skosxl:prefLabel isoiec80000:term-t8-17-0 ;
  skosxl:altLabel isoiec80000:sym-t8-17-0 ;
  skos:definition """time duration (<<iso80000-3>>) required for the space-averaged sound energy density (<<t8-7>>) to decrease to stem:[10^(-6)] of its initial value (i.e. for its level to decrease by stem:[60 \" dB\"]) after the source emission has stopped"""@en ;
  skos:note """The reverberation time can be evaluated based on a dynamic range smaller than stem:[60 \" dB\"] and extrapolated to a decay time of stem:[60 \" dB\"]. It is then labelled accordingly stem:[T_n], where stem:[n] is the dynamic range in stem:[\"dB\"]. See also <<iso3382-1>>."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-s ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-8 .
