@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

isoiec80000:part-8 a smart:PublicationDocument ;
  dcterms:title "Acoustics"@en ;
  dcterms:identifier "ISO 80000-8" ;
  smart:hasPublicationType smart:internationalStandard ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-stem:["oct"] a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "octet"@en ;
