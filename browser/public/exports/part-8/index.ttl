isoiec80000:unit-stem:["dec"] a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "decimal digit"@en ;
  skos:notation "stem:["dec"]" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-Pa a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "pascal"@en ;
