isoiec80000:unit-m*s^(-1) a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "metre per second"@en ;
  skos:notation "m*s^(-1)" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-m*s^(-2) a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "metre per second squared"@en ;
  skos:notation "m*s^(-2)" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-m^3*s^(-1) a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "cubic metre per second"@en ;
  skos:notation "m^3*s^(-1)" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-J/m^3 a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "joule per cubic metre"@en ;
  skos:notation "J/m^3" ;
