      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-7.3",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-7.3",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-7.3-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-7.3-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of thermal diffusivity and diffusion coefficient for heat transfer in a fluid, expressed by\n\nstem:[Le = a//D]; where\n\nstem:[a]:: is thermal diffusivity (<<iso80000-5>>), and\nstem:[D]:: is diffusion coefficient (<<iso80000-9>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Lewis number is also given by\n\nstem:[Le = Sc//Pr]; where\n\nstem:[Sc]:: is the Schmidt number (<<t11-7.2>>), and\nstem:[Pr]:: is the Prandtl number (<<t11-7.1>>).\n\nCompare with <<t11-5.2>>.\n\nThe Lewis number is sometimes defined as reciprocal of this quantity.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-7"
      }
    }
  ]
