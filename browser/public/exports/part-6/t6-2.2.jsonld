        }
      ],
      "skos:definition": {
        "@value": "magnitude of the negative electric charge carried by a single electron, which has charge stem:[-1 e]",
        "@language": "en"
      },
      "skos:note": {
        "@value": "In the SI system the elementary charge, stem:[e], is one of the fundamental constants with an exact value\n\nstem:[e = 1.602176634 xx 10^(-19) \"unitsml(C)\"], see <<bipm-si>>.\n\nElectric charge can be positive, negative or zero. The sign convention is such that the elementary electric charge, stem:[e], of the proton, is positive. See <<iec60050-113,locality:item=\"113-02-12\">>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
