      "skos:definition": {
        "@value": "scalar quantity given by the quotient of magnetic tension stem:[U_\"m\"] (<<t6-37.2>>) and total magnetic flux stem:[Psi] (<<t6-22.4>>);\n\n[stem%unnumbered]\n++++\nR_\"m\" = (U_\"m\")/Psi\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "See <<iec60050-131,locality:item=\"131-12-28\">>.",
        "@language": "en"
      },
