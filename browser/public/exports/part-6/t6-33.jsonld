        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "w",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t6-33",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "6-33",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-33-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-33-0"
        }
      ],
      "skos:definition": {
        "@value": "scalar quantity given by the sum of scalar products:\n\n[stem%unnumbered]\n++++\nw = (1//2)(bb(ii(E)) * bb(ii(D)) + bb(ii(B)) * bb(ii(H)))\n++++\n\nwhere stem:[bb(ii(E))] is electric field strength (<<t6-10>>), stem:[bb(ii(D))] is electric flux density (<<t6-12>>), stem:[bb(ii(B))] is magnetic flux density (<<t6-21>>), and stem:[bb(ii(H))] is magnetic field strength (<<t6-25>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Electromagnetic energy is a special kind of energy (<<iso80000-5>>). The electromagnetic energy density depends on position.\n\nSee <<iec60050-121,locality:item=\"121-11-65\">>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-J/m^3"
        },
        {
          "@id": "isoiec80000:unit-kg*m^(-1)*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-6"
      }
    }
  ]
