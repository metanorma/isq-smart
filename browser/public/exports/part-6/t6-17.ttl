isoiec80000:term-t6-17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "electric flux"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t6-17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "psi"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t6-17 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "6-17" ;
  skosxl:prefLabel isoiec80000:term-t6-17-0 ;
  skosxl:altLabel isoiec80000:sym-t6-17-0 ;
  skos:definition """scalar quantity given by the integral

[stem%unnumbered]
++++
psi = int_\"S\" bb(ii(D)) * e_\"n\" \"d\"A
++++

over a surface stem:[\"S\"], where stem:[bb(ii(D))] is electric flux density (<<t6-12>>) and stem:[e_\"n\"\"d\"A] is a vector surface element (<<iso80000-3>>)
"""@en ;
  skos:note """See <<iec60050-121,locality:item=\"121-11-41\">>."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-C ;
  isoiec80000:hasUnit isoiec80000:unit-s*A ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-6 .