      "skos:definition": {
        "@value": "scalar quantity given by the sum of electric current stem:[I] (<<t6-1>>) and displacement current stem:[I_\"D\"] (<<t6-19.1>>);\n\n[stem%unnumbered]\n++++\nI_\"tot\" = I + I_\"D\"\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "See <<iec60050-121,locality:item=\"121-11-45\">>.",
        "@language": "en"
      },
