isoiec80000:term-t6-15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "relative permittivity"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t6-15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "epsilon_\"r\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t6-15 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "6-15" ;
  skosxl:prefLabel isoiec80000:term-t6-15-0 ;
  skosxl:altLabel isoiec80000:sym-t6-15-0 ;
  skos:definition """for linear media, quotient of permittivity stem:[epsilon] (<<t6-14.2>>) and the electric constant stem:[epsilon_0] (<<t6-14.1>>);

[stem%unnumbered]
++++
epsilon_\"r\" = epsilon/epsilon_0
++++
"""@en ;
  skos:note """See <<iec60050-121,locality:item=\"121-12-13\">>."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-6 .