      "dcterms:identifier": "6-26.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-26.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-26.2-0"
        }
      ],
      "skos:definition": {
        "@value": "for linear media, proportionality constant between magnetic flux density stem:[bb(ii(B))] (<<t6-21>>) and magnetic field strength stem:[bb(ii(H))] (<<t6-25>>)\n\n[stem%unnumbered]\n++++\nbb(ii(B)) = mu bb(ii(H))\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Permeability stem:[mu] is a property of a medium. For an inhomogeneous medium, permeability stem:[mu] depends on position. For an isotropic medium, stem:[mu] is a scalar quantity; for an anisotropic medium, stem:[mu] is a second order tensor.\n\nSee <<iec60050-121,locality:item=\"121-12-28\">>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-H/m"
        },
        {
          "@id": "isoiec80000:unit-kg*m*s^(-2)*A^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-6"
      }
    }
