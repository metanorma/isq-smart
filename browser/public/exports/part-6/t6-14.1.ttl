isoiec80000:term-t6-14.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "electric constant"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t6-14.1-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "permittivity of vacuum"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t6-14.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "epsilon_0"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t6-14.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "6-14.1" ;
  skosxl:prefLabel isoiec80000:term-t6-14.1-0 ;
  skosxl:altLabel isoiec80000:term-t6-14.1-1 ;
  skosxl:altLabel isoiec80000:sym-t6-14.1-0 ;
  skos:definition """scalar quantity given by

[stem%unnumbered]
++++
epsilon_0 = 1/(mu_0 c_0^2)
++++

where stem:[mu_0] is the magnetic constant (<<t6-26.1>>) and stem:[c_0] is luminal speed (<<t6-35.2>>)
"""@en ;
  skos:note """See <<iec60050-121,locality:item=\"121-11-03\">>.

This quantity is considered to be constant in time.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-F/m ;
  isoiec80000:hasUnit isoiec80000:unit-kg^(-1)*m^(-3)*s^4*A^2 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-6 .