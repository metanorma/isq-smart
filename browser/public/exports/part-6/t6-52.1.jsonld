        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-52.1-0"
        }
      ],
      "skos:definition": {
        "@value": "quantity given by the inverse of impedance stem:[ul Z] (<<t6-51.1>>)\n\n[stem%unnumbered]\n++++\nul Y = 1/(ul Z)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[ul Y = G + \"j\"B], where stem:[G] is conductance (<<t6-52.2>>), stem:[B] is susceptance (<<t6-52.3>>) and stem:[\"j\"] is the imaginary unit.\n\n[stem%unnumbered]\n++++\nul Y = abs(Y)e^(-\"j\" varphi)\n++++\n\nSee <<iec60050-131,locality:item=\"131-12-51\">>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-S"
        },
        {
          "@id": "isoiec80000:unit-kg^(-1)*m^(-2)*s^3*A^2"
        }
      ],
