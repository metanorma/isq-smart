        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-2.1-1"
        }
      ],
      "skos:definition": {
        "@value": "additive scalar quantity attributed to any particle and, generally, any system of them, to characterize its electromagnetic interactions",
        "@language": "en"
      },
      "skos:note": {
        "@value": "To denote a point charge, stem:[q] is often used, as is done in this document.\n\nElectromagnetic interactions are Coulomb-Lorentz forces, see <<iec60050-121,locality:item=\"121-11-20\">>.\n\nThe coherent SI unit of charge is coulomb, stem:[\"unitsml(C)\"]. Another frequently used unit is the ampere-hour (stem:[\"unitsml(A*h)\"]) mentioned in <<iec60050-313,locality:item=\"313-01-16\">>, widely used for battery characteristics.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-C"
        },
        {
          "@id": "isoiec80000:unit-A*s"
        },
        {
          "@id": "isoiec80000:unit-s*A"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
