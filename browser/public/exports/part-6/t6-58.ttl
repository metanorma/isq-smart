isoiec80000:term-t6-58-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "power factor"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t6-58-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "lambda"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t6-58 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "6-58" ;
  skosxl:prefLabel isoiec80000:term-t6-58-0 ;
  skosxl:altLabel isoiec80000:sym-t6-58-0 ;
  skos:definition """quotient of the active power stem:[P] (<<t6-56>>) and apparent power stem:[S] (<<t6-57>>);

[stem%unnumbered]
++++
lambda=P/S
++++
"""@en ;
  skos:note """See <<iec60050-131,locality:item=\"131-11-46\">>."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-6 .