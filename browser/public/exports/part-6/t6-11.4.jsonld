      ],
      "skos:definition": {
        "@value": "negative of time derivative of protoflux (<<t6-22.2>>)\n\n[stem%unnumbered]\n++++\nU_i = -\"d\"/(\"d\"t) int_\"C\" bb(ii(A)) * \"d\"bb(ii(r))\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "If the integration path is closed, the loop voltage is\n\n[stem%unnumbered]\n++++\nU_\"l\" = -\"d\"/(\"d\"t) oint_\"C\" bb(ii(A)) * \"d\"bb(ii(r)) = - (\"d\"Phi)/(\"d\"t)\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-V"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-3)*A^(-1)"
        }
      ],
