isoiec80000:term-t6-21-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "magnetic flux density"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t6-21-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(B))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t6-21 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "6-21" ;
  skosxl:prefLabel isoiec80000:term-t6-21-0 ;
  skosxl:altLabel isoiec80000:sym-t6-21-0 ;
  skos:definition """vector quantity expressed by

[stem%unnumbered]
++++
bb(ii(F)) = q sf(ii(v)) xx bb(ii(B))
++++

where stem:[bb(ii(F))] is the force (<<iso80000-4>>) acting on a test particle with electric charge stem:[q] (<<t6-2.1>>) traversing a magnetic field with flux density stem:[bb(ii(B))], with velocity stem:[sf(ii(v))] (<<iso80000-3>>)
"""@en ;
  skos:note """The magnetic flux density depends on position.

See <<iec60050-121,locality:item=\"121-11-19\">>.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-T ;
  isoiec80000:hasUnit isoiec80000:unit-kg*s^(-2)*A^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-6 .