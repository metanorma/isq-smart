    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t6-11.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "6-11.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-11.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-11.1-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-11.1-1"
        }
      ],
      "skos:definition": {
        "@value": "scalar quantity expressed by\n\n[stem%unnumbered]\n++++\n-bb(\"grad\") V = bb(ii(E)) + (del bb(ii(A)))/(del t)\n++++\n\nwhere stem:[bb(ii(E))] is electric field strength (<<t6-10>>), stem:[bb(ii(A))] is magnetic vector potential (<<t6-32>>) and stem:[t] is time (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The electric potential is not unique since any constant scalar field quantity can be added to it without changing its gradient.\n\nThe electric potential, the electric field, and the magnetic vector potential depend on the position.\n\nSee <<iec60050-121,locality:item=\"121-11-25\">>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-V"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-3)*A^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-6"
      }
    }
