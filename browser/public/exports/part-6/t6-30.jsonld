      "skos:definition": {
        "@value": "vector quantity given by the product of the magnetic constant stem:[mu_0] (<<t6-26.1>>) and magnetic moment stem:[m] (<<t6-23>>)\n\n[stem%unnumbered]\n++++\nj_\"m\" = mu_0 m\n++++\n",
        "@language": "en"
      },
