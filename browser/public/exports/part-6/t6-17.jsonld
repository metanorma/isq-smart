        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-17-0"
        }
      ],
      "skos:definition": {
        "@value": "scalar quantity given by the integral\n\n[stem%unnumbered]\n++++\npsi = int_\"S\" bb(ii(D)) * e_\"n\" \"d\"A\n++++\n\nover a surface stem:[\"S\"], where stem:[bb(ii(D))] is electric flux density (<<t6-12>>) and stem:[e_\"n\"\"d\"A] is a vector surface element (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "See <<iec60050-121,locality:item=\"121-11-41\">>.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-C"
        },
        {
          "@id": "isoiec80000:unit-s*A"
        }
      ],
