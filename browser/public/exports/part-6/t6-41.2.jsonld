      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t6-41.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "6-41.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-41.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-41.2-0"
        }
      ],
      "skos:definition": {
        "@value": "for thin conducting loops (numbered stem:[m], stem:[n]), scalar quantity given by\n\n[stem%unnumbered]\n++++\nL_\"mn\" = Phi_\"m\"/I_\"n\"\n++++\n\nwhere stem:[Phi_\"m\"] is the total magnetic flux (<<t6-22.4>>) in a loop stem:[\"m\"], caused by the magnetic flux density (<<t6-21>>) produced by the electric current stem:[I_\"n\"] (<<t6-1>>) in another loop stem:[\"n\"]\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[stem%unnumbered]\n++++\nL_\"mn\" = L_\"nm\"\n++++\n\nSee <<iec60050-131,locality:item=\"131-12-36\">>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-H"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-2)*A^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-6"
      }
    }
  ]
