        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "magnetic tension",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-37.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "U_\"m\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t6-37.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "6-37.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-37.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-37.2-0"
        }
      ],
      "skos:definition": {
        "@value": "in a magnetic field strength, scalar quantity given by the line integral along a given curve stem:[\"C\"] from point stem:[\"a\"] to point stem:[\"b\"];\n\n[stem%unnumbered]\n++++\nU_\"m\" = int_(bb(ii(r))_\"a\"(\"C\"))^(bb(ii(r))_\"b\") bb(ii(H)) * \"d\"bb(ii(r))\n++++\n\nwhere stem:[bb(ii(H))] is magnetic field strength (<<t6-25>>) and stem:[bb(ii(r))] is position vector (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For an irrotational magnetic field strength, this quantity is equal to the magnetic potential difference.\n\nSee <<iec60050-121,locality:item=\"121-11-57\">>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-A"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-6"
      }
    }
  ]
