isoiec80000:term-t6-51.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "apparent impedance"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t6-51.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Z"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t6-51.5 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "6-51.5" ;
  skosxl:prefLabel isoiec80000:term-t6-51.5-0 ;
  skosxl:altLabel isoiec80000:sym-t6-51.5-0 ;
  skos:definition """scalar quantity given by the quotient of RMS voltage (<<t6-11.3>>) and RMS electric current (<<t6-1>>)"""@en ;
  skos:note """Under sinusoidal conditions, the apparent impedance is the modulus of the impedance, stem:[Z = abs(Z)].

See <<iec60050-131,locality:item=\"131-12-44\">>.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Ohm ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^2*s^(-3)*A^(-2) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-6 .