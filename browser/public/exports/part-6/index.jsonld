      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t6-48",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "6-48",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-48-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-48-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-48-0"
        }
      ],
      "skos:definition": {
        "@value": "scalar quantity given by the difference between the phase angle stem:[varphi_\"u\"] (<<iso80000-3>>) of the voltage (<<t6-11.3>>) and the phase angle stem:[varphi_\"i\"] of electric current (<<t6-1>>):\n\n[stem%unnumbered]\n++++\nvarphi = varphi_\"u\" - varphi_\"i\"\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "This concept can be generalized for any couple of periodic quantities.\n\nSee <<iec60050-103,locality:item=\"103-07-06\">>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-rad"
        },
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-49-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "electric current phasor",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-49-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "ul I",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t6-49",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "6-49",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-49-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-49-0"
        }
      ],
      "skos:definition": {
        "@value": "for a sinusoidal current, described by stem:[i = hat I e^(\"j\"(omega t-varphi))], complex quantity stem:[ul I = hat I e^(\"j\" varphi)],\n\nwhere stem:[hat I] is amplitude, stem:[omega] is angular frequency (<<iso80000-3>>), stem:[t] is time (<<iso80000-3>>), stem:[varphi] is the phase angle (<<iso80000-3>>), and stem:[\"j\"] is the imaginary unit (<<iso80000-2>>).\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "See <<iec60050-131,locality:item=\"131-11-26\">>.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-A"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-50-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "voltage phasor",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-50-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "electric tension phasor",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-50-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "ul U",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t6-50",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "6-50",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-50-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-50-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-50-0"
        }
      ],
      "skos:definition": {
        "@value": "for a sinusoidal voltage, described by stem:[u = hat U e^(\"j\"(omega t- varphi))], complex quantity\n\n[stem%unnumbered]\n++++\nul U = hat U e^(\"j\" varphi)\n++++\n\nwhere stem:[hat U] is amplitude, stem:[omega] is angular frequency (<<iso80000-3>>), stem:[t] is time (<<iso80000-3>>), stem:[varphi] is the phase angle (<<iso80000-3>>), and stem:[\"j\"] is the imaginary unit (<<iso80000-2>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "See <<iec60050-131,locality:item=\"131-11-26\">>.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-V"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-3)*A^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-51.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "impedance",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-51.1-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "complex impedance",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-51.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "ul Z",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t6-51.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "6-51.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-51.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-51.1-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-51.1-0"
        }
      ],
      "skos:definition": {
        "@value": "scalar quantity given by the quotient of voltage phasor stem:[ul U] (<<t6-50>>) and electric current phasor stem:[ul I] (<<t6-49>>)\n\n[stem%unnumbered]\n++++\nul Z = ul U // ul I\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[ul Z = R + \"j\"X], where stem:[R] is resistance (<<t6-51.3>>) and stem:[X] is reactance (<<t6-51.4>>).\n\nstem:[\"j\"] is the imaginary unit.\n\nstem:[ul Z = abs(Z)e^(\"j\"varphi)]\n\nSee <<iec60050-131,locality:item=\"131-12-43\">>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Ohm"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-3)*A^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-51.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "impedance of vacuum",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-51.2-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "wave impedance in vacuum",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-51.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Z_0",
