      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t6-52.5",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "6-52.5",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-52.5-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-52.5-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of RMS electric current (<<t6-1>>) and RMS voltage (<<t6-11.3>>)",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Under sinusoidal conditions, the apparent admittance is the modulus of the admittance.(((admittance,modulus of)))\n\nSee <<iec60050-131,locality:item=\"131-12-52\">>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-S"
        },
        {
          "@id": "isoiec80000:unit-kg^(-1)*m^(-2)*s^3*A^2"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-53-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "quality factor",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-53-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Q",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t6-53",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "6-53",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-53-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-53-0"
        }
      ],
      "skos:definition": {
        "@value": "for non-radiating systems, where stem:[ul Z = R + \"j\"X], scalar quantity given by\n\n[stem%unnumbered]\n++++\nQ=(abs X)/R\n++++\n\nwhere stem:[ul Z] is impedance (<<t6-51.1>>), stem:[R] is resistance (<<t6-51.3>>), and stem:[X] is reactance (<<t6-51.4>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For a linear non-radiating two-terminal element or circuit under sinusoidal conditions, the quality factor is the ratio of the absolute value of the reactive power to the active power. See <<iec60050-151,locality:item=\"151-15-45\">>.\n\nFor a resonant system, the quality actor, stem:[Q] is defined as stem:[2pi] multiplied by the quotient of stored energy and dissipated energy. See <<iec60050-151,locality:item=\"151-15-46\">>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
