      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-51.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-51.2-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-51.2-0"
        }
      ],
      "skos:definition": {
        "@value": "scalar quantity given by the quotient of the magnitude of the electric field strength (<<t6-10>>) and that of the magnetic field strength (<<t6-25>>) of electromagnetic waves in vacuum",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The impedance of vacuum is equal to stem:[c_0*mu_0]. This quantity is considered to be constant in time.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-V/A"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-3)*A^(-2)"
        }
      ],
