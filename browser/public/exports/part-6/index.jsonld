          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-46-0"
        }
      ],
      "skos:definition": {
        "@value": "property of a resistive element, equal to the scalar quantity given by the quotient of voltage stem:[u] (<<t6-11.3>>) and electric current stem:[i] (<<t6-1>>)\n\n[stem%unnumbered]\n++++\nR=u/i\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For alternating current, see <<t6-51.2>>.\n\nSee <<iec60050-131,locality:item=\"131-12-04\">>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Ohm"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-3)*A^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
