    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t6-51.5",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "6-51.5",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-51.5-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-51.5-0"
        }
      ],
      "skos:definition": {
        "@value": "scalar quantity given by the quotient of RMS voltage (<<t6-11.3>>) and RMS electric current (<<t6-1>>)",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Under sinusoidal conditions, the apparent impedance is the modulus of the impedance, stem:[Z = abs(Z)].\n\nSee <<iec60050-131,locality:item=\"131-12-44\">>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Ohm"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-3)*A^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-52.1-0",
