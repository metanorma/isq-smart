        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "conductance",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-47-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "G",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t6-47",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "6-47",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-47-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-47-0"
        }
      ],
      "skos:definition": {
        "@value": "property of a resistive element, equal to the scalar quantity given by the inverse of its resistance stem:[R] (<<t6-46>>)\n\n[stem%unnumbered]\n++++\nG=1/R\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For alternating current, see <<t6-52.3>>.\n\nSee <<iec60050-131,locality:item=\"131-12-06\">>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-S"
        },
        {
          "@id": "isoiec80000:unit-kg^(-1)*m^(-2)*s^3*A^2"
        }
      ],
