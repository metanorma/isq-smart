          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-44-0"
        }
      ],
      "skos:definition": {
        "@value": "scalar quantity given by the inverse of conductivity stem:[sigma] (<<t6-43>>)\n\n[stem%unnumbered]\n++++\nrho = 1/sigma\n++++\n",
        "@language": "en"
