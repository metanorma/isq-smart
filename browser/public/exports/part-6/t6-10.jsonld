        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "electric field strength",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-10-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "bb(ii(E))",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t6-10",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "6-10",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-10-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-10-0"
        }
      ],
      "skos:definition": {
        "@value": "additive vector field quantity that exerts on any charged particle located at position stem:[bb(ii(r))] a force stem:[bb(ii(F))] (<<iso80000-4>>) equal to the product of stem:[E] and electric charge stem:[q] (<<t6-2.1>>) of the particle, thus:\n\n[stem%unnumbered]\n++++\nbb(ii(E))(bb(ii(r))) = bb(ii(F))/q\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "See <<iec60050-121,locality:item=\"121-11-18\">>.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-V/m"
        },
        {
          "@id": "isoiec80000:unit-kg*m*s^(-3)*A^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-6"
      }
    }
  ]
