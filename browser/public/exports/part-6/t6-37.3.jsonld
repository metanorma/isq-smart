      "dcterms:identifier": "6-37.3",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-37.3-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-37.3-0"
        }
      ],
      "skos:definition": {
        "@value": "scalar quantity given by the line integral along a closed curve stem:[\"C\"];\n\n[stem%unnumbered]\n++++\nF_\"m\" = oint_\"C\" bb(ii(H)) * \"d\"bb(ii(r))\n++++\n\nwhere stem:[bb(ii(H))] is magnetic field strength (<<t6-25>>) and stem:[bb(ii(r))] is position vector (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Compare to the remark in <<t6-36>>.\n\nSee <<iec60050-121,locality:item=\"121-11-60\">>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-A"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-6"
      }
    }
  ]
