    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t6-6",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "6-6",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-6-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-6-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-6-0"
        }
      ],
      "skos:definition": {
        "@value": "vector quantity given by\n\n[stem%unnumbered]\n++++\np = q(r_\"+\" - r_\"-\")\n++++\n\nwhere stem:[r_\"+\"] and stem:[r_\"-\"] are the position vectors (<<iso80000-3>>) of the carriers of electric charges stem:[q] and stem:[-q] (<<t6-2.1>>), respectively\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The electric dipole moment of a substance within a domain is the vector sum of electric dipole moments of all electric dipoles contained in the domain.\n\nSee <<iec60050-121,locality:item=\"121-11-35\";and!locality:item=\"121-11-36\">>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-C*m"
        },
        {
          "@id": "isoiec80000:unit-m*s*A"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-6"
      }
    }
  ]
