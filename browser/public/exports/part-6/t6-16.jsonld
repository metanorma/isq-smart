      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t6-16",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "6-16",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t6-16-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t6-16-0"
        }
      ],
      "skos:definition": {
        "@value": "for linear media, scalar quantity expressed by\n\n[stem%unnumbered]\n++++\nbb(ii(P)) = epsilon_0 chi bb(ii(E))\n++++\n\nwhere stem:[bb(ii(P))] is electric polarization (<<t6-7>>), stem:[epsilon_0] is the electric constant (<<t6-14.1>>), and stem:[bb(ii(E))] is electric field strength (<<t6-10>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[chi = epsilon_r - 1] where stem:[epsilon_r] is relative permittivity (<<t6-15>>)\n\nElectric susceptibility stem:[chi] is a property of a medium. For an inhomogeneous medium, electric susceptibility stem:[chi] depends on position.\n\nFor an isotropic medium, stem:[chi] is a scalar quantity; for an anisotropic medium, stem:[chi] is a second order tensor.\n\nSee <<iec60050-121,locality:item=\"121-12-19\">>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-6"
      }
    }
  ]
