@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

isoiec80000:part-2-15 a smart:PublicationDocument ;
  dcterms:title "Part 2-15"@en ;
  dcterms:identifier "ISO 80000-2-15" ;
  smart:hasPublicationType smart:internationalStandard ;
  smart:hasBindingnessType smart:normative .

isoiec80000:term-t2-15.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "imaginary unit"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-15.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"i\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-15.1-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"j\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-15.1 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-15.1" ;
  skosxl:prefLabel isoiec80000:term-t2-15.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-15.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-15.1-1 ;
  skos:definition """imaginary unit"""@en ;
  skos:note """stem:[\"i\"^2 = \"j\"^2 = -1]

stem:[\"i\"] is used in mathematics and in physics,

stem:[\"j\"] is used in electrotechnology.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-15 .

isoiec80000:term-t2-15.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "real part"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-15.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"Re \"z"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-15.2 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-15.2" ;
  skosxl:prefLabel isoiec80000:term-t2-15.2-0 ;
  skosxl:altLabel isoiec80000:sym-t2-15.2-0 ;
  skos:definition """real part of stem:[z]"""@en ;
  skos:note """If stem:[z = x + \"i \"y], where stem:[x] and stem:[y] are real numbers, then

stem:[x = \"Re \"z] and stem:[y = \"Im \"z].
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-15 .

isoiec80000:term-t2-15.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "imaginary part"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-15.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"Im \"z"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-15.3 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-15.3" ;
  skosxl:prefLabel isoiec80000:term-t2-15.3-0 ;
  skosxl:altLabel isoiec80000:sym-t2-15.3-0 ;
  skos:definition """imaginary part of stem:[z]"""@en ;
  skos:note """See <<t2-15.2>>."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-15 .

isoiec80000:term-t2-15.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "modulus"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-15.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "abs(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-15.4 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-15.4" ;
  skosxl:prefLabel isoiec80000:term-t2-15.4-0 ;
  skosxl:altLabel isoiec80000:sym-t2-15.4-0 ;
  skos:definition """modulus of stem:[z]"""@en ;
  skos:note """stem:[abs(z) = sqrt(x^2 +y^2)]

where stem:[x = \"Re \"z] and stem:[y = \"Im \"z].

The symbol stem:[abs] is also used for cardinality of a set (see <<t2-6.5>>), absolute value of a real number (see <<t2-10.16>>), and magnitude of a vector (see <<t2-18.4>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-15 .

isoiec80000:term-t2-15.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "argument"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-15.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"arg \"z"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-15.5 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-15.5" ;
  skosxl:prefLabel isoiec80000:term-t2-15.5-0 ;
  skosxl:altLabel isoiec80000:sym-t2-15.5-0 ;
  skos:definition """argument of stem:[z]"""@en ;
  skos:note """If stem:[z = r \"e\"^(i varphi)], where stem:[r = abs(z)] and stem:[-pi < varphi <= pi], then stem:[varphi = \"arg \"z].

It holds stem:[\"Re \"z = r \" cos \"varphi] and stem:[\"Im \"z = r\" sin \"varphi].
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-15 .

isoiec80000:term-t2-15.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "complex conjugate"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-15.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bar z"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-15.6-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "z**"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-15.6 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-15.6" ;
  skosxl:prefLabel isoiec80000:term-t2-15.6-0 ;
  skosxl:altLabel isoiec80000:sym-t2-15.6-0 ;
  skosxl:altLabel isoiec80000:sym-t2-15.6-1 ;
  skos:definition """complex conjugate of stem:[z]"""@en ;
  skos:note """stem:[bar z = \"Re \"z - \"i Im \"z]

stem:[bar z] is mainly used in mathematics,

stem:[z**] is mainly used in physics and engineering.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-15 .

isoiec80000:term-t2-15.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "signum"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-15.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"sgn \"z"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-15.7 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-15.7" ;
  skosxl:prefLabel isoiec80000:term-t2-15.7-0 ;
  skosxl:altLabel isoiec80000:sym-t2-15.7-0 ;
  skos:definition """signum stem:[z]"""@en ;
  skos:note """stem:[\"sgn \"z = z // abs(z) = \"exp \"(\"i arg \"z)] (stem:[z != 0])

stem:[\"sgn \"z = 0] for stem:[z = 0]

See also item <<t2-10.13>>. Sometimes stem:[\"sgn \"0] is left undefined.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-15 .
