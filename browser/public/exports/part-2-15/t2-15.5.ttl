isoiec80000:term-t2-15.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "argument"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-15.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"arg \"z"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-15.5 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-15.5" ;
  skosxl:prefLabel isoiec80000:term-t2-15.5-0 ;
  skosxl:altLabel isoiec80000:sym-t2-15.5-0 ;
  skos:definition """argument of stem:[z]"""@en ;
  skos:note """If stem:[z = r \"e\"^(i varphi)], where stem:[r = abs(z)] and stem:[-pi < varphi <= pi], then stem:[varphi = \"arg \"z].

It holds stem:[\"Re \"z = r \" cos \"varphi] and stem:[\"Im \"z = r\" sin \"varphi].
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-15 .