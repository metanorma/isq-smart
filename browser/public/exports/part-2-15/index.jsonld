  "@graph": [
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-15.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "imaginary unit",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-15.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "\"i\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-15.1-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "\"j\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t2-15.1",
      "@type": [
        "isoiec80000:MathConcept",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "2-15.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-15.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-15.1-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-15.1-1"
        }
      ],
      "skos:definition": {
        "@value": "imaginary unit",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[\"i\"^2 = \"j\"^2 = -1]\n\nstem:[\"i\"] is used in mathematics and in physics,\n\nstem:[\"j\"] is used in electrotechnology.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-2-15"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-15.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "real part",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-15.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "\"Re \"z",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t2-15.2",
      "@type": [
        "isoiec80000:MathConcept",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "2-15.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-15.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-15.2-0"
        }
      ],
      "skos:definition": {
        "@value": "real part of stem:[z]",
        "@language": "en"
      },
      "skos:note": {
        "@value": "If stem:[z = x + \"i \"y], where stem:[x] and stem:[y] are real numbers, then\n\nstem:[x = \"Re \"z] and stem:[y = \"Im \"z].\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-2-15"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-15.3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "imaginary part",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-15.3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "\"Im \"z",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t2-15.3",
      "@type": [
        "isoiec80000:MathConcept",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "2-15.3",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-15.3-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-15.3-0"
        }
      ],
      "skos:definition": {
        "@value": "imaginary part of stem:[z]",
        "@language": "en"
      },
      "skos:note": {
        "@value": "See <<t2-15.2>>.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-2-15"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-15.4-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "modulus",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-15.4-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "abs(z)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t2-15.4",
      "@type": [
        "isoiec80000:MathConcept",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "2-15.4",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-15.4-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-15.4-0"
        }
      ],
      "skos:definition": {
        "@value": "modulus of stem:[z]",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[abs(z) = sqrt(x^2 +y^2)]\n\nwhere stem:[x = \"Re \"z] and stem:[y = \"Im \"z].\n\nThe symbol stem:[abs] is also used for cardinality of a set (see <<t2-6.5>>), absolute value of a real number (see <<t2-10.16>>), and magnitude of a vector (see <<t2-18.4>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-2-15"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-15.5-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "argument",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-15.5-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "\"arg \"z",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t2-15.5",
      "@type": [
        "isoiec80000:MathConcept",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "2-15.5",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-15.5-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-15.5-0"
        }
      ],
      "skos:definition": {
        "@value": "argument of stem:[z]",
        "@language": "en"
      },
      "skos:note": {
        "@value": "If stem:[z = r \"e\"^(i varphi)], where stem:[r = abs(z)] and stem:[-pi < varphi <= pi], then stem:[varphi = \"arg \"z].\n\nIt holds stem:[\"Re \"z = r \" cos \"varphi] and stem:[\"Im \"z = r\" sin \"varphi].\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-2-15"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-15.6-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "complex conjugate",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-15.6-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "bar z",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-15.6-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "z**",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t2-15.6",
      "@type": [
        "isoiec80000:MathConcept",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "2-15.6",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-15.6-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-15.6-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-15.6-1"
        }
      ],
      "skos:definition": {
        "@value": "complex conjugate of stem:[z]",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[bar z = \"Re \"z - \"i Im \"z]\n\nstem:[bar z] is mainly used in mathematics,\n\nstem:[z**] is mainly used in physics and engineering.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-2-15"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-15.7-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "signum",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-15.7-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "\"sgn \"z",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t2-15.7",
      "@type": [
        "isoiec80000:MathConcept",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "2-15.7",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t2-15.7-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-15.7-0"
        }
      ],
      "skos:definition": {
        "@value": "signum stem:[z]",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[\"sgn \"z = z // abs(z) = \"exp \"(\"i arg \"z)] (stem:[z != 0])\n\nstem:[\"sgn \"z = 0] for stem:[z = 0]\n\nSee also item <<t2-10.13>>. Sometimes stem:[\"sgn \"0] is left undefined.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-2-15"
      }
    }
  ]
}