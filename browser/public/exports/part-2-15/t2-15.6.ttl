isoiec80000:term-t2-15.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "complex conjugate"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-15.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bar z"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-15.6-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "z**"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-15.6 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-15.6" ;
  skosxl:prefLabel isoiec80000:term-t2-15.6-0 ;
  skosxl:altLabel isoiec80000:sym-t2-15.6-0 ;
  skosxl:altLabel isoiec80000:sym-t2-15.6-1 ;
  skos:definition """complex conjugate of stem:[z]"""@en ;
  skos:note """stem:[bar z = \"Re \"z - \"i Im \"z]

stem:[bar z] is mainly used in mathematics,

stem:[z**] is mainly used in physics and engineering.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-15 .