      "skos:definition": {
        "@value": "integer part of the real number stem:[a]",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[\"int \"a = \"sgn \"a * floor(abs(a))]\n\n[example]\n====\nstem:[\"int\"(2,4) = 2]\n\nstem:[\"int\"(-2,4) = -2]\n====\n",
        "@language": "en"
      },
