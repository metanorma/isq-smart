isoiec80000:term-t2-10.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "product of"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "prod_(i=1)^n a_i"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.8 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.8" ;
  skosxl:prefLabel isoiec80000:term-t2-10.8-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.8-0 ;
  skos:definition """product of stem:[a_1, a_2, ..., a_n]"""@en ;
  skos:note """The notations stem:[prod_(i=1)^n a_i], stem:[prod_i a_i], stem:[prod_i a_i] and stem:[prod a_i] are also used."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .