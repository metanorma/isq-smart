isoiec80000:t2-10.14 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.14" ;
  skosxl:prefLabel isoiec80000:term-t2-10.14-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.14-0 ;
  skos:definition """infimum of stem:[M]"""@en ;
