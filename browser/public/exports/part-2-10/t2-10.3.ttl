isoiec80000:term-t2-10.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "plus or minus"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a +- b"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.3 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.3" ;
  skosxl:prefLabel isoiec80000:term-t2-10.3-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.3-0 ;
  skos:definition """stem:[a] plus or minus stem:[b]"""@en ;
  skos:note """This is a combination of two values into one expression."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .