isoiec80000:term-t2-10.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "magnitude"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "abs(a)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.16 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.16" ;
  skosxl:prefLabel isoiec80000:term-t2-10.16-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.16-0 ;
  skos:definition """magnitude of stem:[a]"""@en ;
  skos:note """The notation stem:[\"abs \"a] is also used.

The symbol stem:[abs] is also used for cardinality of a set (see <<t2-6.5>>), modulus of a complex number (<<t2-15.4>>) and magnitude of a vector (see <<t2-18.4>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .