isoiec80000:term-t2-10.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "minus"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a - b"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.2 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.2" ;
  skosxl:prefLabel isoiec80000:term-t2-10.2-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.2-0 ;
  skos:definition """stem:[a] minus stem:[b]"""@en ;
  skos:note """This operation is named subtraction. The symbol - is the subtraction symbol."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .