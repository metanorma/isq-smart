isoiec80000:term-t2-10.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "plus"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a + b"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.1 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.1" ;
  skosxl:prefLabel isoiec80000:term-t2-10.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.1-0 ;
  skos:definition """stem:[a] plus stem:[b]"""@en ;
  skos:note """This operation is named addition. The symbol + is the addition symbol."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .