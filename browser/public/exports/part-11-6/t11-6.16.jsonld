    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-6.16",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-6.16",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.16-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.16-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.16-1"
        }
      ],
      "skos:definition": {
        "@value": "quotient of mechanical work and frictional and diffusion energy loss in viscous flow of fluids in pipes, expressed by\n\nstem:[Be** = (Delta pl^2)/(eta D)]; where\n\nstem:[Delta p]:: is drop of pressure (<<iso80000-4>>) along a pipe or channel,\nstem:[l]:: is length (<<iso80000-3>>) of channel,\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>) of the fluid, and\nstem:[D]:: is diffusion coefficient (<<iso80000-9>>), mass diffusivity\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "A similar quantity exists for heat transfer (<<t11-5.9>>).",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-6"
      }
    }
  ]
