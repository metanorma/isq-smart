isoiec80000:term-t11-6.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Stanton number <mass transfer>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-6.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "St**"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-6.5 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-6.5" ;
  skosxl:prefLabel isoiec80000:term-t11-6.5-0 ;
  skosxl:altLabel isoiec80000:sym-t11-6.5-0 ;
  skos:definition """relation between mass transfer perpendicular to the surface of a fluid flow and mass transfer parallel to the surface in a free surface flow, expressed by

stem:[St** = k'//(rho v)]; where

stem:[k']:: is mass flux density stem:[q_m//A] through the surface, where
stem:[q_m]::: is mass flow rate (<<iso80000-4>>), and
stem:[A]::: is area (<<iso80000-3>>),
stem:[rho]:: is mass density (<<iso80000-4>>), and
stem:[v]:: is speed (<<iso80000-3>>)
"""@en ;
  skos:note """The Stanton number for mass transfer is also given by stem:[St** = N]stem:[u** // Pe**]; where

stem:[N u**]:: is the Nusselt number for mass transfer (<<t11-6.4>>), and +
stem:[Pe**]:: is the Péclet number for mass transfer (<<t11-6.2>>).

Compare with <<t11-5.7>>, the Stanton number for heat transfer.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-6 .