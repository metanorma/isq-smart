        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Lockhart-Martinelli parameter",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.15-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Lp",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-6.15",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-6.15",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.15-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.15-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of mass flow rates multiplied by the square root of density in a two-phase flow, expressed by\n\nstem:[Lp = (dot m_\"1\")/(dot m_\"g\") sqrt(rho_\"g\"/rho_\"l\")]; where\n\nstem:[dot m_\"l\" = q_\"m\"]:: is liquid phase mass flow rate (<<iso80000-4>>),\nstem:[dot m_\"g\"]:: is gas phase mass flow rate,\nstem:[rho_\"g\"]:: is gas density (<<iso80000-4>>), and\nstem:[rho_\"l\"]:: is liquid density\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Lockhart-Martinelli parameter is used, for example, in boiling or condensing.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-6"
      }
    }
  ]
