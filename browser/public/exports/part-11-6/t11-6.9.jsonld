      ],
      "skosxl:literalForm": {
        "@value": "Biot number <mass transfer>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.9-0",
