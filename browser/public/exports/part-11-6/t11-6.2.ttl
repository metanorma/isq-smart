isoiec80000:term-t11-6.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Péclet number <mass transfer>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t11-6.2-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bodenstein number <mass transfer>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-6.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Pe**"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-6.2-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bd"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-6.2-2 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bod"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-6.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-6.2" ;
  skosxl:prefLabel isoiec80000:term-t11-6.2-0 ;
  skosxl:altLabel isoiec80000:term-t11-6.2-1 ;
  skosxl:altLabel isoiec80000:sym-t11-6.2-0 ;
  skosxl:altLabel isoiec80000:sym-t11-6.2-1 ;
  skosxl:altLabel isoiec80000:sym-t11-6.2-2 ;
  skos:definition """relation between advective mass transfer rate and longitudinal diffusive mass transfer rate for mass transfer in reactors, expressed by

stem:[Pe** = vl//D]; where

stem:[v]:: is speed (<<iso80000-3>>),
stem:[l]:: is characteristic length (<<iso80000-3>>), and
stem:[D]:: is diffusion coefficient (<<iso80000-9>>)
"""@en ;
  skos:note """The Péclet number for mass transfer is also given by

stem:[Pe** = Pe * Le = Re * Sc]; where

stem:[Pe]:: is the Péclet number for heat transfer,
stem:[Le]:: is the Lewis number (<<t11-7.3>>),
stem:[Re]:: is the Reynolds number (<<t11-4.1>>), and
stem:[Sc]:: is the Schmidt number (<<t11-7.2>>).

Compare with <<t11-5.2>>, the Péclet number for heat transfer.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-6 .