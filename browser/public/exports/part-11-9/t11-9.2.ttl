isoiec80000:term-t11-9.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Landau-Ginzburg number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-9.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "kappa"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-9.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-9.2" ;
  skosxl:prefLabel isoiec80000:term-t11-9.2-0 ;
  skosxl:altLabel isoiec80000:sym-t11-9.2-0 ;
  skos:definition """quotient of penetration depth of a magnetic field into a superconductor and the coherence length of thermodynamic fluctuations within a superconducting phase in a material at zero thermodynamic temperature, expressed by

stem:[kappa = lambda_\"L\" // (xi sqrt(2))]; where

stem:[lambda_\"L\"]:: is London penetration depth (<<iso80000-12>>), and +
stem:[xi]:: is coherence length (<<iso80000-12>>)
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-9 .