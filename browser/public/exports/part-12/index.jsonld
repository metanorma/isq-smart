          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-32.2-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-32.2-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-32.2-2"
        }
      ],
      "skos:definition": {
        "@value": "time constant (<<iso80000-3>>) for recombination or trapping of minority charge carriers in semiconductors",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Indices \"stem:[\"n\"]\" and \"stem:[\"p\"]\" denote negative and positive charge carriers, respectively. Positive charge carriers can also be holes.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-s"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-12"
      }
    },
