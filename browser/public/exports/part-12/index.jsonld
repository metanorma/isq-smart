        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-33-2"
        }
      ],
      "skos:definition": {
        "@value": "square root of the product of diffusion coefficient (<<iso80000-10>>) and lifetime (<<iso80000-10>>)",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The diffusion length can be expressed by:\n\n[stem%unnumbered]\n++++\nL = sqrt(D tau)\n++++\n\nwhere stem:[D] is the diffusion coefficient (<<iso80000-9>>) and stem:[tau] is lifetime (<<iso80000-3>>).\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-12"
      }
    },
    {
