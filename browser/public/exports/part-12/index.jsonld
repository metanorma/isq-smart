    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t12-33",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "12-33",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-33-0"
      },
      "skosxl:altLabel": [
