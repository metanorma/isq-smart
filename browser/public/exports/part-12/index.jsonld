        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t12-8",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "12-8",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-8-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-8-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-8-1"
        }
      ],
      "skos:definition": {
        "@value": "factor by which the intensity of a diffraction line is reduced because of the lattice vibrations",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[D] is sometimes expressed as stem:[D = \"exp\"(-2W)]; in Mössbauer spectroscopy, it is also called the stem:[f] factor and denoted by stem:[f].",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-12"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-9.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "angular wavenumber",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-9.1-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "angular repetency <condensed matter physics>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-9.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "k",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-9.1-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "(q)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t12-9.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "12-9.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-9.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-9.1-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-9.1-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-9.1-1"
        }
      ],
      "skos:definition": {
        "@value": "quotient of momentum (<<iso80000-4>>) and the reduced Planck constant (<<iso80000-1>>)",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The corresponding vector (<<iso80000-2>>) quantity is called wave vector (<<iso80000-3>>), expressed by:\n\n[stem%unnumbered]\n++++\nbb(ii(k)) = bb(ii(p))/&#8463;\n++++\n\nwhere stem:[bb(ii(p))] is the momentum (<<iso80000-4>>) of quasi free electrons in an electron gas, and stem:[&#8463;] is the reduced Planck constant (<<iso80000-1>>); for phonons, its magnitude is\n\n[stem%unnumbered]\n++++\nk = (2pi)/lambda\n++++\n\nwhere stem:[lambda] is the wavelength (<<iso80000-3>>) of the lattice vibrations.\n\nWhen a distinction is needed between stem:[k] and the symbol for the Boltzmann constant (<<iso80000-1>>), stem:[k_\"B\"] can be used for the latter.\n\nWhen a distinction is needed, stem:[q] should be used for phonons, and stem:[k] for particles such as electrons and neutrons.\n\nThe method of cut-off must be specified.\n\nIn condensed matter physics, angular wavenumber is often called wavenumber.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-12"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-9.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Fermi angular wavenumber",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-9.2-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Fermi angular repetency",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-9.2-0",
