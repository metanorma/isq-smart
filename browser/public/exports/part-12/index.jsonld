      "skos:definition": {
        "@value": "angular wavenumber (<<t12-9.1>>) of electrons in states on the Fermi sphere",
        "@language": "en"
      },
      "skos:note": {
        "@value": "In condensed matter physics, angular wavenumber is often called wavenumber.",
        "@language": "en"
      },
