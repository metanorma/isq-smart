    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t12-27.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "12-27.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-27.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-27.1-0"
        }
      ],
      "skos:definition": {
        "@value": "in a metal, highest occupied energy level at zero thermodynamic temperature (<<iso80000-5>>), where energy level means the energy (<<iso80000-5>>) of an electron in the interior of a substance",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The term \"energy level\" is often used for the state of the electron, not only for its energy.\n\nAt stem:[T = 0 \"unitsml(K)\"], stem:[E_\"F\"] is equal to the chemical potential per electron.\n\nIn condensed matter physics, the reference level for the energy is sometimes chosen so that, for instance, stem:[E_\"F\" = 0].\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-J"
        },
        {
          "@id": "isoiec80000:unit-eV"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-2)"
        }
      ],
