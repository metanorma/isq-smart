        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t12-16",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "12-16",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-16-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-16-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-16-1"
        }
      ],
      "skos:definition": {
        "@value": "quantity given by the differential quotient with respect to energy:\n\n[stem%unnumbered]\n++++\nn_\"E\"(E) = (\"d\"n(E))/(\"d\"E)\n++++\n\nwhere stem:[n_\"E\"(E)] is the total number of one-electron states per volume (<<iso80000-3>>) with energy less than stem:[E] (<<iso80000-5>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Density of states refers to electrons or other entities, e.g. phonons. It may be normalized in other ways instead of with respect to volume, e.g. with respect to amount of substance.\n\nSee also <<t12-12>>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-J^(-1)*m^(-3)"
        },
        {
          "@id": "isoiec80000:unit-eV^(-1)*m^(-3)"
        },
        {
          "@id": "isoiec80000:unit-kg^(-1)*m^(-5)*s^2"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-12"
      }
    }
  ]
