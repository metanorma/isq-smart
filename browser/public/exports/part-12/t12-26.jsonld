      ],
      "skos:definition": {
        "@value": "parameter in the expression for the thermionic emission current density stem:[J] (<<iec80000-6>>) for a metal in terms of the thermodynamic temperature stem:[T] (<<iso80000-5>>) and work function stem:[phi], (<<t12-24.1>>):\n\n[stem%unnumbered]\n++++\nJ = AT^2 \"exp\" (phi/(kT))\n++++\n\nwhere stem:[k] is the Boltzmann constant (<<iso80000-1>>)\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-A*m^(-2)*K^(-2)"
        }
      ],
