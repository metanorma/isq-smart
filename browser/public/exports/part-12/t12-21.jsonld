        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Seebeck coefficient (for substances stem:[\"a\"] and stem:[\"b\"])",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-21-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "S_\"ab\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t12-21",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "12-21",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-21-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-21-0"
        }
      ],
      "skos:definition": {
        "@value": "differential quotient of thermoelectric voltage with respect to thermodynamic temperature:\n\n[stem%unnumbered]\n++++\nS_\"ab\" = (\"d\"E_\"ab\")/(\"d\"T)\n++++\n\nwhere stem:[E_\"ab\"] is the thermoelectric voltage between substances stem:[\"a\"] and stem:[\"b\"] (<<t12-20>>) and stem:[T] is thermodynamic temperature (<<iso80000-5>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "This term is also called \"thermoelectric power\".",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-V/K"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-3)"
        },
        {
          "@id": "isoiec80000:unit-A^(-1)*K^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-12"
      }
    }
  ]
