isoiec80000:t12-35.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "12-35.2" ;
  skosxl:prefLabel isoiec80000:term-t12-35.2-0 ;
  skosxl:altLabel isoiec80000:sym-t12-35.2-0 ;
  skos:definition """critical thermodynamic temperature (<<iso80000-5>>) of an antiferromagnet"""@en ;
