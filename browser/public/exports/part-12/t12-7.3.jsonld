        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-7.3-0"
        }
      ],
      "skos:definition": {
        "@value": "difference between the position vector (<<iso80000-3>>) of an ion or atom and its position vector in equilibrium",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The displacement vector can be expressed by:\n\n[stem%unnumbered]\n++++\nbb(ii(u)) = bb(ii(R)) - bb(ii(R))_0\n++++\n\nwhere stem:[bb(ii(R))] is particle position vector (<<t12-7.1>>) and stem:[bb(ii(R))_0] is position vector of an ion or atom in equilibrium (<<t12-7.2>>).\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m"
        }
      ],
