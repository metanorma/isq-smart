isoiec80000:term-t12-35.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "superconduction transition temperature"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t12-35.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "T_\"c\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t12-35.3 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "12-35.3" ;
  skosxl:prefLabel isoiec80000:term-t12-35.3-0 ;
  skosxl:altLabel isoiec80000:sym-t12-35.3-0 ;
  skos:definition """critical thermodynamic temperature (<<iso80000-5>>) of a superconductor"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-K ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-12 .