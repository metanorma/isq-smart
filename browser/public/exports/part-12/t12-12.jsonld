    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t12-12",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "12-12",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-12-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-12-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the number of vibrational modes in an infinitesimal interval of angular frequency (<<iso80000-3>>), and the product of the width of that interval and volume (<<iso80000-3>>)",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[stem%unnumbered]\n++++\ng(omega) = n_omega = (\"d\"n(omega))/(\"d\"omega)\n++++\n\nwhere stem:[n(omega)] is the total number of vibrational modes per volume with angular frequency less than stem:[omega].\n\nThe density of states may also be normalized in other ways instead of with respect to volume.\n\nSee also <<t12-16>>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^(-3)*s"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-12"
      }
    }
  ]
