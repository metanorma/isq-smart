  skosxl:literalForm "superconductor energy gap"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t12-37-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "ii(Delta)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t12-37 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "12-37" ;
  skosxl:prefLabel isoiec80000:term-t12-37-0 ;
  skosxl:altLabel isoiec80000:sym-t12-37-0 ;
  skos:definition """width of the forbidden energy band (<<t12-24.2>>) in a superconductor"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-J ;
  isoiec80000:hasUnit isoiec80000:unit-eV ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^2*s^(-2) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-12 .

isoiec80000:term-t12-38.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "London penetration depth"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t12-38.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "lambda_\"L\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t12-38.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "12-38.1" ;
  skosxl:prefLabel isoiec80000:term-t12-38.1-0 ;
  skosxl:altLabel isoiec80000:sym-t12-38.1-0 ;
  skos:definition """distance (<<iso80000-3>>) a magnetic field penetrates the plane surface of a semi-finite superconductor according to the expression:

[stem%unnumbered]
++++
B(x) = B(0) \"exp\" ((-x)/(lambda_\"L\"))
++++

where stem:[B] is magnetic flux density (<<iec80000-6>>) and stem:[x] is distance (<<iso80000-3>>) from the surface
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-m ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-12 .

isoiec80000:term-t12-38.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "coherence length"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t12-38.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "xi"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t12-38.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "12-38.2" ;
  skosxl:prefLabel isoiec80000:term-t12-38.2-0 ;
  skosxl:altLabel isoiec80000:sym-t12-38.2-0 ;
  skos:definition """distance (<<iso80000-3>>) in a superconductor over which the effect of a perturbation is appreciable at zero thermodynamic temperature (<<iso80000-5>>)"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-m ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-12 .
