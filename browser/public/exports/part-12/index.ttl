  skosxl:prefLabel isoiec80000:term-t12-35.1-0 ;
  skosxl:altLabel isoiec80000:sym-t12-35.1-0 ;
  skos:definition """critical thermodynamic temperature (<<iso80000-5>>) of a ferromagnet"""@en ;
  skos:note """stem:[T_\"cr\"] is used for critical thermodynamic temperature in general."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-K ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-12 .

