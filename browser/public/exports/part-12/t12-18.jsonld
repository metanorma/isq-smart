    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t12-18",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "12-18",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-18-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-18-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of thermal conductivity (<<iso80000-5>>), and the product of electric conductivity (<<iec80000-6>>) and thermodynamic temperature (<<iso80000-3>>)",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Lorenz coefficient can be expressed by\n\n[stem%unnumbered]\n++++\nL = lambda/(sigma T)\n++++\n\nwhere stem:[lambda] is thermal conductivity (<<iso80000-5>>), stem:[sigma] is electric conductivity (<<iec80000-6>>), and stem:[T] is thermodynamic temperature (<<iso80000-5>>).\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-V^2/K^2"
        },
        {
          "@id": "isoiec80000:unit-kg^2*m^4*s^(-6)"
        },
        {
          "@id": "isoiec80000:unit-A^(-2)*K^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-12"
