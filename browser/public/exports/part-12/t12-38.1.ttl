isoiec80000:term-t12-38.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "London penetration depth"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t12-38.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "lambda_\"L\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t12-38.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "12-38.1" ;
  skosxl:prefLabel isoiec80000:term-t12-38.1-0 ;
  skosxl:altLabel isoiec80000:sym-t12-38.1-0 ;
  skos:definition """distance (<<iso80000-3>>) a magnetic field penetrates the plane surface of a semi-finite superconductor according to the expression:

[stem%unnumbered]
++++
B(x) = B(0) \"exp\" ((-x)/(lambda_\"L\"))
++++

where stem:[B] is magnetic flux density (<<iec80000-6>>) and stem:[x] is distance (<<iso80000-3>>) from the surface
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-m ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-12 .