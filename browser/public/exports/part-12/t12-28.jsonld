      ],
      "dcterms:identifier": "12-28",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-28-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-28-0"
        }
      ],
      "skos:definition": {
        "@value": "in the free electron model, the Fermi energy (<<t12-27.1>>) divided by the Boltzmann constant (<<iso80000-1>>)",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Fermi temperature is expressed by:\n\n[stem%unnumbered]\n++++\nT_\"F\" = (E_\"F\")/k\n++++\n\nwhere stem:[E_\"F\"] is Fermi energy (<<t12-27.1>>) and stem:[k] is the Boltzmann constant (<<iso80000-1>>).\n\nstem:[E_\"F\"] is relative to the lowest occupied state.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-K"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
