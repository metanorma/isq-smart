        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Biot number <heat transfer>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.6-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bi",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-5.6",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-5.6",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.6-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.6-0"
        }
      ],
      "skos:definition": {
        "@value": "special case of the Nusselt number for heat transfer (item <<t11-5.5>>) in case of conductive heat transfer in a solid body, expressed by\n\nstem:[Bi = Kl // lambda]; where\n\nstem:[K]:: is coefficient of heat transfer (<<iso80000-5>>) through the surface,\nstem:[l]:: is characteristic length (<<iso80000-3>>), and\nstem:[lambda]:: is thermal conductivity (<<iso80000-5>>) of the body\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The characteristic length is commonly defined as the volume of the body divided by its surface area.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-5"
      }
    }
  ]
