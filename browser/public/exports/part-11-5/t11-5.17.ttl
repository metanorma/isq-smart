isoiec80000:term-t11-5.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "heat transfer number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-5.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "K_Q"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-5.17 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-5.17" ;
  skosxl:prefLabel isoiec80000:term-t11-5.17-0 ;
  skosxl:altLabel isoiec80000:sym-t11-5.17-0 ;
  skos:definition """relation between heat transferred by a flow and its kinetic energy, expressed by

stem:[K_Q = Phi // (v^3l^2rho)]; where

stem:[Phi]:: is heat flow rate (<<iso80000-5>>),
stem:[v]:: is characteristic speed (<<iso80000-3>>),
stem:[l]:: is characteristic length (<<iso80000-3>>), and
stem:[rho]:: is mass density (<<iso80000-4>>)
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-5 .