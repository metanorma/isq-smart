      ],
      "skos:definition": {
        "@value": "efficiency of heat transfer by a fluid, expressed by\n\nstem:[Be_S = (S(Delta T))/(S(Delta T) + S(Delta p))]; where\n\nstem:[S(Delta T)]:: is entropy generation contributed by heat transfer, and\nstem:[S(Delta p)]:: is entropy generation contributed by fluid friction\n",
        "@language": "en"
      },
