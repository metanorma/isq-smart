isoiec80000:term-t2-9.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "vector from point A to B"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-9.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "vec(\"AB\")"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-9.5 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-9.5" ;
  skosxl:prefLabel isoiec80000:term-t2-9.5-0 ;
  skosxl:altLabel isoiec80000:sym-t2-9.5-0 ;
  skos:definition """vector from stem:[\"A\"] to stem:[\"B\"]"""@en ;
  skos:note """If stem:[vec(\"AB\")=vec(\"CD\")] then stem:[\"B\"], seen from stem:[\"A\"], is in the same direction and distance as stem:[\"D\"] is, seen from stem:[\"C\"]. It does not follow that stem:[A = C] and stem:[B = D]."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-9 .