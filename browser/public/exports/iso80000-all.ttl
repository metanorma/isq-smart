  skosxl:prefLabel isoiec80000:term-t13-7-0 ;
  skosxl:altLabel isoiec80000:sym-t13-7-0 ;
  skos:definition """number of call attempts over a specified time interval divided by the duration (ISO 80000-3:2019, item 3-9) of this interval"""@en ;
  skos:note """See <<iec60050-715,droploc%locality:item=\"715-03-13\">>."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-s^{-1} ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

isoiec80000:term-t13-8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "completed call intensity"@en ;
  smart:hasTermFormType smart:fullForm .

