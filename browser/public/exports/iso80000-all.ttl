  dcterms:identifier "4-21.2" ;
  skosxl:prefLabel isoiec80000:term-t4-21.2-0 ;
  skosxl:altLabel isoiec80000:sym-t4-21.2-0 ;
  skos:definition """geometrical characteristic of a shape of a body equal to:

stem:[I_\"p\" = &#8748;_\"M\" r_\"Q\"^2 \"d\"A]

where stem:[\"M\"] is the two-dimensional domain of the cross-section of a
plane and considered body, stem:[r_\"Q\"] is radial distance (<<iso80000-3>>)
from a stem:[\"Q\"]-axis perpendicular to the plane of the surface considered
and stem:[A] is area (<<iso80000-3>>)
"""@en ;
  skos:note """This quantity is often referred to wrongly as \"moment of inertia\" (<<t4-7>>).

The subscript, stem:[p], may be omitted when there is no risk of confusion.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-m^4 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-4 .

isoiec80000:term-t4-22-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "section modulus"@en ;
  smart:hasTermFormType smart:fullForm .

