  skosxl:altLabel isoiec80000:term-t13-3-1 ;
  skosxl:altLabel isoiec80000:sym-t13-3-0 ;
  skos:definition """traffic intensity (<<t13-1>>) of the traffic served by a particular pool of resources"""@en ;
  skos:note """General practice is to estimate the traffic intensity as an average over a specified time interval, e.g. the busy hour.

See <<iec60050-715,locality:item=\"715-05-04\">>.
"""@en ;
