  dcterms:identifier "10-74.1" ;
  skosxl:prefLabel isoiec80000:term-t10-74.1-0 ;
  skosxl:altLabel isoiec80000:sym-t10-74.1-0 ;
  skos:definition """average number of fission neutrons, both prompt and delayed, emitted per fission event"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .

isoiec80000:term-t10-74.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "neutron yield per absorption"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-74.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "eta"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-74.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-74.2" ;
  skosxl:prefLabel isoiec80000:term-t10-74.2-0 ;
  skosxl:altLabel isoiec80000:sym-t10-74.2-0 ;
  skos:definition """average number of fission neutrons, both prompt and delayed, emitted per neutron absorbed in a fissionable nuclide or in a nuclear fuel, as specified"""@en ;
  skos:note """stem:[nu//eta] is equal to the quotient of the macroscopic cross section for fission and that for absorption, both for neutrons in the fuel material."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .

isoiec80000:term-t10-75-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "fast fission factor"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-75-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "varphi"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-75 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-75" ;
  skosxl:prefLabel isoiec80000:term-t10-75-0 ;
  skosxl:altLabel isoiec80000:sym-t10-75-0 ;
  skos:definition """in an infinite medium, the quotient of the mean number of neutrons produced by fission due to neutrons of all energies (<<iso80000-5>>) and the mean number of neutrons produced by fissions due to thermal neutrons only"""@en ;
  skos:note """The class of neutrons must be specified, e.g. thermal."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .

isoiec80000:term-t10-76-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "thermal utilization factor"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-76-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "f"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-76 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-76" ;
  skosxl:prefLabel isoiec80000:term-t10-76-0 ;
  skosxl:altLabel isoiec80000:sym-t10-76-0 ;
  skos:definition """in an infinite medium, the quotient of the number of thermal neutrons absorbed in a fissionable nuclide or in a nuclear fuel, as specified, and the total number of thermal neutrons absorbed"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .

isoiec80000:term-t10-77-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "non-leakage probability"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-77-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "ii(Lambda)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-77 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-77" ;
  skosxl:prefLabel isoiec80000:term-t10-77-0 ;
  skosxl:altLabel isoiec80000:sym-t10-77-0 ;
  skos:definition """probability that a neutron will not escape from the reactor during the slowing-down process or while it diffuses as a thermal neutron"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .

isoiec80000:term-t10-78.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "multiplication factor"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-78.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "k"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-78.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-78.1" ;
  skosxl:prefLabel isoiec80000:term-t10-78.1-0 ;
  skosxl:altLabel isoiec80000:sym-t10-78.1-0 ;
  skos:definition """quotient of the total number of fission or fission-dependent neutrons produced in the duration of a time interval and the total number of neutrons lost by absorption and leakage in that duration"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .

isoiec80000:term-t10-78.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "infinite multiplication factor"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-78.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "k_(oo)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-78.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-78.2" ;
  skosxl:prefLabel isoiec80000:term-t10-78.2-0 ;
  skosxl:altLabel isoiec80000:sym-t10-78.2-0 ;
  skos:definition """multiplication factor (<<t10-78.1>>) for an infinite medium or for an infinite repeating lattice"""@en ;
  skos:note """For a thermal reactor,

[stem%unnumbered]
++++
k_(oo) = eta * epsilon * p * f
++++
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .

isoiec80000:term-t10-79-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "reactor time constant"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-79-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "T"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-79 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-79" ;
  skosxl:prefLabel isoiec80000:term-t10-79-0 ;
  skosxl:altLabel isoiec80000:sym-t10-79-0 ;
  skos:definition """duration (<<iso80000-3>>) required for the neutron fluence rate (<<t10-44>>) in a reactor to change by the factor stem:[\"e\"] when the fluence rate is rising or falling exponentially"""@en ;
  skos:note """Also called reactor period."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-s ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .

isoiec80000:term-t10-80.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "energy imparted"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-80.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "epsilon"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-80.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-80.1" ;
  skosxl:prefLabel isoiec80000:term-t10-80.1-0 ;
  skosxl:altLabel isoiec80000:sym-t10-80.1-0 ;
  skos:definition """sum of all energy deposits in a given volume:

[stem%unnumbered]
++++
epsilon = sum_i epsilon_i
++++

where the summation is performed over all energy (<<iso80000-5>>) deposits stem:[epsilon_i] of interaction stem:[i] in that volume
"""@en ;
  skos:note """Energy imparted is a stochastic quantity.

stem:[epsilon_i] is given by:

[stem%unnumbered]
++++
epsilon_i = epsilon_\"in\" - epsilon_\"out\" + Q
++++

where stem:[epsilon_\"in\"] is the energy (<<iso80000-5>>) of the incident ionizing particle, excluding rest energy (<<t10-3>>), stem:[epsilon_\"out\"] is the sum of the energies (<<iso80000-5>>) of all ionizing particles leaving the interaction, excluding rest energy (<<t10-3>>), and stem:[Q] is the change in the rest energies (<<t10-3>>) of the nucleus and of all particles involved in the interaction.

stem:[Q > 0] means decrease of rest energy;

stem:[Q < 0] means increase of rest energy.

Stochastic quantities such as the energy imparted and the specific energy imparted (<<t10-81.2>>) and their probability distributions have been introduced as they describe the discontinuous nature of the ionizing radiations as a determinant of radiochemical and radiobiological effects. In radiation applications involving large numbers of ionizing particles, e.g. in medicine, radiation protection and materials testing and processing, these fluctuations are adequately represented by the expectation values of the probability distributions. Non-stochastic quantities such as particle fluence (<<t10-43>>), absorbed dose (<<t10-81.1>>) and kerma (<<t10-86.1>>) are based on these expectation values.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-eV ;
  isoiec80000:hasUnit isoiec80000:unit-J ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^2*s^(-2) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .

isoiec80000:term-t10-80.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "mean energy imparted"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-80.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bar epsilon"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-80.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-80.2" ;
  skosxl:prefLabel isoiec80000:term-t10-80.2-0 ;
  skosxl:altLabel isoiec80000:sym-t10-80.2-0 ;
  skos:definition """expectation value of the energy imparted (<<t10-80.1>>):

[stem%unnumbered]
++++
bar epsilon = R_\"in\" - R_\"out\" + sum Q
++++

where

stem:[R_\"in\"]:: is the radiant energy (<<t10-45>>) of all those charged and uncharged ionizing particles that enter the volume,

stem:[R_\"out\"]:: is the radiant energy of all those charged and uncharged ionizing particles that leave the volume, and

stem:[sum Q]:: is the sum of all changes of the rest energy (<<t10-3>>) of nuclei and elementary particles that occur in that volume
"""@en ;
  skos:note """Sometimes, it has been called the integral absorbed dose.

stem:[Q > 0] means decrease of rest energy;

stem:[Q < 0] means increase of rest energy.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-eV ;
  isoiec80000:hasUnit isoiec80000:unit-J ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^2*s^(-2) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .

isoiec80000:term-t10-81.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "absorbed dose"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-81.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "D"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-81.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-81.1" ;
  skosxl:prefLabel isoiec80000:term-t10-81.1-0 ;
  skosxl:altLabel isoiec80000:sym-t10-81.1-0 ;
  skos:definition """differential quotient of stem:[bar epsilon] with respect to stem:[m], where stem:[bar epsilon] is the mean energy (<<iso80000-5>>) imparted by ionizing radiation to matter of mass (<<iso80000-4>>) stem:[m]:

[stem%unnumbered]
++++
D = (\"d\"bar epsilon)/(\"d\"m)
++++
"""@en ;
  skos:note """The gray is a special name for joule per kilogram, to be used as the coherent SI unit for absorbed dose.

[stem%unnumbered]
++++
1 \"unitsml(Gy)\" = 1 \"unitsml(J/kg)\"
++++

[stem%unnumbered]
++++
bar epsilon = int D \"d\"m
++++

where stem:[\"d\"m] is the element of mass of the irradiated matter.

In the limit of a small domain, the mean specific energy stem:[bar z = (ii(Delta)bar epsilon)/(ii(Delta)m)] is equal to the absorbed dose stem:[D].

The absorbed dose can also be expressed in terms of the volume of the mass element by:

[stem%unnumbered]
++++
D = (\"d\"bar epsilon)/(\"d\"m) = (\"d\"bar epsilon)/(rho \"d\"V)
++++

where stem:[rho] is the mass density of the mass element.

In report 85a of the ICRU a definition with an equivalent meaning is given as:

The absorbed dose, stem:[D], is the quotient of stem:[\"d\"bar epsilon] by stem:[\"d\"m], where stem:[\"d\"bar epsilon] is the mean energy imparted by ionizing radiation to matter of mass stem:[\"d\"m]:

[stem%unnumbered]
++++
D = (\"d\"bar epsilon)/(\"d\"m).
++++
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Gy ;
  isoiec80000:hasUnit isoiec80000:unit-J/kg ;
  isoiec80000:hasUnit isoiec80000:unit-m^2*s^(-2) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .

isoiec80000:term-t10-81.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "specific energy imparted"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-81.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "z"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-81.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-81.2" ;
  skosxl:prefLabel isoiec80000:term-t10-81.2-0 ;
  skosxl:altLabel isoiec80000:sym-t10-81.2-0 ;
  skos:definition """quotient of the energy imparted stem:[epsilon] (<<t10-80.1>>) and the mass stem:[m] (<<iso80000-4>>) of the matter in a given volume element:

[stem%unnumbered]
++++
z = epsilon/m
++++
"""@en ;
  skos:note """stem:[z] is a stochastic quantity.

In the limit of a small domain, the mean specific energy stem:[bar z] is equal to the absorbed dose stem:[D].

The specific energy imparted can be due to one or more (energy-deposition) events.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Gy ;
  isoiec80000:hasUnit isoiec80000:unit-J/kg ;
  isoiec80000:hasUnit isoiec80000:unit-m^2*s^(-2) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .

isoiec80000:term-t10-82-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "quality factor <ionizing radiation>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-82-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Q"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-82 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-82" ;
  skosxl:prefLabel isoiec80000:term-t10-82-0 ;
  skosxl:altLabel isoiec80000:sym-t10-82-0 ;
  skos:definition """factor in the calculation and measurement of dose equivalent (<<t10-83.1>>), by which the absorbed dose (<<t10-81.1>>) is to be weighted in order to account for different biological effectiveness of radiations, for radiation protection purposes"""@en ;
  skos:note """stem:[Q] is determined by the linear energy transfer (<<t10-85>>) for stem:[ii(Delta)-> oo], stem:[L_(oo)] (often denoted as stem:[L] or stem:[\"LET\"]), of charged particles passing through a small volume element at this point (the value of stem:[L_(oo)] refers to water, not to tissue; the difference, however, is small). The relationship between stem:[L] and stem:[Q] is given in ICRP Publication 103 (ICRP, 2007)."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .

isoiec80000:term-t10-83.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "dose equivalent"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-83.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "H"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-83.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-83.1" ;
  skosxl:prefLabel isoiec80000:term-t10-83.1-0 ;
  skosxl:altLabel isoiec80000:sym-t10-83.1-0 ;
  skos:definition """product of the absorbed dose stem:[D] (<<t10-81.1>>) to tissue at the point of interest and the quality factor stem:[Q] (<<t10-82>>) at that point:

[stem%unnumbered]
++++
H = DQ
++++
"""@en ;
  skos:note """The sievert (stem:[\"unitsml(Sv)\"]) is a special name for joule per kilogram, and is the coherent SI unit for dose equivalent.

[stem%unnumbered]
++++
1 \"unitsml(Sv)\" = 1 \"unitsml(J/kg)\"
++++

The dose equivalent at a point in tissue is given by:

[stem%unnumbered]
++++
H = int_0^(oo) Q(L)D_L \"d\"L
++++

where stem:[D_L = \"d\"D//\"d\"L] is the distribution of stem:[D] in stem:[L] at the point of interest. See <<icrp>>.

The quantities measured with radiation protection dosimeters are based on the definition stem:[H = Q D]. If various radiation qualities stem:[i] have to be simultaneously accounted for, the definition is:

[stem%unnumbered]
++++
H = sum_i Q_i D_i.
++++

In ICRU 51 this quantity is denoted as \"dose equivalent\".

In order to quantify the radiation exposition of the human body and to specify dose limits, use is made of a quantity defined in ICRP 103, the \"equivalent dose to a tissue or organ\": stem:[H_\"T\" = w_\"T\" sum_\"R\" w_\"R\" D_\"T,R\"]. The weighting factors stem:[w_\"T\"] for various tissues and organs stem:[T] and stem:[w_\"R\"] for various radiation qualities stem:[\"R\"] have been numerically laid down in ICRP 103. stem:[D_\"T,R\"] is the mean absorbed dose to tissue within a tissue or organ stem:[\"T\"], imparted by radiation with radiation quality stem:[\"R\"].
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Sv ;
  isoiec80000:hasUnit isoiec80000:unit-J/kg ;
  isoiec80000:hasUnit isoiec80000:unit-m^2*s^(-2) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .

isoiec80000:term-t10-83.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "dose equivalent rate"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-83.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "dot H"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-83.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-83.2" ;
  skosxl:prefLabel isoiec80000:term-t10-83.2-0 ;
  skosxl:altLabel isoiec80000:sym-t10-83.2-0 ;
  skos:definition """differential quotient of dose equivalent stem:[H] (<<t10-83.1>>) with respect to time (<<iso80000-3>>):

[stem%unnumbered]
++++
dot H = (\"d\"H)/(\"d\"t)
++++
"""@en ;
  skos:note """[stem%unnumbered]
++++
1 \"unitsml(Sv/s)\" = 1 \"unitsml(W/kg)\"
++++

See the remarks for <<t10-83.1>>.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Sv/s ;
  isoiec80000:hasUnit isoiec80000:unit-W/kg ;
  isoiec80000:hasUnit isoiec80000:unit-m^2*s^(-3) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .

isoiec80000:term-t10-84-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "absorbed-dose rate"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-84-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "dot D"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-84 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-84" ;
  skosxl:prefLabel isoiec80000:term-t10-84-0 ;
  skosxl:altLabel isoiec80000:sym-t10-84-0 ;
  skos:definition """differential quotient of the absorbed dose stem:[D] (<<t10-81.1>>) with respect to time (<<iso80000-3>>):

[stem%unnumbered]
++++
dot D = (\"d\"D)/(\"d\"t)
++++
"""@en ;
  skos:note """[stem%unnumbered]
++++
1 \"unitsml(Gy/s)\" = 1 \"unitsml(W/kg)\"
++++

See the remarks for <<t10-81.1>>.

In report 85a of the ICRU a definition with an equivalent meaning is given as:

The absorbed-does rate, stem:[dot D], is the quotient of stem:[\"d\"D] by stem:[\"d\"t], where stem:[\"d\"D] is the increment of absorbed does in the time interval stem:[\"d\"t]:

[stem%unnumbered]
++++
dot D = (\"d\"D)/(\"d\"t).
++++
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Gy/s ;
  isoiec80000:hasUnit isoiec80000:unit-W/kg ;
  isoiec80000:hasUnit isoiec80000:unit-m^2*s^(-3) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .

isoiec80000:term-t10-85-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "linear energy transfer"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-85-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "L_(ii(Delta))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-85 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-85" ;
  skosxl:prefLabel isoiec80000:term-t10-85-0 ;
  skosxl:altLabel isoiec80000:sym-t10-85-0 ;
  skos:definition """quotient of the mean energy (<<iso80000-4>>) stem:[\"d\"E_(ii(Delta))] lost by the charged particles due to electronic interactions in traversing a distance (<<iso80000-3>>) stem:[\"d\"l], minus the mean sum of the kinetic energies in excess of stem:[ii(Delta)] of all the electrons released by the charged particles and stem:[\"d\"l]:

[stem%unnumbered]
++++
L_(ii(Delta)) = (\"d\"E_(ii(Delta)))/(\"d\"l)
++++
"""@en ;
  skos:note """This quantity is not completely defined unless stem:[ii(Delta)] is specified, i.e. the maximum kinetic energy of secondary electrons whose energy is considered to be \"locally deposited.\" stem:[ii(Delta)] may be expressed in stem:[\"unitsml(eV)\"].

Note that the abbreviation LET specifically refers to the quantity stem:[L_(oo)] mentioned in the remark to <<t10-82>>.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-eV/m ;
  isoiec80000:hasUnit isoiec80000:unit-J/m ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m*s^(-2) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .

isoiec80000:term-t10-86.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "kerma"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-86.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "K"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-86.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-86.1" ;
  skosxl:prefLabel isoiec80000:term-t10-86.1-0 ;
  skosxl:altLabel isoiec80000:sym-t10-86.1-0 ;
  skos:definition """for uncharged ionizing radiation, differential quotient of stem:[E_\"tr\"] with respect to stem:[m], where stem:[E_\"tr\"] is the mean sum of the initial kinetic energies (<<iso80000-4>>) of all the charged ionizing particles liberated in a mass (<<iso80000-4>>) stem:[m] of a material:

[stem%unnumbered]
++++
K = (\"d\"E_(\"tr\"))/(\"d\"m)
++++
"""@en ;
  skos:note """[stem%unnumbered]
++++
1 \"unitsml(Gy)\" = 1 \"unitsml(J/kg)\"
++++

See the remarks for <<t10-81.1>>.

The name \"kerma\" is derived from Kinetic Energy Released in MAtter (or MAss or MAterial).

The quantity stem:[\"d\"E_\"tr\"] includes also the kinetic energy of the charged particles emitted in the decay of excited atoms, molecules, or nuclei.

When the mass element stem:[\"d\"m] consists of air the term air kerma is used. It can be convenient to refer to a value of air kerma in free space or at a point inside a material different from air, e.g. to the air kerma at a point inside a water phantom.

In report 85a of the ICRU a definition with an equivalent meaning is given as:

The kerma, stem:[K], for ionizing uncharged particles, is the quotient of stem:[\"d\"E_\"tr\"] by stem:[\"d\"m], where stem:[\"d\"E_\"tr\"] is the mean sum of the initial kinetic energies of all the charged particles liberated in a mass stem:[\"d\"m] of a material by the uncharged particles incident on stem:[\"d\"m]:

[stem%unnumbered]
++++
K = (\"d\"E_\"tr\")/(\"d\"m).
++++
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Gy ;
  isoiec80000:hasUnit isoiec80000:unit-J/kg ;
  isoiec80000:hasUnit isoiec80000:unit-m^2*s^(-2) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .

isoiec80000:term-t10-86.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "kerma rate"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-86.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "dot K"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-86.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-86.2" ;
  skosxl:prefLabel isoiec80000:term-t10-86.2-0 ;
  skosxl:altLabel isoiec80000:sym-t10-86.2-0 ;
  skos:definition """differential quotient of kerma (<<t10-86.1>>) with respect to time (<<iso80000-3>>):

[stem%unnumbered]
++++
dot K = (\"d\"K)/(\"d\"t)
++++
"""@en ;
  skos:note """[stem%unnumbered]
++++
1 \"unitsml(Gy/s)\" = 1 \"unitsml(W/kg)\"
++++

See the Remarks for <<t10-81.1>>.

In report 85a of the ICRU a definition with an equivalent meaning is given as:

The kerma rate, stem:[dot K], is the quotient of stem:[\"d\"K] by stem:[\"d\"t], where stem:[\"d\"K] is the increment of kerma in the time interval stem:[\"d\"t]:

[stem%unnumbered]
++++
dot K = (\"d\"K)/(\"d\"t).
++++
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Gy/s ;
  isoiec80000:hasUnit isoiec80000:unit-W/kg ;
  isoiec80000:hasUnit isoiec80000:unit-m^2*s^(-3) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .

isoiec80000:term-t10-87-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "mass energy-transfer coefficient"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-87-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "mu_\"tr\"//rho"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-87 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-87" ;
  skosxl:prefLabel isoiec80000:term-t10-87-0 ;
  skosxl:altLabel isoiec80000:sym-t10-87-0 ;
  skos:definition """for ionizing uncharged particles of a given type and energy, the differential quotient of stem:[R_\"tr\"] with respect to stem:[l]:

[stem%unnumbered]
++++
(mu_\"tr\")/rho = 1/rho 1/R (\"d\"R_\"tr\")/(\"d\"l)
++++

where stem:[R_\"tr\"] is the mean energy (<<iso80000-5>>) that is transferred to kinetic energy (<<iso80000-4>>) of charged particles by interactions of the uncharged particles of incident radiant energy stem:[R] (<<t10-45>>) in traversing a distance (<<iso80000-3>>) stem:[l] in the material of density (<<iso80000-4>>) stem:[rho], divided by stem:[rho] and stem:[R]
"""@en ;
  skos:note """stem:[mu_\"tr\"//rho = dot K//ii(Psi)], where stem:[dot K] is kerma rate (<<t10-86.2>>) and stem:[ii(Psi)] is energy fluence rate (<<t10-47>>).

The quantity:

[stem%unnumbered]
++++
mu_\"en\"//rho = (mu_\"tr\"//rho)(1-g)
++++

where stem:[g] is mean fraction of the kinetic energy of the liberated charged particles that is lost in radiative processes in the material, is called mass energy-absorption coefficient.

The mass energy-absorption coefficient of a compound material depends on the stopping power of the material. Thus, its evaluation cannot, in principle, be reduced to a simple summation of the mass energy-absorption coefficient of the atomic constituents. Such a summation can provide an adequate approximation when the value of stem:[g] is sufficiently small.

In report 85a of the ICRU a definition with an equivalent meaning is given as:

The mass energy-transfer coefficient, stem:[mu_\"tr\"//rho], of a material, for uncharged particles of a given type and energy, is the quotient of stem:[\"d\"R_\"tr\"//R] by stem:[rho \"d\"l], where stem:[\"d\"R_\"tr\"] is the mean energy that is transferred to kinetic energy of charged particles by interactions of the uncharged particles of incident radiant energy stem:[R] in traversing a distance stem:[\"d\"l] in the material of density stem:[rho]:

[stem%unnumbered]
++++
(mu_\"tr\")/rho = 1/(rho \"d\"l) (\"d\"R_\"tr\")/R.
++++
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-kg^(-1)*m^2 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .

isoiec80000:term-t10-88-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "exposure <ionizing radiation>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-88-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "X"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-88 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-88" ;
  skosxl:prefLabel isoiec80000:term-t10-88-0 ;
  skosxl:altLabel isoiec80000:sym-t10-88-0 ;
  skos:definition """for X- or gamma radiation the differential quotient of stem:[q] with respect to stem:[m], where stem:[q] is the absolute value of the mean total electric charge of the ions of one sign produced when all the electrons and positrons liberated or created by photons incident on an element of dry air with mass stem:[m] (<<iso80000-4>>) are completely stopped in dry air:

[stem%unnumbered]
++++
X = (\"d\"q)/(\"d\"m)
++++
"""@en ;
  skos:note """The ionization produced by electrons emitted in atomic or molecular relaxation is included in stem:[\"d\"q]. The ionization due to photons emitted by radiative processes (i.e. bremsstrahlung and fluorescence photons) is not included in stem:[\"d\"q].

This quantity should not be confused with the quantity photon exposure (<<iso80000-7>>), radiation exposure (<<iso80000-7>>), or the quantity luminous exposure (<<iso80000-7>>).

It can be convenient to refer to a value of exposure in free space or at a point inside a material different from air, e.g. to the exposure at a point inside a water phantom.

The exposure is related to the air kerma, stem:[K_\"a\"], (see <<t10-86.1>>) by:

[stem%unnumbered]
++++
X = (e(1-g))/W K_\"a\",
++++

where stem:[e] is the elementary charge (<<iso80000-1>>), stem:[W] the average energy loss per elementary charge produced (<<t10-60>>), and stem:[g] is the fraction of the kinetic energy of liberated charged particles that is lost in radiative processes.

In report 85a of the ICRU a definition with an equivalent meaning is given as:

The exposure, stem:[X], is the quotient of stem:[\"d\"q] by stem:[\"d\"m], where stem:[\"d\"q] is the absolute value of the mean total charge of the ions of one sign produced when all the electrons and positrons liberated or created by photons incident on a mass stem:[\"d\"m] of dry air are completely stopped in dry air:

[stem%unnumbered]
++++
X = (\"d\"q)/(\"d\"m).
++++
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-C/kg ;
  isoiec80000:hasUnit isoiec80000:unit-kg^(-1)*s*A ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .

isoiec80000:term-t10-89-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "exposure rate"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-89-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "dot X"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-89 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-89" ;
  skosxl:prefLabel isoiec80000:term-t10-89-0 ;
  skosxl:altLabel isoiec80000:sym-t10-89-0 ;
  skos:definition """differential quotient of the exposure stem:[X] (<<t10-88>>) with respect to time (<<iso80000-3>>):

[stem%unnumbered]
++++
dot X = (\"d\"X)/(\"d\"t)
++++
"""@en ;
  skos:note """[stem%unnumbered]
++++
1 \"unitsml(C/(kg*s))\" = 1 \"unitsml(A/kg)\"
++++

In report 85a of the ICRU a definition with an equivalent meaning is given as:

The exposure rate, stem:[dot X], is the quotient of stem:[\"d\"X] by stem:[\"d\"t], where stem:[\"d\"X] is the increment of exposure in the time interval stem:[\"d\"t]:

[stem%unnumbered]
++++
dot X = (\"d\"X)/(\"d\"t).
++++
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-C/(kg*s) ;
  isoiec80000:hasUnit isoiec80000:unit-kg^(-1)*A ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .

@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

isoiec80000:part-11-4 a smart:PublicationDocument ;
  dcterms:title "Part 11-4"@en ;
  dcterms:identifier "ISO 80000-11-4" ;
  smart:hasPublicationType smart:internationalStandard ;
  smart:hasBindingnessType smart:normative .

isoiec80000:term-t11-4.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Reynolds number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Re"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.1" ;
  skosxl:prefLabel isoiec80000:term-t11-4.1-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.1-0 ;
  skos:definition """quotient of inertial forces and viscous forces in a fluid flow, expressed by

stem:[Re = (rho v l)/eta = (v l)/sf(ii(v))]; where

stem:[rho]:: is mass density (<<iso80000-4>>),
stem:[v]:: is speed (<<iso80000-3>>),
stem:[l]:: is characteristic length (<<iso80000-3>>),
stem:[eta]:: is dynamic viscosity (<<iso80000-4>>), and
stem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>)
"""@en ;
  skos:note """The value of the Reynolds number gives an estimate on the flow state: laminar flow or turbulent flow.

In rotating movement, the speed stem:[v= omega l], where stem:[l] is the distance from the rotation axis and stem:[omega] is the angular velocity.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Euler number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Eu"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.2" ;
  skosxl:prefLabel isoiec80000:term-t11-4.2-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.2-0 ;
  skos:definition """relationship between pressure drop in a flow and the kinetic energy per volume for flow of fluids in a pipe, expressed by

stem:[Eu = (Delta p)/(rho v^2)]; where

stem:[Delta p]:: is drop of pressure (<<iso80000-4>>),
stem:[rho]:: is mass density (<<iso80000-4>>), and
stem:[v]:: is speed (<<iso80000-3>>)
"""@en ;
  skos:note """The Euler number is used to characterize losses in the flow.

A modification of the Euler number is considering the dimensions of the containment (pipe):

stem:[Eu' = d/l Eu]; where

stem:[d]:: is inner diameter (<<iso80000-3>>) of the pipe, and
stem:[l]:: is length (<<iso80000-3>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Froude number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Fr"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.3 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.3" ;
  skosxl:prefLabel isoiec80000:term-t11-4.3-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.3-0 ;
  skos:definition """quotient of a body's inertial forces and its gravitational forces for flow of fluids, expressed by

stem:[Fr = v/(sqrt(lg))]; where

stem:[v]:: is speed (<<iso80000-3>>) of flow,
stem:[l]:: is characteristic length (<<iso80000-3>>), and
stem:[g]:: is acceleration of free fall (<<iso80000-3>>)
"""@en ;
  skos:note """The Froude number can be modified by buoyancy.

Sometimes the square and sometimes the inverse of the Froude number as defined here is wrongly used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Grashof number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Gr"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.4 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.4" ;
  skosxl:prefLabel isoiec80000:term-t11-4.4-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.4-0 ;
  skos:definition """quotient of buoyancy forces due to thermal expansion which results in a change of mass density and viscous forces for free convection due to temperature differences, expressed by

stem:[Gr = l^3 g alpha_V Delta T // sf(ii(v))^2]; where

stem:[l]:: is characteristic length (<<iso80000-3>>),
stem:[g]:: is acceleration of free fall (<<iso80000-3>>),
stem:[alpha_V]:: is thermal cubic expansion coefficient (<<iso80000-5>>),
stem:[Delta T]:: is difference of thermodynamic temperature stem:[T] (<<iso80000-5>>) between surface of the body and the fluid far away from the body, and
stem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>)
"""@en ;
  skos:note """Heating can occur near hot vertical walls, in pipes, or by a bluff body.

The characteristic length can be the vertical height of a hot plate, the diameter of a pipe, or the effective length of a body.

See also Rayleigh number (<<t11-5.3>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Weber number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "We"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.5 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.5" ;
  skosxl:prefLabel isoiec80000:term-t11-4.5-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.5-0 ;
  skos:definition """relation between inertial forces and capillary forces due to surface tension at the interface between two different fluids, expressed by

stem:[We = rho v^2 l // gamma]; where

stem:[rho]:: is mass density (<<iso80000-4>>),
stem:[v]:: is speed (<<iso80000-3>>),
stem:[l]:: is characteristic length (<<iso80000-3>>), and
stem:[gamma]:: is surface tension (<<iso80000-4>>)
"""@en ;
  skos:note """The fluids can be gases or liquids.

The different fluids often are drops moving in a gas or bubbles in a liquid.

The characteristic length is commonly the diameter of bubbles or drops.

The square root of the Weber number is called Rayleigh number.

Sometimes the square root of the Weber number as defined here is called the Weber number. That definition is deprecated.

Interfaces only exist between two fluids which are not miscible.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Mach number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ma"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.6 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.6" ;
  skosxl:prefLabel isoiec80000:term-t11-4.6-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.6-0 ;
  skos:definition """quotient of the speed of flow and the speed of sound, expressed by

stem:[Ma = v//c]; where

stem:[v]:: is speed (<<iso80000-3>>) of the body, and
stem:[c]:: is speed of sound (<<iso80000-8>>) in the fluid
"""@en ;
  skos:note """The Mach number represents the relationship of inertial forces compared to compression forces.

For an ideal gas

stem:[c = sqrt(gamma p/rho) = sqrt(gamma (RT)/M) = sqrt(gamma (kT)/m)]; where stem:[gamma] is ratio of the specific heat capacity (<<iso80000-5>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Knudsen number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Kn"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.7 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.7" ;
  skosxl:prefLabel isoiec80000:term-t11-4.7-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.7-0 ;
  skos:definition """quotient of free path length of a particle and a characteristic length, expressed by

stem:[Kn = lambda // l]; where

stem:[lambda]:: is mean free path (<<iso80000-9>>), and
stem:[l]:: is characteristic length (<<iso80000-3>>)
"""@en ;
  skos:note """The Knudsen number is a measure to estimate whether the gas in flow behaves like a continuum.

The characteristic length, stem:[l], can be a characteristic size of the gas flow region like a pipe diameter.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Strouhal number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t11-4.8-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Thomson number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Sr"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-4.8-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Sh"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.8 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.8" ;
  skosxl:prefLabel isoiec80000:term-t11-4.8-0 ;
  skosxl:altLabel isoiec80000:term-t11-4.8-1 ;
  skosxl:altLabel isoiec80000:sym-t11-4.8-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.8-1 ;
  skos:definition """relation between a characteristic frequency and a characteristic speed for unsteady flow with periodic behaviour, expressed by

stem:[Sr = fl // v]; where

stem:[f]:: is frequency (<<iso80000-3>>) of vortex shedding,
stem:[l]:: is characteristic length (<<iso80000-3>>), and
stem:[v]:: is speed (<<iso80000-3>>) of flow
"""@en ;
  skos:note """The characteristic length, stem:[l], can be the diameter of an obstacle in the flow which can cause vortex shedding, or the length of it."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "drag coefficient"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "c_\"D\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.9 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.9" ;
  skosxl:prefLabel isoiec80000:term-t11-4.9-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.9-0 ;
  skos:definition """relation between the effective drag force and inertial forces for a body moving in a fluid, expressed by

stem:[c_\"D\" = (2F_\"D\")/(rho v^2 A)]; where

stem:[F_\"D\"]:: is drag force (<<iso80000-4>>) on the body,
stem:[rho]:: is mass density (<<iso80000-4>>) of the fluid,
stem:[v]:: is speed (<<iso80000-3>>) of the body, and
stem:[A]:: is cross-sectional area (<<iso80000-3>>)
"""@en ;
  skos:note """The drag coefficient is strongly dependant on the shape of the body."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bagnold number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bg"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.10 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.10" ;
  skosxl:prefLabel isoiec80000:term-t11-4.10-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.10-0 ;
  skos:definition """quotient of drag force and gravitational force for a body moving in a fluid, expressed by

stem:[Bg = (c_\"D\"rho v^2)/(l g rho_\"b\")]; where

stem:[c_\"D\"]:: is drag coefficient (<<t11-4.9>>) of the body,
stem:[rho]:: is mass density (<<iso80000-4>>) of the fluid,
stem:[v]:: is speed (<<iso80000-3>>) of the body,
stem:[l]:: is characteristic length (<<iso80000-3>>),
stem:[g]:: is acceleration of free fall (<<iso80000-3>>), and
stem:[rho_\"b\"]:: is mass density (<<iso80000-4>>) of the body
"""@en ;
  skos:note """The characteristic length, stem:[l], is the body's volume divided by its cross-sectional area."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bagnold number <solid particles>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ba_2"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.11 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.11" ;
  skosxl:prefLabel isoiec80000:term-t11-4.11-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.11-0 ;
  skos:definition """quotient of drag force and viscous force in a fluid transferring solid particles, expressed by

stem:[Ba_2 = (rho_\"s\" d^2 dot gamma)/eta sqrt(1//(f_\"s\"^(1//2)-1))]; where

stem:[rho_\"s\"]:: is mass density (<<iso80000-4>>) of particles,
stem:[d]:: is diameter (<<iso80000-3>>) of particles,
stem:[dot gamma = v//d]:: is shear rate time-derivative of shear strain (<<iso80000-4>>),
stem:[eta]:: is dynamic viscosity (<<iso80000-4>>) of fluid, and
stem:[f_\"s\"]:: is volumic fraction of solid particles
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "lift coefficient"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "c_\"l\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-4.12-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "c_\"A\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.12 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.12" ;
  skosxl:prefLabel isoiec80000:term-t11-4.12-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.12-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.12-1 ;
  skos:definition """quotient of the lift force available from a wing at a given angle and the inertial force for a wing shaped body moving in a fluid, expressed by

stem:[c_\"l\" = (2F_\"l\")/(rho v^2 S) = F_\"l\"/(qS)]; where

stem:[F_\"l\"]:: is lift force (<<iso80000-4>>) on the wing,
stem:[rho]:: is mass density (<<iso80000-4>>) of the fluid,
stem:[v]:: is speed (<<iso80000-3>>) of the body,
stem:[S = A\" cos \"alpha]:: is effective area (<<iso80000-3>>) when stem:[alpha] is the angle of attack and stem:[A] is area of the wing, and
stem:[q=rho v^2//2]:: is dynamic pressure.
"""@en ;
  skos:note """The lift coefficient is dependant on the shape of the wing."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "thrust coefficient"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "c_\"t\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.13 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.13" ;
  skosxl:prefLabel isoiec80000:term-t11-4.13-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.13-0 ;
  skos:definition """quotient of the effective thrust force available from a propeller and the inertial force in a fluid, expressed by

stem:[c_\"t\" = F_\"T\" // (rho n^2 d^4)]; where

stem:[F_\"T\"]:: is thrust force (<<iso80000-4>>) of the propeller,
stem:[rho]:: is mass density (<<iso80000-4>>) of the fluid,
stem:[n]:: is rotational frequency (<<iso80000-3>>), and
stem:[d]:: is tip diameter (<<iso80000-3>>) of the propeller
"""@en ;
  skos:note """The thrust coefficient is dependant on the shape of the propeller."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Dean number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Dn"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.14 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.14" ;
  skosxl:prefLabel isoiec80000:term-t11-4.14-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.14-0 ;
  skos:definition """relation between centrifugal force and inertial force, for flows of fluids in curved pipes, expressed by

stem:[Dn = (2vr)/sf(ii(v)) sqrt(r/R)]; where

stem:[v]:: is (axial) speed (<<iso80000-3>>),
stem:[r]:: is radius (<<iso80000-3>>) of the pipe,
stem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>) of the fluid, and
stem:[R]:: is radius of curvature (<<iso80000-3>>) of the path of the pipe
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bejan number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Be"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.15 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.15" ;
  skosxl:prefLabel isoiec80000:term-t11-4.15-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.15-0 ;
  skos:definition """quotient of mechanical work and frictional energy loss in fluid dynamics in a pipe, expressed by

stem:[Be = (Delta p l^2)/(eta sf(ii(v))) = (rho Delta p l^2)/eta^2]; where

stem:[Delta p]:: is drop of pressure (<<iso80000-4>>) along the pipe,
stem:[l]:: is characteristic length (<<iso80000-3>>),
stem:[eta]:: is dynamic viscosity (<<iso80000-4>>),
stem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>), and
stem:[rho]:: is mass density (<<iso80000-4>>).
"""@en ;
  skos:note """A similar number exists for heat transfer (<<t11-5.9>>).

The kinematic viscosity is also called momentum diffusivity.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Lagrange number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Lg"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.16 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.16" ;
  skosxl:prefLabel isoiec80000:term-t11-4.16-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.16-0 ;
  skos:definition """quotient of mechanical work and frictional energy loss in fluid dynamics in a pipe, expressed by

stem:[Lg = (l Delta p)/(eta v)]; where

stem:[l]:: is length (<<iso80000-3>>) of the pipe,
stem:[Delta p]:: is drop of pressure (<<iso80000-4>>) along the pipe,
stem:[eta]:: is dynamic viscosity (<<iso80000-4>>), and
stem:[v]:: is speed (<<iso80000-3>>)
"""@en ;
  skos:note """The Lagrange number is also given by

stem:[La = Re * Eu]; where

stem:[Re]:: is the Reynolds number (<<t11-4.1>>), and
stem:[Eu]:: is the Euler number (<<t11-4.2>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bingham number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t11-4.17-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "plasticity number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bm"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-4.17-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bn"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.17 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.17" ;
  skosxl:prefLabel isoiec80000:term-t11-4.17-0 ;
  skosxl:altLabel isoiec80000:term-t11-4.17-1 ;
  skosxl:altLabel isoiec80000:sym-t11-4.17-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.17-1 ;
  skos:definition """quotient of yield stress and viscous stress in a viscous material for flow of viscoplastic material in channels, expressed by

stem:[Bm = (tau d)/(eta v)]; where

stem:[tau]:: is shear stress (<<iso80000-4>>),
stem:[d]:: is characteristic diameter (<<iso80000-3>>), e.g. effective channel width,
stem:[eta]:: is dynamic viscosity (<<iso80000-4>>), and
stem:[v]:: is speed (<<iso80000-3>>)
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.18-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Hedström number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.18-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "He"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-4.18-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Hd"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.18 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.18" ;
  skosxl:prefLabel isoiec80000:term-t11-4.18-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.18-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.18-1 ;
  skos:definition """quotient of yield stress and viscous stress of a viscous material at flow limit for visco-plastic material in a channel, expressed by

stem:[He = (tau_0 d^2 rho)/eta^2]; where

stem:[tau_0]:: is shear stress (<<iso80000-4>>) at flow limit,
stem:[d]:: is characteristic diameter (<<iso80000-3>>), e.g. effective channel width,
stem:[rho]:: is mass density (<<iso80000-4>>), and
stem:[eta]:: is dynamic viscosity (<<iso80000-4>>)
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.19-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bodenstein number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.19-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bd"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.19 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.19" ;
  skosxl:prefLabel isoiec80000:term-t11-4.19-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.19-0 ;
  skos:definition """mathematical expression of the transfer of matter by convection in reactors with respect to diffusion,

stem:[Bd = vl//D]; where

stem:[v]:: is speed (<<iso80000-3>>),
stem:[l]:: is length (<<iso80000-3>>) of the reactor, and
stem:[D]:: is diffusion coefficient (<<iso80000-9>>)
"""@en ;
  skos:note """The Bodenstein number is also given by

stem:[Bd = Pe** = Re * Sc]; where

stem:[Pe**]:: is the Péclet number for mass transfer (<<t11-6.2>>),
stem:[Re]:: is the Reynolds number (<<t11-4.1>>), and
stem:[Sc = eta//(rho D) = v//D]:: is Schmidt number (<<t11-7.2>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.20-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Rossby number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t11-4.20-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Kiebel number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.20-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ro"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.20 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.20" ;
  skosxl:prefLabel isoiec80000:term-t11-4.20-0 ;
  skosxl:altLabel isoiec80000:term-t11-4.20-1 ;
  skosxl:altLabel isoiec80000:sym-t11-4.20-0 ;
  skos:definition """quotient of inertial forces and Coriolis forces in the context of transfer of matter in geophysics, expressed by

stem:[Ro = v//(2 l omega_\"E\" \"sin\"varphi)]; where

stem:[v]:: is speed (<<iso80000-3>>) of motion,
stem:[l]:: is characteristic length (<<iso80000-3>>), the scale of the phenomenon,
stem:[omega_\"E\"]:: is angular velocity (<<iso80000-3>>) of the Earth's rotation, and
stem:[varphi]:: is angle (<<iso80000-3>>) of latitude
"""@en ;
  skos:note """The Rossby number represents the effect of Earth's rotation on flow in pipes, rivers, ocean currents, tornadoes, etc.

The quantity stem:[omega_\"E\" \"sin\"varphi] is called Coriolis frequency.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.21-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ekman number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.21-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ek"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.21 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.21" ;
  skosxl:prefLabel isoiec80000:term-t11-4.21-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.21-0 ;
  skos:definition """quotient of viscous forces and Coriolis forces in the context of transfer of matter for the flow of a rotating fluid, expressed by

stem:[Ek = sf(ii(v))//(2l^2 omega_\"E\" \"sin\"varphi)]; where

stem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>),
stem:[l]:: is characteristic length (<<iso80000-3>>), the scale of the phenomenon,
stem:[omega_\"E\"]:: is angular frequency (<<iso80000-3>>) of the Earth's rotation, and
stem:[varphi]:: is angle of latitude
"""@en ;
  skos:note """In plasma physics, the square root of this number is used.

The Ekman number is also given by

stem:[Ek = Ro//Re]; where

stem:[Ro]:: is the Rossby number (<<t11-4.20>>), and
stem:[Re]:: is the Reynolds number (<<t11-4.1>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.22-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "elasticity number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.22-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "El"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.22 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.22" ;
  skosxl:prefLabel isoiec80000:term-t11-4.22-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.22-0 ;
  skos:definition """relation between relaxation time and diffusion time in viscoelastic flows, expressed by

stem:[El = t_\"r\" sf(ii(v))//r^2]; where

stem:[t_\"r\"]:: is relaxation time (<<iso80000-12>>),
stem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>), and
stem:[r]:: is radius (<<iso80000-3>>) of pipe
"""@en ;
  skos:note """See also Deborah number (<<t11-7.8>>)."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.23-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Darcy friction factor"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t11-4.23-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Moody friction factor"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.23-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "f_\"D\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.23 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.23" ;
  skosxl:prefLabel isoiec80000:term-t11-4.23-0 ;
  skosxl:altLabel isoiec80000:term-t11-4.23-1 ;
  skosxl:altLabel isoiec80000:sym-t11-4.23-0 ;
  skos:definition """representation of pressure loss in a pipe due to friction within a laminar or turbulent flow of a fluid in a pipe, expressed by

stem:[f_\"D\" = (2 Delta p)/(rho v^2) d/l]; where

stem:[Delta p]:: is drop of pressure (<<iso80000-4>>) due to friction,
stem:[rho]:: is mass density (<<iso80000-4>>) of the fluid,
stem:[v]:: is (average) speed (<<iso80000-3>>) of the fluid in the pipe,
stem:[d]:: is diameter (<<iso80000-3>>) of the pipe, and
stem:[l]:: is length (<<iso80000-3>>) of the pipe
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.24-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Fanning number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.24-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "f_\"n\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-4.24-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "f"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.24 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.24" ;
  skosxl:prefLabel isoiec80000:term-t11-4.24-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.24-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.24-1 ;
  skos:definition """relation between shear stress and dynamic pressure in the flow of a fluid in a containment, expressed by

stem:[f_\"n\" = (2 tau)/(rho v^2)]; where

stem:[tau]:: is shear stress (<<iso80000-4>>) at the wall,
stem:[rho]:: is mass density (<<iso80000-4>>) of the fluid, and
stem:[v]:: is speed (<<iso80000-3>>) of the fluid in the pipe
"""@en ;
  skos:note """The Fanning number describes the flow of fluids in a pipe with friction at the walls represented by its shear stress.

Symbol stem:[f] may be used where no conflicts are possible.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.25-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Goertler number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t11-4.25-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Goertler parameter"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.25-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Go"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.25 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.25" ;
  skosxl:prefLabel isoiec80000:term-t11-4.25-0 ;
  skosxl:altLabel isoiec80000:term-t11-4.25-1 ;
  skosxl:altLabel isoiec80000:sym-t11-4.25-0 ;
  skos:definition """characterization of the stability of laminar boundary layer flows in transfer of matter in a boundary layer on curved surfaces, expressed by

stem:[Go = (v l_\"b\")/sf(ii(v)) sqrt((l_\"b\"/r_\"c\"))]; where

stem:[v]:: is speed (<<iso80000-3>>),
stem:[l_\"b\"]:: is boundary layer thickness (<<iso80000-3>>),
stem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>), and
stem:[r_\"c\"]:: is radius of curvature (<<iso80000-3>>)
"""@en ;
  skos:note """The Goertler number represents the ratio of centrifugal effects to viscous effects."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.26-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Hagen number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.26-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Hg"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-4.26-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ha"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.26 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.26" ;
  skosxl:prefLabel isoiec80000:term-t11-4.26-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.26-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.26-1 ;
  skos:definition """generalization of the Grashof number for forced or free convection in laminar flow, expressed by

stem:[Hg = -1/rho (\"d\"p)/(\"d\"x) l^3/v^2]; where

stem:[rho]:: is mass density (<<iso80000-4>>) of fluid,
stem:[(\"d\"p)/(\"d\"x)]:: is gradient of pressure (<<iso80000-4>>),
stem:[l]:: is characteristic length (<<iso80000-3>>), and
stem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>)
"""@en ;
  skos:note """For free thermal convection with stem:[(\"d\"p)/(\"d\"x) = rho g alpha_\"V\" Delta T], the Hagen number then coincides with the Grashof number (<<t11-4.4>>). See also the Poiseuille number (<<t11-4.28>>)."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.27-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Laval number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.27-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "La"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.27 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.27" ;
  skosxl:prefLabel isoiec80000:term-t11-4.27-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.27-0 ;
  skos:definition """quotient of speed and the (critical) sound speed at the throat of a nozzle, expressed by

stem:[La = v // sqrt((R_\"s\"T 2 gamma)//(gamma + 1))]; where

stem:[v]:: is speed (<<iso80000-3>>),
stem:[R_\"s\" = R/M]:: is specific gas constant, where
stem:[R]::: is molar gas constant (<<iso80000-9>>), and
stem:[M]::: is molar mass (<<iso80000-9>>),
stem:[T]:: is thermodynamic temperature (<<iso80000-5>>), and
stem:[gamma]:: is ratio of the specific heat capacities (<<iso80000-5>>)
"""@en ;
  skos:note """The Laval number is a specific kind of Mach number (<<t11-4.6>>)."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.28-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Poiseuille number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.28-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Poi"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.28 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.28" ;
  skosxl:prefLabel isoiec80000:term-t11-4.28-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.28-0 ;
  skos:definition """quotient of propulsive force by pressure and viscous force for a flow of fluids in a pipe, expressed by

stem:[Poi = (Delta p)/l d^2/(eta v)]; where

stem:[Delta p]:: is drop of pressure (<<iso80000-4>>) along the pipe,
stem:[l]:: is length (<<iso80000-3>>) of the pipe,
stem:[d]:: is diameter (<<iso80000-3>>) of the pipe,
stem:[eta]:: is dynamic viscosity (<<iso80000-4>>) of the fluid, and
stem:[v]:: is characteristic speed (<<iso80000-3>>) of the fluid
"""@en ;
  skos:note """The Poiseuille number is stem:[Poi=32] for laminar flow in a round pipe.

See also the Hagen number (<<t11-4.26>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.29-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "power number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.29-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Pn"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.29 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.29" ;
  skosxl:prefLabel isoiec80000:term-t11-4.29-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.29-0 ;
  skos:definition """quotient of power consumption by agitators due to drag and rotational inertial power in fluids, expressed by

stem:[Pn = P//(rho n^3d^5)]; where

stem:[P]:: is active power (<<iec80000-6>>) consumed by a stirrer,
stem:[rho]:: is mass density (<<iso80000-4>>) of fluid,
stem:[n]:: is rotational frequency (<<iso80000-3>>), and
stem:[d]:: is diameter (<<iso80000-3>>) of stirrer
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.30-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Richardson number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.30-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ri"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.30 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.30" ;
  skosxl:prefLabel isoiec80000:term-t11-4.30-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.30-0 ;
  skos:definition """quotient of potential energy and kinetic energy for a falling body, expressed by

stem:[Ri = gh//v^2]; where

stem:[g]:: is acceleration of free fall (<<iso80000-3>>),
stem:[h]:: is characteristic height (<<iso80000-3>>), and
stem:[v]:: is characteristic speed (<<iso80000-3>>)
"""@en ;
  skos:note """In geophysics differences of these quantities are of interest."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.31-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Reech number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.31-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ree"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.31 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.31" ;
  skosxl:prefLabel isoiec80000:term-t11-4.31-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.31-0 ;
  skos:definition """relation between the speed of an object submerged in water relative to the water, and wave propagation speed, expressed by

stem:[Ree = sqrt(gl)//v]; where

stem:[g]:: is acceleration of free fall (<<iso80000-3>>),
stem:[l]:: is characteristic length (<<iso80000-3>>), and
stem:[v]:: is speed (<<iso80000-3>>) of the object relative to the water
"""@en ;
  skos:note """The Reech number can be used to determine the resistance of a partially submerged object (e.g. a ship) of length stem:[l] (in direction of the motion) moving through water.

A similar quantity is defined as the Boussinesq number stem:[Bs = v//sqrt(2gl)].
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.32-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Stokes number <time-related>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.32-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Stk"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.32 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.32" ;
  skosxl:prefLabel isoiec80000:term-t11-4.32-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.32-0 ;
  skos:definition """quotient of friction and inertia forces for particles in a fluid or in a plasma, expressed by

stem:[Stkt = t_\"r\"//t_\"a\"]; where

stem:[t_\"r\"]:: is relaxation time (<<iso80000-12>>) of particles to achieve fluid's velocity due to friction (viscosity), and
stem:[t_\"a\"]:: is time (<<iso80000-3>>) of fluid to alter its velocity under external influence
"""@en ;
  skos:note """In most cases stem:[t_\"r\"=l//v]; where stem:[l] is characteristic length, and stem:[v] is speed of fluid. The characteristic length can be the diameter of an obstacle or hole."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.33-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Stokes number <vibrating particles>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.33-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Stk_1"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.33 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.33" ;
  skosxl:prefLabel isoiec80000:term-t11-4.33-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.33-0 ;
  skos:definition """quotient of friction and inertia forces for the special case of particles vibrating in a fluid or plasma, expressed by

stem:[Stk_1 = sf(ii(v)) // (d^2f)]; where

stem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>) of the fluid or plasma,
stem:[d]:: is diameter (<<iso80000-3>>) of particle, and
stem:[f]:: is frequency (<<iso80000-3>>) of particle vibrations
"""@en ;
  skos:note """Sometimes the inverse of this number is wrongly used."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.34-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Stokes number <rotameter>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t11-4.34-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "power coefficient <rotameter>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.34-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Stk_2"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.34 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.34" ;
  skosxl:prefLabel isoiec80000:term-t11-4.34-0 ;
  skosxl:altLabel isoiec80000:term-t11-4.34-1 ;
  skosxl:altLabel isoiec80000:sym-t11-4.34-0 ;
  skos:definition """Stokes number for calibration of rotameters metering vertical flows of fluids by means of a floating body, expressed by

stem:[Stk_2 = {r^3 g m rho}/{eta^2} {(rho_{\"b\"} - rho)}/{rho_{\"b\"}} = {r^3 g m}/{v^2} (1/{rho} - 1/{rho_{\"b\"}})]; where

stem:[r]:: is ratio of pipe and float radii,
stem:[g]:: is acceleration of free fall (<<iso80000-3>>),
stem:[m]:: is mass (<<iso80000-4>>) of the body,
stem:[rho]:: is mass density (<<iso80000-4>>) of the fluid,
stem:[eta]:: is dynamic viscosity (<<iso80000-4>>) of the fluid,
stem:[rho_\"b\"]:: is mass density (<<iso80000-4>>) of the body, and
stem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>) of the fluid
"""@en ;
  skos:note """In general use, this value is multiplied by stem:[1.042].

See also the Archimedes number (<<t11-6.12>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.35-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Stokes number <gravity>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.35-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Stk_3"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.35 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.35" ;
  skosxl:prefLabel isoiec80000:term-t11-4.35-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.35-0 ;
  skos:definition """relation between viscous forces and gravity forces for particles falling in a fluid, expressed by

stem:[Stk_3 = v sf(ii(v)) // (gl^2)]; where

stem:[v]:: is characteristic speed (<<iso80000-3>>) of particles,
stem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>) of the fluid,
stem:[g]:: is acceleration of free fall (<<iso80000-3>>), and
stem:[l]:: is length (<<iso80000-3>>) of fall
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.36-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Stokes number <drag>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.36-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Stk_4"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.36 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.36" ;
  skosxl:prefLabel isoiec80000:term-t11-4.36-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.36-0 ;
  skos:definition """quotient of drag force and internal friction forces for particles dragged in a fluid

stem:[Stk_4=F_\"D\"//(eta v l)]; where

stem:[F_\"D\"]:: is drag force (<<iso80000-4>>),
stem:[eta]:: is dynamic viscosity (<<iso80000-4>>),
stem:[v]:: is speed (<<iso80000-3>>), and
stem:[l]:: is characteristic length (<<iso80000-3>>)
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.37-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Laplace number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t11-4.37-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Suratman number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.37-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "La"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-4.37-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Su"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.37 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.37" ;
  skosxl:prefLabel isoiec80000:term-t11-4.37-0 ;
  skosxl:altLabel isoiec80000:term-t11-4.37-1 ;
  skosxl:altLabel isoiec80000:sym-t11-4.37-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.37-1 ;
  skos:definition """relation between capillary forces and viscous forces when characterizing free surface flow, expressed by

stem:[La = Su = gamma p l // eta^2]; where

stem:[gamma]:: is surface tension (<<iso80000-4>>),
stem:[rho]:: is mass density (<<iso80000-4>>) of the fluid,
stem:[l]:: is characteristic length (<<iso80000-3>>), and
stem:[eta]:: is dynamic viscosity (<<iso80000-4>>) of the fluid
"""@en ;
  skos:note """The Laplace number is also the ratio of surface tension to momentum transfer, especially dissipation, inside a fluid.

The Laplace number is also given by

stem:[La = Su = 1//Oh^2 = Re^2//We]; where

stem:[Oh]:: is the Ohnesorge number (<<t11-7.4>>),
stem:[Re]:: is the Reynolds number (<<t11-4.1>>), and
stem:[We]:: is the Weber number (<<t11-4.5>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.38-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Blake number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.38-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bl"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.38 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.38" ;
  skosxl:prefLabel isoiec80000:term-t11-4.38-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.38-0 ;
  skos:definition """relation between inertial forces and viscous forces in a porous material, expressed by

stem:[Bl = (vpl)/(eta(1-epsilon))]; where

stem:[v]:: is speed (<<iso80000-3>>) of the fluid,
stem:[rho]:: is mass density (<<iso80000-4>>) of the fluid,
stem:[l]:: is characteristic length (<<iso80000-3>>) defined as the volume of a particle divided by its surface area,
stem:[eta]:: is dynamic viscosity (<<iso80000-4>>) of the fluid, and
stem:[epsilon]:: is porosity of the material (=void fraction)
"""@en ;
  skos:note """The Blake number can be interpreted as a Reynolds number for flow in porous material."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.39-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Sommerfeld number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.39-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "So"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-4.39-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Sm"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.39 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.39" ;
  skosxl:prefLabel isoiec80000:term-t11-4.39-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.39-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.39-1 ;
  skos:definition """relation between viscous force and load force in a lubrication boundary, expressed by

stem:[So = (eta n)/p (r/c)^2]; where

stem:[eta]:: is dynamic viscosity (<<iso80000-4>>) of the lubricant,
stem:[n]:: is rotational frequency (<<iso80000-3>>),
stem:[p]:: is mean bearing pressure (<<iso80000-4>>),
stem:[r]:: is radius (<<iso80000-3>>) of the shaft, and
stem:[c]:: is radial distance (<<iso80000-3>>) between rotating shaft and annulus
"""@en ;
  skos:note """Sometimes the inverse of this number is wrongly used."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.40-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Taylor number <momentum transfer>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.40-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ta"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.40 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.40" ;
  skosxl:prefLabel isoiec80000:term-t11-4.40-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.40-0 ;
  skos:definition """relation between centrifugal force and viscous force of a rotating shaft, expressed by

stem:[Ta = 4 omega^2 l^4 // sf(ii(v))^2]; where

stem:[omega]:: is angular velocity (<<iso80000-3>>) of rotation,
stem:[l]:: is length (<<iso80000-3>>) perpendicular to the rotation axis, and
stem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>)
"""@en ;
  skos:note """Sometimes the square root of this quantity is wrongly used.

The Taylor number for a rotating shaft relative to an annulus is given by

stem:[Ta_\"a\" = (omega//sf(ii(v)))^2 ra^3]; where

stem:[omega]:: is angular velocity (<<iso80000-3>>) of the shaft,
stem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>),
stem:[r = (r_2+r_1)//2]:: is mean radius (<<iso80000-3>>) of the annulus, and
stem:[a = (r_2-r_1)]:: is width of the annulus, where
stem:[r_1]::: is inner radius of the annulus, and
stem:[r_2]::: is outer radius of the annulus.

Sometimes the square root of this quantity is used; this use is deprecated.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.41-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Galilei number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.41-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ga"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.41 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.41" ;
  skosxl:prefLabel isoiec80000:term-t11-4.41-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.41-0 ;
  skos:definition """relation between gravitational force and viscous force in fluid films flowing over walls, expressed by

stem:[Ga = gl^3 // sf(ii(v))^2]; where

stem:[g]:: is acceleration of free fall (<<iso80000-3>>),
stem:[l]:: is characteristic length (<<iso80000-3>>), and
stem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>) of the fluid
"""@en ;
  skos:note """The Galilei number is also given by

stem:[Ga = Re^2 * Ri] or +
stem:[Ga = Re^2 // Fr^2]; where

stem:[Re]:: is the Reynolds number (<<t11-4.1>>),
stem:[Ri]:: is the Richardson number (<<t11-4.30>>), and
stem:[Fr]:: is the Froude number (<<t11-4.3>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

isoiec80000:term-t11-4.42-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Womersley number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-4.42-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Wo"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-4.42-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "alpha"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-4.42 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-4.42" ;
  skosxl:prefLabel isoiec80000:term-t11-4.42-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.42-0 ;
  skosxl:altLabel isoiec80000:sym-t11-4.42-1 ;
  skos:definition """relation between inertial forces and viscous forces in oscillating flows of fluids in pipes, expressed by

stem:[Wo = R sqrt(omega//sf(ii(v)))]; where

stem:[R]:: is (effective) radius (<<iso80000-3>>) of the pipe,
stem:[omega]:: is angular frequency (<<iso80000-3>>) of oscillations, and
stem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>)
"""@en ;
  skos:note """The Womersley number is used for pulsating flows e.g. in blood flow."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-4 .

@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

isoiec80000:part-11-5 a smart:PublicationDocument ;
  dcterms:title "Part 11-5"@en ;
  dcterms:identifier "ISO 80000-11-5" ;
  smart:hasPublicationType smart:internationalStandard ;
  smart:hasBindingnessType smart:normative .

isoiec80000:term-t11-5.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Fourier number <heat transfer>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-5.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Fo"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-5.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-5.1" ;
  skosxl:prefLabel isoiec80000:term-t11-5.1-0 ;
  skosxl:altLabel isoiec80000:sym-t11-5.1-0 ;
  skos:definition """relation between heat conduction rate and the rate of thermal energy storage in a body for conductive heat transfer into a body, expressed by

stem:[Fo = (alpha t)/l^2]; where

stem:[alpha]:: is thermal diffusivity (<<iso80000-5>>),
stem:[t]:: is time (<<iso80000-3>>), and
stem:[l]:: is characteristic length (<<iso80000-3>>)
"""@en ;
  skos:note """The characteristic length stem:[l] of the body is often defined as the quotient of the body's volume and its heated surface.

Sometimes the reciprocal of this number is wrongly used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-5 .

isoiec80000:term-t11-5.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Péclet number <heat transfer>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-5.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Pe"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-5.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-5.2" ;
  skosxl:prefLabel isoiec80000:term-t11-5.2-0 ;
  skosxl:altLabel isoiec80000:sym-t11-5.2-0 ;
  skos:definition """relation between convective heat transfer rate and conductive heat transfer rate, expressed by

stem:[Pe = vl//alpha]; where

stem:[v]:: is speed (<<iso80000-3>>),
stem:[l]:: is length (<<iso80000-3>>) in the direction of heat transfer, and
stem:[alpha]:: is thermal diffusivity (<<iso80000-5>>)
"""@en ;
  skos:note """The thermal Péclet number is also given by

stem:[Pe = Re * Pr]; where

stem:[Re]:: is the Reynolds number (<<t11-4.1>>), and
stem:[Pr]:: is the Prandtl number (<<t11-7.1>>).

Compare with <<t11-6.2>>, Péclet number for mass transfer.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-5 .

isoiec80000:term-t11-5.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Rayleigh number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-5.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ra"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-5.3 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-5.3" ;
  skosxl:prefLabel isoiec80000:term-t11-5.3-0 ;
  skosxl:altLabel isoiec80000:sym-t11-5.3-0 ;
  skos:definition """relation between buoyancy forces due to thermal expansion and viscous forces in free convection in buoyancy driven flow near a heated surface perpendicular to the gravity force, expressed by

stem:[Ra = (l^3 g alpha_V Delta T)/(sf(ii(v)) alpha)]; where

stem:[l]:: is distance (<<iso80000-3>>) from the wall,
stem:[g]:: is acceleration of free fall (<<iso80000-3>>),
stem:[alpha_V]:: is cubic expansion coefficient (<<iso80000-5>>) of the fluid,
stem:[Delta T]:: is difference of thermodynamic temperature (<<iso80000-5>>) between surface of the wall and the fluid far away from the wall,
stem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>) of the fluid, and
stem:[alpha]:: is thermal diffusivity (<<iso80000-5>>) of the fluid
"""@en ;
  skos:note """The Rayleigh number is also given by

stem:[Ra = Gr * Pr]; where

stem:[Gr]:: is the Grashof number (<<t11-4.4>>), and
stem:[Pr]:: is the Prandtl number (<<t11-7.1>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-5 .

isoiec80000:term-t11-5.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Froude number <heat transfer>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-5.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Fr**"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-5.4 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-5.4" ;
  skosxl:prefLabel isoiec80000:term-t11-5.4-0 ;
  skosxl:altLabel isoiec80000:sym-t11-5.4-0 ;
  skos:definition """quotient of gravitational forces and thermodiffusion forces for heat transfer in forced convection of fluids, expressed by

stem:[Fr** = (gl^3)/alpha^2]; where

stem:[g]:: is acceleration of free fall (<<iso80000-3>>),
stem:[l]:: is characteristic length (<<iso80000-3>>), and
stem:[alpha]:: is thermal diffusivity (<<iso80000-5>>)
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-5 .

isoiec80000:term-t11-5.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Nusselt number <heat transfer>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-5.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "N u"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-5.5 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-5.5" ;
  skosxl:prefLabel isoiec80000:term-t11-5.5-0 ;
  skosxl:altLabel isoiec80000:sym-t11-5.5-0 ;
  skos:definition """relation between the internal thermal resistance of a body and its surface thermal resistance in a body transferring heat from a surface into its interior or vice versa, expressed by

stem:[N]stem:[u = Kl // lambda = Kl // (alpha rho c_p)] where

stem:[K]:: is coefficient of heat transfer (<<iso80000-5>>) through the surface,
stem:[l]:: is length (<<iso80000-3>>) of the body in direction of heat flow,
stem:[lambda]:: is thermal conductivity (<<iso80000-5>>) of the surface,
stem:[alpha]:: is thermal diffusivity (<<iso80000-5>>),
stem:[rho]:: is mass density (<<iso80000-4>>), and
stem:[c_p]:: is specific heat capacity at constant pressure (<<iso80000-5>>)
"""@en ;
  skos:note """The body under consideration can be a solid body, a fluid, or their combination, and additional heat transfer due to convective motion can occur.

In case of merely conductive heat transfer especially in a solid body, the \"Biot number for heat transfer\" (<<t11-5.6>>) is used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-5 .

isoiec80000:term-t11-5.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Biot number <heat transfer>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-5.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bi"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-5.6 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-5.6" ;
  skosxl:prefLabel isoiec80000:term-t11-5.6-0 ;
  skosxl:altLabel isoiec80000:sym-t11-5.6-0 ;
  skos:definition """special case of the Nusselt number for heat transfer (item <<t11-5.5>>) in case of conductive heat transfer in a solid body, expressed by

stem:[Bi = Kl // lambda]; where

stem:[K]:: is coefficient of heat transfer (<<iso80000-5>>) through the surface,
stem:[l]:: is characteristic length (<<iso80000-3>>), and
stem:[lambda]:: is thermal conductivity (<<iso80000-5>>) of the body
"""@en ;
  skos:note """The characteristic length is commonly defined as the volume of the body divided by its surface area."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-5 .

isoiec80000:term-t11-5.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Stanton number <heat transfer>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-5.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "St"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-5.7 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-5.7" ;
  skosxl:prefLabel isoiec80000:term-t11-5.7-0 ;
  skosxl:altLabel isoiec80000:sym-t11-5.7-0 ;
  skos:definition """relation between heat transfer into a fluid from a surface and its heat transfer by convection, expressed by

stem:[St = K // (rho v c_p)]; where

stem:[K]:: is coefficient of heat transfer (<<iso80000-5>>) through the surface,
stem:[rho]:: is mass density (<<iso80000-4>>),
stem:[v]:: is speed (<<iso80000-3>>), and
stem:[c_p]:: is specific heat capacity at constant pressure (<<iso80000-5>>) of the fluid
"""@en ;
  skos:note """The Stanton number is also given by

stem:[St = N u // (Re*Pr) = N u//Pe]; where

stem:[N u]:: is Nusselt number for heat transfer (<<t11-5.5>>),
stem:[Re]:: is the Reynolds number (<<t11-4.1>>),
stem:[Pr]:: is the Prandtl number (<<t11-7.1>>), and
stem:[Pe]:: is the Péclet number (<<t11-5.2>>).

Sometimes this quantity is called Margoulis number, symbol stem:[Ms] or stem:[Mg].
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-5 .

isoiec80000:term-t11-5.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "stem:[j]-factor <heat transfer>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t11-5.8-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "heat transfer factor"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t11-5.8-2 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Colburn number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-5.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "j"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-5.8-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Co"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-5.8-2 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Jq"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-5.8 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-5.8" ;
  skosxl:prefLabel isoiec80000:term-t11-5.8-0 ;
  skosxl:altLabel isoiec80000:term-t11-5.8-1 ;
  skosxl:altLabel isoiec80000:term-t11-5.8-2 ;
  skosxl:altLabel isoiec80000:sym-t11-5.8-0 ;
  skosxl:altLabel isoiec80000:sym-t11-5.8-1 ;
  skosxl:altLabel isoiec80000:sym-t11-5.8-2 ;
  skos:definition """relation between heat transfer and mass transfer in a fluid, expressed by

stem:[j = K/(c_p rho v) ((c_p eta)/lambda)^(2//3)]; where

stem:[K]:: is coefficient of heat transfer (<<iso80000-5>>),
stem:[c_p]:: is specific heat capacity at constant pressure (<<iso80000-5>>),
stem:[rho]:: is mass density (<<iso80000-4>>),
stem:[v]:: is speed (<<iso80000-3>>),
stem:[eta]:: is dynamic viscosity (<<iso80000-4>>), and
stem:[lambda]:: is thermal conductivity (<<iso80000-5>>)
"""@en ;
  skos:note """The heat transfer factor is also given by

stem:[j=St * Pr^(2//3)]; where

stem:[St]:: is the Stanton number for heat transfer (<<t11-5.7>>), and
stem:[Pr]:: is the Prandtl number (<<t11-7.1>>).

See also mass transfer factor (<<t11-6.7>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-5 .

isoiec80000:term-t11-5.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bejan number <heat transfer>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-5.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Be_1"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-5.9 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-5.9" ;
  skosxl:prefLabel isoiec80000:term-t11-5.9-0 ;
  skosxl:altLabel isoiec80000:sym-t11-5.9-0 ;
  skos:definition """quotient of mechanical work and frictional and thermal diffusion energy losses for a forced flow, expressed by

stem:[Be_1 = (Delta pl^2)/(eta alpha)]; where

stem:[Delta p]:: is drop of pressure (<<iso80000-4>>) along a pipe,
stem:[l]:: is length (<<iso80000-3>>) of the pipe,
stem:[eta]:: is dynamic viscosity (<<iso80000-4>>), and
stem:[alpha]:: is thermal diffusivity (<<iso80000-5>>)
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-5 .

isoiec80000:term-t11-5.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bejan number <entropy>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-5.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Be_S"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-5.10 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-5.10" ;
  skosxl:prefLabel isoiec80000:term-t11-5.10-0 ;
  skosxl:altLabel isoiec80000:sym-t11-5.10-0 ;
  skos:definition """efficiency of heat transfer by a fluid, expressed by

stem:[Be_S = (S(Delta T))/(S(Delta T) + S(Delta p))]; where

stem:[S(Delta T)]:: is entropy generation contributed by heat transfer, and
stem:[S(Delta p)]:: is entropy generation contributed by fluid friction
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-5 .

isoiec80000:term-t11-5.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Stefan number <phase transition>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-5.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ste"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-5.11-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Stf"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-5.11 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-5.11" ;
  skosxl:prefLabel isoiec80000:term-t11-5.11-0 ;
  skosxl:altLabel isoiec80000:sym-t11-5.11-0 ;
  skosxl:altLabel isoiec80000:sym-t11-5.11-1 ;
  skos:definition """relation between heat content and latent heat content in a binary mixture undergoing a phase transition, expressed by

stem:[Ste = c_p Delta T // Q]; where

stem:[c_p]:: is specific heat capacity at constant pressure (<<iso80000-5>>),
stem:[Delta T]:: is difference of thermodynamic temperature stem:[T] (<<iso80000-5>>) between the phases, and
stem:[Q]:: is quotient of latent heat of phase transition (<<iso80000-5>>) and mass (<<iso80000-4>>)
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-5 .

isoiec80000:term-t11-5.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Brinkman number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-5.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Br"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-5.12-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "N_(Br)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-5.12 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-5.12" ;
  skosxl:prefLabel isoiec80000:term-t11-5.12-0 ;
  skosxl:altLabel isoiec80000:sym-t11-5.12-0 ;
  skosxl:altLabel isoiec80000:sym-t11-5.12-1 ;
  skos:definition """relation between heat produced by viscosity and heat conducted from a wall adjacent to a fluid moving relative to it, expressed by

stem:[Br = eta v^2 // (lambda Delta T)]; where

stem:[eta]:: is dynamic viscosity (<<iso80000-4>>),
stem:[v]:: is characteristic speed (<<iso80000-3>>),
stem:[lambda]:: is thermal conductivity (<<iso80000-5>>), and
stem:[Delta T = T_W - T_0]:: is difference of thermodynamic temperature stem:[T] (<<iso80000-5>>), where
stem:[T_0]:: is bulk fluid temperature, and
stem:[T_W]:: is wall temperature
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-5 .

isoiec80000:term-t11-5.13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Clausius number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-5.13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Cl"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-5.13 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-5.13" ;
  skosxl:prefLabel isoiec80000:term-t11-5.13-0 ;
  skosxl:altLabel isoiec80000:sym-t11-5.13-0 ;
  skos:definition """relation between energy transfer associated with fluid momentum and energy transfer by thermal conduction in forced heating, expressed by

stem:[Cl = v^3 l rho // (lambda Delta T)]; where

stem:[v]:: is speed (<<iso80000-3>>),
stem:[l]:: is length (<<iso80000-3>>) of the path of energy transfer,
stem:[rho]:: is mass density (<<iso80000-4>>),
stem:[lambda]:: is thermal conductivity (<<iso80000-5>>), and
stem:[Delta T]:: is difference of thermodynamic temperature stem:[T] (<<iso80000-5>>) along length stem:[l]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-5 .

isoiec80000:term-t11-5.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Carnot number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-5.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ca"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-5.14 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-5.14" ;
  skosxl:prefLabel isoiec80000:term-t11-5.14-0 ;
  skosxl:altLabel isoiec80000:sym-t11-5.14-0 ;
  skos:definition """theoretical maximum efficiency (<<iso80000-5>>) of a Carnot cycle operating between temperature reservoirs

stem:[Ca = (T_2-T_1)//T_2]; where

stem:[T]:: is thermodynamic temperature (<<iso80000-5>>), and +
stem:[T_2, T_1]:: are the thermodynamic temperatures of a heat source and a heat sink, respectively
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-5 .

isoiec80000:term-t11-5.15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Eckert number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t11-5.15-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Dulong number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-5.15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ec"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-5.15 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-5.15" ;
  skosxl:prefLabel isoiec80000:term-t11-5.15-0 ;
  skosxl:altLabel isoiec80000:term-t11-5.15-1 ;
  skosxl:altLabel isoiec80000:sym-t11-5.15-0 ;
  skos:definition """relation between the kinetic energy of a flow and its enthalpy change in fluid dynamics exhibiting dissipation, expressed by

stem:[Ec = v^2 // (c_p Delta T)]; where

stem:[v]:: is characteristic speed (<<iso80000-3>>),
stem:[c_p]:: is specific heat capacity at constant pressure (<<iso80000-5>>) of the flow, and
stem:[Delta T]:: is difference of thermodynamic temperature stem:[T] (<<iso80000-5>>) due to dissipation (by friction)
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-5 .

isoiec80000:term-t11-5.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Graetz number <heat transfer>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-5.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Gz"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-5.16 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-5.16" ;
  skosxl:prefLabel isoiec80000:term-t11-5.16-0 ;
  skosxl:altLabel isoiec80000:sym-t11-5.16-0 ;
  skos:definition """relation between heat transferred by convection and heat transferred by conduction in a laminar flow in a pipe, expressed by

stem:[Gz = (vd^2)/(alpha l)]; where

stem:[v]:: is speed (<<iso80000-3>>) of the fluid, +
stem:[d]:: is diameter (<<iso80000-3>>) of the pipe, +
stem:[alpha]:: is thermal diffusivity (<<iso80000-5>>) of the fluid, and +
stem:[l]:: is length (<<iso80000-3>>) of the pipe
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-5 .

isoiec80000:term-t11-5.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "heat transfer number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-5.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "K_Q"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-5.17 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-5.17" ;
  skosxl:prefLabel isoiec80000:term-t11-5.17-0 ;
  skosxl:altLabel isoiec80000:sym-t11-5.17-0 ;
  skos:definition """relation between heat transferred by a flow and its kinetic energy, expressed by

stem:[K_Q = Phi // (v^3l^2rho)]; where

stem:[Phi]:: is heat flow rate (<<iso80000-5>>),
stem:[v]:: is characteristic speed (<<iso80000-3>>),
stem:[l]:: is characteristic length (<<iso80000-3>>), and
stem:[rho]:: is mass density (<<iso80000-4>>)
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-5 .

isoiec80000:term-t11-5.18-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Pomerantsev number <heat transfer>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-5.18-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Po"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-5.18-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Pov"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-5.18 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-5.18" ;
  skosxl:prefLabel isoiec80000:term-t11-5.18-0 ;
  skosxl:altLabel isoiec80000:sym-t11-5.18-0 ;
  skosxl:altLabel isoiec80000:sym-t11-5.18-1 ;
  skos:definition """relation between heat generated in a body and conducted heat in the body, expressed by

stem:[Po = Q_\"m\" l^2 // (lambda Delta T)]; where

stem:[Q_\"m\"]:: is (constant) volumic heat generation rate,
stem:[l]:: is characteristic length (<<iso80000-3>>),
stem:[lambda]:: is thermal conductivity (<<iso80000-5>>), and
stem:[Delta T = T_\"m\" - T_0]:: is difference of thermodynamic temperature (<<iso80000-5>>) between that of the medium (stem:[T_\"m\"]) and the initial temperature of the body (stem:[T_0])
"""@en ;
  skos:note """Similar numbers are known for areic, lineic and point sources of heat, each with decreasing power of length stem:[l] respectively."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-5 .

isoiec80000:term-t11-5.19-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Boltzmann number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-5.19-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bz"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-5.19-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bol"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-5.19-2 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bo"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-5.19 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-5.19" ;
  skosxl:prefLabel isoiec80000:term-t11-5.19-0 ;
  skosxl:altLabel isoiec80000:sym-t11-5.19-0 ;
  skosxl:altLabel isoiec80000:sym-t11-5.19-1 ;
  skosxl:altLabel isoiec80000:sym-t11-5.19-2 ;
  skos:definition """relation between convective heat and radiant heat for a fluid in a channel, expressed by

stem:[Bz = rho v c_p // (epsilon sigma T^3)]; where

stem:[rho]:: is mass density (<<iso80000-4>>) of the fluid,
stem:[v]:: is characteristic speed (<<iso80000-3>>) of the fluid,
stem:[c_p]:: is specific heat capacity at constant pressure (<<iso80000-5>>),
stem:[epsilon]:: is emissivity (<<iso80000-7>>),
stem:[sigma]:: is the Stefan-Boltzmann constant (<<iso80000-7>>), and
stem:[T]:: is thermodynamic temperature (<<iso80000-5>>)
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-5 .

isoiec80000:term-t11-5.20-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Stark number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t11-5.20-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "DEPRECATED: Stefan number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t11-5.20-2 a smart:Term, skosxl:Label ;
  skosxl:literalForm "DEPRECATED: Biot radiation number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-5.20-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Sk"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-5.20 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-5.20" ;
  skosxl:prefLabel isoiec80000:term-t11-5.20-0 ;
  skosxl:altLabel isoiec80000:term-t11-5.20-1 ;
  skosxl:altLabel isoiec80000:term-t11-5.20-2 ;
  skosxl:altLabel isoiec80000:sym-t11-5.20-0 ;
  skos:definition """relation between radiant heat and conductive heat multiplied by the relative temperature difference for a body, expressed by

stem:[Sk = epsilon sigma T^3l//lambda]; where

stem:[epsilon]:: is emissivity (<<iso80000-7>>) of the surface,
stem:[sigma]:: is the Stefan-Boltzmann constant (<<iso80000-7>>),
stem:[T]:: is thermodynamic temperature (<<iso80000-5>>),
stem:[l]:: is characteristic length (<<iso80000-3>>), and
stem:[lambda]:: is thermal conductivity (<<iso80000-5>>)
"""@en ;
  skos:note """The relative temperature difference is defined by stem:[(Delta T)/T]; where stem:[Delta T = T_\"s\" - T_\"l\"] is the difference of the temperature at the surface, stem:[T_\"s\"], and the temperature at a layer at a distance stem:[l] from the surface, stem:[T_\"l\"].

Sometimes this characteristic number is wrongly defined without the factor stem:[epsilon].
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-5 .

@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

isoiec80000:part-11-6 a smart:PublicationDocument ;
  dcterms:title "Part 11-6"@en ;
  dcterms:identifier "ISO 80000-11-6" ;
  smart:hasPublicationType smart:internationalStandard ;
  smart:hasBindingnessType smart:normative .

isoiec80000:term-t11-6.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Fourier number <mass transfer>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-6.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Fo**"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-6.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-6.1" ;
  skosxl:prefLabel isoiec80000:term-t11-6.1-0 ;
  skosxl:altLabel isoiec80000:sym-t11-6.1-0 ;
  skos:definition """relation between diffusive mass transfer within a given duration and mass storage rate in transient mass transfer, expressed by

stem:[Fo** = (Dt)/l^2]; where

stem:[D]:: is diffusion coefficient (<<iso80000-9>>),
stem:[t]:: is duration (<<iso80000-3>>) of observation, and
stem:[l]:: is length (<<iso80000-3>>) of transfer
"""@en ;
  skos:note """The Fourier number for mass transfer is also given by

stem:[Fo** = Fo//Le]; where

stem:[Fo]:: is the Fourier number for heat transfer (<<t11-5.1>>), and
stem:[Le]:: is the Lewis number (<<t11-7.3>>).

See also the Fourier number for heat transfer (<<t11-5.1>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-6 .

isoiec80000:term-t11-6.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Péclet number <mass transfer>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t11-6.2-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bodenstein number <mass transfer>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-6.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Pe**"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-6.2-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bd"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-6.2-2 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bod"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-6.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-6.2" ;
  skosxl:prefLabel isoiec80000:term-t11-6.2-0 ;
  skosxl:altLabel isoiec80000:term-t11-6.2-1 ;
  skosxl:altLabel isoiec80000:sym-t11-6.2-0 ;
  skosxl:altLabel isoiec80000:sym-t11-6.2-1 ;
  skosxl:altLabel isoiec80000:sym-t11-6.2-2 ;
  skos:definition """relation between advective mass transfer rate and longitudinal diffusive mass transfer rate for mass transfer in reactors, expressed by

stem:[Pe** = vl//D]; where

stem:[v]:: is speed (<<iso80000-3>>),
stem:[l]:: is characteristic length (<<iso80000-3>>), and
stem:[D]:: is diffusion coefficient (<<iso80000-9>>)
"""@en ;
  skos:note """The Péclet number for mass transfer is also given by

stem:[Pe** = Pe * Le = Re * Sc]; where

stem:[Pe]:: is the Péclet number for heat transfer,
stem:[Le]:: is the Lewis number (<<t11-7.3>>),
stem:[Re]:: is the Reynolds number (<<t11-4.1>>), and
stem:[Sc]:: is the Schmidt number (<<t11-7.2>>).

Compare with <<t11-5.2>>, the Péclet number for heat transfer.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-6 .

isoiec80000:term-t11-6.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Grashof number <mass transfer>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-6.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Gr**"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-6.3 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-6.3" ;
  skosxl:prefLabel isoiec80000:term-t11-6.3-0 ;
  skosxl:altLabel isoiec80000:sym-t11-6.3-0 ;
  skos:definition """relation between buoyancy forces and viscous forces in natural convection of fluids, expressed by

stem:[Gr** = l^3 g beta Delta x // sf(ii(v))^2]; where

stem:[l]:: is characteristic length (<<iso80000-3>>),
stem:[g]:: is acceleration of free fall (<<iso80000-3>>)
stem:[beta = -(1//rho)(del rho // del x)_(T,p)], where::
stem:[rho]::: is mass density (<<iso80000-4>>) of the fluid, and
stem:[x]::: is amount-of-substance fraction (<<iso80000-9>>),
stem:[Delta x]:: is difference of amount-of-substance fraction (<<iso80000-9>>) along length stem:[l], and
stem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>)
"""@en ;
  skos:note """Instead of \"amount-of-substance fraction\" the \"amount-of-substance concentration\" (<<iso80000-9>>) is used also.

Compare with <<t11-4.4>>, the Grashof number.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-6 .

isoiec80000:term-t11-6.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Nusselt number <mass transfer>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-6.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "N u**"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-6.4 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-6.4" ;
  skosxl:prefLabel isoiec80000:term-t11-6.4-0 ;
  skosxl:altLabel isoiec80000:sym-t11-6.4-0 ;
  skos:definition """relation between mass flux at an interface and specific flux by pure molecular diffusion in a layer of thickness stem:[l] for mass transfer at the boundary of a fluid, expressed by

stem:[N u** = k'l//(rho D)]; where

stem:[k']:: is mass flux density stem:[q_m//A] through the surface, where
stem:[q_m]::: is mass flow rate (<<iso80000-4>>), and
stem:[A]::: is area (<<iso80000-3>>),
stem:[l]:: is thickness (<<iso80000-3>>),
stem:[rho]:: is mass density (<<iso80000-4>>) of the fluid, and
stem:[D]:: is diffusion coefficient (<<iso80000-9>>)
"""@en ;
  skos:note """Sometimes this quantity is called the Sherwood number, stem:[Sh]. +

Compare with <<t11-5.5>>, Nusselt number for heat transfer.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-6 .

isoiec80000:term-t11-6.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Stanton number <mass transfer>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-6.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "St**"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-6.5 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-6.5" ;
  skosxl:prefLabel isoiec80000:term-t11-6.5-0 ;
  skosxl:altLabel isoiec80000:sym-t11-6.5-0 ;
  skos:definition """relation between mass transfer perpendicular to the surface of a fluid flow and mass transfer parallel to the surface in a free surface flow, expressed by

stem:[St** = k'//(rho v)]; where

stem:[k']:: is mass flux density stem:[q_m//A] through the surface, where
stem:[q_m]::: is mass flow rate (<<iso80000-4>>), and
stem:[A]::: is area (<<iso80000-3>>),
stem:[rho]:: is mass density (<<iso80000-4>>), and
stem:[v]:: is speed (<<iso80000-3>>)
"""@en ;
  skos:note """The Stanton number for mass transfer is also given by stem:[St** = N]stem:[u** // Pe**]; where

stem:[N u**]:: is the Nusselt number for mass transfer (<<t11-6.4>>), and +
stem:[Pe**]:: is the Péclet number for mass transfer (<<t11-6.2>>).

Compare with <<t11-5.7>>, the Stanton number for heat transfer.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-6 .

isoiec80000:term-t11-6.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Graetz number <mass transfer>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-6.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Gz**"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-6.6 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-6.6" ;
  skosxl:prefLabel isoiec80000:term-t11-6.6-0 ;
  skosxl:altLabel isoiec80000:sym-t11-6.6-0 ;
  skos:definition """quotient of advective mass transfer rate and radial diffusive mass transfer rate for mass transfer in pipes, expressed by

stem:[Gz** = (vd)/D = d/l Pe**]; where

stem:[v]:: is characteristic speed (<<iso80000-3>>) of the fluid,
stem:[d]:: is hydraulic diameter (<<iso80000-3>>) of the pipe,
stem:[D]:: is diffusion coefficient (<<iso80000-9>>),
stem:[l]:: is length (<<iso80000-3>>) of the pipe, and
stem:[Pe**]:: is the Péclet number for mass transfer (<<t11-6.2>>)
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-6 .

isoiec80000:term-t11-6.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "mass transfer factor"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t11-6.7-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "stem:[j]-factor <mass transfer>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-6.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "j**"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-6.7 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-6.7" ;
  skosxl:prefLabel isoiec80000:term-t11-6.7-0 ;
  skosxl:altLabel isoiec80000:term-t11-6.7-1 ;
  skosxl:altLabel isoiec80000:sym-t11-6.7-0 ;
  skos:definition """relation between mass transfer perpendicular to the surface of a fluid and mass transfer parallel to the surface in an open flow of fluids, expressed by

stem:[j** = k/v (sf(ii(v))/D)^(2//3)]; where

stem:[k]:: is the mass transfer coefficient through the surface, stem:[k=k'//rho], where
stem:[rho]::: is mass density (<<iso80000-4>>),
stem:[k']::: is mass flux density stem:[q_m//A] through the surface, where
stem:[q_m]:::: is mass flow rate (<<iso80000-4>>), and
stem:[A]:::: is area (<<iso80000-3>>),
stem:[v]:: is speed (<<iso80000-3>>),
stem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>), and
stem:[D]:: is diffusion coefficient (<<iso80000-9>>)
"""@en ;
  skos:note """The mass transfer factor is also given by

stem:[j_m = j** = St** * Sc^(2//3)]; where

stem:[St**]:: is the Stanton number for mass transfer (<<t11-6.5>>), and
stem:[Sc]:: is the Schmidt number (<<t11-7.2>>).

See also heat transfer factor (<<t11-5.17>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-6 .

isoiec80000:term-t11-6.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Atwood number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-6.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "At"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-6.8 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-6.8" ;
  skosxl:prefLabel isoiec80000:term-t11-6.8-0 ;
  skosxl:altLabel isoiec80000:sym-t11-6.8-0 ;
  skos:definition """scaled density difference of heavier and lighter fluids, expressed by

stem:[At = (rho_1 - rho_2)/(rho_1 + rho_2)]; where

stem:[rho_1]:: is density of heavier fluid, and
stem:[rho_2]:: is density of lighter fluid
"""@en ;
  skos:note """The Atwood number is used in the study of hydrodynamic instabilities in density stratified flows."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-6 .

isoiec80000:term-t11-6.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Biot number <mass transfer>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-6.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bi**"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-6.9 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-6.9" ;
  skosxl:prefLabel isoiec80000:term-t11-6.9-0 ;
  skosxl:altLabel isoiec80000:sym-t11-6.9-0 ;
  skos:definition """relation between mass transfer rate at the interface and mass transfer rate in the interior of a body, expressed by

stem:[Bi** = kl//D_\"int\"]; where

stem:[k]:: is the mass transfer coefficient through the surface, stem:[k=k'//rho], where
stem:[rho]::: is mass density (<<iso80000-4>>),
stem:[k']::: is mass flux density stem:[q_m//A] through the surface, where
stem:[q_m]:::: is mass flow rate (<<iso80000-4>>), and
stem:[A]:::: is area (<<iso80000-3>>),
stem:[l]:: is thickness (<<iso80000-3>>) of layer, and
stem:[D_\"int\"]:: is diffusion coefficient (<<iso80000-9>>) at the interface
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-6 .

isoiec80000:term-t11-6.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Morton number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-6.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Mo"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-6.10 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-6.10" ;
  skosxl:prefLabel isoiec80000:term-t11-6.10-0 ;
  skosxl:altLabel isoiec80000:sym-t11-6.10-0 ;
  skos:definition """quotient of gravitational forces and viscous forces for gas bubbles in a liquid, or liquid drops in a gas, expressed by

stem:[Mo = (g eta^4)/(rho gamma^3) (rho_\"b\"/rho -1)]; where

stem:[g]:: is acceleration of free fall (<<iso80000-3>>),
stem:[eta]:: is dynamic viscosity (<<iso80000-4>>) of the surrounding fluid,
stem:[rho]:: is mass density (<<iso80000-4>>) of the surrounding fluid,
stem:[gamma]:: is surface tension (<<iso80000-4>>) of the interface, and
stem:[rho_b]:: is mass density (<<iso80000-4>>) of the bubble or drop
"""@en ;
  skos:note """The Morton number is used to determine the shape of bubbles or drops.

The Morton number is also given by

stem:[Mo = We^3 Fr^(-2)Re^(-4)]; where

stem:[We]:: is the Weber number (<<t11-4.5>>),
stem:[Fr]:: is the Froude number (<<t11-4.3>>), and
stem:[Re]:: is the Reynolds number (<<t11-4.1>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-6 .

isoiec80000:term-t11-6.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bond number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t11-6.11-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Eötvös number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-6.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bo"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-6.11-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Eo"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-6.11 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-6.11" ;
  skosxl:prefLabel isoiec80000:term-t11-6.11-0 ;
  skosxl:altLabel isoiec80000:term-t11-6.11-1 ;
  skosxl:altLabel isoiec80000:sym-t11-6.11-0 ;
  skosxl:altLabel isoiec80000:sym-t11-6.11-1 ;
  skos:definition """quotient of inertial force and capillary force for gas bubbles or liquid drops in a fluid, expressed by

stem:[Bo = a/gamma rho l^2 (rho_\"b\"/rho -1)]; where

stem:[a]:: is the acceleration of the body (<<iso80000-3>>), mostly acceleration of free fall, stem:[g] (<<iso80000-3>>),
stem:[gamma]:: is surface tension (<<iso80000-4>>) of the interface,
stem:[rho]:: is density (<<iso80000-4>>) of the medium,
stem:[l]:: is characteristic length (<<iso80000-3>>) (radius of a drop or radius of a capillary tube), and
stem:[rho_\"b\"]:: is mass density (<<iso80000-4>>) of the drop or bubble
"""@en ;
  skos:note """In the case of gravity stem:[a = g] acceleration of free fall (<<iso80000-3>>), the name Eötvös number is mostly used.

The Bond number is also given by

stem:[Bo = We//Fr]; where

stem:[We]:: is the Weber number (<<t11-4.5>>), and
stem:[Fr]:: is the Froude number (<<t11-4.3>>).

The Bond number is also used for capillary action driven by buoyancy.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-6 .

isoiec80000:term-t11-6.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Archimedes number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-6.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ar"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-6.12 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-6.12" ;
  skosxl:prefLabel isoiec80000:term-t11-6.12-0 ;
  skosxl:altLabel isoiec80000:sym-t11-6.12-0 ;
  skos:definition """quotient of buoyancy forces and viscous forces in fluids motion due to density differences for a body in a fluid, expressed by

stem:[Ar = (gl^3)/sf(ii(v))^2 (rho_\"b\"/rho - 1)]; where

stem:[g]:: is acceleration of free fall (<<iso80000-3>>),
stem:[l]:: is characteristic length (<<iso80000-3>>) of the body,
stem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>) of the fluid,
stem:[rho_\"b\"]:: is mass density (<<iso80000-4>>) of the body, and
stem:[rho]:: is mass density (<<iso80000-4>>) of the fluid
"""@en ;
  skos:note """In this definition, the body can be replaced by an immiscible fluid.

See also Stokes number <rotameter> (<<t11-4.34>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-6 .

isoiec80000:term-t11-6.13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "expansion number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-6.13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ex"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-6.13 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-6.13" ;
  skosxl:prefLabel isoiec80000:term-t11-6.13-0 ;
  skosxl:altLabel isoiec80000:sym-t11-6.13-0 ;
  skos:definition """quotient of buoyancy force and inertial force in moving fluids due to density differences for gas bubbles rising in a liquid, expressed by

stem:[Ex = (gd)/v^2 (1-rho_\"b\"/rho)]; where

stem:[g]:: is acceleration of free fall (<<iso80000-3>>),
stem:[d]:: is diameter (<<iso80000-3>>) of bubbles,
stem:[v]:: is speed (<<iso80000-3>>) of bubbles,
stem:[rho_\"b\"]:: is mass density (<<iso80000-4>>) of bubbles, and
stem:[rho]:: is mass density (<<iso80000-4>>) of the liquid
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-6 .

isoiec80000:term-t11-6.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Marangoni number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-6.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Mg"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-6.14-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Mar"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-6.14 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-6.14" ;
  skosxl:prefLabel isoiec80000:term-t11-6.14-0 ;
  skosxl:altLabel isoiec80000:sym-t11-6.14-0 ;
  skosxl:altLabel isoiec80000:sym-t11-6.14-1 ;
  skos:definition """quotient of heat transferred by Marangoni convection and heat transferred by thermal diffusivity in thermo-capillary convection of liquid films on a free surface, expressed by

stem:[Mg = l (Delta T)/(eta a) ((\"d\"gamma)/(\"d\"T))]; where

stem:[l]:: is characteristic thickness (<<iso80000-3>>) of the film,
stem:[Delta T]:: is difference of thermodynamic temperature stem:[T] (<<iso80000-5>>) between surface and outer surface of the film,
stem:[eta]:: is dynamic viscosity (<<iso80000-4>>) of the liquid,
stem:[a]:: is thermal diffusivity (<<iso80000-5>>) of the liquid, and
stem:[gamma]:: is surface tension (<<iso80000-4>>) of the film
"""@en ;
  skos:note """The Marangoni convection is free surface flow due to different surface tensions caused by a temperature gradient.

This quantity is sometimes called Thompson number.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-6 .

isoiec80000:term-t11-6.15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Lockhart-Martinelli parameter"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-6.15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Lp"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-6.15 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-6.15" ;
  skosxl:prefLabel isoiec80000:term-t11-6.15-0 ;
  skosxl:altLabel isoiec80000:sym-t11-6.15-0 ;
  skos:definition """quotient of mass flow rates multiplied by the square root of density in a two-phase flow, expressed by

stem:[Lp = (dot m_\"1\")/(dot m_\"g\") sqrt(rho_\"g\"/rho_\"l\")]; where

stem:[dot m_\"l\" = q_\"m\"]:: is liquid phase mass flow rate (<<iso80000-4>>),
stem:[dot m_\"g\"]:: is gas phase mass flow rate,
stem:[rho_\"g\"]:: is gas density (<<iso80000-4>>), and
stem:[rho_\"l\"]:: is liquid density
"""@en ;
  skos:note """The Lockhart-Martinelli parameter is used, for example, in boiling or condensing."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-6 .

isoiec80000:term-t11-6.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bejan number <mass transfer>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-6.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Be**"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-6.16-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Be_2"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-6.16 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-6.16" ;
  skosxl:prefLabel isoiec80000:term-t11-6.16-0 ;
  skosxl:altLabel isoiec80000:sym-t11-6.16-0 ;
  skosxl:altLabel isoiec80000:sym-t11-6.16-1 ;
  skos:definition """quotient of mechanical work and frictional and diffusion energy loss in viscous flow of fluids in pipes, expressed by

stem:[Be** = (Delta pl^2)/(eta D)]; where

stem:[Delta p]:: is drop of pressure (<<iso80000-4>>) along a pipe or channel,
stem:[l]:: is length (<<iso80000-3>>) of channel,
stem:[eta]:: is dynamic viscosity (<<iso80000-4>>) of the fluid, and
stem:[D]:: is diffusion coefficient (<<iso80000-9>>), mass diffusivity
"""@en ;
  skos:note """A similar quantity exists for heat transfer (<<t11-5.9>>)."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-6 .

isoiec80000:term-t11-6.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "cavitation number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-6.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ca"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-6.17-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Cn"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-6.17 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-6.17" ;
  skosxl:prefLabel isoiec80000:term-t11-6.17-0 ;
  skosxl:altLabel isoiec80000:sym-t11-6.17-0 ;
  skosxl:altLabel isoiec80000:sym-t11-6.17-1 ;
  skos:definition """quotient of the excess of local static head over vapour pressure head and velocity head for fast flow in liquids, expressed by

stem:[Ca = (p-p_\"v\")/(rho v^2//2)]; where

stem:[p]:: is local static pressure (<<iso80000-4>>),
stem:[p_\"v\"]:: is vapour pressure (<<iso80000-4>>) of the fluid,
stem:[rho]:: is mass density (<<iso80000-4>>) of the fluid, and
stem:[v]:: is characteristic speed (<<iso80000-3>>) of the flow
"""@en ;
  skos:note """The cavitation number represents the ratio of the excess of local static head over vapour pressure head to velocity head."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-6 .

isoiec80000:term-t11-6.18-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "absorption number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-6.18-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ab"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-6.18 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-6.18" ;
  skosxl:prefLabel isoiec80000:term-t11-6.18-0 ;
  skosxl:altLabel isoiec80000:sym-t11-6.18-0 ;
  skos:definition """relation between mass flow rate and surface area for gas absorption at wetted walls, expressed by

stem:[Ab = k sqrt((ld)/(Dq_V))]; where

stem:[k]:: is the mass transfer coefficient through the surface, stem:[k=k'//rho], where
stem:[rho]::: is mass density (<<iso80000-4>>), and
stem:[k']::: is mass flux density through the surface, stem:[k' = q_\"m\"//A], where
stem:[q_\"m\"]:::: is mass flow rate (<<iso80000-4>>), and
stem:[A]:::: is area (<<iso80000-3>>),
stem:[l]:: is length (<<iso80000-3>>) of wetted surface,
stem:[d]:: is thickness (<<iso80000-3>>) of liquid film,
stem:[D]:: is diffusion coefficient (<<iso80000-9>>), and
stem:[q_V]:: is volume flow rate (<<iso80000-4>>) per wetted perimeter
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-6 .

isoiec80000:term-t11-6.19-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "capillary number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-6.19-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ca"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-6.19 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-6.19" ;
  skosxl:prefLabel isoiec80000:term-t11-6.19-0 ;
  skosxl:altLabel isoiec80000:sym-t11-6.19-0 ;
  skos:definition """quotient of gravitational forces and capillary forces for fluids in narrow pipes, expressed by

stem:[Ca = d^2 rho g//gamma]; where

stem:[d]:: is diameter (<<iso80000-3>>) of the pipe,
stem:[rho]:: is mass density (<<iso80000-4>>) of the fluid,
stem:[g]:: is acceleration of free fall (<<iso80000-3>>), and
stem:[gamma]:: is surface tension (<<iso80000-4>>) of the fluid
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-6 .

isoiec80000:term-t11-6.20-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "dynamic capillary number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-6.20-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ca**"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-6.20-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Cn"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-6.20 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-6.20" ;
  skosxl:prefLabel isoiec80000:term-t11-6.20-0 ;
  skosxl:altLabel isoiec80000:sym-t11-6.20-0 ;
  skosxl:altLabel isoiec80000:sym-t11-6.20-1 ;
  skos:definition """quotient of viscous force and capillary force acting across an interface between a liquid and a gas, or between two immiscible liquids for a flow of fluid influenced by interfacial tension, expressed by

stem:[Ca** = eta v//gamma]; where

stem:[eta]:: is dynamic viscosity (<<iso80000-4>>) of the fluid,
stem:[v]:: is characteristic speed (<<iso80000-3>>), and
stem:[gamma]:: is surface or interfacial tension (<<iso80000-4>>)
"""@en ;
  skos:note """The dynamic capillary number is also given by the quotient of the Weber number and the Reynolds number."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-6 .

@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

isoiec80000:part-11-7 a smart:PublicationDocument ;
  dcterms:title "Part 11-7"@en ;
  dcterms:identifier "ISO 80000-11-7" ;
  smart:hasPublicationType smart:internationalStandard ;
  smart:hasBindingnessType smart:normative .

isoiec80000:term-t11-7.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Prandtl number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-7.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Pr"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-7.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-7.1" ;
  skosxl:prefLabel isoiec80000:term-t11-7.1-0 ;
  skosxl:altLabel isoiec80000:sym-t11-7.1-0 ;
  skos:definition """quotient of kinematic viscosity and thermal diffusivity for a fluid, expressed by

stem:[Pr = sf(ii(v))//a]; where

stem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>), and
stem:[a]:: is thermal diffusivity (<<iso80000-5>>)
"""@en ;
  skos:note """The Prandtl number also represents the quotient of heat produced by viscosity and heat transferred by thermal diffusivity.

The mass transfer analogue of the Prandtl number is the Schmidt number (<<t11-7.2>>).

The Prandtl number is also given by

stem:[Pr = Pe//Re]; where

stem:[Pe]:: is the Péclet number (<<t11-5.2>>), and
stem:[Re]:: is the Reynolds number (<<t11-4.1>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-7 .

isoiec80000:term-t11-7.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Schmidt number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t11-7.2-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "DEPRECATED: Colburn number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-7.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Sc"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-7.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-7.2" ;
  skosxl:prefLabel isoiec80000:term-t11-7.2-0 ;
  skosxl:altLabel isoiec80000:term-t11-7.2-1 ;
  skosxl:altLabel isoiec80000:sym-t11-7.2-0 ;
  skos:definition """quotient of kinematic viscosity and diffusion coefficient for a fluid, expressed by

stem:[Sc = sf(ii(v))//D]; where

stem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>), and
stem:[D]:: is diffusion coefficient (<<iso80000-9>>)
"""@en ;
  skos:note """The heat transfer analogue of the Schmidt number is the Prandtl number (<<t11-7.1>>)."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-7 .

isoiec80000:term-t11-7.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Lewis number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-7.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Le"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-7.3 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-7.3" ;
  skosxl:prefLabel isoiec80000:term-t11-7.3-0 ;
  skosxl:altLabel isoiec80000:sym-t11-7.3-0 ;
  skos:definition """quotient of thermal diffusivity and diffusion coefficient for heat transfer in a fluid, expressed by

stem:[Le = a//D]; where

stem:[a]:: is thermal diffusivity (<<iso80000-5>>), and
stem:[D]:: is diffusion coefficient (<<iso80000-9>>)
"""@en ;
  skos:note """The Lewis number is also given by

stem:[Le = Sc//Pr]; where

stem:[Sc]:: is the Schmidt number (<<t11-7.2>>), and
stem:[Pr]:: is the Prandtl number (<<t11-7.1>>).

Compare with <<t11-5.2>>.

The Lewis number is sometimes defined as reciprocal of this quantity.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-7 .

isoiec80000:term-t11-7.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ohnesorge number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-7.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Oh"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-7.4 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-7.4" ;
  skosxl:prefLabel isoiec80000:term-t11-7.4-0 ;
  skosxl:altLabel isoiec80000:sym-t11-7.4-0 ;
  skos:definition """relation between viscous force and the square root of the product of inertia force and capillary force for atomization of liquids, expressed by

stem:[Oh = eta/(sqrt(gamma rho l))]; where

stem:[eta]:: is dynamic viscosity (<<iso80000-4>>),
stem:[gamma]:: is surface tension (<<iso80000-4>>),
stem:[rho]:: is mass density (<<iso80000-4>>), and
stem:[l]:: is characteristic length (<<iso80000-3>>)
"""@en ;
  skos:note """The Ohnesorge number is also given by

stem:[Oh = sqrt(We)//Re]; where

stem:[We]:: is the Weber number (<<t11-4.5>>), and
stem:[Re]:: is the Reynolds number (<<t11-4.1>>).

See also Laplace number (<<t11-4.37>>).

The characteristic length typically is the drop diameter.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-7 .

isoiec80000:term-t11-7.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Cauchy number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t11-7.5-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "aeroelasticity parameter"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-7.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Cy"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-7.5 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-7.5" ;
  skosxl:prefLabel isoiec80000:term-t11-7.5-0 ;
  skosxl:altLabel isoiec80000:term-t11-7.5-1 ;
  skosxl:altLabel isoiec80000:sym-t11-7.5-0 ;
  skos:definition """relation between inertia forces and compression forces in compressible fluids, expressed by

stem:[Cy = rho v^2//K]; where

stem:[rho]:: is mass density (<<iso80000-4>>),
stem:[v]:: is speed (<<iso80000-3>>), and
stem:[K]:: is modulus of compression, bulk modulus (<<iso80000-4>>)
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-7 .

isoiec80000:term-t11-7.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Hooke number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-7.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ho_2"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-7.6 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-7.6" ;
  skosxl:prefLabel isoiec80000:term-t11-7.6-0 ;
  skosxl:altLabel isoiec80000:sym-t11-7.6-0 ;
  skos:definition """relation between inertia forces and linear stress forces in elastic fluids, expressed by

stem:[Ho_2 = rho v^2 // E]; where

stem:[rho]:: is mass density (<<iso80000-4>>),
stem:[v]:: is speed (<<iso80000-3>>), and
stem:[E]:: is modulus of elasticity (<<iso80000-4>>)
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-7 .

isoiec80000:term-t11-7.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Weissenberg number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-7.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Wi"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-7.7 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-7.7" ;
  skosxl:prefLabel isoiec80000:term-t11-7.7-0 ;
  skosxl:altLabel isoiec80000:sym-t11-7.7-0 ;
  skos:definition """product of time derivative of shear rate and relaxation time in viscoelastic flows, expressed by

stem:[Wi = dot gamma t_\"r\"]; where

stem:[dot gamma]:: is time derivative of shear strain (<<iso80000-4>>), and
stem:[t_\"r\"]:: is relaxation time (<<iso80000-12>>)
"""@en ;
  skos:note """The Weissenberg number represents the relative importance of viscous forces when compared to elastic forces.

The time derivative of shear strain is sometimes called the shear rate.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-7 .

isoiec80000:term-t11-7.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Deborah number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-7.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "De"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-7.8 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-7.8" ;
  skosxl:prefLabel isoiec80000:term-t11-7.8-0 ;
  skosxl:altLabel isoiec80000:sym-t11-7.8-0 ;
  skos:definition """quotient of relaxation time of viscoelastic fluids and observation duration in rheology of viscoelastic fluids, expressed by

stem:[De = t_\"c\"//t_\"p\"]; where

stem:[t_\"c\"]:: is stress relaxation time, and
stem:[t_\"p\"]:: is observation duration (<<iso80000-3>>)
"""@en ;
  skos:note """The stress relaxation time is sometimes called the Maxwell relaxation time."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-7 .

isoiec80000:term-t11-7.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Lorentz number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-7.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Lo"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-7.9 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-7.9" ;
  skosxl:prefLabel isoiec80000:term-t11-7.9-0 ;
  skosxl:altLabel isoiec80000:sym-t11-7.9-0 ;
  skos:definition """quotient of electrical conductivity and thermal conductivity, expressed by

stem:[Lo = (sigma (Delta U)^2)/(lambda Delta T)]; where

stem:[sigma]:: is electrical conductivity (<<iec80000-6>>),
stem:[Delta U]:: is difference of voltage stem:[U] (<<iec80000-6>>) between two reference points,
stem:[lambda]:: is thermal conductivity (<<iso80000-5>>), and
stem:[Delta T]:: is difference in thermodynamic temperature stem:[T] (<<iso80000-5>>) between the reference points
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-7 .

isoiec80000:term-t11-7.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "compressibility number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-7.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Z"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-7.10 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-7.10" ;
  skosxl:prefLabel isoiec80000:term-t11-7.10-0 ;
  skosxl:altLabel isoiec80000:sym-t11-7.10-0 ;
  skos:definition """quotient of isothermal compressibility (<<iso80000-5>>) of a gas and that of an ideal gas, expressed by

stem:[Z=p/(rho R_\"s\"T)]; where

stem:[p]:: is pressure (<<iso80000-4>>),
stem:[rho]:: is mass density (<<iso80000-4>>),
stem:[R_\"s\"]:: is specific gas constant (<<iso80000-5>>), and
stem:[T]:: is thermodynamic temperature (<<iso80000-5>>)
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-7 .

@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

isoiec80000:part-11-8 a smart:PublicationDocument ;
  dcterms:title "Part 11-8"@en ;
  dcterms:identifier "ISO 80000-11-8" ;
  smart:hasPublicationType smart:internationalStandard ;
  smart:hasBindingnessType smart:normative .

isoiec80000:term-t11-8.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Reynolds magnetic number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-8.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Rm"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-8.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-8.1" ;
  skosxl:prefLabel isoiec80000:term-t11-8.1-0 ;
  skosxl:altLabel isoiec80000:sym-t11-8.1-0 ;
  skos:definition """relation between inertial force and magneto-dynamic viscous force in an electrically conducting fluid, expressed by

stem:[Rm = vl mu sigma = vl // sf(ii(v))_\"m\"]; where

stem:[v]:: is speed (<<iso80000-3>>) of the fluid,
stem:[l]:: is characteristic length (<<iso80000-3>>),
stem:[mu]:: is magnetic permeability (<<iec80000-6>>),
stem:[sigma]:: is electrical conductivity (<<iec80000-6>>), and
stem:[sf(ii(v))_\"m\" = 1//(mu sigma)]:: is magnetic viscosity (magnetic diffusivity)
"""@en ;
  skos:note """This number is also called magnetic Reynolds number.

The Reynolds magnetic number is also given by

stem:[Rm = Re * Pr_\"m\"]; where

stem:[Re]:: is the Reynolds number (<<t11-4.1>>), and
stem:[Pr_\"m\"]:: is the Prandtl magnetic number (<<t11-8.10>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-8 .

isoiec80000:term-t11-8.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Batchelor number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-8.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bt"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-8.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-8.2" ;
  skosxl:prefLabel isoiec80000:term-t11-8.2-0 ;
  skosxl:altLabel isoiec80000:sym-t11-8.2-0 ;
  skos:definition """relation between inertia and magneto-dynamic diffusion in an electrically conducting liquid, expressed by

stem:[Bt = v l sigma mu // (epsilon_\"r\" mu_\"r\")]; where

stem:[v]:: is speed (<<iso80000-3>>),
stem:[l]:: is characteristic length (<<iso80000-3>>),
stem:[sigma]:: is electrical conductivity (<<iec80000-6>>),
stem:[mu]:: is magnetic permeability (<<iec80000-6>>),
stem:[epsilon_\"r\"]:: is relative permittivity (<<iec80000-6>>), and
stem:[mu_\"r\"]:: is relative permeability (<<iec80000-6>>)
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-8 .

isoiec80000:term-t11-8.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Nusselt electric number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-8.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ne"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-8.3 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-8.3" ;
  skosxl:prefLabel isoiec80000:term-t11-8.3-0 ;
  skosxl:altLabel isoiec80000:sym-t11-8.3-0 ;
  skos:definition """relation between convective current and diffusive current of ions in electrochemistry, expressed by

stem:[Ne = vl//D**]; where

stem:[v]:: is speed (<<iso80000-3>>),
stem:[l]:: is characteristic length (<<iso80000-3>>), and
stem:[D** = (D^+ + D^-)//2]; where::
stem:[D^+], stem:[D^-]::: are diffusion coefficients (<<iso80000-9>>) of positive or negative ions respectively
"""@en ;
  skos:note """This number is also called electric Nusselt number.

Sometimes this quantity is called the Reynolds electric number.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-8 .

isoiec80000:term-t11-8.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Alfvén number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t11-8.4-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Mach magnetic number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t11-8.4-2 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Kárman number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-8.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Al"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-8.4 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-8.4" ;
  skosxl:prefLabel isoiec80000:term-t11-8.4-0 ;
  skosxl:altLabel isoiec80000:term-t11-8.4-1 ;
  skosxl:altLabel isoiec80000:term-t11-8.4-2 ;
  skosxl:altLabel isoiec80000:sym-t11-8.4-0 ;
  skos:definition """relation between speed of a plasma and the Alfvén wave speed, expressed by

stem:[Al = v/(B//sqrt(rho mu))]; where

stem:[v]:: is speed (<<iso80000-3>>),
stem:[B]:: is magnetic flux density (<<iec80000-6>>),
stem:[rho]:: is mass density (<<iso80000-4>>), and
stem:[mu]:: is magnetic permeability (<<iec80000-6>>)
"""@en ;
  skos:note """Often, the inverse of this number is wrongly used.

The name \"Alfvén Mach number\" is used in investigations on the solar wind.

The quantity stem:[v_\"A\"=B//sqrt(rho mu)] is called Alfvén wave speed, where

stem:[B]:: is magnetic flux density (<<iec80000-6>>),
stem:[rho]:: is mass density (<<iso80000-4>>), and
stem:[mu]:: is magnetic permeability (<<iec80000-6>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-8 .

isoiec80000:term-t11-8.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Hartmann number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-8.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ha"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-8.5 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-8.5" ;
  skosxl:prefLabel isoiec80000:term-t11-8.5-0 ;
  skosxl:altLabel isoiec80000:sym-t11-8.5-0 ;
  skos:definition """relation between magnetically induced stress and hydrodynamic shear stress in an electrically conducting fluid, expressed by

stem:[Ha = Bl sqrt((sigma//mu))]; where

stem:[B]:: is magnetic flux density (<<iec80000-6>>),
stem:[l]:: is characteristic length (<<iso80000-3>>),
stem:[sigma]:: is electrical conductivity (<<iec80000-6>>), and
stem:[mu]:: is dynamic viscosity (<<iso80000-4>>)
"""@en ;
  skos:note """The Hartmann number represents also the ratio of magnetic force to viscous force."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-8 .

isoiec80000:term-t11-8.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Cowling number <magnetism>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t11-8.6-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Euler magnetic number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-8.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Co"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-8.6 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-8.6" ;
  skosxl:prefLabel isoiec80000:term-t11-8.6-0 ;
  skosxl:altLabel isoiec80000:term-t11-8.6-1 ;
  skosxl:altLabel isoiec80000:sym-t11-8.6-0 ;
  skos:definition """quotient of magnetic and kinematic energy density in a plasma, expressed by

stem:[Co = B^2 // (mu rho v^2)]; where

stem:[B]:: is magnetic flux density (<<iec80000-6>>),
stem:[mu]:: is magnetic permeability (<<iec80000-6>>),
stem:[rho]:: is mass density (<<iso80000-4>>), and
stem:[v]:: is speed (<<iso80000-3>>)
"""@en ;
  skos:note """The Cowling number also represents the ratio of magnetic to dynamic pressure.

This quantity is equal to the square of the inverse of the Alfvén number.

This quantity is often called the second Cowling number, stem:[Co_2].

The first Cowling number is then defined as stem:[Co_1 = Co * Rm]; where stem:[Rm] is the Reynolds magnetic number (<<t11-8.1>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-8 .

isoiec80000:term-t11-8.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Stuart electrical number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-8.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Se"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-8.7 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-8.7" ;
  skosxl:prefLabel isoiec80000:term-t11-8.7-0 ;
  skosxl:altLabel isoiec80000:sym-t11-8.7-0 ;
  skos:definition """quotient of electric energy density and kinematic energy density in a plasma, expressed by

stem:[Se = epsilon E^2 // (rho v^2)]; where

stem:[epsilon]:: is electric permittivity (<<iec80000-6>>),
stem:[E]:: is electric field strength (<<iec80000-6>>),
stem:[rho]:: is mass density (<<iso80000-4>>), and
stem:[v]:: is speed (<<iso80000-3>>)
"""@en ;
  skos:note """The Stuart electrical number is the electrical counterpart of the Cowling number (<<t11-8.6>>)."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-8 .

isoiec80000:term-t11-8.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "magnetic pressure number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-8.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "N_(m p)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-8.8 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-8.8" ;
  skosxl:prefLabel isoiec80000:term-t11-8.8-0 ;
  skosxl:altLabel isoiec80000:sym-t11-8.8-0 ;
  skos:definition """quotient of gas pressure and magnetic pressure in a gas or plasma, expressed by

stem:[N_(m p) = p (2mu)/B^2]; where

stem:[p]:: is pressure (<<iso80000-4>>),
stem:[mu]:: is magnetic permeability (<<iec80000-6>>), and
stem:[B]:: is magnetic flux density (<<iec80000-6>>)
"""@en ;
  skos:note """The quantity stem:[p_\"m\" = B^2//(2mu)] is called magnetic pressure, where

stem:[B]:: is magnetic flux density (<<iec80000-6>>), and
stem:[mu]:: is magnetic permeability (<<iec80000-6>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-8 .

isoiec80000:term-t11-8.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Chandrasekhar number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-8.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Q"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-8.9-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ch"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-8.9 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-8.9" ;
  skosxl:prefLabel isoiec80000:term-t11-8.9-0 ;
  skosxl:altLabel isoiec80000:sym-t11-8.9-0 ;
  skosxl:altLabel isoiec80000:sym-t11-8.9-1 ;
  skos:definition """quotient of Lorentz force and viscous force in magnetic convection in a fluid, expressed by

stem:[Q=(Bl)^2 sigma // rho sf(ii(v))]; where

stem:[B]:: is magnetic flux density (<<iec80000-6>>),
stem:[l]:: is characteristic length (<<iso80000-3>>), a length scale of the system,
stem:[sigma]:: is electrical conductivity (<<iec80000-6>>),
stem:[rho]:: is mass density (<<iso80000-4>>), and
stem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>)
"""@en ;
  skos:note """The Chandrasekhar number is also given by stem:[Q = Ha^2] where stem:[Ha] is the Hartmann number (<<t11-8.5>>)."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-8 .

isoiec80000:term-t11-8.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Prandtl magnetic number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-8.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Pr_\"m\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-8.10 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-8.10" ;
  skosxl:prefLabel isoiec80000:term-t11-8.10-0 ;
  skosxl:altLabel isoiec80000:sym-t11-8.10-0 ;
  skos:definition """quotient of kinematic viscosity and magnetic viscosity in an electrically conducting liquid, expressed by

stem:[Pr_\"m\" = sf(ii(v)) sigma mu]; where

stem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>),
stem:[sigma]:: is electrical conductivity (<<iec80000-6>>), and
stem:[mu]:: is magnetic permeability (<<iec80000-6>>)
"""@en ;
  skos:note """The quantity stem:[sf(ii(v))_\"m\" = 1//(mu sigma)] is called magnetic viscosity or magnetic diffusivity. See <<t11-8.11>>.

The Prandtl magnetic number is also given by

stem:[Pr_\"m\" = Rm//Re]; where

stem:[Rm]:: is the Reynolds magnetic number (<<t11-8.1>>), and
stem:[Re]:: is the Reynolds number (<<t11-4.1>>).

This number is also called magnetic Prandtl number.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-8 .

isoiec80000:term-t11-8.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Roberts number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-8.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ro"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-8.11 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-8.11" ;
  skosxl:prefLabel isoiec80000:term-t11-8.11-0 ;
  skosxl:altLabel isoiec80000:sym-t11-8.11-0 ;
  skos:definition """quotient of thermal diffusivity and magnetic viscosity in an electrically conducting liquid, expressed by

stem:[Ro = alpha sigma mu]; where

stem:[alpha]:: is thermal diffusivity (<<iso80000-5>>),
stem:[sigma]:: is electrical conductivity (<<iec80000-6>>), and
stem:[mu]:: is magnetic permeability (<<iec80000-6>>)
"""@en ;
  skos:note """The quantity stem:[v_\"m\" = 1//(mu sigma)] is called magnetic viscosity or magnetic diffusivity; where

stem:[mu]:: is magnetic permeability (<<iec80000-6>>), and
stem:[sigma]:: is electrical conductivity (<<iec80000-6>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-8 .

isoiec80000:term-t11-8.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Stuart number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-8.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Stw"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-8.12 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-8.12" ;
  skosxl:prefLabel isoiec80000:term-t11-8.12-0 ;
  skosxl:altLabel isoiec80000:sym-t11-8.12-0 ;
  skos:definition """quotient of magnetic forces and inertia forces in an electrically conducting liquid, expressed by

stem:[Stw = B^2 l sigma // (v rho)]; where

stem:[B]:: is magnetic flux density (<<iec80000-6>>),
stem:[l]:: is characteristic length (<<iso80000-3>>),
stem:[sigma]:: is electrical conductivity (<<iec80000-6>>),
stem:[v]:: is characteristic speed (<<iso80000-3>>), and
stem:[rho]:: is mass density (<<iso80000-4>>)
"""@en ;
  skos:note """The Stuart number sometimes is called magnetic force parameter.

Sometimes the square root is wrongly used.

The Stuart number is also given by

stem:[Stw = Ha^2//Re]; where

stem:[Ha]:: is the Hartmann number, and
stem:[Re]:: is the Reynolds number.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-8 .

isoiec80000:term-t11-8.13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "magnetic number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-8.13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "N_(mg)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-8.13 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-8.13" ;
  skosxl:prefLabel isoiec80000:term-t11-8.13-0 ;
  skosxl:altLabel isoiec80000:sym-t11-8.13-0 ;
  skos:definition """quotient of magnetic forces and viscous forces in an electrically conducting fluid, expressed by

stem:[N_(mg) = B sqrt(l sigma // (eta v))]; where

stem:[B]:: is magnetic flux density (<<iec80000-6>>),
stem:[l]:: is characteristic length (<<iso80000-3>>),
stem:[sigma]:: is electrical conductivity (<<iec80000-6>>),
stem:[eta]:: is dynamic viscosity (<<iso80000-4>>), and
stem:[v]:: is speed (<<iso80000-3>>)
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-8 .

isoiec80000:term-t11-8.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "electric field parameter"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-8.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ef"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-8.14 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-8.14" ;
  skosxl:prefLabel isoiec80000:term-t11-8.14-0 ;
  skosxl:altLabel isoiec80000:sym-t11-8.14-0 ;
  skos:definition """quotient of Coulomb force and Lorentz force on moving electrically charged material or particles, expressed by

stem:[Ef = E // (vB)]; where

stem:[E]:: is electric field strength (<<iec80000-6>>),
stem:[v]:: is speed (<<iso80000-3>>), and
stem:[B]:: is magnetic flux density (<<iec80000-6>>)
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-8 .

isoiec80000:term-t11-8.15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Hall number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-8.15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "H_\"c\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t11-8.15-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "C_\"H\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-8.15 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-8.15" ;
  skosxl:prefLabel isoiec80000:term-t11-8.15-0 ;
  skosxl:altLabel isoiec80000:sym-t11-8.15-0 ;
  skosxl:altLabel isoiec80000:sym-t11-8.15-1 ;
  skos:definition """quotient of gyro frequency and collision frequency in a plasma, expressed by

stem:[H_\"c\" = (omega_\"c\")/(2pi) lambda/v]; where

stem:[omega_\"c\"]:: is cyclotron angular frequency (<<iso80000-10>>),
stem:[lambda]:: is mean free path (<<iso80000-9>>), and
stem:[v]:: is average speed (<<iso80000-3>>)
"""@en ;
  skos:note """Sometimes the inverse of this number is wrongly used.

stem:[2pi] times this quantity is called the Hall parameter.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-8 .

isoiec80000:term-t11-8.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Lundquist number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-8.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Lu"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-8.16 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-8.16" ;
  skosxl:prefLabel isoiec80000:term-t11-8.16-0 ;
  skosxl:altLabel isoiec80000:sym-t11-8.16-0 ;
  skos:definition """quotient of Alfvén speed and magneto-dynamic speed in a plasma, expressed by

stem:[Lu = Bl sigma sqrt(mu/rho)]; where

stem:[B]:: is magnetic flux density (<<iec80000-6>>),
stem:[l]:: is characteristic length (<<iso80000-3>>),
stem:[sigma]:: is electrical conductivity (<<iec80000-6>>),
stem:[mu]:: is magnetic permeability (<<iec80000-6>>), and
stem:[rho]:: is mass density (<<iso80000-4>>)
"""@en ;
  skos:note """The quantity stem:[v_\"A\" = B//sqrt(phi mu)] is called Alfvén wave speed. See <<t11-8.4>>.

The quantity stem:[v_\"m\" = 1//(l sigma mu)] is called magneto dynamic speed; where

stem:[l]:: is characteristic length (<<iso80000-3>>),
stem:[sigma]:: is electrical conductivity (<<iec80000-6>>), and
stem:[mu]:: is magnetic permeability (<<iec80000-6>>).

The Lundquist number is also given by

stem:[Lu = Rm//Al]; where

stem:[Rm]:: is the Reynolds magnetic number (<<t11-8.1>>), and
stem:[Al]:: is the Alfvén number (<<t11-8.4>>).

See also Hartmann number (<<t11-8.5>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-8 .

isoiec80000:term-t11-8.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Joule magnetic number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-8.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Jo_\"m\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-8.17 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-8.17" ;
  skosxl:prefLabel isoiec80000:term-t11-8.17-0 ;
  skosxl:altLabel isoiec80000:sym-t11-8.17-0 ;
  skos:definition """quotient of Joule heating energy and magnetic field energy in a plasma, expressed by

stem:[Jo_\"m\" = 2 rho mu c_p Delta T // B^2]; where

stem:[rho]:: is mass density (<<iso80000-4>>),
stem:[mu]:: is magnetic permeability (<<iec80000-6>>),
stem:[c_p]:: is specific heat capacity at constant pressure (<<iso80000-5>>),
stem:[T]:: is thermodynamic temperature (<<iso80000-5>>), and
stem:[B]:: is magnetic flux density (<<iec80000-6>>)
"""@en ;
  skos:note """This number is also called magnetic Joule number."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-8 .

isoiec80000:term-t11-8.18-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Grashof magnetic number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-8.18-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Gr_\"m\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-8.18 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-8.18" ;
  skosxl:prefLabel isoiec80000:term-t11-8.18-0 ;
  skosxl:altLabel isoiec80000:sym-t11-8.18-0 ;
  skos:definition """mathematical expression for the heat transfer by free thermo-magnetic convection of a paramagnetic fluid under gravity,

stem:[Gr_\"m\" = 4 pi sigma_\"e\" mu_\"e\" g alpha_V Delta T l^3 // sf(ii(v))]; where

stem:[sigma_\"e\"]:: is electrical conductivity (<<iec80000-6>>),
stem:[mu_\"e\"]:: is magnetic permeability (<<iec80000-6>>),
stem:[g]:: is acceleration of free fall (<<iso80000-3>>),
stem:[alpha_V]:: is cubic expansion coefficient (<<iso80000-5>>),
stem:[Delta T = T_\"S\"-T_(oo)]:: is difference of thermodynamic temperature stem:[T] (<<iso80000-5>>), where stem:[T_\"S\"] is surface temperature and stem:[T_(oo)] is bulk temperature
stem:[l]:: is characteristic length (<<iso80000-3>>), and
stem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>)
"""@en ;
  skos:note """This number is also called magnetic Grashof number.

See also Grashof number (<<t11-4.4>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-8 .

isoiec80000:term-t11-8.19-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Naze number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-8.19-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Na"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-8.19 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-8.19" ;
  skosxl:prefLabel isoiec80000:term-t11-8.19-0 ;
  skosxl:altLabel isoiec80000:sym-t11-8.19-0 ;
  skos:definition """quotient of velocity of Alfvén waves and velocity of sound in a plasma, expressed by

stem:[Na = B // (c sqrt(rho mu))]; where

stem:[B]:: is magnetic flux density (<<iec80000-6>>),
stem:[c]:: is speed of sound (<<iso80000-8>>),
stem:[rho]:: is mass density (<<iso80000-4>>), and
stem:[mu]:: is magnetic permeability (<<iec80000-6>>)
"""@en ;
  skos:note """The quantity stem:[v_\"A\" = B // sqrt(rho mu)] is called Alfvén wave speed. See <<t11-8.4>>."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-8 .

isoiec80000:term-t11-8.20-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Reynolds electric number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-8.20-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Re_\"e\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-8.20 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-8.20" ;
  skosxl:prefLabel isoiec80000:term-t11-8.20-0 ;
  skosxl:altLabel isoiec80000:sym-t11-8.20-0 ;
  skos:definition """quotient of speed of a fluid and average drift speed of the charged particles in an electrically conducting fluid, expressed by

stem:[Re_\"e\" = v epsilon_\"e\" // (rho_\"e\" l mu)]; where

stem:[v]:: is characteristic speed (<<iso80000-3>>) of the fluid,
stem:[epsilon_\"e\"]:: is electric permittivity (<<iec80000-6>>),
stem:[rho_\"e\"]:: is electric charge density (<<iec80000-6>>),
stem:[l]:: is characteristic length (<<iso80000-3>>), and
stem:[mu]:: is mobility (<<iso80000-10>>) of charge carriers
"""@en ;
  skos:note """This number is also called electrical Reynolds number.

The drift speed of the charged particles in an electric field is given by stem:[v_\"d\" = 1/(mu E)],where

stem:[E]:: is electric field strength (<<iec80000-6>>), and
stem:[mu]:: is mobility (<<iso80000-10>>) of charge carriers.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-8 .

isoiec80000:term-t11-8.21-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Ampère number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-8.21-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Am"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-8.21 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-8.21" ;
  skosxl:prefLabel isoiec80000:term-t11-8.21-0 ;
  skosxl:altLabel isoiec80000:sym-t11-8.21-0 ;
  skos:definition """relation between electric surface current and magnetic field strength in an electrically conducting liquid, expressed by

stem:[Am = I_A // lH]; where

stem:[I_A]:: is electric surface current,
stem:[l]:: is characteristic length (<<iso80000-3>>), and
stem:[H]:: is magnetic field strength (<<iec80000-6>>)
"""@en ;
  skos:note """This number is also called ((magnetic field number)).

The electric surface current is given by

stem:[I_A = rho_A I mu E]; where

stem:[rho_A]:: is surface density of electric charge (<<iec80000-6>>),
stem:[l]:: is characteristic length (<<iso80000-3>>),
stem:[mu]:: is mobility (<<iso80000-10>>) of charge carriers, and
stem:[E]:: is electric field strength (<<iec80000-6>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-8 .

@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

isoiec80000:part-11-9 a smart:PublicationDocument ;
  dcterms:title "Part 11-9"@en ;
  dcterms:identifier "ISO 80000-11-9" ;
  smart:hasPublicationType smart:internationalStandard ;
  smart:hasBindingnessType smart:normative .

isoiec80000:term-t11-9.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Arrhenius number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-9.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "alpha"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-9.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-9.1" ;
  skosxl:prefLabel isoiec80000:term-t11-9.1-0 ;
  skosxl:altLabel isoiec80000:sym-t11-9.1-0 ;
  skos:definition """quotient of chemical activation energy and thermal energy; in a chemical reaction it is the exponential factor of the reaction rate constant, stem:[k], expressed by

stem:[k ~ \"exp \"(alpha)], with stem:[alpha = E_0 // (RT)]; where

stem:[E_0]:: is activation energy (<<iso80000-5>>),
stem:[R]:: is molar gas constant (<<iso80000-9>>), and
stem:[T]:: is thermodynamic temperature (<<iso80000-5>>)
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-9 .

isoiec80000:term-t11-9.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Landau-Ginzburg number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t11-9.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "kappa"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t11-9.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "11-9.2" ;
  skosxl:prefLabel isoiec80000:term-t11-9.2-0 ;
  skosxl:altLabel isoiec80000:sym-t11-9.2-0 ;
  skos:definition """quotient of penetration depth of a magnetic field into a superconductor and the coherence length of thermodynamic fluctuations within a superconducting phase in a material at zero thermodynamic temperature, expressed by

stem:[kappa = lambda_\"L\" // (xi sqrt(2))]; where

stem:[lambda_\"L\"]:: is London penetration depth (<<iso80000-12>>), and +
stem:[xi]:: is coherence length (<<iso80000-12>>)
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-11-9 .

@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

isoiec80000:part-12 a smart:PublicationDocument ;
  dcterms:title "Condensed Matter"@en ;
  dcterms:identifier "ISO 80000-12" ;
  smart:hasPublicationType smart:internationalStandard ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-m a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "metre"@en ;
  skos:notation "m" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-m^(-1) a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "per metre"@en ;
  skos:notation "m^(-1)" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-1 a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "one"@en ;
  skos:notation "1" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-deg a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "degree"@en ;
  skos:notation "deg" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-s^(-1) a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "per second"@en ;
  skos:notation "s^(-1)" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-K a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "kelvin"@en ;
  skos:notation "K" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-m^(-3)*s a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "per cubic metre second"@en ;
  skos:notation "m^(-3)*s" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-J^(-1)*m^(-3) a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "per joule cubic metre"@en ;
  skos:notation "J^(-1)*m^(-3)" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-eV^(-1)*m^(-3) a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "per electronvolt cubic metre"@en ;
  skos:notation "eV^(-1)*m^(-3)" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-kg^(-1)*m^(-5)*s^2 a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "second squared per kilogram metre to the fifth"@en ;
