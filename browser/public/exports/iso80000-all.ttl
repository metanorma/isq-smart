  skosxl:altLabel isoiec80000:sym-t4-19.3-2 ;
  skos:definition """negative of the quotient of pressure stem:[p] (<<t4-14.1>>) and relative
volume strain stem:[vartheta] (<<t4-17.4>>):

stem:[K = p/vartheta]
"""@en ;
  skos:note """Conditions should be specified (e.g. isentropic or isothermal process)."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Pa ;
  isoiec80000:hasUnit isoiec80000:unit-N*m^(-2) ;
