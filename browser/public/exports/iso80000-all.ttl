  skosxl:altLabel isoiec80000:sym-t4-22-0 ;
  skosxl:altLabel isoiec80000:sym-t4-22-1 ;
  skos:definition """geometrical characteristic of a shape of a body equal to:

stem:[Z = I_\"a\"//r_\"Q,max\"]

where stem:[I_\"a\"] is the second axial moment of area (<<t4-21.1>>) and
stem:[r_\"Q,max\"] is the maximum radial distance (<<iso80000-3>>) of any
point in the surface considered from the stem:[\"Q\"]-axis with respect to
which stem:[I_\"a\"] is defined
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-m^3 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-4 .

