isoiec80000:unit-eV a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "electronvolt"@en ;
  skos:notation "eV" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-m^2*A a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "square metre ampere"@en ;
  skos:notation "m^2*A" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-kg*m^2*s^(-1) a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "kilogram square metre per second"@en ;
  skos:notation "kg*m^2*s^(-1)" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-J*s a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "joule second"@en ;
  skos:notation "J*s" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-eV*s a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "electronvolt second"@en ;
  skos:notation "eV*s" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-A*m^2*J^(-1)*s^(-1) a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "ampere square metre per joule second"@en ;
  skos:notation "A*m^2*J^(-1)*s^(-1)" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-A*s/kg a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "ampere second per kilogram"@en ;
  skos:notation "A*s/kg" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-kg^(-1)*s*A a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "second ampere per kilogram"@en ;
  skos:notation "kg^(-1)*s*A" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-rad*s^(-1) a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "radian per second"@en ;
  skos:notation "rad*s^(-1)" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-s^(-1) a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "per second"@en ;
  skos:notation "s^(-1)" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-m^2 a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "square metre"@en ;
  skos:notation "m^2" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-s a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "second"@en ;
  skos:notation "s" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-Bq a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "becquerel"@en ;
  skos:notation "Bq" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-Bq/kg a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "becquerel per kilogram"@en ;
  skos:notation "Bq/kg" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-kg^(-1)*s^(-1) a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "per kilogram second"@en ;
  skos:notation "kg^(-1)*s^(-1)" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-Bq/m^3 a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "becquerel per cubic metre"@en ;
  skos:notation "Bq/m^3" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-m^(-3)*s^(-1) a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "per cubic metre second"@en ;
  skos:notation "m^(-3)*s^(-1)" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-Bq/m^2 a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "becquerel per square metre"@en ;
  skos:notation "Bq/m^2" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-m^(-2)*s^(-1) a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "per square metre second"@en ;
  skos:notation "m^(-2)*s^(-1)" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-stem:["b"] a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "barn"@en ;
  skos:notation "stem:["b"]" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-m^2*sr^(-1) a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "square metre per steradian"@en ;
  skos:notation "m^2*sr^(-1)" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-m^2//J a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "square metre per joule"@en ;
  skos:notation "m^2//J" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-kg^(-1)*s^2 a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "second squared per kilogram"@en ;
  skos:notation "kg^(-1)*s^2" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-m^2/(J*sr) a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "square metre per joule steradian"@en ;
  skos:notation "m^2/(J*sr)" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-m^(-2) a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "per square metre"@en ;
  skos:notation "m^(-2)" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-eV/m^2 a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "electronvolt per square metre"@en ;
  skos:notation "eV/m^2" ;
  smart:hasBindingnessType smart:normative .

isoiec80000:unit-J/m^2 a isoiec80000:Unit, smart:TermEntry ;
  skos:prefLabel "joule per square metre"@en ;
  skos:notation "J/m^2" ;
  smart:hasBindingnessType smart:normative .

