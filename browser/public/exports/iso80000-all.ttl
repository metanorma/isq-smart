  skosxl:literalForm "static friction factor"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t4-23.1-2 a smart:Term, skosxl:Label ;
  skosxl:literalForm "coefficient of static friction"@en ;
  smart:hasTermFormType smart:fullForm .

