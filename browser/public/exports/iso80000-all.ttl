  skosxl:prefLabel isoiec80000:term-t13-21-0 ;
  skosxl:altLabel isoiec80000:sym-t13-21-0 ;
  skos:definition """number of digit positions in which the corresponding digits of two words of the same length are different"""@en ;
  skos:note """For the unit one, see the <<intro>>.

See <<iec60050-721,droploc%locality:item=\"721-08-25\">>.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

isoiec80000:term-t13-22-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "clock frequency, clock rate"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-22-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "f_{\"cl\"}"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-22 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-22" ;
  skosxl:prefLabel isoiec80000:term-t13-22-0 ;
  skosxl:altLabel isoiec80000:sym-t13-22-0 ;
  skos:definition """frequency at which a clock oscillates"""@en ;
  skos:note """For the unit hertz, see <<iec60050-103,droploc%locality:item=\"103-06-18\">>."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Hz ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

isoiec80000:term-t13-23-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "decision content"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-23-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "D_a"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-23 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-23" ;
  skosxl:prefLabel isoiec80000:term-t13-23-0 ;
  skosxl:altLabel isoiec80000:sym-t13-23-0 ;
  skos:definition """stem:[D_a = log_a\\ n]

where stem:[a] is the number of possibilities at
each decision and stem:[n] the number of
events
"""@en ;
  skos:note """For the unit one, see the <<intro>>.

When the same base is used for the same number of
events then stem:[D_a = H_0] where stem:[H_0] is maximum entropy
(<<t13-26,item 13-26>>).

See <<iec60050-171,droploc%locality:item=\"171-07-10\">>.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

isoiec80000:term-t13-24-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "information content"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-24-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "I(x)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-24 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-24" ;
  skosxl:prefLabel isoiec80000:term-t13-24-0 ;
  skosxl:altLabel isoiec80000:sym-t13-24-0 ;
  skos:definition """stem:[I(x)] +
stem:[= lb 1/p(x) \" Sh\"] +
stem:[= lg 1/p(x) \" Hart\"] +
stem:[= ln 1/p(x) \" nat\"]

where stem:[p(x)] is the probability of event stem:[x]
"""@en ;
  skos:note """One shannon is the quantity value when the argument
is equal to two.

stem:[1 \" Sh\" ~~ 0,693 \"unitsml(nat)\" ~~ 0,301 \" Hart\"]

One hartley is the quantity value when the argument
is equal to ten.

stem:[1 \" Hart\" ~~ 3,322 \" Sh\" ~~ 2,303 \"unitsml(nat)\"]

One natural unit of information is the quantity value
when the argument is equal to stem:[e], Euler's number.

stem:[1 \"unitsml(nat)\" ~~ 1,433 \" Sh\" ~~ 0,434 \" Hart\"]

See <<iec60050-171,droploc%locality:item=\"171-07-14\">>.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Sh ;
  isoiec80000:hasUnit isoiec80000:unit-Hart ;
  isoiec80000:hasUnit isoiec80000:unit-nat ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

isoiec80000:term-t13-25-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "entropy"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-25-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "H"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-25 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-25" ;
  skosxl:prefLabel isoiec80000:term-t13-25-0 ;
  skosxl:altLabel isoiec80000:sym-t13-25-0 ;
  skos:definition """stem:[H(X) = sum_{i=1}^n p(X_i) I(X_i)] for the set
stem:[X = {X_1, ..., X_n}]

where stem:[p(X_i)] is the probability, and

stem:[I(X_i)] is the information content of event
stem:[X_i]
"""@en ;
  skos:note """See <<iec60050-171,droploc%locality:item=\"171-07-15\">>."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Sh ;
  isoiec80000:hasUnit isoiec80000:unit-Hart ;
  isoiec80000:hasUnit isoiec80000:unit-nat ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

isoiec80000:term-t13-26-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "maximum entropy"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-26-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "H_0"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t13-26-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "(H_{\"max\"})"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-26 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-26" ;
  skosxl:prefLabel isoiec80000:term-t13-26-0 ;
  skosxl:altLabel isoiec80000:sym-t13-26-0 ;
  skosxl:altLabel isoiec80000:sym-t13-26-1 ;
  skos:definition """maximum entropy occurs when

stem:[p(X_i) = 1//n] for stem:[i = 1, ..., n]
"""@en ;
  skos:note """The maximum entropy is sometimes called \"decision
content\" because the value is the same when the
base is an integer, for the same number of events.
See <<t13-23,item 13-23>>.

See <<iec60050-171,droploc%locality:item=\"171-07-16\">>.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Sh ;
  isoiec80000:hasUnit isoiec80000:unit-Hart ;
  isoiec80000:hasUnit isoiec80000:unit-nat ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

isoiec80000:term-t13-27-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "relative entropy"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-27-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "H_r"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-27 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-27" ;
  skosxl:prefLabel isoiec80000:term-t13-27-0 ;
  skosxl:altLabel isoiec80000:sym-t13-27-0 ;
  skos:definition """stem:[H_r = H // H_0]

where stem:[H] is entropy (<<t13-25,item 13-25>>) and stem:[H_0]
is maximum entropy (<<t13-26,item 13-26>>)
"""@en ;
  skos:note """See <<iec60050-171,droploc%locality:item=\"171-07-17\">>."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

isoiec80000:term-t13-28-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "redundancy"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-28-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "R"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-28 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-28" ;
  skosxl:prefLabel isoiec80000:term-t13-28-0 ;
  skosxl:altLabel isoiec80000:sym-t13-28-0 ;
  skos:definition """stem:[R = H_0 - H]

where H is entropy (<<t13-25,item 13-25>>) and stem:[H_0]
is maximum entropy (<<t13-26,item 13-26>>)
"""@en ;
  skos:note """See <<iec60050-171,droploc%locality:item=\"171-07-18\">>."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Sh ;
  isoiec80000:hasUnit isoiec80000:unit-Hart ;
  isoiec80000:hasUnit isoiec80000:unit-nat ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

isoiec80000:term-t13-29-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "relative redundancy"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-29-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "r"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-29 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-29" ;
  skosxl:prefLabel isoiec80000:term-t13-29-0 ;
  skosxl:altLabel isoiec80000:sym-t13-29-0 ;
  skos:definition """stem:[r = R // H_0]

where stem:[R] is redundancy (<<t13-28,item 13-28>>) and
stem:[H_0] is maximum entropy (<<t13-26,item 13-26>>)
"""@en ;
  skos:note """For the unit one, see the <<intro>>.

See <<iec60050-171,droploc%locality:item=\"171-07-19\">>.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

isoiec80000:term-t13-30-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "joint information content"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-30-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "I(x,y)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-30 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-30" ;
  skosxl:prefLabel isoiec80000:term-t13-30-0 ;
  skosxl:altLabel isoiec80000:sym-t13-30-0 ;
  skos:definition """stem:[I(x,y)]

stem:[= \"lb\" {1}/{p(x,y)} \" Sh\"]

stem:[= \"lg\" {1}/{p(x,y)} \" Hart\"]

stem:[= \"ln\" {1}/{p(x,y)} \"unitsml(nat)\"]

is the joint probability of events stem:[x] and stem:[y]
"""@en ;
  skos:note """See <<iec60050-171,droploc%locality:item=\"171-07-20\">>."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Sh ;
  isoiec80000:hasUnit isoiec80000:unit-Hart ;
  isoiec80000:hasUnit isoiec80000:unit-nat ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

isoiec80000:term-t13-31-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "conditional information content"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-31-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "I(x\\|y)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-31 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-31" ;
  skosxl:prefLabel isoiec80000:term-t13-31-0 ;
  skosxl:altLabel isoiec80000:sym-t13-31-0 ;
  skos:definition """information content (<<t13-2,item 13-2>>) of event stem:[x]
under the condition that stem:[y] has occurred:

stem:[I(x\\|y) = I(x,y) - I(y)]
"""@en ;
  skos:note """See <<iec60050-171,droploc%locality:item=\"171-07-21\">>."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Sh ;
  isoiec80000:hasUnit isoiec80000:unit-Hart ;
  isoiec80000:hasUnit isoiec80000:unit-nat ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

isoiec80000:term-t13-32-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "conditional entropy, mean conditional information content, average conditional information content"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-32-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "H(x\\|y)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-32 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-32" ;
  skosxl:prefLabel isoiec80000:term-t13-32-0 ;
  skosxl:altLabel isoiec80000:sym-t13-32-0 ;
  skos:definition """stem:[H(x\\|y) = sum_{i=1}^n sum_{j=1}^m p(x_i,y_j) I(x_i\\|y_j)]

where stem:[p(x_i,y_j)] is the joint probability of
events stem:[x_i] and stem:[y_j], and stem:[I(x_i\\|y_j)] is
conditional information content (<<t13-31,item 13-31>>)
"""@en ;
  skos:note """See <<iec60050-171,droploc%locality:item=\"171-07-23\">>."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Sh ;
  isoiec80000:hasUnit isoiec80000:unit-Hart ;
  isoiec80000:hasUnit isoiec80000:unit-nat ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

isoiec80000:term-t13-33-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "equivocation"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-33-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "H_{\"+\"}(X\\|I)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-33 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-33" ;
  skosxl:prefLabel isoiec80000:term-t13-33-0 ;
  skosxl:altLabel isoiec80000:sym-t13-33-0 ;
  skos:definition """conditional entropy (<<t13-32,item 13-32>>) of a set stem:[X] of emitted characters given the set I of received characters"""@en ;
  skos:note """Equivocation is a quantitative measure of the loss of
information due to noise.

See <<iec60050-171,droploc%locality:item=\"171-07-24\">>.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Sh ;
  isoiec80000:hasUnit isoiec80000:unit-Hart ;
  isoiec80000:hasUnit isoiec80000:unit-nat ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

isoiec80000:term-t13-34-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "irrelevance"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-34-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "H_{\"-\"}(I\\|X)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-34 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-34" ;
  skosxl:prefLabel isoiec80000:term-t13-34-0 ;
  skosxl:altLabel isoiec80000:sym-t13-34-0 ;
  skos:definition """conditional entropy (<<t13-32,item 13-32>>) of a set stem:[I] of received characters
given the set stem:[X] of emitted characters:

stem:[H_{\"-\"}(I\\|X) = H_{\"+\"}(X\\|I) + H(I) - H(X)],

where stem:[H_{\"+\"}(X\\|I)] is equivocation (<<t13-33,item 13-33>>)
and stem:[H] is entropy (<<t13-25,item 13-25>>)
"""@en ;
  skos:note """Irrelevance is a quantitative measure of the
information added to the emitted information owing to
distortion.

See <<iec60050-171,droploc%locality:item=\"171-07-25\">>.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Sh ;
  isoiec80000:hasUnit isoiec80000:unit-Hart ;
  isoiec80000:hasUnit isoiec80000:unit-nat ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

isoiec80000:term-t13-35-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "transinformation content, mutual information"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-35-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "T(x,y)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-35 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-35" ;
  skosxl:prefLabel isoiec80000:term-t13-35-0 ;
  skosxl:altLabel isoiec80000:sym-t13-35-0 ;
  skos:definition """stem:[T(x,y) = I(x) + I(y) - I(x,y)]

where stem:[I(x)] and stem:[I(y)] are the information
contents (<<t13-24,13-24>>) of events stem:[x] and stem:[y],
respectively, and stem:[I(x,y)] is their joint
information content (<<t13-30,item 13-30>>)
"""@en ;
  skos:note """See <<iec60050-171,droploc%locality:item=\"171-07-26\">>."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Sh ;
  isoiec80000:hasUnit isoiec80000:unit-Hart ;
  isoiec80000:hasUnit isoiec80000:unit-nat ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

isoiec80000:term-t13-36-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "mean transinformation content"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-36-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "T"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-36 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-36" ;
  skosxl:prefLabel isoiec80000:term-t13-36-0 ;
  skosxl:altLabel isoiec80000:sym-t13-36-0 ;
  skos:definition """stem:[T(X,Y) = sum_{i=1}^n sum_{j=1}^m p(x_i,y_j) T(x_i,y_j)]

for the sets stem:[X = {x_1,...,x_n}],
stem:[Y = {y_1,...,y_m}],

where stem:[p(x_i,y_j)] is the joint probability of
events stem:[x_i] and stem:[y_j], and stem:[T(x_i,y_j)] is their
transinformation content (<<t13-35,item 13-35>>)
"""@en ;
  skos:note """In practice, the unit \"shannon per character\" is
generally used, and sometimes the units \"hartley per
character\" and \"natural unit per character\".

See <<iec60050-171,droploc%locality:item=\"171-07-27\">>.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Sh ;
  isoiec80000:hasUnit isoiec80000:unit-Hart ;
  isoiec80000:hasUnit isoiec80000:unit-nat ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

isoiec80000:term-t13-37-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "character mean entropy"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-37-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "H'"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-37 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-37" ;
  skosxl:prefLabel isoiec80000:term-t13-37-0 ;
  skosxl:altLabel isoiec80000:sym-t13-37-0 ;
  skos:definition """stem:[H' = lim_{m -> oo} H_m/m]

where stem:[H_m] is the entropy (<<t13-25,item 13-25>>) of the set
of all sequences of stem:[m] characters
"""@en ;
  skos:note """See <<iec60050-171,droploc%locality:item=\"171-07-28\">>."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Sh ;
  isoiec80000:hasUnit isoiec80000:unit-Hart ;
  isoiec80000:hasUnit isoiec80000:unit-nat ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

isoiec80000:term-t13-38-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "average information rate"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-38-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "H^{**}"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-38 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-38" ;
  skosxl:prefLabel isoiec80000:term-t13-38-0 ;
  skosxl:altLabel isoiec80000:sym-t13-38-0 ;
  skos:definition """stem:[H^{**} = H' // t(X)]

where stem:[H'] is character mean entropy (<<t13-37,item 13-37>>) and stem:[t(X)] is the mean value of the duration of a character in the set stem:[X]
"""@en ;
  skos:note """See <<iec60050-171,droploc%locality:item=\"171-07-29\">>."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Sh/s ;
  isoiec80000:hasUnit isoiec80000:unit-Hart/s ;
  isoiec80000:hasUnit isoiec80000:unit-nat/s ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

isoiec80000:term-t13-39-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "character mean transinformation content"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-39-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "T'"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-39 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-39" ;
  skosxl:prefLabel isoiec80000:term-t13-39-0 ;
  skosxl:altLabel isoiec80000:sym-t13-39-0 ;
  skos:definition """stem:[T' = lim_{m -> oo} T_m/m]

where stem:[T_m] is the mean transinformation content (<<t13-36,item 13-36>>) for all pairs of input and output sequences of stem:[m] characters
"""@en ;
  skos:note """In practice, the unit \"shannon per character\" is
generally used, and sometimes the units \"hartley per
character\" and \"natural unit per character\".

See <<iec60050-171,droploc%locality:item=\"171-07-30\">>.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Sh ;
  isoiec80000:hasUnit isoiec80000:unit-Hart ;
  isoiec80000:hasUnit isoiec80000:unit-nat ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

isoiec80000:term-t13-40-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "average transinformation rate"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-40-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "T^{**}"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-40 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-40" ;
  skosxl:prefLabel isoiec80000:term-t13-40-0 ;
  skosxl:altLabel isoiec80000:sym-t13-40-0 ;
  skos:definition """stem:[T^{**} = (T')/(sum_(i=1)^n sum_(j=1)^m p(x_i,y_j)t(x_i,y_j))]

where stem:[T'] is character mean transinformation content (<<t13-39,item 13-39>>) and stem:[t(x_i, y_j)] is the mean duration of the pair of characters stem:[(x_i, y_j)] with joint probability stem:[p(x_i, y_j)]
"""@en ;
  skos:note """See <<iec60050-171,droploc%locality:item=\"171-07-31\">>."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Sh/s ;
  isoiec80000:hasUnit isoiec80000:unit-Hart/s ;
  isoiec80000:hasUnit isoiec80000:unit-nat/s ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

isoiec80000:term-t13-41-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "channel capacity per character"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-41-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "C'"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-41 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-41" ;
  skosxl:prefLabel isoiec80000:term-t13-41-0 ;
  skosxl:altLabel isoiec80000:sym-t13-41-0 ;
  skos:definition """stem:[C' = maxT']

where stem:[T'] is character mean transinformation content (<<t13-39,item 13-39>>)
"""@en ;
  skos:note """In practice, the unit \"shannon per character\" is generally used,
and sometimes the units \"hartley per character\" and \"natural unit per character\".

See <<iec60050-171,droploc%locality:item=\"171-07-32\">>.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Sh ;
  isoiec80000:hasUnit isoiec80000:unit-Hart ;
  isoiec80000:hasUnit isoiec80000:unit-nat ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

isoiec80000:term-t13-42-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "channel time capacity; channel capacity"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-42-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "C^{**}"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-42 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-42" ;
  skosxl:prefLabel isoiec80000:term-t13-42-0 ;
  skosxl:altLabel isoiec80000:sym-t13-42-0 ;
  skos:definition """stem:[C^{**} = maxT^{**}]

where stem:[T^{**}] is average transinformation rate (<<t13-40,item 13-40>>)
"""@en ;
  skos:note """See <<iec60050-171,droploc%locality:item=\"171-07-33\">>."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Sh/s ;
  isoiec80000:hasUnit isoiec80000:unit-Hart/s ;
  isoiec80000:hasUnit isoiec80000:unit-nat/s ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

isoiec80000:part-2-5 a smart:PublicationDocument ;
  dcterms:title "Part 2-5"@en ;
  dcterms:identifier "ISO 80000-2-5" ;
  smart:hasPublicationType smart:internationalStandard ;
  smart:hasBindingnessType smart:normative .

isoiec80000:term-t2-5.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "conjunction"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-5.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "p ^^ q"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-5.1 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-5.1" ;
  skosxl:prefLabel isoiec80000:term-t2-5.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-5.1-0 ;
  skos:definition """conjunction of stem:[p] and stem:[q], stem:[p]
and stem:[q]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-5 .

isoiec80000:term-t2-5.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "disjunction"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-5.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "p vv q"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-5.2 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-5.2" ;
  skosxl:prefLabel isoiec80000:term-t2-5.2-0 ;
  skosxl:altLabel isoiec80000:sym-t2-5.2-0 ;
  skos:definition """disjunction of stem:[p] and stem:[q], stem:[p] or stem:[q]"""@en ;
  skos:note """This \"or\" is inclusive, i.e. stem:[p vv q] is
true, if either stem:[p] or stem:[q], or both
are true.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-5 .

isoiec80000:term-t2-5.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "negation"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-5.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "not p"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-5.3 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-5.3" ;
  skosxl:prefLabel isoiec80000:term-t2-5.3-0 ;
  skosxl:altLabel isoiec80000:sym-t2-5.3-0 ;
  skos:definition """negation of stem:[p], not stem:[p]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-5 .

isoiec80000:term-t2-5.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "implication"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-5.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "p => q"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-5.4 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-5.4" ;
  skosxl:prefLabel isoiec80000:term-t2-5.4-0 ;
  skosxl:altLabel isoiec80000:sym-t2-5.4-0 ;
  skos:definition """stem:[p] implies stem:[q], if stem:[p], then stem:[q]"""@en ;
  skos:note """stem:[q lArr p] has the same meaning as stem:[p => q].

stem:[=>] is the implication symbol.

stem:[->] is also used as implication symbol.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-5 .

isoiec80000:term-t2-5.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "equivalent"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-5.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "p <=> q"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-5.5 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-5.5" ;
  skosxl:prefLabel isoiec80000:term-t2-5.5-0 ;
  skosxl:altLabel isoiec80000:sym-t2-5.5-0 ;
  skos:definition """stem:[p] is equivalent to stem:[q]"""@en ;
  skos:note """stem:[(p => q) ^^ (q => p)] has the same meaning as stem:[p <=> q].

stem:[<=>] is the equivalence symbol.

stem:[harr] is also used as equivalence symbol.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-5 .

isoiec80000:term-t2-5.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "belonging to"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-5.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "AA x in A p(x)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-5.6 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-5.6" ;
  skosxl:prefLabel isoiec80000:term-t2-5.6-0 ;
  skosxl:altLabel isoiec80000:sym-t2-5.6-0 ;
  skos:definition """for every stem:[x] belonging to stem:[A], the proposition stem:[p(x)] is true"""@en ;
  skos:note """If it is clear from the context which set stem:[A] is considered, the notation stem:[AA x p(x)] can be used."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-5 .

isoiec80000:term-t2-5.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "exists"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-5.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "EE x in A p(x)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-5.7 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-5.7" ;
  skosxl:prefLabel isoiec80000:term-t2-5.7-0 ;
  skosxl:altLabel isoiec80000:sym-t2-5.7-0 ;
  skos:definition """there exists an stem:[x] belonging to stem:[A] for which
stem:[p(x)] is true
"""@en ;
  skos:note """If it is clear from the context which set stem:[A] is
considered, the notation stem:[EE x p(x)] can be used.

stem:[EE] is the existential quantifier.

For stem:[x in A], see <<t2-6.1>>.

stem:[EE^1x p(x)] is used to indicate that there is exactly one element for which stem:[p(x)] is true.

stem:[EE!] is also used for stem:[EE^1].
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-5 .

@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

isoiec80000:part-2-6 a smart:PublicationDocument ;
  dcterms:title "Part 2-6"@en ;
  dcterms:identifier "ISO 80000-2-6" ;
  smart:hasPublicationType smart:internationalStandard ;
  smart:hasBindingnessType smart:normative .

isoiec80000:term-t2-6.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "belongs to set"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-6.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "x in A"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-6.1 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-6.1" ;
  skosxl:prefLabel isoiec80000:term-t2-6.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-6.1-0 ;
  skos:definition """stem:[x] belongs to stem:[A], stem:[x] is an element of the set stem:[A]"""@en ;
  skos:note """stem:[A\" \"&#8715;\" \"x] has the same meaning as stem:[x in A]."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-6 .

isoiec80000:term-t2-6.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "not belong to"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-6.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "y !in A"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-6.2 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-6.2" ;
  skosxl:prefLabel isoiec80000:term-t2-6.2-0 ;
  skosxl:altLabel isoiec80000:sym-t2-6.2-0 ;
  skos:definition """stem:[y] does not belong to stem:[A], stem:[y] is not an element of the set stem:[A]"""@en ;
  skos:note """stem:[A\" \"&#x220C;\" \"y] has the same meaning as latexmath:[y \\notin A].

The negating stroke may also be vertical.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-6 .

isoiec80000:term-t2-6.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "set with elements"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-6.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "{x_1, x_2, ..., x_n}"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-6.3 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-6.3" ;
  skosxl:prefLabel isoiec80000:term-t2-6.3-0 ;
  skosxl:altLabel isoiec80000:sym-t2-6.3-0 ;
  skos:definition """set with elements stem:[x_1, x_2, ..., x_n]"""@en ;
  skos:note """Also stem:[{x_i &#x2223; i in I}], where stem:[I] denotes a set of subscripts."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-6 .

isoiec80000:term-t2-6.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "set of elements"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-6.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "{x in A &#x2223; p(x)}"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-6.4 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-6.4" ;
  skosxl:prefLabel isoiec80000:term-t2-6.4-0 ;
  skosxl:altLabel isoiec80000:sym-t2-6.4-0 ;
  skos:definition """set of those elements of stem:[A] for which the proposition stem:[p(x)] is true"""@en ;
  skos:note """[example]
====
[stem]
++++
{x in bb(sf(R)) &#x2223; x >= 5}
++++

If it is clear from the context which set stem:[A] is considered, the notation stem:[{x &#x2223; p(x)}] can be used (for example stem:[{x &#x2223; x >= 5}], if it is clear that real numbers are considered).

Instead of the vertical line often a colon is used as separator:

stem:[{x in A : p(x)}].
====
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-6 .

isoiec80000:term-t2-6.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "number of elements"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-6.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "text(card) \" \" A"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-6.5-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "abs(A)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-6.5 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-6.5" ;
  skosxl:prefLabel isoiec80000:term-t2-6.5-0 ;
  skosxl:altLabel isoiec80000:sym-t2-6.5-0 ;
  skosxl:altLabel isoiec80000:sym-t2-6.5-1 ;
  skos:definition """number of elements in stem:[A], cardinality of stem:[A]"""@en ;
  skos:note """The cardinality can be a transfinite number.

The symbol stem:[abs] is also used for absolute value of a real number (see <<t2-10.16>>), modulus of a complex number (see <<t2-15.4>>) and magnitude of a vector (see <<t2-18.4>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-6 .

isoiec80000:term-t2-6.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "empty set"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-6.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "O/"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-6.6-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "{}"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-6.6 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-6.6" ;
  skosxl:prefLabel isoiec80000:term-t2-6.6-0 ;
  skosxl:altLabel isoiec80000:sym-t2-6.6-0 ;
  skosxl:altLabel isoiec80000:sym-t2-6.6-1 ;
  skos:definition """the empty set"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-6 .

isoiec80000:term-t2-6.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "included in"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-6.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "B sube A"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-6.7 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-6.7" ;
  skosxl:prefLabel isoiec80000:term-t2-6.7-0 ;
  skosxl:altLabel isoiec80000:sym-t2-6.7-0 ;
  skos:definition """stem:[B] is included in stem:[A],

stem:[B] is a subset of stem:[A]
"""@en ;
  skos:note """Every element of stem:[B] belongs to stem:[A].

stem:[sub] is also used, but see remark to <<t2-6.8>>.

stem:[A supe B] has the same meaning as stem:[B sube A].
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-6 .

isoiec80000:term-t2-6.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "proper subset"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-6.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "B sub A"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-6.8 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-6.8" ;
  skosxl:prefLabel isoiec80000:term-t2-6.8-0 ;
  skosxl:altLabel isoiec80000:sym-t2-6.8-0 ;
  skos:definition """stem:[B] is properly included in stem:[A],

stem:[B] is a proper subset of stem:[A]
"""@en ;
  skos:note """Every element of stem:[B] belongs to stem:[A], but at least one element of stem:[A] does not belong to stem:[B].

If stem:[sub] is used for <<t2-6.7>>, then &#x228A; shall be used for <<t2-6.8>>.

stem:[A sup B] has the same meaning as stem:[B sub A].
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-6 .

isoiec80000:term-t2-6.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "union"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-6.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "A uu B"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-6.9 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-6.9" ;
  skosxl:prefLabel isoiec80000:term-t2-6.9-0 ;
  skosxl:altLabel isoiec80000:sym-t2-6.9-0 ;
  skos:definition """union of stem:[A] and stem:[B]"""@en ;
  skos:note """The set of elements which belong to at least one of the sets stem:[A] and stem:[B].

stem:[A uu B = {x &#x2223; x in A vv x in B}]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-6 .

isoiec80000:term-t2-6.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "intersection"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-6.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "A nn B"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-6.10 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-6.10" ;
  skosxl:prefLabel isoiec80000:term-t2-6.10-0 ;
  skosxl:altLabel isoiec80000:sym-t2-6.10-0 ;
  skos:definition """intersection of stem:[A] and stem:[B]"""@en ;
  skos:note """The set of elements which belong to both sets stem:[A] and stem:[B].

stem:[A nn B = {x &#x2223; x in A ^^ x in B}]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-6 .

isoiec80000:term-t2-6.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "union of sets"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-6.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "uuu_(i=1)^n A_i"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-6.11 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-6.11" ;
  skosxl:prefLabel isoiec80000:term-t2-6.11-0 ;
  skosxl:altLabel isoiec80000:sym-t2-6.11-0 ;
  skos:definition """union of the sets stem:[A_1, A_2, ..., A_n]

stem:[uuu_(i=1)^n A_i = A_1 uu ... uu A_n]
"""@en ;
  skos:note """The set of elements belonging to at least one of the sets stem:[A_1, A_2, ..., A_n]

stem:[uuu_(i=1)^n], stem:[uuu_(i in I)] and stem:[uuu_(i in I)] are also used,

where stem:[I] denotes a set of subscripts.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-6 .

isoiec80000:term-t2-6.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "intersection of sets"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-6.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "nnn_(i=1)^n A_i"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-6.12 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-6.12" ;
  skosxl:prefLabel isoiec80000:term-t2-6.12-0 ;
  skosxl:altLabel isoiec80000:sym-t2-6.12-0 ;
  skos:definition """intersection of the sets +
stem:[A_1, A_2,..., A_n] +
stem:[nnn_(i=1)^n A_i = A_1 nn ... nn A_n]
"""@en ;
  skos:note """The set of elements belonging to all sets stem:[A_1, A_2, ..., A_n]

stem:[nnn_(i=1)^n], stem:[nnn_(i in I)] and stem:[nnn_(i in I)] are also used,

where stem:[I] denotes a set of subscripts.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-6 .

isoiec80000:term-t2-6.13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "difference of sets"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-6.13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "A \\\\ B"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-6.13 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-6.13" ;
  skosxl:prefLabel isoiec80000:term-t2-6.13-0 ;
  skosxl:altLabel isoiec80000:sym-t2-6.13-0 ;
  skos:definition """difference of stem:[A] and stem:[B], +
stem:[A] minus stem:[B]
"""@en ;
  skos:note """The set of elements which belong to stem:[A] but not to stem:[B].

stem:[A \\\\ B = {x &#x2223; x in A ^^ x !in B}]

The notation stem:[A - B] should not be used.

stem:[C_A B] is also used. stem:[C_A B] is mainly used when stem:[B] is a subset of stem:[A], and the symbol stem:[A] may be omitted if it is clear from the context which set stem:[A] is considered.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-6 .

isoiec80000:term-t2-6.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "ordered pair"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-6.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "(a, b)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-6.14 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-6.14" ;
  skosxl:prefLabel isoiec80000:term-t2-6.14-0 ;
  skosxl:altLabel isoiec80000:sym-t2-6.14-0 ;
  skos:definition """ordered pair stem:[a, b], +
couple stem:[a, b]
"""@en ;
  skos:note """stem:[(a, b) = (c, d)] if and only if stem:[a = c] and stem:[b = d].

If the comma can be mistaken as the decimal sign, then the semicolon (;) or a stroke (&#x2223;) may be used as separator.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-6 .

isoiec80000:term-t2-6.15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "ordered stem:[n]-tuple"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-6.15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "(a_1, a_2, ..., a_n)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-6.15 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-6.15" ;
  skosxl:prefLabel isoiec80000:term-t2-6.15-0 ;
  skosxl:altLabel isoiec80000:sym-t2-6.15-0 ;
  skos:definition """ordered stem:[n]-tuple"""@en ;
  skos:note """See remark to <<t2-6.14>>."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-6 .

isoiec80000:term-t2-6.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Cartesian product of two sets"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-6.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "A xx B"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-6.16 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-6.16" ;
  skosxl:prefLabel isoiec80000:term-t2-6.16-0 ;
  skosxl:altLabel isoiec80000:sym-t2-6.16-0 ;
  skos:definition """Cartesian product of the sets stem:[A] and stem:[B]"""@en ;
  skos:note """The set of ordered pairs stem:[(a, b)] such that stem:[a in A] and stem:[b in B].

stem:[A xx B = {(x, y) &#x2223; x in A ^^ y in B}]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-6 .

isoiec80000:term-t2-6.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Cartesian product of several sets"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-6.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "prod_(i=1)^n A_i"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-6.17 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-6.17" ;
  skosxl:prefLabel isoiec80000:term-t2-6.17-0 ;
  skosxl:altLabel isoiec80000:sym-t2-6.17-0 ;
  skos:definition """Cartesian product of the sets

stem:[A_1, A_2, ..., A_n]

stem:[prod_(i=1)^n A_i = A_1 xx ... xx A_n]
"""@en ;
  skos:note """The set of ordered stem:[n]-tuples stem:[(x_1, x_2, ..., x_n)] such that stem:[x_1 in A_1, x_2 in A_2, ..., x_n in A_n].

stem:[A xx A xx ... xx A] is denoted by stem:[A^n], where stem:[n] is the number of factors in the product.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-6 .

isoiec80000:term-t2-6.18-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "identity relation"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-6.18-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"id\"_A"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-6.18 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-6.18" ;
  skosxl:prefLabel isoiec80000:term-t2-6.18-0 ;
  skosxl:altLabel isoiec80000:sym-t2-6.18-0 ;
  skos:definition """identity relation on set stem:[A], +
diagonal of stem:[A xx A]
"""@en ;
  skos:note """stem:[\"id\"_A] is the set of all pairs stem:[(x, x)] where stem:[x in A]. If the set stem:[A] is clear from the context, the subscript stem:[A] can be omitted."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-6 .

@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

isoiec80000:part-2-7 a smart:PublicationDocument ;
  dcterms:title "Part 2-7"@en ;
  dcterms:identifier "ISO 80000-2-7" ;
  smart:hasPublicationType smart:internationalStandard ;
  smart:hasBindingnessType smart:normative .

isoiec80000:term-t2-7.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "natural numbers"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-7.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(N)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-7.1 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-7.1" ;
  skosxl:prefLabel isoiec80000:term-t2-7.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-7.1-0 ;
  skos:definition """the set of natural numbers, +
the set of positive integers and zero
"""@en ;
  skos:note """stem:[bb(sf(N)) = {0, 1, 2, 3, ...}]

stem:[bb(sf(N))** = {1, 2, 3, ...}]

Other restrictions can be indicated in an obvious way, as shown below.

stem:[bb(sf(N))_(>5) = {n in bb(sf(N)) &#x2223; n > 5}]

The symbols stem:[rm(&#8739;N)] and stem:[NN] are also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-7 .

isoiec80000:term-t2-7.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "set of integers"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-7.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(sf(Z))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-7.2 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-7.2" ;
  skosxl:prefLabel isoiec80000:term-t2-7.2-0 ;
  skosxl:altLabel isoiec80000:sym-t2-7.2-0 ;
  skos:definition """the set of integers"""@en ;
  skos:note """stem:[bb(sf(Z)) = {..., -2, -1, 0, 1, 2, ...}]

stem:[bb(sf(Z))** = {n in bb(sf(Z)) &#x2223; n != 0}]

Other restrictions can be indicated in an obvious way, as shown below.

stem:[bb(sf(Z))_(>-3) = {n in bb(sf(Z)) &#x2223; n > -3}]

The symbol stem:[ZZ] is also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-7 .

isoiec80000:term-t2-7.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "set of rational numbers"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-7.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(sf(Q))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-7.3 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-7.3" ;
  skosxl:prefLabel isoiec80000:term-t2-7.3-0 ;
  skosxl:altLabel isoiec80000:sym-t2-7.3-0 ;
  skos:definition """the set of rational numbers"""@en ;
  skos:note """stem:[bb(sf(Q))** = {r in bb(sf(Q)) &#x2223; r != 0}]

Other restrictions can be indicated in an obvious way, as shown below.

stem:[bb(sf(Q))_(<0) = {r in bb(sf(Q)) &#x2223; r < 0}]

The symbols stem:[rm(&#8739;Q)] and stem:[QQ] are also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-7 .

isoiec80000:term-t2-7.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "set of real numbers"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-7.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(sf(R))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-7.4 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-7.4" ;
  skosxl:prefLabel isoiec80000:term-t2-7.4-0 ;
  skosxl:altLabel isoiec80000:sym-t2-7.4-0 ;
  skos:definition """the set of real numbers"""@en ;
  skos:note """stem:[bb(sf(R))** = {x in bb(sf(R)) &#x2223; x != 0}]

Other restrictions can be indicated in an obvious way, as shown below.

stem:[bb(sf(R))_(>0) = {x in bb(sf(R)) &#x2223; x > 0}]

The symbols stem:[rm(&#8739;R)] and stem:[RR] are also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-7 .

isoiec80000:term-t2-7.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "set of complex numbers"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-7.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(sf(C))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-7.5 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-7.5" ;
  skosxl:prefLabel isoiec80000:term-t2-7.5-0 ;
  skosxl:altLabel isoiec80000:sym-t2-7.5-0 ;
  skos:definition """the set of complex numbers"""@en ;
  skos:note """stem:[bb(sf(C))** = {z in bb(sf(C)) &#x2223; z != 0}]

The symbol stem:[CC] is also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-7 .

isoiec80000:term-t2-7.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "set of prime numbers"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-7.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(sf(P))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-7.6 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-7.6" ;
  skosxl:prefLabel isoiec80000:term-t2-7.6-0 ;
  skosxl:altLabel isoiec80000:sym-t2-7.6-0 ;
  skos:definition """the set of prime numbers"""@en ;
  skos:note """stem:[bb(sf(P)) = {2, 3, 5, 7, 11, 13, 17, ...}]

The symbol stem:[&#8473;] is also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-7 .

isoiec80000:term-t2-7.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "closed interval"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-7.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "[a, b\\]"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-7.7 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-7.7" ;
  skosxl:prefLabel isoiec80000:term-t2-7.7-0 ;
  skosxl:altLabel isoiec80000:sym-t2-7.7-0 ;
  skos:definition """closed interval from stem:[a] included to stem:[b] included"""@en ;
  skos:note """stem:[[a, b\\] = {x in bb(sf(R)) &#x2223; a <= x <= b}]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-7 .

isoiec80000:term-t2-7.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "left half-open interval"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-7.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "(a, b\\]"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-7.8 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-7.8" ;
  skosxl:prefLabel isoiec80000:term-t2-7.8-0 ;
  skosxl:altLabel isoiec80000:sym-t2-7.8-0 ;
  skos:definition """left half-open interval from stem:[a] excluded to stem:[b] included"""@en ;
  skos:note """stem:[(a, b\\] = {x in bb(sf(R)) &#x2223; a < x <= b}]

The notation stem:[\\]a, b\\]] is also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-7 .

isoiec80000:term-t2-7.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "right half-open interval"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-7.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "[a, b)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-7.9 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-7.9" ;
  skosxl:prefLabel isoiec80000:term-t2-7.9-0 ;
  skosxl:altLabel isoiec80000:sym-t2-7.9-0 ;
  skos:definition """right half-open interval from stem:[a] included to stem:[b] excluded"""@en ;
  skos:note """stem:[[a, b) = {x in bb(sf(R)) &#x2223; a <= x < b}]

The notation stem:[[a, b[] is also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-7 .

isoiec80000:term-t2-7.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "open interval"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-7.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "(a, b)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-7.10 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-7.10" ;
  skosxl:prefLabel isoiec80000:term-t2-7.10-0 ;
  skosxl:altLabel isoiec80000:sym-t2-7.10-0 ;
  skos:definition """open interval from stem:[a] excluded to stem:[b] excluded"""@en ;
  skos:note """stem:[(a, b) = {x in bb(sf(R)) &#x2223; a < x < b}]

The notation stem:[\\]a], stem:[b[] is also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-7 .

isoiec80000:term-t2-7.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "closed unbounded interval"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-7.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "(-oo, b\\]"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-7.11 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-7.11" ;
  skosxl:prefLabel isoiec80000:term-t2-7.11-0 ;
  skosxl:altLabel isoiec80000:sym-t2-7.11-0 ;
  skos:definition """closed unbounded interval up to stem:[b] included"""@en ;
  skos:note """stem:[(-oo, b\\] = {x in bb(sf(R)) &#x2223; x <= b}]

The notation stem:[\\]-oo, b\\]] is also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-7 .

isoiec80000:term-t2-7.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "open unbounded interval"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-7.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "(-oo, b)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-7.12 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-7.12" ;
  skosxl:prefLabel isoiec80000:term-t2-7.12-0 ;
  skosxl:altLabel isoiec80000:sym-t2-7.12-0 ;
  skos:definition """open unbounded interval up to stem:[b] excluded"""@en ;
  skos:note """stem:[(-oo, b) = {x in bb(sf(R)) &#x2223; x < b}]

The notation stem:[\\]-oo, b[] is also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-7 .

isoiec80000:term-t2-7.13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "closed unbounded interval"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-7.13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "[a, +oo)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-7.13 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-7.13" ;
  skosxl:prefLabel isoiec80000:term-t2-7.13-0 ;
  skosxl:altLabel isoiec80000:sym-t2-7.13-0 ;
  skos:definition """closed unbounded interval onward from stem:[a] included"""@en ;
  skos:note """stem:[[a, +oo) = {x in bb(sf(R)) &#x2223; a <= x}]

The notations stem:[[a, oo), [a, +oo[] and stem:[[a, oo[] are also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-7 .

isoiec80000:term-t2-7.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "open unbounded interval"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-7.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "(a, +oo)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-7.14 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-7.14" ;
  skosxl:prefLabel isoiec80000:term-t2-7.14-0 ;
  skosxl:altLabel isoiec80000:sym-t2-7.14-0 ;
  skos:definition """open unbounded interval onward from stem:[a] excluded"""@en ;
  skos:note """stem:[(a, +oo) = {x in bb(sf(R)) &#x2223; a < x}]

The notations stem:[(a, oo)], stem:[\\]a, +oo[] and stem:[\\]a, oo[] are also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-7 .

@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
