@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

isoiec80000:part-2-8 a smart:PublicationDocument ;
  dcterms:title "Part 2-8"@en ;
  dcterms:identifier "ISO 80000-2-8" ;
  smart:hasPublicationType smart:internationalStandard ;
  smart:hasBindingnessType smart:normative .

isoiec80000:term-t2-8.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "equality"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a = b"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.1 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.1" ;
  skosxl:prefLabel isoiec80000:term-t2-8.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.1-0 ;
  skos:definition """stem:[a] is equal to stem:[b] +
stem:[a] equals stem:[b]
"""@en ;
  skos:note """The symbol stem:[-=] may be used to emphasize that a particular equality is an identity, i.e. holds universally.

But see <<t2-8.18>> for another meaning.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .

isoiec80000:term-t2-8.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "inequality"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a != b"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.2 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.2" ;
  skosxl:prefLabel isoiec80000:term-t2-8.2-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.2-0 ;
  skos:definition """stem:[a] is not equal to stem:[b]"""@en ;
  skos:note """The negating stroke may also be vertical."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .

isoiec80000:term-t2-8.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "equal to"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a &#x2254; b"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.3 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.3" ;
  skosxl:prefLabel isoiec80000:term-t2-8.3-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.3-0 ;
  skos:definition """stem:[a] is by definition equal to stem:[b]"""@en ;
  skos:note """[example]
====
stem:[p &#x2254; mv], where stem:[p] is momentum, stem:[m] is mass and stem:[v] is velocity.

The symbols stem:[=_(\"def\")] and stem:[&#x225D;] are also used.
====
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .

isoiec80000:term-t2-8.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "corresponds to"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a &#x2259; b"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.4 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.4" ;
  skosxl:prefLabel isoiec80000:term-t2-8.4-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.4-0 ;
  skos:definition """stem:[a] corresponds to stem:[b]"""@en ;
  skos:note """[example]
====
When stem:[E = kT], then stem:[1 \"unitsml(eV)\" &#x2259; 11604.5 \"unitsml(K)\"].

When stem:[1 \"unitsml(cm)\"] on a map corresponds to a length of stem:[10 \"unitsml(km)\"], one may write stem:[1 \"unitsml(cm)\" &#x2259; 10 \"unitsml(km)\"].

The correspondence is not symmetric.
====
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .

isoiec80000:term-t2-8.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "approximately equal to"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a ~~ b"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.5 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.5" ;
  skosxl:prefLabel isoiec80000:term-t2-8.5-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.5-0 ;
  skos:definition """stem:[a] is approximately equal to stem:[b]"""@en ;
  skos:note """It depends on the user whether an approximation is sufficiently good. Equality is not excluded."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .

isoiec80000:term-t2-8.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "asymptotically equal to"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a &#x2243; b"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.6 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.6" ;
  skosxl:prefLabel isoiec80000:term-t2-8.6-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.6-0 ;
  skos:definition """stem:[a] is asymptotically equal to stem:[b]"""@en ;
  skos:note """[example]
====
stem:[1/(sin(x-a)) &#x2243; 1/(x-a)] as stem:[x -> a]

(For stem:[x -> a], see <<t2-8.16>>.)
====
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .

isoiec80000:term-t2-8.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "proportional to"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a ~ b"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.7 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.7" ;
  skosxl:prefLabel isoiec80000:term-t2-8.7-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.7-0 ;
  skos:definition """stem:[a] is proportional to stem:[b]"""@en ;
  skos:note """The symbol stem:[~] is also used for equivalence relations.

The notation stem:[a prop b] is also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .

isoiec80000:term-t2-8.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "congruent to"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "M ~= N"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.8 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.8" ;
  skosxl:prefLabel isoiec80000:term-t2-8.8-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.8-0 ;
  skos:definition """stem:[M] is congruent to stem:[N],

stem:[M] is isomorphic to stem:[N]
"""@en ;
  skos:note """stem:[M] and stem:[N] are point sets (geometrical figures).

This symbol is also used for isomorphisms of mathematical structures.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .

isoiec80000:term-t2-8.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "less than"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a < b"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.9 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.9" ;
  skosxl:prefLabel isoiec80000:term-t2-8.9-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.9-0 ;
  skos:definition """stem:[a] is less than stem:[b]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .

isoiec80000:term-t2-8.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "greater than"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "b > a"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.10 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.10" ;
  skosxl:prefLabel isoiec80000:term-t2-8.10-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.10-0 ;
  skos:definition """stem:[b] is greater than stem:[a]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .

isoiec80000:term-t2-8.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "less than or equal to"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a <= b"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.11 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.11" ;
  skosxl:prefLabel isoiec80000:term-t2-8.11-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.11-0 ;
  skos:definition """stem:[a] is less than or equal to stem:[b]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .

isoiec80000:term-t2-8.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "greater than or equal to"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "b >= a"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.12 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.12" ;
  skosxl:prefLabel isoiec80000:term-t2-8.12-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.12-0 ;
  skos:definition """stem:[b] is greater than or equal to stem:[a]"""@en ;
  skos:note """It depends on the situation whether stem:[a] is sufficiently small as compared to stem:[b]."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .

isoiec80000:term-t2-8.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "much greater than"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "b &#x226B; a"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.14 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.14" ;
  skosxl:prefLabel isoiec80000:term-t2-8.14-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.14-0 ;
  skos:definition """stem:[b] is much greater than stem:[a]"""@en ;
  skos:note """It depends on the situation whether stem:[b] is sufficiently great as compared to stem:[a]."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .

isoiec80000:term-t2-8.15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "infinity"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "oo"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.15 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.15" ;
  skosxl:prefLabel isoiec80000:term-t2-8.15-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.15-0 ;
  skos:definition """infinity"""@en ;
  skos:note """This symbol does not denote a number but is often part of various expressions dealing with limits.

The notations stem:[+oo, -oo] are also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .

isoiec80000:term-t2-8.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "tends to"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "x -> a"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.16 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.16" ;
  skosxl:prefLabel isoiec80000:term-t2-8.16-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.16-0 ;
  skos:definition """stem:[x] tends to stem:[a]"""@en ;
  skos:note """This symbol occurs as part of various expressions dealing with limits.

stem:[a] may be also stem:[oo], stem:[+oo], or stem:[-oo].
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .

isoiec80000:term-t2-8.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "divides"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "m &#x2223; n"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.17 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.17" ;
  skosxl:prefLabel isoiec80000:term-t2-8.17-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.17-0 ;
  skos:definition """stem:[m] divides stem:[n]"""@en ;
  skos:note """For integers stem:[m] and stem:[n]:

stem:[EE k in bb(sf(Z))] stem:[m*k = n]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .

isoiec80000:term-t2-8.18-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "congruent to"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.18-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "n -= k \" mod \" m"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.18 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.18" ;
  skosxl:prefLabel isoiec80000:term-t2-8.18-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.18-0 ;
  skos:definition """stem:[n] is congruent to stem:[k] modulo stem:[m]"""@en ;
  skos:note """For integers stem:[n], stem:[k] and stem:[m]:

stem:[m &#x2223; (n - k)]

This concept of number theory must not be confused with identity of an equation, mentioned in <<t2-8.1>>, column 4.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .

isoiec80000:term-t2-8.19-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "parentheses"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t2-8.19-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "square brackets"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t2-8.19-2 a smart:Term, skosxl:Label ;
  skosxl:literalForm "braces"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t2-8.19-3 a smart:Term, skosxl:Label ;
  skosxl:literalForm "angle brackets"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-8.19-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "(a + b)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-8.19-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "[a + b\\]"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-8.19-2 a smart:Term, skosxl:Label ;
  skosxl:literalForm "{a + b}"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-8.19-3 a smart:Term, skosxl:Label ;
  skosxl:literalForm "<<a + b>>"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-8.19 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-8.19" ;
  skosxl:prefLabel isoiec80000:term-t2-8.19-0 ;
  skosxl:altLabel isoiec80000:term-t2-8.19-1 ;
  skosxl:altLabel isoiec80000:term-t2-8.19-2 ;
  skosxl:altLabel isoiec80000:term-t2-8.19-3 ;
  skosxl:altLabel isoiec80000:sym-t2-8.19-0 ;
  skosxl:altLabel isoiec80000:sym-t2-8.19-1 ;
  skosxl:altLabel isoiec80000:sym-t2-8.19-2 ;
  skosxl:altLabel isoiec80000:sym-t2-8.19-3 ;
  skos:definition """parentheses +
square brackets +
braces +
angle brackets
"""@en ;
  skos:note """It is recommended to use only parentheses for grouping, since brackets and braces often have a specific meaning in particular fields. Parentheses can be nested without ambiguity."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-8 .

@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

isoiec80000:part-2-9 a smart:PublicationDocument ;
  dcterms:title "Part 2-9"@en ;
  dcterms:identifier "ISO 80000-2-9" ;
  smart:hasPublicationType smart:internationalStandard ;
  smart:hasBindingnessType smart:normative .

isoiec80000:term-t2-9.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "straight line"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-9.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"AB\" &#8741; \"CD\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-9.1 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-9.1" ;
  skosxl:prefLabel isoiec80000:term-t2-9.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-9.1-0 ;
  skos:definition """the straight line stem:[\"AB\"] is parallel to the straight line stem:[\"CD\"]"""@en ;
  skos:note """It is written stem:[\"g\" &#8741; \"h\"] if stem:[\"g\"] and stem:[\"h\"] are the straight lines determined by the points stem:[\"A\"] and stem:[\"B\"], and the points stem:[\"C\"] and stem:[\"D\"], respectively."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-9 .

isoiec80000:term-t2-9.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "perpendicular to the straight line"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-9.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"AB\" &#8869; \"CD\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-9.2 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-9.2" ;
  skosxl:prefLabel isoiec80000:term-t2-9.2-0 ;
  skosxl:altLabel isoiec80000:sym-t2-9.2-0 ;
  skos:definition """the straight line stem:[\"AB\"] is perpendicular to the straight line stem:[\"CD\"]"""@en ;
  skos:note """It is written stem:[\"g\" &#8869; \"h\"] if stem:[\"g\"] and stem:[\"h\"] are the straight lines determined by the points stem:[\"A\"] and stem:[\"B\"], and the points stem:[\"C\"] and stem:[\"D\"], respectively. In a plane, the straight lines intersect."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-9 .

isoiec80000:term-t2-9.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "angle at triangle vertex"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-9.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "&#x2222; \"ABC\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-9.3 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-9.3" ;
  skosxl:prefLabel isoiec80000:term-t2-9.3-0 ;
  skosxl:altLabel isoiec80000:sym-t2-9.3-0 ;
  skos:definition """angle at vertex stem:[\"B\"] in the triangle stem:[\"ABC\"]"""@en ;
  skos:note """The angle is not oriented, it holds that stem:[&#x2222; \"ABC\" = &#x2222; \"CBA\"] and

stem:[0 <= &#x2222; \"ABC\" <= pi \"unitsml(rad)\"].

For a more general definition including rotation angles see <<iso80000-3>>.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-9 .

isoiec80000:term-t2-9.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "line segment"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-9.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bar(\"AB\")"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-9.4 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-9.4" ;
  skosxl:prefLabel isoiec80000:term-t2-9.4-0 ;
  skosxl:altLabel isoiec80000:sym-t2-9.4-0 ;
  skos:definition """line segment from stem:[\"A\"] to stem:[\"B\"]"""@en ;
  skos:note """The line segment is the set of points between stem:[\"A\"] and stem:[\"B\"] on the straight line stem:[\"AB\"] including the end points stem:[\"A\"] and stem:[\"B\"]."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-9 .

isoiec80000:term-t2-9.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "vector from point A to B"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-9.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "vec(\"AB\")"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-9.5 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-9.5" ;
  skosxl:prefLabel isoiec80000:term-t2-9.5-0 ;
  skosxl:altLabel isoiec80000:sym-t2-9.5-0 ;
  skos:definition """vector from stem:[\"A\"] to stem:[\"B\"]"""@en ;
  skos:note """If stem:[vec(\"AB\")=vec(\"CD\")] then stem:[\"B\"], seen from stem:[\"A\"], is in the same direction and distance as stem:[\"D\"] is, seen from stem:[\"C\"]. It does not follow that stem:[A = C] and stem:[B = D]."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-9 .

isoiec80000:term-t2-9.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "distance between points A and B"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-9.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "d(\"A\", \"B\")"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-9.6 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-9.6" ;
  skosxl:prefLabel isoiec80000:term-t2-9.6-0 ;
  skosxl:altLabel isoiec80000:sym-t2-9.6-0 ;
  skos:definition """distance between points stem:[\"A\"] and stem:[\"B\"]"""@en ;
  skos:note """The distance is the length of the line segment stem:[bar(\"AB\")] and also the magnitude of the vector stem:[vec(\"AB\")]."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-9 .

@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

isoiec80000:part-2-10 a smart:PublicationDocument ;
  dcterms:title "Part 2-10"@en ;
  dcterms:identifier "ISO 80000-2-10" ;
  smart:hasPublicationType smart:internationalStandard ;
  smart:hasBindingnessType smart:normative .

isoiec80000:term-t2-10.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "plus"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a + b"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.1 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.1" ;
  skosxl:prefLabel isoiec80000:term-t2-10.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.1-0 ;
  skos:definition """stem:[a] plus stem:[b]"""@en ;
  skos:note """This operation is named addition. The symbol + is the addition symbol."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .

isoiec80000:term-t2-10.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "minus"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a - b"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.2 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.2" ;
  skosxl:prefLabel isoiec80000:term-t2-10.2-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.2-0 ;
  skos:definition """stem:[a] minus stem:[b]"""@en ;
  skos:note """This operation is named subtraction. The symbol - is the subtraction symbol."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .

isoiec80000:term-t2-10.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "plus or minus"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a +- b"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.3 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.3" ;
  skosxl:prefLabel isoiec80000:term-t2-10.3-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.3-0 ;
  skos:definition """stem:[a] plus or minus stem:[b]"""@en ;
  skos:note """This is a combination of two values into one expression."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .

isoiec80000:term-t2-10.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "minus or plus"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a &#x2213; b"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.4 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.4" ;
  skosxl:prefLabel isoiec80000:term-t2-10.4-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.4-0 ;
  skos:definition """stem:[a] minus or plus stem:[b]"""@en ;
  skos:note """stem:[-(a pm b) = -a &#x2213; b]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .

isoiec80000:term-t2-10.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "multiplication"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "ab"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.5 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.5" ;
  skosxl:prefLabel isoiec80000:term-t2-10.5-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.5-0 ;
  skos:definition """stem:[a] times stem:[b]"""@en ;
  skos:note """See also <<t2-6.16>>, <<t2-6.17>>, <<t2-18.11>>, <<t2-18.12>>, <<t2-18.23>> and <<t2-18.24>> for the use of the dot and cross in various products."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .

isoiec80000:term-t2-10.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "divided by"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a\" \":\" \"b"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.6 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.6" ;
  skosxl:prefLabel isoiec80000:term-t2-10.6-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.6-0 ;
  skos:definition """stem:[a] divided by stem:[b]"""@en ;
  skos:note """The symbol stem:[-:] should not be used."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .

isoiec80000:term-t2-10.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sum of"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sum_(i=1)^n a_i"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.7 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.7" ;
  skosxl:prefLabel isoiec80000:term-t2-10.7-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.7-0 ;
  skos:definition """sum of stem:[a_1, a_2, ..., a_n]"""@en ;
  skos:note """The notations stem:[sum_(i=1)^n], stem:[sum_i a_i], stem:[sum_i a_i] and stem:[sum a_i] are also used."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .

isoiec80000:term-t2-10.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "product of"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "prod_(i=1)^n a_i"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.8 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.8" ;
  skosxl:prefLabel isoiec80000:term-t2-10.8-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.8-0 ;
  skos:definition """product of stem:[a_1, a_2, ..., a_n]"""@en ;
  skos:note """The notations stem:[prod_(i=1)^n a_i], stem:[prod_i a_i], stem:[prod_i a_i] and stem:[prod a_i] are also used."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .

isoiec80000:term-t2-10.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "power"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a^p"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.9 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.9" ;
  skosxl:prefLabel isoiec80000:term-t2-10.9-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.9-0 ;
  skos:definition """stem:[a] to the power stem:[p]"""@en ;
  skos:note """The verbal equivalent of stem:[a^2] is a squared; the verbal equivalent of stem:[a^3] is a cubed."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .

isoiec80000:term-t2-10.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "square root"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a^(1//2)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-10.10-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sqrt(a)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.10 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.10" ;
  skosxl:prefLabel isoiec80000:term-t2-10.10-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.10-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.10-1 ;
  skos:definition """stem:[a] a to the power stem:[1//2], +
square root of stem:[a]
"""@en ;
  skos:note """If stem:[a >= 0], then stem:[sqrt(a) >= 0].

The symbol stem:[sqrt(a)] should be avoided.

See remark to <<t2-10.11>>.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .

isoiec80000:term-t2-10.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "power"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "root(n)(a)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.11 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.11" ;
  skosxl:prefLabel isoiec80000:term-t2-10.11-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.11-0 ;
  skos:definition """stem:[n]^th^ root of stem:[a]"""@en ;
  skos:note """If stem:[a >= 0], then stem:[root(n)(a) >= 0].

The symbol without the upper line stem:[root(n)(a)] should be avoided.

If however the symbol stem:[root(n)(\" \")] or stem:[sqrt] is used acting on a composite expression, parentheses shall be used to avoid ambiguity.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .

isoiec80000:term-t2-10.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "mean value"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bar x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-10.12-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "<< x >>"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-10.12-2 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bar x_a"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.12 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.12" ;
  skosxl:prefLabel isoiec80000:term-t2-10.12-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.12-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.12-1 ;
  skosxl:altLabel isoiec80000:sym-t2-10.12-2 ;
  skos:definition """mean value of stem:[x], +
arithmetic mean of stem:[x]
"""@en ;
  skos:note """Mean values obtained by other methods are the

* harmonic mean denoted by subscript stem:[\"h\"],
* geometric mean denoted by subscript stem:[\"g\"],
* quadratic mean, often called \"root mean square\", denoted by subscript stem:[\"q\"] or stem:[\"rms\"].

The subscript may only be omitted for the arithmetic mean.

In mathematics, stem:[bar x] is also used for the complex conjugate of stem:[x]; see <<t2-15.6>>.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .

isoiec80000:term-t2-10.13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "signum"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"sgn \" a"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.13 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.13" ;
  skosxl:prefLabel isoiec80000:term-t2-10.13-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.13-0 ;
  skos:definition """signum stem:[a]"""@en ;
  skos:note """For real stem:[a]:

stem:[\"sgn \" a = {(1 \" if \" a>0),(0 \" if \" a=0),(-1 \" if \" a<0):}]

See also item <<t2-15.7>>. Sometimes stem:[\"sgn \"0] is left undefined.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .

isoiec80000:term-t2-10.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "infimum"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"inf \"M"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.14 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.14" ;
  skosxl:prefLabel isoiec80000:term-t2-10.14-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.14-0 ;
  skos:definition """infimum of stem:[M]"""@en ;
  skos:note """Greatest lower bound of a non-empty set of numbers bounded from below."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .

isoiec80000:term-t2-10.15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "supremum"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"sup \"M"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.15 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.15" ;
  skosxl:prefLabel isoiec80000:term-t2-10.15-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.15-0 ;
  skos:definition """supremum of stem:[M]"""@en ;
  skos:note """Smallest upper bound of a non-empty set of numbers bounded from above."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .

isoiec80000:term-t2-10.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "magnitude"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "abs(a)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.16 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.16" ;
  skosxl:prefLabel isoiec80000:term-t2-10.16-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.16-0 ;
  skos:definition """magnitude of stem:[a]"""@en ;
  skos:note """The notation stem:[\"abs \"a] is also used.

The symbol stem:[abs] is also used for cardinality of a set (see <<t2-6.5>>), modulus of a complex number (<<t2-15.4>>) and magnitude of a vector (see <<t2-18.4>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .

isoiec80000:term-t2-10.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "floor"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "floor(a)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.17 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.17" ;
  skosxl:prefLabel isoiec80000:term-t2-10.17-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.17-0 ;
  skos:definition """floor stem:[a], +
the greatest integer less than or equal to the real number stem:[a]
"""@en ;
  skos:note """The notation stem:[\"ent \"a] is also used.

[example]
====
stem:[floor(2,4) = 2]

stem:[floor(-2,4) = -3]
====
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .

isoiec80000:term-t2-10.18-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "ceil"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.18-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "ceil(a)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.18 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.18" ;
  skosxl:prefLabel isoiec80000:term-t2-10.18-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.18-0 ;
  skos:definition """ceil stem:[a], +
the least integer greater than or equal to the real number stem:[a]
"""@en ;
  skos:note """\"ceil\" is an abbreviation of the English word \"ceiling\".

[example]
====
stem:[ceil(2,4) = 3]

stem:[ceil(-2,4) = -2]
====
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .

isoiec80000:term-t2-10.19-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "integer part"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.19-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"int \"a"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.19 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.19" ;
  skosxl:prefLabel isoiec80000:term-t2-10.19-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.19-0 ;
  skos:definition """integer part of the real number stem:[a]"""@en ;
  skos:note """stem:[\"int \"a = \"sgn \"a * floor(abs(a))]

[example]
====
stem:[\"int\"(2,4) = 2]

stem:[\"int\"(-2,4) = -2]
====
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .

isoiec80000:term-t2-10.20-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "fractional part"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.20-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"frac \"a"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.20 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.20" ;
  skosxl:prefLabel isoiec80000:term-t2-10.20-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.20-0 ;
  skos:definition """fractional part of the real number stem:[a]"""@en ;
  skos:note """stem:[\"frac \"a = a - \"int \"a]

[example]
====
stem:[\"frac\"(2,4) = 0,4]

stem:[\"frac\"(-2,4) = -0,4]
====
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .

isoiec80000:term-t2-10.21-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "minimum"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.21-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"min\"(a, b)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.21 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.21" ;
  skosxl:prefLabel isoiec80000:term-t2-10.21-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.21-0 ;
  skos:definition """minimum of stem:[a] and stem:[b]"""@en ;
  skos:note """The operation generalizes to more than two numbers and to sets of numbers. However, an infinite set of numbers need not have a smallest element, in this case use stem:[\"inf\"] (see <<t2-10.14>>)."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .

isoiec80000:term-t2-10.22-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "maximum"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-10.22-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"max\"(a, b)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-10.22 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-10.22" ;
  skosxl:prefLabel isoiec80000:term-t2-10.22-0 ;
  skosxl:altLabel isoiec80000:sym-t2-10.22-0 ;
  skos:definition """maximum of stem:[a] and stem:[b]"""@en ;
  skos:note """The operation generalizes to more than two numbers and to sets of numbers. However, an infinite set of numbers need not have a greatest element, in this case use sup (see <<t2-10.15>>)."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-10 .

@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

isoiec80000:part-2-11 a smart:PublicationDocument ;
  dcterms:title "Part 2-11"@en ;
  dcterms:identifier "ISO 80000-2-11" ;
  smart:hasPublicationType smart:internationalStandard ;
  smart:hasBindingnessType smart:normative .

isoiec80000:term-t2-11.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "factorial"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-11.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "n!"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-11.1 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-11.1" ;
  skosxl:prefLabel isoiec80000:term-t2-11.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-11.1-0 ;
  skos:definition """factorial"""@en ;
  skos:note """stem:[n! = prod_(k=1)^n] stem:[k=1*2*3*...*n] (for stem:[n>0])

stem:[0! = 1]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-11 .

isoiec80000:term-t2-11.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "falling factorial"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-11.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a^(ul(k))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-11.2 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-11.2" ;
  skosxl:prefLabel isoiec80000:term-t2-11.2-0 ;
  skosxl:altLabel isoiec80000:sym-t2-11.2-0 ;
  skos:definition """falling factorial"""@en ;
  skos:note """stem:[a^(ul(k)) = a*(a - 1)*...*(a - k + 1)] (for stem:[k > 0])

stem:[a^(ul(0))=1]

stem:[a] may be a complex number.

For a natural number stem:[n]:

stem:[n^(ul(k)) = (n!)/((n-k)!)]

In combinatorics and statistics, the symbol stem:[(a)_k] is often used for the falling factorial. In the theory of special functions, however, the same symbol is often used for the rising factorial and called Pochhammer symbol.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-11 .

isoiec80000:term-t2-11.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "rising factorial"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-11.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a^(bar(k))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-11.3 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-11.3" ;
  skosxl:prefLabel isoiec80000:term-t2-11.3-0 ;
  skosxl:altLabel isoiec80000:sym-t2-11.3-0 ;
  skos:definition """rising factorial"""@en ;
  skos:note """stem:[a^(bar(k)) = a *(a + 1)* ... *(a + k - 1)] (for stem:[k > 0])

stem:[a^(bar(0)) = 1]

stem:[a] may be a complex number.

For a natural number stem:[n]:

stem:[n^(bar(k)) = ((n+k-1)!)/((n-1)!)]

In the theory of special functions, the symbol stem:[(a)_k] is often used for the rising factorial and called Pochhammer symbol. In combinatorics and statistics, however, the same symbol is often used for the falling factorial.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-11 .

isoiec80000:term-t2-11.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "binomial coefficient"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-11.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "((n),(k))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-11.4 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-11.4" ;
  skosxl:prefLabel isoiec80000:term-t2-11.4-0 ;
  skosxl:altLabel isoiec80000:sym-t2-11.4-0 ;
  skos:definition """binomial coefficient"""@en ;
  skos:note """stem:[((n),(k)) = (n!)/(k!(n-k)!)] (for stem:[0<=k<=n])"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-11 .

isoiec80000:term-t2-11.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bernoulli numbers"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-11.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"B\"_n"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-11.5 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-11.5" ;
  skosxl:prefLabel isoiec80000:term-t2-11.5-0 ;
  skosxl:altLabel isoiec80000:sym-t2-11.5-0 ;
  skos:definition """Bernoulli numbers"""@en ;
  skos:note """stem:[\"B\"_n = -1/(n+1) sum_(k=0)^(n-1) ((n+1),(k)) \"B\"_k]

(for stem:[n > 0])

stem:[\"B\"_0 = 1]

stem:[\"B\"_1 = -1//2], stem:[\"B\"_(2n+3)= 0]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-11 .

isoiec80000:term-t2-11.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "number of combinations without repetition"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-11.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"C\"_n^k"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-11.6 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-11.6" ;
  skosxl:prefLabel isoiec80000:term-t2-11.6-0 ;
  skosxl:altLabel isoiec80000:sym-t2-11.6-0 ;
  skos:definition """number of combinations without repetition"""@en ;
  skos:note """stem:[\"C\"_n^k = ((n),(k)) = (n!)/(k!(n-k)!)]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-11 .

isoiec80000:term-t2-11.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "number of combinations with repetition"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-11.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "&#x200c;^\"R\" \"C\"_n^k"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-11.7 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-11.7" ;
  skosxl:prefLabel isoiec80000:term-t2-11.7-0 ;
  skosxl:altLabel isoiec80000:sym-t2-11.7-0 ;
  skos:definition """number of combinations with repetition"""@en ;
  skos:note """stem:[&#x200c;^\"R\" \"C\"_n^k = ((n+k-1),(k))]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-11 .

isoiec80000:term-t2-11.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "number of variations without repetition"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-11.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"V\"_n^k"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-11.8 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-11.8" ;
  skosxl:prefLabel isoiec80000:term-t2-11.8-0 ;
  skosxl:altLabel isoiec80000:sym-t2-11.8-0 ;
  skos:definition """number of variations without repetition"""@en ;
  skos:note """stem:[\"V\"_n^k = n^(ul k) = (n!)/((n-k)!)]

The term \"permutation\" is used when stem:[n = k].
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-11 .

isoiec80000:term-t2-11.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "number of variations with repetition"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-11.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "&#x200c;^\"R\" \"V\"_n^k"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-11.9 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-11.9" ;
  skosxl:prefLabel isoiec80000:term-t2-11.9-0 ;
  skosxl:altLabel isoiec80000:sym-t2-11.9-0 ;
  skos:definition """number of variations with repetition"""@en ;
  skos:note """stem:[&#x200c;^\"R\" \"V\"_n^k = n^k]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-11 .

@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

isoiec80000:part-2-12 a smart:PublicationDocument ;
  dcterms:title "Part 2-12"@en ;
  dcterms:identifier "ISO 80000-2-12" ;
  smart:hasPublicationType smart:internationalStandard ;
  smart:hasBindingnessType smart:normative .

isoiec80000:term-t2-12.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "f, g, h, ..."@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.1 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.1" ;
  skosxl:prefLabel isoiec80000:term-t2-12.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.1-0 ;
  skos:definition """functions"""@en ;
  skos:note """A function assigns to any argument in its domain a unique value in its range.

The arguments are said to be _mapped_ by the function onto the values, which are called _images_ of the arguments under the function.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "value of function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "f(x)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-12.2-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "f(x_1, ..., x_n)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.2 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.2" ;
  skosxl:prefLabel isoiec80000:term-t2-12.2-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.2-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.2-1 ;
  skos:definition """value of function stem:[f] for argument stem:[x] or for argument stem:[(x_1, ..., x_n)], respectively"""@en ;
  skos:note """A function having a set of stem:[n]-tuples as its domain is an stem:[n]-place function."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "domain"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"dom \"f"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.3 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.3" ;
  skosxl:prefLabel isoiec80000:term-t2-12.3-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.3-0 ;
  skos:definition """domain of stem:[f]"""@en ;
  skos:note """Set of objects to which stem:[f] assigns a value.

stem:[\"D\"(f)] is also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "range"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"ran \"f"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.4 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.4" ;
  skosxl:prefLabel isoiec80000:term-t2-12.4-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.4-0 ;
  skos:definition """range of stem:[f]"""@en ;
  skos:note """Set of values of the function stem:[f].

stem:[R(f)] is also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "maps into"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "f: A -> B"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.5 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.5" ;
  skosxl:prefLabel isoiec80000:term-t2-12.5-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.5-0 ;
  skos:definition """stem:[f] maps stem:[A] into stem:[B]"""@en ;
  skos:note """stem:[\"dom \"f = A] and stem:[\"ran \"f sube B]

It is not necessary that all elements of stem:[B] are values of the function stem:[f].
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "maps surjectively onto"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "f: A ->> B"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.6 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.6" ;
  skosxl:prefLabel isoiec80000:term-t2-12.6-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.6-0 ;
  skos:definition """stem:[f] maps stem:[A] surjectively onto stem:[B]"""@en ;
  skos:note """stem:[\"dom \"f = A] and stem:[\"ran \"f = B]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "maps injectively onto"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "f: A >-> B"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.7 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.7" ;
  skosxl:prefLabel isoiec80000:term-t2-12.7-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.7-0 ;
  skos:definition """stem:[f] maps stem:[A] injectively into stem:[B]"""@en ;
  skos:note """stem:[f: A -> B] and for all stem:[x, y in A]

if stem:[x != y] then stem:[f(x) != f(y)].

The function stem:[f] is then said to be injective or one-one.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "function mapping onto"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "f: A >->> B"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.8 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.8" ;
  skosxl:prefLabel isoiec80000:term-t2-12.8-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.8-0 ;
  skos:definition """stem:[f] maps stem:[A] bijectively onto stem:[B]"""@en ;
  skos:note """stem:[f: A ->> B] and stem:[f: A >-> B]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "function mapping onto"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "x \\|-> T(x), \" \" x in A"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.9 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.9" ;
  skosxl:prefLabel isoiec80000:term-t2-12.9-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.9-0 ;
  skos:definition """function that maps any stem:[x in A] onto stem:[T(x)]"""@en ;
  skos:note """stem:[T(x)] is a defining term denoting the values of some function for the arguments stem:[x in A].

If this function is called stem:[f], then it holds stem:[f(x) = T(x)] for any stem:[x in A]. Therefore the defining term stem:[T(x)] is often used to denote the function stem:[f].

[example]
stem:[x &#8614; 3x^2y], stem:[x in [0, 2\\]]

This is the quadratic function (of stem:[x] depending on the parameter stem:[y]) defined on the stated interval by the term stem:[3x^2y].

If no function symbol is introduced, the term stem:[3x^2y] is used to denote this function.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "inverse function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "f^(-1)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.10 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.10" ;
  skosxl:prefLabel isoiec80000:term-t2-12.10-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.10-0 ;
  skos:definition """inverse function of stem:[f]"""@en ;
  skos:note """The inverse function stem:[f^(-1)] of a function stem:[f] is only defined if stem:[f] is injective.

If stem:[f] is injective then

stem:[\"dom\"(f^(-1)) = \"ran\"(f), \"ran\"(f^(-1)) = \"dom\"(f)], and

stem:[f^(-1)(f(x)) = x] for stem:[x in \"dom \"f].

The inverse function stem:[f^(-1)] should not be confused with the pointwise reciprocal function stem:[x &#8614; f(x)^(-1)].
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "composite function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "g @ f"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.11 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.11" ;
  skosxl:prefLabel isoiec80000:term-t2-12.11-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.11-0 ;
  skos:definition """composite function of stem:[f] and stem:[g], +
stem:[g] circle stem:[f]
"""@en ;
  skos:note """(g @ f)(x) = g(f(x))

In the composite stem:[g @ f], the function stem:[g] is applied after function stem:[f] has been applied.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "maps onto"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "x overset(f)(->) y"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-12.12-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "f : x &#8614; y"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.12 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.12" ;
  skosxl:prefLabel isoiec80000:term-t2-12.12-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.12-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.12-1 ;
  skos:definition """stem:[f(x) = y], +
stem:[f] maps stem:[x] onto stem:[y]
"""@en ;
  skos:note """[example]
stem:[pi overset(\"cos\")(->) -1]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "definite integrals"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "f &#x2223;_a^b"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-12.13-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "f(...,u,...)&#x2223;_(u=a)^(u=b)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.13 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.13" ;
  skosxl:prefLabel isoiec80000:term-t2-12.13-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.13-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.13-1 ;
  skos:definition """stem:[f(b)-f(a)] +
stem:[f(...,b,...)-f(...,a,...)]
"""@en ;
  skos:note """This notation is used mainly when evaluating definite integrals."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "limit"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "lim_(x->a)f(x)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-12.14-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "lim_(x->a)f(x)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.14 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.14" ;
  skosxl:prefLabel isoiec80000:term-t2-12.14-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.14-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.14-1 ;
  skos:definition """limit of stem:[f(x)] as stem:[x] tends to stem:[a]"""@en ;
  skos:note """stem:[f(x) -> b] as stem:[x -> a]

may be written for stem:[lim_(x->a)f(x)=b].

Limits \"from the right\" stem:[(x > a)] and \"from the left\" stem:[(x < a)] are denoted by

stem:[lim_(x->a+)f(x)] and

stem:[lim_(x->a-)f(x)], respectively.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "order comparable with or inferior to"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "f(x) = \"O\"(g(x))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.15 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.15" ;
  skosxl:prefLabel isoiec80000:term-t2-12.15-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.15-0 ;
  skos:definition """stem:[f(x)] is upper case stem:[\"O\"] of stem:[g(x)],

stem:[abs(f(x)//g(x))] is bounded from above in the limit implied by the context,

stem:[f(x)] is of the order comparable with or inferior to stem:[g(x)]
"""@en ;
  skos:note """The symbol \"=\" here is used for historical reasons and does not have the meaning of equality, because transitivity does not apply.

[example]
stem:[\"sin\" x=\"O\"(x)], when stem:[x -> 0]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "order inferior to"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "f(x) = \"o\"(g(x))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.16 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.16" ;
  skosxl:prefLabel isoiec80000:term-t2-12.16-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.16-0 ;
  skos:definition """stem:[f(x)] is lower case stem:[\"o\"] of stem:[g(x)],

stem:[f(x)//g(x) -> 0] in the limit implied by the context,

stem:[f(x)] is of the order inferior to stem:[g(x)]
"""@en ;
  skos:note """The symbol \"=\" here is used for historical reasons and does not have the meaning of equality, because transitivity does not apply.

[example]
stem:[\"cos\" x = 1 + \"o\"(x)], when stem:[x -> 0]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "delta"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Delta f"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.17 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.17" ;
  skosxl:prefLabel isoiec80000:term-t2-12.17-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.17-0 ;
  skos:definition """delta stem:[f], +
finite increment of stem:[f]
"""@en ;
  skos:note """Difference of two function values implied by the context.

[example]
====
stem:[Delta x = x_2-x_1]

stem:[Delta f(x) = f(x_2) - f(x_1)]
====
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.18-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "derivative"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.18-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "(\"d\"f)/(\"d\"x)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-12.18-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"d\"f//\"d\"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-12.18-2 a smart:Term, skosxl:Label ;
  skosxl:literalForm "f'"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-12.18-3 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"D\"f"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.18 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.18" ;
  skosxl:prefLabel isoiec80000:term-t2-12.18-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.18-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.18-1 ;
  skosxl:altLabel isoiec80000:sym-t2-12.18-2 ;
  skosxl:altLabel isoiec80000:sym-t2-12.18-3 ;
  skos:definition """derivative of stem:[f] with respect to stem:[x]"""@en ;
  skos:note """Only to be used for functions of one variable.

The independent variable may also be indicated, for example

stem:[(\"d\"f(x))/(\"d\"x)], stem:[\"d\"f(x)//\"d\"x], stem:[f'(x)] and stem:[\"D\"f(x)].

If the independent variable is time stem:[t], stem:[f] is also used for stem:[f'].
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.19-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "derivative"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.19-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "((\"d\"f)/(\"d\"x))_(x=a)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-12.19-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "(\"d\"f//\"d\"x)_(x=a)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-12.19-2 a smart:Term, skosxl:Label ;
  skosxl:literalForm "f'(a)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-12.19-3 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"D\"f(a)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.19 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.19" ;
  skosxl:prefLabel isoiec80000:term-t2-12.19-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.19-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.19-1 ;
  skosxl:altLabel isoiec80000:sym-t2-12.19-2 ;
  skosxl:altLabel isoiec80000:sym-t2-12.19-3 ;
  skos:definition """value of the derivative of stem:[f] for stem:[x = a]"""@en ;
  skos:note """See also <<t2-12.18>>"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.20-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "derivative"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.20-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "(\"d\"^nf)/(\"d\"x^n)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-12.20-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"d\"^nf//\"d\"x^n"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-12.20-2 a smart:Term, skosxl:Label ;
  skosxl:literalForm "f^((n))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-12.20-3 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"D\"^n f"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.20 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.20" ;
  skosxl:prefLabel isoiec80000:term-t2-12.20-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.20-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.20-1 ;
  skosxl:altLabel isoiec80000:sym-t2-12.20-2 ;
  skosxl:altLabel isoiec80000:sym-t2-12.20-3 ;
  skos:definition """stem:[n^(\"th\")] derivative of stem:[f] with respect to stem:[x]"""@en ;
  skos:note """Only to be used for functions of one variable.

stem:[(\"d\"^nf(x))/(\"d\"x^n)], stem:[\"d\"^nf(x)//\"d\"x^n], stem:[f^((n))(x)] and stem:[\"D\"^nf] are also used.

stem:[f^('')] and stem:[f^(''')] are also used for stem:[f^((2))] and stem:[f^((3))], respectively.

If the independent variable is time stem:[t], stem:[ddot f] is also used for stem:[f^(''')].
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.21-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "partial derivative"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.21-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "(del f)/(del x)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-12.21-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "del f//del x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-12.21-2 a smart:Term, skosxl:Label ;
  skosxl:literalForm "del_x f"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.21 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.21" ;
  skosxl:prefLabel isoiec80000:term-t2-12.21-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.21-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.21-1 ;
  skosxl:altLabel isoiec80000:sym-t2-12.21-2 ;
  skos:definition """partial derivative of stem:[f] with respect to stem:[x]"""@en ;
  skos:note """Only to be used for functions of several variables.

stem:[(del f(x,y,...))/(del x)], stem:[del f(x,y,...)//del x], stem:[del_x f(x,y,...)]
and stem:[\"D\"_x f(x,y,...)] are also used.

The other independent variables may be shown as subscripts, e.g. stem:[((del f)/(del x))_(y...)].

This partial derivative notation is extended to derivatives of higher order, e.g.

stem:[(del^2f)/(del x^2) = del/(del x) ((del f)/(del x))]

stem:[(del^2f)/(delx dely) = del/(delx) ((del f)/(del y))]

Other notations, e.g. stem:[f_(xy) = del/(del x)((del f)/(del y))], are also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.22-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "total differential"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.22-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"d\"f"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.22 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.22" ;
  skosxl:prefLabel isoiec80000:term-t2-12.22-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.22-0 ;
  skos:definition """total differential of stem:[f]"""@en ;
  skos:note """stem:[\"d\"f(x,y,...) = (del f)/(del x) \"d\"x + (del f)/(del y) \"d\"y + ...]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.23-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "infinitesimal variation of function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.23-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "delta f"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.23 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.23" ;
  skosxl:prefLabel isoiec80000:term-t2-12.23-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.23-0 ;
  skos:definition """(infinitesimal) variation of stem:[f]
"""@en ;
  skos:note """This symbol is used in variational calculus."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.24-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "indefinite integral"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.24-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "int f(x)\"d\"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.24 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.24" ;
  skosxl:prefLabel isoiec80000:term-t2-12.24-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.24-0 ;
  skos:definition """indefinite integral of stem:[f]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.25-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "definite integral"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.25-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "int_a^b f(x)\"d\"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.25 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.25" ;
  skosxl:prefLabel isoiec80000:term-t2-12.25-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.25-0 ;
  skos:definition """definite integral of stem:[f] from stem:[a] to stem:[b]"""@en ;
  skos:note """This is the simple case of a function defined on an interval. Integration of functions defined on more general domains may also be defined. Special notations, e.g. stem:[int_\"C\"], stem:[int_\"S\"], stem:[int_\"V\"], stem:[oint], are used for integration over a curve stem:[\"C\"], a surface stem:[\"S\"], a three-dimensional domain stem:[\"V\"], and a closed curve or surface, respectively.

Multiple integrals are also denoted stem:[&#x222C;], stem:[&#x222F;] etc.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.26-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Cauchy principal value"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.26-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "&#x2A0D;_a^b f(x)\"d\"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.26 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.26" ;
  skosxl:prefLabel isoiec80000:term-t2-12.26-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.26-0 ;
  skos:definition """Cauchy principal value of the integral of stem:[f] with singularity at stem:[c], where stem:[a<c<b]"""@en ;
  skos:note """stem:[lim_(delta -> 0+) (int_a^(c-delta)f(x)\"d\"x + int_(c+delta)^b f(x)\"d\"x)]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

isoiec80000:term-t2-12.27-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Cauchy principal value"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-12.27-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "&#x2A0D;_(-oo)^(+oo) f(x)\"d\"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-12.27 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-12.27" ;
  skosxl:prefLabel isoiec80000:term-t2-12.27-0 ;
  skosxl:altLabel isoiec80000:sym-t2-12.27-0 ;
  skos:definition """Cauchy principal value of the integral of stem:[f]"""@en ;
  skos:note """stem:[lim_(a -> oo) &#x2A0D;_{-a}^{+a} f(x)\"d\"x]

See <<t2-12.26>>.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-12 .

@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

isoiec80000:part-2-13 a smart:PublicationDocument ;
  dcterms:title "Part 2-13"@en ;
  dcterms:identifier "ISO 80000-2-13" ;
  smart:hasPublicationType smart:internationalStandard ;
  smart:hasBindingnessType smart:normative .

isoiec80000:term-t2-13.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "base of natural logarithm"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-13.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "e"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-13.1 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-13.1" ;
  skosxl:prefLabel isoiec80000:term-t2-13.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-13.1-0 ;
  skos:definition """base of natural logarithm"""@en ;
  skos:note """stem:[e := lim_(n->oo) (1 + 1/n)^n = 2.7188128...]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-13 .

isoiec80000:term-t2-13.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "exponential function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-13.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a^x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-13.2 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-13.2" ;
  skosxl:prefLabel isoiec80000:term-t2-13.2-0 ;
  skosxl:altLabel isoiec80000:sym-t2-13.2-0 ;
  skos:definition """stem:[a] to the power of stem:[x], +
exponential function to the base stem:[a] of argument stem:[x]
"""@en ;
  skos:note """See also <<t2-10.9>>."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-13 .

isoiec80000:term-t2-13.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "exponential function to the base stem:[\"e\"]"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-13.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"e\"^x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-13.3-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"exp \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-13.3 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-13.3" ;
  skosxl:prefLabel isoiec80000:term-t2-13.3-0 ;
  skosxl:altLabel isoiec80000:sym-t2-13.3-0 ;
  skosxl:altLabel isoiec80000:sym-t2-13.3-1 ;
  skos:definition """stem:[\"e\"] to the power of stem:[x], +
exponential function to the base stem:[\"e\"] of argument stem:[x]
"""@en ;
  skos:note """See <<t2-15.5>>."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-13 .

isoiec80000:term-t2-13.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "logarithm to the base stem:[a]"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-13.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"log\"_a x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-13.4 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-13.4" ;
  skosxl:prefLabel isoiec80000:term-t2-13.4-0 ;
  skosxl:altLabel isoiec80000:sym-t2-13.4-0 ;
  skos:definition """logarithm to the base stem:[a] of argument stem:[x]"""@en ;
  skos:note """stem:[\"log \"x] is used when the base does not need to be specified."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-13 .

isoiec80000:term-t2-13.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "natural logarithm"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-13.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"ln \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-13.5 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-13.5" ;
  skosxl:prefLabel isoiec80000:term-t2-13.5-0 ;
  skosxl:altLabel isoiec80000:sym-t2-13.5-0 ;
  skos:definition """natural logarithm of stem:[x]"""@en ;
  skos:note """stem:[\"ln \"x = \"log\"_e x]

stem:[\"log \"x] shall not be used in place of stem:[\"ln \"x], stem:[\"lg \"x], stem:[\"lb \"x], or stem:[\"log\"_e x], stem:[log_(10) x], stem:[log_2 x].
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-13 .

isoiec80000:term-t2-13.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "decimal logarithm"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-13.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"lg \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-13.6 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-13.6" ;
  skosxl:prefLabel isoiec80000:term-t2-13.6-0 ;
  skosxl:altLabel isoiec80000:sym-t2-13.6-0 ;
  skos:definition """decimal logarithm of stem:[x], +
common logarithm of stem:[x]
"""@en ;
  skos:note """stem:[\"lg \"x = \"log\"_(10) x]

See remark to <<t2-13.5>>.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-13 .

isoiec80000:term-t2-13.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "binary logarithm"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-13.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"lb \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-13.7 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-13.7" ;
  skosxl:prefLabel isoiec80000:term-t2-13.7-0 ;
  skosxl:altLabel isoiec80000:sym-t2-13.7-0 ;
  skos:definition """binary logarithm of stem:[x]"""@en ;
  skos:note """stem:[\"lb \"x = \"log\"_2 x]

See remark to <<t2-13.5>>.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-13 .

@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

isoiec80000:part-2-14 a smart:PublicationDocument ;
  dcterms:title "Part 2-14"@en ;
  dcterms:identifier "ISO 80000-2-14" ;
  smart:hasPublicationType smart:internationalStandard ;
  smart:hasBindingnessType smart:normative .

isoiec80000:term-t2-14.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "ratio of the circumference to diameter"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "pi"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.1 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.1" ;
  skosxl:prefLabel isoiec80000:term-t2-14.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.1-0 ;
  skos:definition """ratio of the circumference of a circle to its diameter"""@en ;
  skos:note """stem:[pi = 3.1415926...]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .

isoiec80000:term-t2-14.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sine"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"sin \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.2 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.2" ;
  skosxl:prefLabel isoiec80000:term-t2-14.2-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.2-0 ;
  skos:definition """sine of stem:[x]"""@en ;
  skos:note """stem:[\"sin \"x = (e^(ix)-e^(-ix))/(2i)]

stem:[\"sin \"x = x - x^3//3! + x^5//5! - ...]

stem:[(\"sin \"x)^n], stem:[(\"cos \"x)^n], etc. (for stem:[n >= 2]), are often written stem:[\"sin\"^n x], stem:[\"cos\"^n x], etc.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .

isoiec80000:term-t2-14.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "cosine"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"cos \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.3 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.3" ;
  skosxl:prefLabel isoiec80000:term-t2-14.3-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.3-0 ;
  skos:definition """cosine of stem:[x]"""@en ;
  skos:note """stem:[\"cos \"x = \"sin\"(x + pi//2)]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .

isoiec80000:term-t2-14.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "tangent"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"tan \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.4 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.4" ;
  skosxl:prefLabel isoiec80000:term-t2-14.4-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.4-0 ;
  skos:definition """tangent of stem:[x]"""@en ;
  skos:note """stem:[\"tan \"x = \"sin \" x//\"cos \"x]

stem:[\"tg \"x] should not be used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .

isoiec80000:term-t2-14.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "cotangent"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"cot \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.5 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.5" ;
  skosxl:prefLabel isoiec80000:term-t2-14.5-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.5-0 ;
  skos:definition """cotangent of stem:[x]"""@en ;
  skos:note """stem:[\"cot \"x = 1//\"tan \"x]

stem:[\"ctg \"x] should not be used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .

isoiec80000:term-t2-14.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "secant"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"sec \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.6 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.6" ;
  skosxl:prefLabel isoiec80000:term-t2-14.6-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.6-0 ;
  skos:definition """secant of stem:[x]"""@en ;
  skos:note """stem:[\"sec \"x = 1//\"cos \"x]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .

isoiec80000:term-t2-14.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "cosecant"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"csc \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.7 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.7" ;
  skosxl:prefLabel isoiec80000:term-t2-14.7-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.7-0 ;
  skos:definition """cosecant of stem:[x]"""@en ;
  skos:note """stem:[\"csc \"x = 1//\"sin \"x]

stem:[\"cosec \"x] is also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .

isoiec80000:term-t2-14.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "arc sine"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"arcsin \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.8 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.8" ;
  skosxl:prefLabel isoiec80000:term-t2-14.8-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.8-0 ;
  skos:definition """arcus sine of stem:[x]"""@en ;
  skos:note """stem:[y = \"arcsin \"x <=> x = \"sin \"y]

(for stem:[-pi//2 <= y <= pi//2])

The function stem:[\"arcsin\"] is the inverse of the function stem:[\"sin\"] with the restriction mentioned above.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .

isoiec80000:term-t2-14.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "arc cosine"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"arccos \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.9 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.9" ;
  skosxl:prefLabel isoiec80000:term-t2-14.9-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.9-0 ;
  skos:definition """arcus cosine of stem:[x]"""@en ;
  skos:note """stem:[y = \"arccos \"x <=> x = \"cos \"y] (for stem:[0 <= y <= pi])

The function stem:[\"arccos\"] is the inverse of the function stem:[\"cos\"] with the restriction mentioned above.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .

isoiec80000:term-t2-14.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "arc tangent"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"arctan \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.10 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.10" ;
  skosxl:prefLabel isoiec80000:term-t2-14.10-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.10-0 ;
  skos:definition """arcus tangent of stem:[x]"""@en ;
  skos:note """stem:[y = \"arctan \"x <=> x = \"tan \"y]

(for stem:[-pi//2 <= y <= pi//2])

The function stem:[\"arctan\"] is the inverse of the function stem:[\"tan\"] with the restriction mentioned above.

stem:[\"arctg \"x] should not be used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .

isoiec80000:term-t2-14.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "arc cotangent"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"arccot \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.11 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.11" ;
  skosxl:prefLabel isoiec80000:term-t2-14.11-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.11-0 ;
  skos:definition """arcus cotangent of stem:[x]"""@en ;
  skos:note """stem:[y = \"arccot \"x <=> x = \"cot \"y] (for stem:[0 <= y <= pi])

The function stem:[\"arccot\"] is the inverse of the function stem:[\"cot\"] with the restriction mentioned above.

stem:[\"arcctg \"x] should not be used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .

isoiec80000:term-t2-14.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "arc secant"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"arcsec \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.12 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.12" ;
  skosxl:prefLabel isoiec80000:term-t2-14.12-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.12-0 ;
  skos:definition """arcus secant of stem:[x]"""@en ;
  skos:note """stem:[y = \"arcsec \"x <=> x = \"sec \"y]

(for stem:[0 <= y <= pi], stem:[y != pi//2])

The function stem:[\"arcsec\"] is the inverse of the function stem:[\"sec\"] with the restriction mentioned above.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .

isoiec80000:term-t2-14.13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "arc cosecant"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"arccsc \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.13 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.13" ;
  skosxl:prefLabel isoiec80000:term-t2-14.13-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.13-0 ;
  skos:definition """arcus cosecant of stem:[x]"""@en ;
  skos:note """stem:[y = \"arccsc \"x <=> x = \"csc \"y]

(for stem:[-pi//2 <= y <= pi//2, y != 0])

The function stem:[\"arccsc\"] is the inverse of the function stem:[\"csc\"] with the restriction mentioned above.

stem:[\"arccosec \"x] should be avoided.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .

isoiec80000:term-t2-14.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "hyperbolic sine"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"sinh \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.14 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.14" ;
  skosxl:prefLabel isoiec80000:term-t2-14.14-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.14-0 ;
  skos:definition """hyperbolic sine of stem:[x]"""@en ;
  skos:note """stem:[\"sinh \"x = (\"e\"^x-\"e\"^(-x))/2]

stem:[\"sinh \"x = x + x^3//3! + ...]

stem:[\"sh \"x] should be avoided.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .

isoiec80000:term-t2-14.15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "hyperbolic cosine"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"cosh \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.15 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.15" ;
  skosxl:prefLabel isoiec80000:term-t2-14.15-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.15-0 ;
  skos:definition """hyperbolic cosine of stem:[x]"""@en ;
  skos:note """stem:[\"cosh\"^2\" \"x = \"sinh\"^2\" \"x + 1]

stem:[\"ch \"x] should be avoided.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .

isoiec80000:term-t2-14.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "hyperbolic tangent"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"tanh \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.16 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.16" ;
  skosxl:prefLabel isoiec80000:term-t2-14.16-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.16-0 ;
  skos:definition """hyperbolic tangent of stem:[x]"""@en ;
  skos:note """stem:[\"tanh \"x = \"sinh \"x//\"cosh \"x]

stem:[\"th \"x] should be avoided.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .

isoiec80000:term-t2-14.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "hyperbolic cotangent"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"coth \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.17 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.17" ;
  skosxl:prefLabel isoiec80000:term-t2-14.17-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.17-0 ;
  skos:definition """hyperbolic cotangent of stem:[x]"""@en ;
  skos:note """stem:[\"coth \"x = 1//\"tanh \"x]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .

isoiec80000:term-t2-14.18-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "hyperbolic secant"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.18-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"sech \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.18 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.18" ;
  skosxl:prefLabel isoiec80000:term-t2-14.18-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.18-0 ;
  skos:definition """hyperbolic secant of stem:[x]"""@en ;
  skos:note """stem:[\"sech \"x = 1//\"cosh \"x]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .

isoiec80000:term-t2-14.19-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "hyperbolic cosecant"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.19-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"csch \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.19 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.19" ;
  skosxl:prefLabel isoiec80000:term-t2-14.19-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.19-0 ;
  skos:definition """hyperbolic cosecant of stem:[x]"""@en ;
  skos:note """stem:[\"csch \"x = 1//\"sinh \"x]

stem:[\"cosech \"x] should be avoided.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .

isoiec80000:term-t2-14.20-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "inverse hyperbolic sine"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.20-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"arsinh \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.20 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.20" ;
  skosxl:prefLabel isoiec80000:term-t2-14.20-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.20-0 ;
  skos:definition """inverse hyperbolic sine of stem:[x], +
area hyperbolic sine of stem:[x]
"""@en ;
  skos:note """stem:[y = \"arsinh \"x <=> x = \"sinh \"y]

The function stem:[\"arsinh\"] is the inverse of the function stem:[\"sinh\"].

stem:[\"arsh \"x] should be avoided.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .

isoiec80000:term-t2-14.21-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "inverse hyperbolic cosine"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.21-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"arcosh \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.21 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.21" ;
  skosxl:prefLabel isoiec80000:term-t2-14.21-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.21-0 ;
  skos:definition """inverse hyperbolic cosine of stem:[x], +
area hyperbolic cosine of stem:[x]
"""@en ;
  skos:note """stem:[y = \"arcosh \"x <=> x = \"cosh \"y] (for stem:[y >= 0])

The function stem:[\"arcosh\"] is the inverse of the function stem:[\"cosh\"] with the restriction mentioned above.

stem:[\"arch \"x] should be avoided.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .

isoiec80000:term-t2-14.22-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "inverse hyperbolic tangent"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.22-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"artanh \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.22 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.22" ;
  skosxl:prefLabel isoiec80000:term-t2-14.22-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.22-0 ;
  skos:definition """inverse hyperbolic tangent of stem:[x], +
area hyperbolic tangent of stem:[x]
"""@en ;
  skos:note """stem:[y = \"artanh \"x <=> x = \"tanh \"y]

The function stem:[\"artanh\"] is the inverse of the function stem:[\"tanh\"].

stem:[\"arth \"x] should be avoided.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .

isoiec80000:term-t2-14.23-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "inverse hyperbolic cotangent"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.23-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"arcoth \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.23 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.23" ;
  skosxl:prefLabel isoiec80000:term-t2-14.23-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.23-0 ;
  skos:definition """inverse hyperbolic cotangent of stem:[x], +
area hyperbolic cotangent of stem:[x]
"""@en ;
  skos:note """stem:[y = \"arcoth \"x <=> x = \"coth \"y] (for stem:[y != 0])

The function stem:[\"arcoth\"] is the inverse of the function stem:[\"coth\"] with the restriction mentioned above.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .

isoiec80000:term-t2-14.24-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "inverse hyperbolic secant"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.24-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"arsech \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.24 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.24" ;
  skosxl:prefLabel isoiec80000:term-t2-14.24-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.24-0 ;
  skos:definition """inverse hyperbolic secant of stem:[x], +
area hyperbolic secant of stem:[x]
"""@en ;
  skos:note """stem:[y = \"arsech \"x <=> x = \"sech \"y] (for stem:[y >= 0])

The function stem:[\"arsech\"] is the inverse of the function stem:[\"sech\"] with the restriction mentioned above.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .

isoiec80000:term-t2-14.25-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "inverse hyperbolic cosecant"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-14.25-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"arcsch \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-14.25 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-14.25" ;
  skosxl:prefLabel isoiec80000:term-t2-14.25-0 ;
  skosxl:altLabel isoiec80000:sym-t2-14.25-0 ;
  skos:definition """inverse hyperbolic cosecant of stem:[x], +
area hyperbolic cosecant of stem:[x]
"""@en ;
  skos:note """stem:[y = \"arcsch \"x <=> x = \"csch \"y] (for stem:[y >= 0])

The function stem:[\"arcsch\"] is the inverse of the function stem:[\"csch\"] with the restriction mentioned above.

stem:[\"arcosech \"x] should be avoided.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-14 .

@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

isoiec80000:part-2-15 a smart:PublicationDocument ;
  dcterms:title "Part 2-15"@en ;
  dcterms:identifier "ISO 80000-2-15" ;
  smart:hasPublicationType smart:internationalStandard ;
  smart:hasBindingnessType smart:normative .

isoiec80000:term-t2-15.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "imaginary unit"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-15.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"i\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-15.1-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"j\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-15.1 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-15.1" ;
  skosxl:prefLabel isoiec80000:term-t2-15.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-15.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-15.1-1 ;
  skos:definition """imaginary unit"""@en ;
  skos:note """stem:[\"i\"^2 = \"j\"^2 = -1]

stem:[\"i\"] is used in mathematics and in physics,

stem:[\"j\"] is used in electrotechnology.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-15 .

isoiec80000:term-t2-15.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "real part"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-15.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"Re \"z"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-15.2 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-15.2" ;
  skosxl:prefLabel isoiec80000:term-t2-15.2-0 ;
  skosxl:altLabel isoiec80000:sym-t2-15.2-0 ;
  skos:definition """real part of stem:[z]"""@en ;
  skos:note """If stem:[z = x + \"i \"y], where stem:[x] and stem:[y] are real numbers, then

stem:[x = \"Re \"z] and stem:[y = \"Im \"z].
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-15 .

isoiec80000:term-t2-15.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "imaginary part"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-15.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"Im \"z"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-15.3 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-15.3" ;
  skosxl:prefLabel isoiec80000:term-t2-15.3-0 ;
  skosxl:altLabel isoiec80000:sym-t2-15.3-0 ;
  skos:definition """imaginary part of stem:[z]"""@en ;
  skos:note """See <<t2-15.2>>."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-15 .

isoiec80000:term-t2-15.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "modulus"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-15.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "abs(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-15.4 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-15.4" ;
  skosxl:prefLabel isoiec80000:term-t2-15.4-0 ;
  skosxl:altLabel isoiec80000:sym-t2-15.4-0 ;
  skos:definition """modulus of stem:[z]"""@en ;
  skos:note """stem:[abs(z) = sqrt(x^2 +y^2)]

where stem:[x = \"Re \"z] and stem:[y = \"Im \"z].

The symbol stem:[abs] is also used for cardinality of a set (see <<t2-6.5>>), absolute value of a real number (see <<t2-10.16>>), and magnitude of a vector (see <<t2-18.4>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-15 .

isoiec80000:term-t2-15.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "argument"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-15.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"arg \"z"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-15.5 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-15.5" ;
  skosxl:prefLabel isoiec80000:term-t2-15.5-0 ;
  skosxl:altLabel isoiec80000:sym-t2-15.5-0 ;
  skos:definition """argument of stem:[z]"""@en ;
  skos:note """If stem:[z = r \"e\"^(i varphi)], where stem:[r = abs(z)] and stem:[-pi < varphi <= pi], then stem:[varphi = \"arg \"z].

It holds stem:[\"Re \"z = r \" cos \"varphi] and stem:[\"Im \"z = r\" sin \"varphi].
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-15 .

isoiec80000:term-t2-15.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "complex conjugate"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-15.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bar z"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-15.6-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "z**"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-15.6 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-15.6" ;
  skosxl:prefLabel isoiec80000:term-t2-15.6-0 ;
  skosxl:altLabel isoiec80000:sym-t2-15.6-0 ;
  skosxl:altLabel isoiec80000:sym-t2-15.6-1 ;
  skos:definition """complex conjugate of stem:[z]"""@en ;
  skos:note """stem:[bar z = \"Re \"z - \"i Im \"z]

stem:[bar z] is mainly used in mathematics,

stem:[z**] is mainly used in physics and engineering.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-15 .

isoiec80000:term-t2-15.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "signum"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-15.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"sgn \"z"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-15.7 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-15.7" ;
  skosxl:prefLabel isoiec80000:term-t2-15.7-0 ;
  skosxl:altLabel isoiec80000:sym-t2-15.7-0 ;
  skos:definition """signum stem:[z]"""@en ;
  skos:note """stem:[\"sgn \"z = z // abs(z) = \"exp \"(\"i arg \"z)] (stem:[z != 0])

stem:[\"sgn \"z = 0] for stem:[z = 0]

See also item <<t2-10.13>>. Sometimes stem:[\"sgn \"0] is left undefined.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-15 .

@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

isoiec80000:part-2-16 a smart:PublicationDocument ;
  dcterms:title "Part 2-16"@en ;
  dcterms:identifier "ISO 80000-2-16" ;
  smart:hasPublicationType smart:internationalStandard ;
  smart:hasBindingnessType smart:normative .

isoiec80000:term-t2-16.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "matrix"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-16.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(A))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-16.1-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "([a_(11), ..., a_(1n)\\],[vdots,ddots,vdots\\],[a_(m1), ..., a_(mn)\\])"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-16.1 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-16.1" ;
  skosxl:prefLabel isoiec80000:term-t2-16.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-16.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-16.1-1 ;
  skos:definition """matrix stem:[bb(ii(A))] of type stem:[m] by stem:[n]"""@en ;
  skos:note """stem:[bb(ii(A))] is the matrix with the elements stem:[a_(ij) = (bb(ii(A)))_(ij)], stem:[m] is the number of rows and stem:[n] is the number of columns.

stem:[bb(ii(A)) = (a_(ij))] is also used.

Square brackets are also used instead of parentheses.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-16 .

isoiec80000:term-t2-16.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sum of matrices"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-16.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(A)) + bb(ii(B))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-16.2 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-16.2" ;
  skosxl:prefLabel isoiec80000:term-t2-16.2-0 ;
  skosxl:altLabel isoiec80000:sym-t2-16.2-0 ;
  skos:definition """sum of matrices stem:[bb(ii(A))] and stem:[bb(ii(B))]"""@en ;
  skos:note """stem:[(bb(ii(A)) + bb(ii(B)))_(ij) = (bb(ii(A)))_(ij) + (bb(ii(B)))_(ij)]

The matrices stem:[bb(ii(A))] and stem:[bb(ii(B))] must have the same number of columns and the same number of rows.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-16 .

isoiec80000:term-t2-16.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "product of scalar and matrix"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-16.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "x bb(ii(A))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-16.3 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-16.3" ;
  skosxl:prefLabel isoiec80000:term-t2-16.3-0 ;
  skosxl:altLabel isoiec80000:sym-t2-16.3-0 ;
  skos:definition """product of scalar stem:[x] and matrix stem:[bb(ii(A))]"""@en ;
  skos:note """stem:[(x bb(ii(A)))_(ij) = x (bb(ii(A)))_(ij)]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-16 .

isoiec80000:term-t2-16.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "product of matrices"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-16.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(AB))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-16.4 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-16.4" ;
  skosxl:prefLabel isoiec80000:term-t2-16.4-0 ;
  skosxl:altLabel isoiec80000:sym-t2-16.4-0 ;
  skos:definition """product of matrices stem:[bb(ii(A))] and stem:[bb(ii(B))]"""@en ;
  skos:note """stem:[(bb(ii(AB)))_(ik) = sum_j (bb(ii(A))_(ij))bb(ii(B))_(jk)]

The number of columns of stem:[bb(ii(A))] must be equal to the number of rows of stem:[bb(ii(B))].
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-16 .

isoiec80000:term-t2-16.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "identity matrix"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-16.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(I))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-16.5-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(E))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-16.5 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-16.5" ;
  skosxl:prefLabel isoiec80000:term-t2-16.5-0 ;
  skosxl:altLabel isoiec80000:sym-t2-16.5-0 ;
  skosxl:altLabel isoiec80000:sym-t2-16.5-1 ;
  skos:definition """identity matrix"""@en ;
  skos:note """A square matrix for which stem:[(bb(ii(I)))_(ik) = delta_(ik)]

For the definition of stem:[delta_(ik)] see <<t2-18.9>>.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-16 .

isoiec80000:term-t2-16.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "inverse of a square matrix"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-16.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(A))^(-1)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-16.6 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-16.6" ;
  skosxl:prefLabel isoiec80000:term-t2-16.6-0 ;
  skosxl:altLabel isoiec80000:sym-t2-16.6-0 ;
  skos:definition """inverse of a square matrix stem:[bb(ii(A))]"""@en ;
  skos:note """stem:[bb(ii(A)ii(A)^(-1))=bb(ii(A))^(-1)bb(A) = bb(I)]

when stem:[\"det \"bb(ii(A)) != 0], for the definition of stem:[\"det \"bb(ii(A))] see <<t2-16.10>>.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-16 .

isoiec80000:term-t2-16.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "transpose matrix"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-16.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(A))^TT"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-16.7 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-16.7" ;
  skosxl:prefLabel isoiec80000:term-t2-16.7-0 ;
  skosxl:altLabel isoiec80000:sym-t2-16.7-0 ;
  skos:definition """transpose matrix of stem:[bb(ii(A))]"""@en ;
  skos:note """stem:[(bb(ii(A))^TT)_(ik) = (bb(ii(A)))_(ki)]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-16 .

isoiec80000:term-t2-16.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "complex conjugate matrix"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-16.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bar bb(ii(A))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-16.8-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(A))**"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-16.8 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-16.8" ;
  skosxl:prefLabel isoiec80000:term-t2-16.8-0 ;
  skosxl:altLabel isoiec80000:sym-t2-16.8-0 ;
  skosxl:altLabel isoiec80000:sym-t2-16.8-1 ;
  skos:definition """complex conjugate matrix of stem:[bb(ii(A))]"""@en ;
  skos:note """stem:[(bar bb(ii(A)))_(ik) = bar((bb(ii(A)))_(ik))]

stem:[bar bb(ii(A))] is used in mathematics,

stem:[bb(ii(A))**] in physics and electrotechnology.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-16 .

isoiec80000:term-t2-16.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Hermitian conjugate matrix"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-16.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(A))^(\"H\")"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-16.9 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-16.9" ;
  skosxl:prefLabel isoiec80000:term-t2-16.9-0 ;
  skosxl:altLabel isoiec80000:sym-t2-16.9-0 ;
  skos:definition """Hermitian conjugate matrix of stem:[bb(ii(A))]"""@en ;
  skos:note """stem:[bb(ii(A))^(\"H\") = (bb(bar A))^(\"T\")]

The term \"adjoint matrix\" is also used.

stem:[bb(ii(A))**] and stem:[bb(ii(A))^(+)] are also used for stem:[bb(ii(A))^(\"H\")].
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-16 .

isoiec80000:term-t2-16.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "determinant of matrix"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-16.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"det \"bb(ii(A))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-16.10-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\\|[a_(11), ..., a_(1n)\\],[vdots,ddots,vdots\\],[a_(n1), ..., a_(n n)\\]\\|"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-16.10 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-16.10" ;
  skosxl:prefLabel isoiec80000:term-t2-16.10-0 ;
  skosxl:altLabel isoiec80000:sym-t2-16.10-0 ;
  skosxl:altLabel isoiec80000:sym-t2-16.10-1 ;
  skos:definition """determinant of a square matrix stem:[bb(ii(A))]"""@en ;
  skos:note """Sometimes stem:[abs(bb(ii(A)))] is used."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-16 .

isoiec80000:term-t2-16.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "rank of matrix"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-16.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"rank \"bb(ii(A))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-16.11 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-16.11" ;
  skosxl:prefLabel isoiec80000:term-t2-16.11-0 ;
  skosxl:altLabel isoiec80000:sym-t2-16.11-0 ;
  skos:definition """rank of matrix stem:[bb(ii(A))]"""@en ;
  skos:note """The rank of matrix stem:[bb(ii(A))] is the number of the linearly independent rows of stem:[bb(ii(A))]. It is also equal to the number of linearly independent columns."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-16 .

isoiec80000:term-t2-16.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "trace of a square matrix"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-16.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"tr \"bb(ii(A))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-16.12 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-16.12" ;
  skosxl:prefLabel isoiec80000:term-t2-16.12-0 ;
  skosxl:altLabel isoiec80000:sym-t2-16.12-0 ;
  skos:definition """trace of a square matrix stem:[bb(ii(A))]"""@en ;
  skos:note """stem:[\"tr \"bb(ii(A)) = sum_i (bb(ii(A)))_(i i)]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-16 .

isoiec80000:term-t2-16.13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "norm of matrix"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-16.13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "norm(bb(ii(A)))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-16.13 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-16.13" ;
  skosxl:prefLabel isoiec80000:term-t2-16.13-0 ;
  skosxl:altLabel isoiec80000:sym-t2-16.13-0 ;
  skos:definition """norm of matrix stem:[bb(ii(A))]"""@en ;
  skos:note """The norm of matrix stem:[bb(ii(A))] is a number characterizing this matrix and satisfying the triangle inequality:

if stem:[bb(ii(A)) + bb(ii(B)) = bb(ii(C))], then stem:[norm(bb(ii(A))) + norm(bb(ii(B))) >= norm(bb(ii(C)))].

Different matrix norms are used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-16 .

@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

isoiec80000:part-2-17 a smart:PublicationDocument ;
  dcterms:title "Part 2-17"@en ;
  dcterms:identifier "ISO 80000-2-17" ;
  smart:hasPublicationType smart:internationalStandard ;
  smart:hasBindingnessType smart:normative .

isoiec80000:term-t2-17.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Cartesian coordinate"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-17.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "x, y, z"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-17.1 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-17.1" ;
  skosxl:prefLabel isoiec80000:term-t2-17.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-17.1-0 ;
  skos:definition """stem:[bb(ii(r)) = xbb(ii(e))_x + ybb(ii(e))_y + zbb(ii(e))_z] +
stem:[\"d\"bb(ii(r)) = \"d\"x\" \"bb(ii(e))_x + \"d\"y\" \"bb(ii(e))_y + \"d\"z\" \"bb(ii(e))_z]
"""@en ;
  skos:note """The base vectors stem:[bb(ii(e))_x, bb(ii(e))_y, bb(ii(e))_z] form an orthonormal system (i.e. the vectors are unit vectors and orthogonal) which is right-handed, see <<fig1;and!fig4>>.

stem:[bb(ii(e))_1, bb(ii(e))_2, bb(ii(e))_3] or stem:[bb(ii(i)), bb(ii(j)), bb(ii(k))] are also used for the base vectors and stem:[x_1, x_2, x_3] or stem:[i, j, k] for the coordinates.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-17 .

isoiec80000:term-t2-17.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "cylindrical coordinate"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-17.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "rho, varphi, z"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-17.2 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-17.2" ;
  skosxl:prefLabel isoiec80000:term-t2-17.2-0 ;
  skosxl:altLabel isoiec80000:sym-t2-17.2-0 ;
  skos:definition """stem:[bb(ii(r)) = rho\" \"bb(ii(e))_rho + z\" \"bb(ii(e))_z] +
stem:[\"d\"bb(ii(r)) = \"d\"rho\" \"bb(e)_rho + rho\" d\"varphi\" \"e_varphi + \"d\"z\" \"e_z]
"""@en ;
  skos:note """stem:[bb(ii(e))_rho (varphi), bb(ii(e))_varphi(varphi), bb(ii(e))_z] form an orthonormal right-handed system. See <<fig2>>.

If stem:[z = 0], then stem:[rho] and stem:[varphi] are polar coordinates in the plane.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-17 .

isoiec80000:term-t2-17.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "spherical coordinate"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-17.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "r, vartheta, varphi"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-17.3 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-17.3" ;
  skosxl:prefLabel isoiec80000:term-t2-17.3-0 ;
  skosxl:altLabel isoiec80000:sym-t2-17.3-0 ;
  skos:definition """stem:[bb(ii(r)) = r\" \"bb(ii(e))_r] +
stem:[\"d\"bb(ii(r)) = \"d\"r bb(ii(e))_r + r \"d\"vartheta bb(ii(e))_vartheta + r\" sin \"vartheta\" d\"varphi\" \"bb(ii(e))_varphi]
"""@en ;
  skos:note """stem:[bb(ii(e))_r(vartheta,varphi), bb(ii(e))_vartheta(vartheta, varphi), bb(ii(e))_varphi(varphi)] form an orthonormal right-handed system.

See <<fig3>>.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-17 .

@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

isoiec80000:part-2-18 a smart:PublicationDocument ;
  dcterms:title "Part 2-18"@en ;
  dcterms:identifier "ISO 80000-2-18" ;
  smart:hasPublicationType smart:internationalStandard ;
  smart:hasBindingnessType smart:normative .

isoiec80000:term-t2-18.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "vector"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(a))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-18.1-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "vec a"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.1 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.1" ;
  skosxl:prefLabel isoiec80000:term-t2-18.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.1-1 ;
  skos:definition """vector stem:[bb(ii(a))]"""@en ;
  skos:note """An arrow above the letter symbol can be used instead of bold face type to indicate a vector."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

isoiec80000:term-t2-18.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sum of vectors"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(a)) + bb(ii(b))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.2 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.2" ;
  skosxl:prefLabel isoiec80000:term-t2-18.2-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.2-0 ;
  skos:definition """sum of vectors stem:[bb(ii(a))] and stem:[bb(ii(b))]"""@en ;
  skos:note """stem:[(bb(ii(a)) + bb(ii(b)))_i = a_i + b_i]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

isoiec80000:term-t2-18.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "product of scalar and vector"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "x bb(ii(a))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.3 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.3" ;
  skosxl:prefLabel isoiec80000:term-t2-18.3-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.3-0 ;
  skos:definition """product of a number, scalar, or component stem:[x] and vector stem:[bb(ii(a))]"""@en ;
  skos:note """stem:[(x bb(ii(a)))_i = xa_i]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

isoiec80000:term-t2-18.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "magnitude of vector"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "abs(bb(ii(a)))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.4 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.4" ;
  skosxl:prefLabel isoiec80000:term-t2-18.4-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.4-0 ;
  skos:definition """magnitude of the vector stem:[bb(ii(a))], +
norm of the vector stem:[bb(ii(a))]
"""@en ;
  skos:note """stem:[abs(bb(ii(a))) = sqrt(a_x^2 + a_y^2 + a_z^2)]

stem:[norm(bb(ii(a)))] is also used.

The symbol stem:[abs] is also used for cardinality of a set (see <<t2-6.5>>), absolute value of a real number (see <<t2-10.16>>), modulus of a complex number (<<t2-15.4>>).
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

isoiec80000:term-t2-18.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "zero vector"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(0)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-18.5-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "vec 0"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.5 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.5" ;
  skosxl:prefLabel isoiec80000:term-t2-18.5-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.5-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.5-1 ;
  skos:definition """zero vector"""@en ;
  skos:note """The zero vector has magnitude stem:[0]."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

isoiec80000:term-t2-18.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "unit vector"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(e_a)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-18.6-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "hat bb(ii(a))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.6 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.6" ;
  skosxl:prefLabel isoiec80000:term-t2-18.6-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.6-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.6-1 ;
  skos:definition """unit vector in the direction of stem:[bb(ii(a))]"""@en ;
  skos:note """stem:[bb(e_a) = hat bb(ii(a)) = bb(ii(a))//abs(bb(ii(a)))], (for stem:[bb(ii(a)) != 0])"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

isoiec80000:term-t2-18.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "unit vector"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(e)_x, bb(e)_y, bb(e)_z"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-18.7-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(e)_1, bb(e)_2, bb(e)_3"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.7 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.7" ;
  skosxl:prefLabel isoiec80000:term-t2-18.7-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.7-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.7-1 ;
  skos:definition """unit vectors in the directions of the Cartesian coordinate axes"""@en ;
  skos:note """stem:[bb(i), bb(j), bb(k)] are also used."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

isoiec80000:term-t2-18.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Cartesian coordinates of vector"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a_x, a_y, a_z"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-18.8-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a_i"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.8 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.8" ;
  skosxl:prefLabel isoiec80000:term-t2-18.8-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.8-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.8-1 ;
  skos:definition """Cartesian coordinates of vector stem:[bb(ii(a))], +
Cartesian components of vector stem:[bb(ii(a))]
"""@en ;
  skos:note """stem:[bb(ii(a)) = a_x\" \"bb(e)_x + a_y\" \"bb(e)_y + a_z\" \"bb(e)_z]

stem:[a_1\" \"bb(e)_1, a_2\" \"bb(e)_2, a_3\" \"bb(e)_3] are the component vectors. If it is clear from the context which are the base vectors, the vector can be written

stem:[bb(ii(a)) = (a_x, a_y, a_z)].

stem:[a_x = bb(ii(a))*bb(e)_x, a_y = bb(ii(a))*bb(e)_y, a_z = bb(ii(a))*bb(e)_z]

stem:[bb(r) = x bb(e)_x + y bb(e)_y + z bb(e)_z] is the position vector (radius vector) of the point with coordinates stem:[x, y, z].
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

isoiec80000:term-t2-18.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Kronecker delta symbol"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "delta_(ik)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.9 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.9" ;
  skosxl:prefLabel isoiec80000:term-t2-18.9-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.9-0 ;
  skos:definition """Kronecker delta symbol"""@en ;
  skos:note """stem:[delta_(ik)={(1,\"for\",i=k),(0,\"for\",i!=k):}]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

isoiec80000:term-t2-18.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Levi-Civita symbol"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "rm(varepsilon)_(ijk)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.10 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.10" ;
  skosxl:prefLabel isoiec80000:term-t2-18.10-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.10-0 ;
  skos:definition """Levi-Civita symbol"""@en ;
  skos:note """stem:[rm(varepsilon)_(123) = rm(varepsilon)_(231) = rm(varepsilon)_(312) = 1]

stem:[rm(varepsilon)_(132) = rm(varepsilon)_(321) = rm(varepsilon)_(213) = -1]

All other stem:[rm(varepsilon)_(ijk)] are equal to stem:[0].
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

isoiec80000:term-t2-18.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "scalar product of vectors"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(a)) * bb(ii(b))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.11 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.11" ;
  skosxl:prefLabel isoiec80000:term-t2-18.11-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.11-0 ;
  skos:definition """scalar product of stem:[bb(ii(a))] and stem:[bb(ii(b))]"""@en ;
  skos:note """stem:[bb(ii(a)) * bb(ii(b)) = a_xb_x + a_yb_y + a_zb_z]

stem:[bb(ii(a)) * bb(ii(a)) = sum_i a_i b_i]

stem:[bb(ii(a)) * bb(ii(a)) = bb(ii(a))^2 = abs(bb(ii(a)))^2 = a^2]

In special fields, stem:[(bb(ii(a)), bb(ii(b)))] or stem:[< a, b >] is also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

isoiec80000:term-t2-18.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "product of vectors"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(a)) xx bb(ii(b))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.12 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.12" ;
  skosxl:prefLabel isoiec80000:term-t2-18.12-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.12-0 ;
  skos:definition """vector product of stem:[bb(ii(a))] and stem:[bb(ii(b))]"""@en ;
  skos:note """The coordinates, in a right-handed Cartesian coordinate system, are

stem:[(bb(ii(a)) xx bb(ii(b)))_x = a_y b_z - a_z b_y]

stem:[(bb(ii(a)) xx bb(ii(b)))_y = a_z b_x - a_x b_z]

stem:[(bb(ii(a)) xx bb(ii(b)))_z = a_x b_y - a_y b_x]

stem:[(bb(ii(a)) xx bb(ii(b)))_i = sum_j sum_k varepsilon_(ijk) a_j b_k]

See <<t2-18.10>>.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

isoiec80000:term-t2-18.13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "nabla operator"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(grad)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-18.13-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "vec grad"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.13 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.13" ;
  skosxl:prefLabel isoiec80000:term-t2-18.13-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.13-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.13-1 ;
  skos:definition """nabla operator"""@en ;
  skos:note """stem:[bb(grad) = e_x del/(del x) + e_y del/(del y) + e_z del/(del z) = sum_i e_i del/(del x_i)]

The operator is also called \"del operator\".
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

isoiec80000:term-t2-18.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "gradient"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(grad) varphi"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-18.14-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(\"grad\")\" \"varphi"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.14 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.14" ;
  skosxl:prefLabel isoiec80000:term-t2-18.14-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.14-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.14-1 ;
  skos:definition """gradient of stem:[varphi]"""@en ;
  skos:note """stem:[bb(grad) varphi = sum_i e_i (del varphi)/(del x_i)]

The operator stem:[bb(\"grad\")] should be written in bold face.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

isoiec80000:term-t2-18.15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "divergence"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(grad) * a"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-18.15-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(\"div\")\" \"a"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.15 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.15" ;
  skosxl:prefLabel isoiec80000:term-t2-18.15-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.15-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.15-1 ;
  skos:definition """divergence of stem:[bb(ii(a))]"""@en ;
  skos:note """stem:[bb(grad) * a = sum_i (del a_i)/(del x_i)]

The operator stem:[bb(\"div\")] should be written in bold face.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

isoiec80000:term-t2-18.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "rotation"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(grad) xx a"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-18.16-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(\"rot\")\" \"bb(ii(a))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.16 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.16" ;
  skosxl:prefLabel isoiec80000:term-t2-18.16-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.16-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.16-1 ;
  skos:definition """rotation of stem:[bb(ii(a))]"""@en ;
  skos:note """The coordinates are

stem:[(bb(grad) xx bb(ii(a)))_x = (del a_z)/(del y) - (del a_y)/(del z)]

stem:[(bb(grad) xx bb(ii(a)))_y = (del a_x)/(del z) - (del a_z)/(del x)]

stem:[(bb(grad) xx bb(ii(a)))_z = (del a_y)/(del x) - (del a_x)/(del y)]

The operator stem:[bb(\"curl\")] should be avoided and the operator stem:[bb(\"rot\")] should be written in bold face.

stem:[(bb(grad) xx bb(ii(a)))_i = sum_j sum_k varepsilon_(ijk) (del a_k)/(del x_j)]

See <<t2-18.10>>.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

isoiec80000:term-t2-18.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Laplacian"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(grad)^2"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-18.17-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Delta"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.17 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.17" ;
  skosxl:prefLabel isoiec80000:term-t2-18.17-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.17-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.17-1 ;
  skos:definition """Laplacian"""@en ;
  skos:note """stem:[bb(grad)^2 = (del^2)/(del x^2) + (del^2)/(del y^2) + (del^2)/(del z^2)]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

isoiec80000:term-t2-18.18-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "d'Alembertian"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.18-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "square"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.18 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.18" ;
  skosxl:prefLabel isoiec80000:term-t2-18.18-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.18-0 ;
  skos:definition """d'Alembertian"""@en ;
  skos:note """stem:[square = (del^2)/(del x^2) + (del^2)/(del y^2) + (del^2)/(del z^2) - 1/(c^2) (del^2)/(del t^2)]

where the independent variable stem:[t] is time (<<iso80000-3>>) and stem:[c] is the speed (<<iso80000-3>>) of light
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

isoiec80000:term-t2-18.19-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "tensor of second order"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.19-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sf(bb(ii(T)))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-18.19-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "vec(vec T)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.19 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.19" ;
  skosxl:prefLabel isoiec80000:term-t2-18.19-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.19-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.19-1 ;
  skos:definition """tensor stem:[sf(bb(ii(T))] of the second order"""@en ;
  skos:note """Two arrows above the letter symbol can be used instead of bold face sans serif type to indicate a tensor of the second order."""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

isoiec80000:term-t2-18.20-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Cartesian coordinates of tensor"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.20-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "T_(x x), T_(xy), ..., T_(zz)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-18.20-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "T_(11), T_(12), ..., T_(33)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.20 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.20" ;
  skosxl:prefLabel isoiec80000:term-t2-18.20-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.20-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.20-1 ;
  skos:definition """Cartesian coordinates of tensor stem:[sf(bb(ii(T)))], +
Cartesian components of tensor stem:[sf(bb(ii(T)))]
"""@en ;
  skos:note """The scalars stem:[T_(x x), T_(xy), ..., T_(zz)] in the representation

stem:[sf(bb(ii(T))) = T_(x x) e_x e_x + T_(xy) e_x e_y + ... + T_(zz) e_z e_z]

of the tensor stem:[bb(ii(T))] by the base tensors

stem:[e_x e_x, e_x e_y, ..., e_z e_z].

stem:[T_(x x) e_x e_x, T_(xy) e_x e_y, ..., T_(zz) e_z e_z], are the component tensors.

If it is clear from the context which are the base vectors, the tensor can be written

stem:[sf(bb(ii(T))) = ([T_(x x), T_(xy), T_(xz)\\],[T_(yx), T_(yy), T_(yz)\\],[T_(zx), T_(zy), T_(zz)\\]) ].
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

isoiec80000:term-t2-18.21-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "dyadic product"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.21-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ab)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-18.21-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "bb(ii(a)) ox bb(ii(b))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.21 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.21" ;
  skosxl:prefLabel isoiec80000:term-t2-18.21-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.21-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.21-1 ;
  skos:definition """dyadic product, +
tensor product of two vectors stem:[bb(ii(a))] and stem:[bb(ii(b))]
"""@en ;
  skos:note """tensor of the second order with coordinates

stem:[(bb(ab))_(ij) = a_ib_j]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

isoiec80000:term-t2-18.22-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "tensor product of tensors"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.22-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sf(bb(ii(T))) ox sf(bb(ii(S)))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.22 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.22" ;
  skosxl:prefLabel isoiec80000:term-t2-18.22-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.22-0 ;
  skos:definition """tensor product of two tensors stem:[sf(bb(ii(T)))] and stem:[sf(bb(ii(S)))] of the second order"""@en ;
  skos:note """tensor of the fourth order with coordinates

stem:[(sf(bb(ii(T))) ox sf(bb(ii(S))))_(ijkl) = T_(ij) S_(kl)]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

isoiec80000:term-t2-18.23-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "inner product of tensors"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.23-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sf(bb(ii(T))) * sf(bb(ii(S)))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.23 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.23" ;
  skosxl:prefLabel isoiec80000:term-t2-18.23-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.23-0 ;
  skos:definition """inner product of two tensors stem:[sf(bb(ii(T)))] and stem:[sf(bb(ii(S)))] of the second order"""@en ;
  skos:note """tensor of the second order with coordinates

stem:[(sf(bb(ii(T)))* sf(bb(ii(S))))_(ik) = sum_j T_(ij) S_(jk)]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

isoiec80000:term-t2-18.24-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "inner product of tensor and vector"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.24-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sf(bb(ii(T)))* bb(ii(a))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.24 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.24" ;
  skosxl:prefLabel isoiec80000:term-t2-18.24-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.24-0 ;
  skos:definition """inner product of a tensor stem:[sf(bb(ii(T)))] of the second order and a vector stem:[bb(ii(a))]"""@en ;
  skos:note """vector with coordinates

stem:[(sf(bb(ii(T)))* bb(ii(a)))_i = sum_j T_(ij) a_j]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

isoiec80000:term-t2-18.25-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "scalar product of tensors"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-18.25-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sf(bb(ii(T:S)))"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-18.25 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-18.25" ;
  skosxl:prefLabel isoiec80000:term-t2-18.25-0 ;
  skosxl:altLabel isoiec80000:sym-t2-18.25-0 ;
  skos:definition """scalar product of two tensors stem:[sf(bb(ii(T)))] and stem:[sf(bb(ii(S)))] of the second order"""@en ;
  skos:note """scalar quantity +
stem:[sf(bb(ii(T:S))) = sum_i sum_j T_(ij) S_(ij)]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-18 .

@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

isoiec80000:part-2-19 a smart:PublicationDocument ;
  dcterms:title "Part 2-19"@en ;
  dcterms:identifier "ISO 80000-2-19" ;
  smart:hasPublicationType smart:internationalStandard ;
  smart:hasBindingnessType smart:normative .

isoiec80000:term-t2-19.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Fourier transform"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-19.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "&#x1D4D5; f"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-19.1 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-19.1" ;
  skosxl:prefLabel isoiec80000:term-t2-19.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-19.1-0 ;
  skos:definition """Fourier transform of stem:[f]"""@en ;
  skos:note """stem:[(&#x1D4D5; f)(omega) = int_(-oo)^(+oo) e^(-i omega t) f(t) \"d\"t]

(where stem:[omega in bb(sf(R))])

This is often denoted by stem:[&#x1D4D5;(omega)].

stem:[(&#x1D4D5;f)(omega) = 1/(sqrt(2pi)) int_(-oo)^(+oo) e^(-i omega t) f(t) \"d\"t]

is also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-19 .

isoiec80000:term-t2-19.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Laplace transform"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-19.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "&#x1D4DB; f"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-19.2 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-19.2" ;
  skosxl:prefLabel isoiec80000:term-t2-19.2-0 ;
  skosxl:altLabel isoiec80000:sym-t2-19.2-0 ;
  skos:definition """Laplace transform of stem:[f]"""@en ;
  skos:note """stem:[(&#x1D4DB; f)(s) = int_0^(oo) e^(-st) f(t) \"d\"t]

(where stem:[s in bb(sf(C))])

This is often denoted by stem:[&#x1D4DB;(s)].

The two-sided Laplace transform is also used, defined by the same formula, but with minus infinity instead of zero.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-19 .

isoiec80000:term-t2-19.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Z transform"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-19.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "&#x01B7; (a_n)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-19.3 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-19.3" ;
  skosxl:prefLabel isoiec80000:term-t2-19.3-0 ;
  skosxl:altLabel isoiec80000:sym-t2-19.3-0 ;
  skos:definition """Z transform of stem:[(a_n)]"""@en ;
  skos:note """stem:[&#x01B7;(a_n) = sum_(n=0)^(oo) a_n z^(-n)]

(where stem:[z in bb(sf(C))])

stem:[&#x01B7;] is an operator operating on a sequence (stem:[a_n]) and not a function of stem:[a_n].

The two-sided Z transform is also used, defined by the same formula, but with minus infinity instead of zero.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-19 .

isoiec80000:term-t2-19.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Heaviside function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-19.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "H(x)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-19.4-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "vartheta(x)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-19.4 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-19.4" ;
  skosxl:prefLabel isoiec80000:term-t2-19.4-0 ;
  skosxl:altLabel isoiec80000:sym-t2-19.4-0 ;
  skosxl:altLabel isoiec80000:sym-t2-19.4-1 ;
  skos:definition """Heaviside function, +
unit step function
"""@en ;
  skos:note """stem:[H(x) = {(1,\"for\",x>0),(0,\"for\",x<0):}]

stem:[H(0) in [0,1\\]], depending on the field of application.

stem:[U(x)] is also used.

stem:[vartheta(t)] is used for the unit step function of time.

[example]
stem:[(&#x1D4DB;H)(s) = 1//s] (for stem:[\"Re \"s>0])
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-19 .

isoiec80000:term-t2-19.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Dirac delta distribution"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-19.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "delta(x)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-19.5 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-19.5" ;
  skosxl:prefLabel isoiec80000:term-t2-19.5-0 ;
  skosxl:altLabel isoiec80000:sym-t2-19.5-0 ;
  skos:definition """Dirac delta distribution, +
Dirac delta function
"""@en ;
  skos:note """The Dirac delta distribution is defined by

stem:[int_(-oo)^(+oo) varphi(t) delta(t-x) \"d\"t = varphi(x)]

The Dirac delta distribution can be interpreted as derivative of the Heaviside function.
The name \"unit pulse\" is also used.

[example]
stem:[&#x1D4DB; delta = 1]

See also item <<t2-19.6>> and <<iec60027-6,clause=2.01>>.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-19 .

isoiec80000:term-t2-19.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "convolution"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-19.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "f ** g"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-19.6 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-19.6" ;
  skosxl:prefLabel isoiec80000:term-t2-19.6-0 ;
  skosxl:altLabel isoiec80000:sym-t2-19.6-0 ;
  skos:definition """convolution of stem:[f] and stem:[g]"""@en ;
  skos:note """stem:[f ** g(x) = int_(-oo)^(+oo) f(y) g(x-y) \"d\"y]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-19 .

@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

isoiec80000:part-2-20 a smart:PublicationDocument ;
  dcterms:title "Part 2-20"@en ;
  dcterms:identifier "ISO 80000-2-20" ;
  smart:hasPublicationType smart:internationalStandard ;
  smart:hasBindingnessType smart:normative .

isoiec80000:term-t2-20.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Euler-Mascheroni constant"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "rm(gamma)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-20.1-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "rm(C)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.1 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.1" ;
  skosxl:prefLabel isoiec80000:term-t2-20.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.1-1 ;
  skos:definition """Euler-Mascheroni constant"""@en ;
  skos:note """stem:[rm(gamma) = lim_(n -> oo) (sum_(k=1)^n 1/k - \"ln\" n) = 0.5772156...]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "gamma function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Gamma(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.2 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.2" ;
  skosxl:prefLabel isoiec80000:term-t2-20.2-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.2-0 ;
  skos:definition """gamma function"""@en ;
  skos:note """stem:[Gamma(z)] is a meromorphic function with poles at stem:[0, -1, -2, -3, ...]

stem:[Gamma(z) = int_0^(oo) t^(z-1) e^(-t) \"d\"t] (for stem:[\"Re \"z>0])

stem:[Gamma(n+1) = n!] (for stem:[n in bb(sf(N))])
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Riemann zeta function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "rm(zeta)(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.3 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.3" ;
  skosxl:prefLabel isoiec80000:term-t2-20.3-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.3-0 ;
  skos:definition """Riemann zeta function"""@en ;
  skos:note """stem:[rm(zeta)(z)] is a meromorphic function with one pole at stem:[z=1].

stem:[rm(zeta)(z) = sum_(n=1)^(oo) 1/(n^2)] (for stem:[\"Re \"z > 1])
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "beta function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"B\"(z,w)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.4 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.4" ;
  skosxl:prefLabel isoiec80000:term-t2-20.4-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.4-0 ;
  skos:definition """beta function"""@en ;
  skos:note """stem:[\"B\"(z,w) = int_0^1 t^(z-1)(1-t)^(w-1) \"d\"t]

(for stem:[\"Re \"z > 0], stem:[\"Re \"w > 0])

stem:[rm(B)(z,w) = Gamma(z) Gamma(w) // Gamma(z+w)]

stem:[1/((n+1)rm(B)(k+1,n-k+1))= ((n),(k))] (for stem:[k <= n])
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "exponential integral"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"Ei \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.5 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.5" ;
  skosxl:prefLabel isoiec80000:term-t2-20.5-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.5-0 ;
  skos:definition """exponential integral"""@en ;
  skos:note """stem:[\"Ei \"x =] stem:[&#x2A0D;_{-oo}^x bb(e)^t/t \"d\"t]

For stem:[&#x2A0D;], see <<t2-12.26>>.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "logarithmic integral"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.6-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"li \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.6 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.6" ;
  skosxl:prefLabel isoiec80000:term-t2-20.6-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.6-0 ;
  skos:definition """logarithmic integral"""@en ;
  skos:note """stem:[\"li \"x = int_0^x 1/(\"ln\"t)\"d\"t] (for stem:[0<x<1])

stem:[\"li \"x =] stem:[&#x2A0D;_0^x 1/(\"ln\"t)\"d\"t] (for stem:[x>1])

For stem:[&#x2A0D;], see <<t2-12.26>>.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "sine integral"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"Si \"z"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.7 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.7" ;
  skosxl:prefLabel isoiec80000:term-t2-20.7-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.7-0 ;
  skos:definition """sine integral"""@en ;
  skos:note """stem:[\"Si \"z= int_0^z (\"sin \"t)/t \"d\"t]

stem:[\"si \"z = - pi/2 + \"Si \"z]

is called the complementary sine integral.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Fresnel integral"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.8-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"S\"(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-20.8-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"C\"(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.8 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.8" ;
  skosxl:prefLabel isoiec80000:term-t2-20.8-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.8-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.8-1 ;
  skos:definition """Fresnel integrals"""@en ;
  skos:note """stem:[\"S\"(z) = int_0^z \"sin\"(pi/2 t^2)\"d\"t]

stem:[\"C\"(z) = int_0^z \"cos\"(pi/2 t^2)\"d\"t]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "error function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"erf \"x"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.9 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.9" ;
  skosxl:prefLabel isoiec80000:term-t2-20.9-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.9-0 ;
  skos:definition """error function"""@en ;
  skos:note """stem:[\"erf \"x = 2/(sqrt pi) int_0^x e^(-t^2) \"d\"t]

stem:[\"erfc \" x = 1 - \"erf \"x] is called the complementary error function.

In statistics, the distribution function

stem:[rm(Phi)(x) = 1/(sqrt(2pi)) int_(-oo)^x e^(-t^2//2)\"d\"t]

is used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "incomplete elliptic integral of the first kind"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.10-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"F\"(varphi,k)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.10 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.10" ;
  skosxl:prefLabel isoiec80000:term-t2-20.10-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.10-0 ;
  skos:definition """incomplete elliptic integral of the first kind"""@en ;
  skos:note """stem:[\"F\"(varphi,k) = int_0^varphi (\"d\"sigma)/(sqrt(1-k^2\"sin\"^2 sigma))]

stem:[k in bb(sf(R))], stem:[0<k<1]

stem:[\"K\"(k) = F(pi/2,k)], is the complete elliptic integral of the first kind.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "incomplete elliptic integral of the second kind"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.11-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"E\"(varphi,k)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.11 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.11" ;
  skosxl:prefLabel isoiec80000:term-t2-20.11-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.11-0 ;
  skos:definition """incomplete elliptic integral of the second kind"""@en ;
  skos:note """stem:[E(varphi,k) = int_0^varphi sqrt(1-k^2 \"sin\"^2 sigma)\"d\"sigma]

stem:[k in bb(sf(R))], stem:[0<k<1]

stem:[\"E\"(k) = \"E\"(pi/2,k)], is the complete elliptic integral of the second kind.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "incomplete elliptic integral of the third kind"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Pi(n,varphi,k)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.12 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.12" ;
  skosxl:prefLabel isoiec80000:term-t2-20.12-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.12-0 ;
  skos:definition """incomplete elliptic integral of the third kind"""@en ;
  skos:note """stem:[Pi(n,varphi,k) = int_0^varphi (\"d\" vartheta)/((1-n \"sin\"^2 vartheta)sqrt(1-k^2 \"sin\"^2 vartheta))]

stem:[n,k in bb(sf(R))], stem:[0<k<1].

stem:[Pi(n,k) = Pi(n, pi/2, k)] is the complete elliptic integral of the third kind. (Sometimes the elliptic integral of the third kind is defined with an inverse sign for the _characteristic_ stem:[n].)
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "hypergeometric function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.13-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"F\"(a,b,c;z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.13 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.13" ;
  skosxl:prefLabel isoiec80000:term-t2-20.13-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.13-0 ;
  skos:definition """hypergeometric function"""@en ;
  skos:note """stem:[F(a,b,c;z) = sum_(n=0)^(oo) ((a)_n (b)_n z^n)/((c)_n n!)]

(for stem:[-c !in bb(sf(N))])

For stem:[(a)_n], stem:[(b)_n] and stem:[(c)_n], see <<t2-11.3>>.

Solution of

stem:[z(1-z)y'' + [c-(a+b+1)z\\]y' - aby = 0]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "confluent hypergeometric function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.14-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "F(a;c;z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.14 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.14" ;
  skosxl:prefLabel isoiec80000:term-t2-20.14-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.14-0 ;
  skos:definition """confluent hypergeometric function"""@en ;
  skos:note """stem:[F(a;c;z) = sum_(n=0)^(oo) ((a)_n)/((c)_n n!) z^n]

(for stem:[-c !in bb(sf(N))])

For stem:[(a)_n] and stem:[(c)_n], see <<t2-11.3>>.

Solution of stem:[zy'' + (c-z)y' - ay = 0]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Legendre polynomial"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"P\"_n(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.15 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.15" ;
  skosxl:prefLabel isoiec80000:term-t2-20.15-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.15-0 ;
  skos:definition """Legendre polynomial"""@en ;
  skos:note """stem:[\"P\"_n(z) = 1/(2^n n!) (\"d\"^n)/(\"d\"z^n) (z^2-1)^n]

(for stem:[n in bb(sf(N))])

Solution of

stem:[(1-z^2)y'' - 2zy' + n(n+1)y = 0]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "associated Legendre function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.16-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"P\"_n^m(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.16 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.16" ;
  skosxl:prefLabel isoiec80000:term-t2-20.16-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.16-0 ;
  skos:definition """associated Legendre function"""@en ;
  skos:note """stem:[\"P\"_n^m(z) = (-1)^m (1-z^2)^(m//2) (\"d\"^m)/(\"d\"z^m) \"P\"_n(z)]

(for stem:[m, n in bb(sf(N))], stem:[m <= n])

Solution of

stem:[(1-z^2)y'' - 2zy' + [n(n+1) - (m^2)/(1-z^2)\\] y=0]

The factor stem:[(-1)^m] follows from the general theory of spherical functions.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "spherical harmonic"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.17-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"Y\"_l^m(vartheta,varphi)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.17 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.17" ;
  skosxl:prefLabel isoiec80000:term-t2-20.17-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.17-0 ;
  skos:definition """spherical harmonic"""@en ;
  skos:note """stem:[\"Y\"_l^m(vartheta, varphi) = [((2l+1)/(4pi)) ((l-abs m)!)/((l+ abs m)!)\\]^(1//2) P_l^(abs m) (\"cos\" vartheta)\"e\"^(\"i\" m varphi)]

(for stem:[l, abs(m) in bb(sf(N)); abs(m) <= l])

Solution of

stem:[1/(\"sin \"vartheta) del/(del vartheta) (sin vartheta (del y)/(del vartheta)) + 1/(\"sin\"^2 vartheta) (del^2y)/(del varphi^2) + l(l+1)y=0]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.18-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Hermite polynomial"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.18-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"H\"_n(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.18 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.18" ;
  skosxl:prefLabel isoiec80000:term-t2-20.18-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.18-0 ;
  skos:definition """Hermite polynomial"""@en ;
  skos:note """stem:[\"H\"_n(z) = (-1)^n \"e\"^(z^2) (\"d\"^n)/(\"d\"z^n) \"e\"^(-z^2)]

(for stem:[n in bb(sf(N))])

Solution of stem:[y'' - 2zy' + 2ny =0]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.19-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Laguerre polynomial"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.19-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"L\"_n(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.19 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.19" ;
  skosxl:prefLabel isoiec80000:term-t2-20.19-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.19-0 ;
  skos:definition """Laguerre polynomial"""@en ;
  skos:note """stem:[\"L\"_n(z) = (e^z)/(n!) (\"d\"^n)/(\"d\"z^n) (z^n\"e\"^(-z))]

(for stem:[n in bb(sf(N))])

Solution of stem:[zy'' + (1-z)y' + ny = 0]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.20-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "associated Laguerre polynomial"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.20-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"L\"_n^m(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.20 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.20" ;
  skosxl:prefLabel isoiec80000:term-t2-20.20-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.20-0 ;
  skos:definition """associated Laguerre polynomial"""@en ;
  skos:note """stem:[\"L\"_n^m(z) = (-1)^m (\"d\"^m)/(\"d\"z^m) \"L\"_n (z)]

(for stem:[m in bb(sf(N))], stem:[m <= n])

Solution of

stem:[zy'' + (m+1-z)y' + (n-m)y =0]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.21-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Chebyshev polynomial of the first kind"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.21-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"T\"_n(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.21 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.21" ;
  skosxl:prefLabel isoiec80000:term-t2-20.21-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.21-0 ;
  skos:definition """Chebyshev polynomial of the first kind"""@en ;
  skos:note """stem:[\"T\"_n(z) = \"cos\"(n \" arccos \" z)]

(for stem:[n in bb(sf(N))])

Solution of stem:[(1-z^2)y'' - zy' + n^2y=0]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.22-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Chebyshev polynomial of the second kind"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.22-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"U\"_n(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.22 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.22" ;
  skosxl:prefLabel isoiec80000:term-t2-20.22-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.22-0 ;
  skos:definition """Chebyshev polynomial of the second kind"""@en ;
  skos:note """stem:[\"U\"_n(z) = (\"sin\"[(n+1)\"arccos\"z\\])/(\"sin\"(\"arccos\"z))]

(for stem:[n in bb(sf(N))])

Solution of

stem:[(1-z^2)y'' - 3zy' + n(n+2)y=0]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.23-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Bessel function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.23-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"J\"_nu(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.23 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.23" ;
  skosxl:prefLabel isoiec80000:term-t2-20.23-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.23-0 ;
  skos:definition """Bessel function, +
cylinder function of the first kind
"""@en ;
  skos:note """stem:[\"J\"_nu(z) = sum_(k=0)^(oo) ((-1)^k(z//2)^(nu+2k))/(k!Gamma(nu+k+1))]

(for stem:[nu in bb(sf(C))])

Solution of

stem:[z^2y'' + zy' + (z^2 - nu^2)y = 0]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.24-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Neumann function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.24-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"N\"_nu(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.24 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.24" ;
  skosxl:prefLabel isoiec80000:term-t2-20.24-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.24-0 ;
  skos:definition """Neumann function, +
cylinder Bessel function of the second kind
"""@en ;
  skos:note """stem:[\"N\"_nu(z) = (\"J\"_nu (z)\"cos\"(nu pi)-\"J\"_(-nu)(z))/(\"sin\"(nu pi))]

(for stem:[nu in bb(sf(C))])

The right-hand side of this equation is replaced by its limiting value if stem:[nu in bb(sf(Z))].

stem:[\"Y\"_nu(z)] is also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.25-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Hankel function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.25-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"H\"_nu^((1))(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-20.25-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"H\"_nu^((2))(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.25 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.25" ;
  skosxl:prefLabel isoiec80000:term-t2-20.25-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.25-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.25-1 ;
  skos:definition """Hankel function, +
cylinder Bessel function of the third kind
"""@en ;
  skos:note """stem:[\"H\"_nu^((1))(z) = \"J\"_nu (z) + \"iN\"_nu(z)]

stem:[\"H\"_nu^((2))(z) = \"J\"_nu (z) + \"iN\"_nu(z)]

(for stem:[nu in bb(sf(C))])
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.26-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "modified Bessel function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.26-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"I\"_nu(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-20.26-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"K\"_nu(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.26 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.26" ;
  skosxl:prefLabel isoiec80000:term-t2-20.26-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.26-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.26-1 ;
  skos:definition """modified Bessel function"""@en ;
  skos:note """stem:[\"I\"_nu (z) = \"e\"^(-1//2 \"i\"nu pi)\"J\"_nu (\"e\"^(1//2 \"i\"pi_Z))]

stem:[\"K\"_nu (z) = (\"i\"pi)/2 \"e\"^(1//2 nu pi) \"H\"_nu^((1)) (\"e\"^(1//2 \"i\"pi_Z))]

(for stem:[nu in bb(sf(C))])

Solution of stem:[z^2 y'' + zy' - (z^2+nu^2)y=0]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.27-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "spherical Bessel function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.27-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"j\"_l(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.27 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.27" ;
  skosxl:prefLabel isoiec80000:term-t2-20.27-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.27-0 ;
  skos:definition """spherical Bessel function"""@en ;
  skos:note """stem:[\"j\"_l(z) = (pi/(2z))^(1/2) \"J\"_(l+1//2)(z)]

(for stem:[l in bb(sf(N))])

Solution of

stem:[z^2y'' + 2zy' + [z^2-l(l+1)\\]y=0]
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.28-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "spherical Neumann function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.28-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"n\"_l(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.28 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.28" ;
  skosxl:prefLabel isoiec80000:term-t2-20.28-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.28-0 ;
  skos:definition """spherical Neumann function"""@en ;
  skos:note """stem:[\"n\"_l(z) = (pi/(2z))^(1/2) \"N\"_(l+1//2)(z)]

(for stem:[l in bb(sf(N))])

stem:[y_l(z)] is also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.29-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "spherical Hankel function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.29-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"h\"_l^((1))(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-20.29-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"h\"_l^((2))(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.29 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.29" ;
  skosxl:prefLabel isoiec80000:term-t2-20.29-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.29-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.29-1 ;
  skos:definition """spherical Hankel function"""@en ;
  skos:note """stem:[\"h\"_l^((1))(z) = \"j\"_l(z) + i\"n\"_l (z) = (pi/(2z))^(1/2) \"H\"_(l+1/2)^((1))(z)]

stem:[\"h\"_l^((2))(z) = \"j\"_l(z) + i\"n\"_l (z) = (pi/(2z))^(1/2) \"H\"_(l+1/2)^((2))(z)]

Modified spherical Bessel function (analogous to <<t2-20.26>>) can be defined and are denoted by stem:[\"i\"_l(z)] and stem:[\"k\"_l(z)] respectively.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .

isoiec80000:term-t2-20.30-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Airy function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-20.30-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"Ai\"(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t2-20.30-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "\"Bi\"(z)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-20.30 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-20.30" ;
  skosxl:prefLabel isoiec80000:term-t2-20.30-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.30-0 ;
  skosxl:altLabel isoiec80000:sym-t2-20.30-1 ;
  skos:definition """Airy function"""@en ;
  skos:note """stem:[\"Ai\"(z) = 1/3 sqrt(z) [\"I\"_(-1/3)(w) - \"I\"_(1/3)(w)\\]]

stem:[\"Bi\"(z) = sqrt(z/3) [\"I\"_(-1/3)(w) + \"I\"_(1/3)(w)\\]]

where stem:[w=2/3 z^(3//2)].

Entire solution of stem:[y'' - zy=0]"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-20 .
