  skosxl:literalForm "slowing-down length"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-73.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "L_\"s\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t10-73.1-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "L_\"sl\""@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-73.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-73.1" ;
  skosxl:prefLabel isoiec80000:term-t10-73.1-0 ;
  skosxl:altLabel isoiec80000:sym-t10-73.1-0 ;
  skosxl:altLabel isoiec80000:sym-t10-73.1-1 ;
  skos:definition """square root of the slowing down area stem:[L_\"s\"^2] (<<t10-72.1>>):

[stem%unnumbered]
++++
L_\"s\" = sqrt(L_\"s\"^2)
++++
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-m ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .

isoiec80000:term-t10-73.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "diffusion length <atomic physics>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-73.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "L"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-73.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-73.2" ;
  skosxl:prefLabel isoiec80000:term-t10-73.2-0 ;
  skosxl:altLabel isoiec80000:sym-t10-73.2-0 ;
  skos:definition """square root of the diffusion area stem:[L^2] (<<t10-72.2>>):

[stem%unnumbered]
++++
L = sqrt(L^2)
++++
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-m ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .

isoiec80000:term-t10-73.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "migration length"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-73.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "M"@en ;
  smart:hasTermFormType smart:symbol .

