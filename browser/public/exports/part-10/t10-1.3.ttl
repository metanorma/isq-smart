isoiec80000:term-t10-1.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "nucleon number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t10-1.3-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "mass number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-1.3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "A"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-1.3 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-1.3" ;
  skosxl:prefLabel isoiec80000:term-t10-1.3-0 ;
  skosxl:altLabel isoiec80000:term-t10-1.3-1 ;
  skosxl:altLabel isoiec80000:sym-t10-1.3-0 ;
  skos:definition """number of nucleons in an atomic nucleus"""@en ;
  skos:note """[stem%unnumbered]
++++
A = Z + N
++++

Nuclides with the same value of stem:[A] are called isobars.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .