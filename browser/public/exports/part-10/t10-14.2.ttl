isoiec80000:term-t10-14.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "stem:[g] factor of nucleus or nuclear particle"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-14.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "g"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-14.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-14.2" ;
  skosxl:prefLabel isoiec80000:term-t10-14.2-0 ;
  skosxl:altLabel isoiec80000:sym-t10-14.2-0 ;
  skos:definition """quotient of the magnetic dipole moment of an atom, and the product of the nuclear spin quantum number and the nuclear magneton:

[stem%unnumbered]
++++
g = mu/(I*mu_\"N\")
++++

where

stem:[mu]:: is magnitude of magnetic dipole moment (<<t10-9.1>>),
stem:[I]:: is nuclear spin quantum number (<<t10-13.7>>), and
stem:[mu_\"N\"]:: is the nuclear magneton (<<t10-9.3>>)
"""@en ;
  skos:note """The stem:[g] factors for nuclei or nucleons are known from measurements."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .