isoiec80000:term-t10-62.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "ion number density"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t10-62.2-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "ion density"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-62.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "n^(+)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t10-62.2-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "n^(-)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-62.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-62.2" ;
  skosxl:prefLabel isoiec80000:term-t10-62.2-0 ;
  skosxl:altLabel isoiec80000:term-t10-62.2-1 ;
  skosxl:altLabel isoiec80000:sym-t10-62.2-0 ;
  skosxl:altLabel isoiec80000:sym-t10-62.2-1 ;
  skos:definition """quotient of the number of positive and negative ions, stem:[N^(+)] and stem:[N^(-)], respectively, in the volume stem:[V] (<<iso80000-3>>), and that volume:

[stem%unnumbered]
++++
n^(+) = N^(+)//V,\" \"n^(-) = N^(-)//V
++++
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-m^(-3) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .