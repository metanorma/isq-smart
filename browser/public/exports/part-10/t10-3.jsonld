      "skos:definition": {
        "@value": "energy stem:[E_0] (<<iso80000-5>>) of a particle at rest:\n\n[stem%unnumbered]\n++++\nE_0 = m_0c_0^2\n++++\n\nwhere\n\nstem:[m_0]:: is the rest mass (<<t10-2>>) of that particle, and\nstem:[c_0]:: is speed of light in vacuum (<<iso80000-1>>)\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-J"
        },
        {
          "@id": "isoiec80000:unit-N*m"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-2)"
        }
      ],
