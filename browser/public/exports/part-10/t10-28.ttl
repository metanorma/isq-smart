isoiec80000:term-t10-28-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "specific activity"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t10-28-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "massic activity"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-28-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "a"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-28 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-28" ;
  skosxl:prefLabel isoiec80000:term-t10-28-0 ;
  skosxl:altLabel isoiec80000:term-t10-28-1 ;
  skosxl:altLabel isoiec80000:sym-t10-28-0 ;
  skos:definition """quotient of the activity stem:[A] (<<t10-27>>) of a sample and the mass stem:[m] (<<iso80000-4>>) of that sample:

[stem%unnumbered]
++++
a = A//m
++++
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Bq/kg ;
  isoiec80000:hasUnit isoiec80000:unit-kg^(-1)*s^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .