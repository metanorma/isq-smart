        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "particle fluence",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-43-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "ii(Phi)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-43",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-43",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-43-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-43-0"
        }
      ],
      "skos:definition": {
        "@value": "differential quotient of stem:[N] with respect to stem:[a], where stem:[N] is the number of particles incident on a sphere of cross-sectional area stem:[a] (<<t10-38.1>>):\n\n[stem%unnumbered]\n++++\nii(Phi) = (\"d\"N)/(\"d\"a)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The word \"particle\" is usually replaced by the name of a specific particle, for example _proton_ fluence.\n\nIf a flat area of size stem:[\"d\"A] is passed perpendicularly by a number of stem:[\"d\"N] particles, the corresponding particle fluence is: stem:[ii(Phi) = (\"d\"N)/(\"d\"A)]\n\nA plane area of size stem:[\"d\"A] crossed at an angle stem:[alpha] with respect to the surface normal by a number of stem:[\"d\"N] particles results in the particle fluence:\n\n[stem%unnumbered]\n++++\nii(Phi) = (\"d\"N)/(\"cos\"(alpha)\"d\"A)\n++++\n\nIn report 85a of the ICRU a definition with an equivalent meaning is given as:\n\nThe fluence, stem:[ii(Phi)], is the quotient of stem:[\"d\"N] and stem:[\"d\"a], where stem:[\"d\"N] is the number of particles incident on a sphere of cross-sectional area stem:[\"d\"a]:\n\n[stem%unnumbered]\n++++\nii(Phi) = (\"d\"N)/(\"d\"a)\n++++\n\nSee also <<cls-0.3>>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    }
  ]
}