        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "mass excess",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-21.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "ii(Delta)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-21.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-21.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-21.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-21.1-0"
        }
      ],
      "skos:definition": {
        "@value": "difference between the mass of an atom, and the product of its mass number and the unified mass constant:\n\n[stem%unnumbered]\n++++\nii(Delta) = m_\"a\" - A * m_\"u\"\n++++\n\nwhere\n\nstem:[m_\"a\"]:: is the rest mass (<<t10-2>>) of the atom,\nstem:[A]:: is its nucleon number (<<t10-1.3>>), and\nstem:[m_\"u\"]:: is the unified atomic mass constant (<<t10-4.3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The mass excess is usually expressed in daltons, stem:[1 \"unitsml(Da)\" = 1 \"unitsml(u)\"].\n\nSee <<t10-2>>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-kg"
        },
        {
          "@id": "isoiec80000:unit-Da"
        },
        {
          "@id": "isoiec80000:unit-u"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    }
  ]
