isoiec80000:term-t10-74.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "neutron yield per absorption"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-74.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "eta"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-74.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-74.2" ;
  skosxl:prefLabel isoiec80000:term-t10-74.2-0 ;
  skosxl:altLabel isoiec80000:sym-t10-74.2-0 ;
  skos:definition """average number of fission neutrons, both prompt and delayed, emitted per neutron absorbed in a fissionable nuclide or in a nuclear fuel, as specified"""@en ;
  skos:note """stem:[nu//eta] is equal to the quotient of the macroscopic cross section for fission and that for absorption, both for neutrons in the fuel material."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .