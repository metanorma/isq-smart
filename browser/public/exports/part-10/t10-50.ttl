isoiec80000:term-t10-50-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "mass attenuation coefficient <ionizing radiation>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-50-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "mu_m"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-50 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-50" ;
  skosxl:prefLabel isoiec80000:term-t10-50-0 ;
  skosxl:altLabel isoiec80000:sym-t10-50-0 ;
  skos:definition """quotient of the linear attenuation coefficient stem:[mu] (<<t10-49>>) and the mass density stem:[rho] (<<iso80000-4>>) of the medium:

[stem%unnumbered]
++++
mu_m = mu//rho
++++
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-kg^(-1)*m^2 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .