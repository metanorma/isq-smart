    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-6",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-6",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-6-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-6-0"
        }
      ],
      "skos:definition": {
        "@value": "radius (<<iso80000-3>>) of the electron orbital in the hydrogen atom in its ground state in the Bohr model of the atom:\n\n[stem%unnumbered]\n++++\na_0 = (4pi epsilon_0 &#8463;^2)/(m_\"e\"e^2)\n++++\n\nwhere\n\nstem:[epsilon_0]:: is the electric constant (<<iec80000-6>>),\nstem:[&#8463;]:: is the reduced Planck constant (<<iso80000-1>>),\nstem:[m_\"e\"]:: is the rest mass (<<t10-2>>) of electron, and\nstem:[e]:: is the elementary charge (<<iso80000-1>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The radius of the electron orbital in the stem:[\"H\"] atom in its ground state is stem:[a_0] in the Bohr model of the atom.\n\nångström (stem:[\"unitsml(Aring)\"]), stem:[1 \"unitsml(Aring)\" := 10^(-10) \"unitsml(m)\"]\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m"
        },
        {
          "@id": "isoiec80000:unit-Aring"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    }
