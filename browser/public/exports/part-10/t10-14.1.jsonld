    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-14.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-14.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-14.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-14.1-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-14.1-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the magnetic dipole moment of an atom, and the product of the total angular momentum quantum number and the Bohr magneton:\n\n[stem%unnumbered]\n++++\ng = mu/(J * mu_\"B\")\n++++\n\nwhere\n\nstem:[mu]:: is magnitude of magnetic dipole moment (<<t10-9.1>>),\nstem:[J]:: is total angular momentum quantum number (<<t10-13.6>>), and\nstem:[mu_\"B\"]:: is the Bohr magneton (<<t10-9.2>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "These quantities are also called stem:[g] values.\n\nThe Landé factor can be calculated from the expression:\n\n[stem%unnumbered]\n++++\ng(L,S,J) = 1 + (g_\"e\"-1) xx (J(J+1) + S(S+1) - L(L+1))/(2J(J+1))\n++++\n\nwhere stem:[g_\"e\"] is the stem:[g] factor of the electron.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    }
  ]
