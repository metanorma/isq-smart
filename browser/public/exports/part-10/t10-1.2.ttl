isoiec80000:term-t10-1.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "neutron number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-1.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "N"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-1.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-1.2" ;
  skosxl:prefLabel isoiec80000:term-t10-1.2-0 ;
  skosxl:altLabel isoiec80000:sym-t10-1.2-0 ;
  skos:definition """number of neutrons in an atomic nucleus"""@en ;
  skos:note """Nuclides with the same value of stem:[N] but different values of stem:[Z] are called isotones.

stem:[N - Z] is called the neutron excess number.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .