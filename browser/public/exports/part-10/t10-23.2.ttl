isoiec80000:term-t10-23.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "binding fraction"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-23.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "b"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-23.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-23.2" ;
  skosxl:prefLabel isoiec80000:term-t10-23.2-0 ;
  skosxl:altLabel isoiec80000:sym-t10-23.2-0 ;
  skos:definition """quotient of relative mass defect and the nucleon number:

[stem%unnumbered]
++++
b = B_\"r\"//A
++++

where

stem:[B_\"r\"]:: is relative mass defect (<<t10-22.2>>), and
stem:[A]:: is the nucleon number (<<t10-1.3>>)
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .