      ],
      "dcterms:identifier": "10-38.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-38.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-38.1-0"
        }
      ],
      "skos:definition": {
        "@value": "for a specified target entity and for a specified reaction or process produced by incident charged or uncharged particles of a given type and energy, the quotient of the mean number of such reactions or processes and the incident-particle fluence (<<t10-43>>)",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The type of process is indicated by subscripts, e.g. absorption cross section stem:[sigma_\"a\"], scattering cross section stem:[sigma_\"s\"], fission cross section stem:[sigma_\"f\"].\n\n[stem%unnumbered]\n++++\n1 \" barn (b)\" = 10^(-28) \"unitsml(m^2)\"\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^2"
        },
        {
          "@id": "isoiec80000:unit-stem:[\"b\"]"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    }
  ]
