        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Compton wavelength",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-20-0",
