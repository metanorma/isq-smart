    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-24",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-24",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-24-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-24-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-24-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of stem:[-\"d\"N//N] and stem:[\"d\"t], where stem:[\"d\"N//N] is the mean fractional change in the number of nuclei in a particular energy state due to spontaneous transformations in a time interval of duration (<<iso80000-3>>) stem:[\"d\"t]:\n\n[stem%unnumbered]\n++++\nlambda = -1/N (\"d\"N)/(\"d\"t)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For exponential decay, this quantity is constant.\n\nFor more than one decay channel,\n\n[stem%unnumbered]\n++++\nlambda = sum lambda_a\n++++\n\nwhere stem:[lambda_a] denotes the decay constant for a specified final state and the sum is taken over all final states.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-s^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    }
  ]
