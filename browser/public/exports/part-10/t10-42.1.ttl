isoiec80000:term-t10-42.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "volumic cross section"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t10-42.1-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "macroscopic cross section <atomic physics>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-42.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "ii(Sigma)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-42.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-42.1" ;
  skosxl:prefLabel isoiec80000:term-t10-42.1-0 ;
  skosxl:altLabel isoiec80000:term-t10-42.1-1 ;
  skosxl:altLabel isoiec80000:sym-t10-42.1-0 ;
  skos:definition """product of the number density stem:[n_\"a\"] of the atoms and of the cross section (<<t10-38.1>>) stem:[sigma_\"a\"] for a given type of atoms:

[stem%unnumbered]
++++
ii(Sigma) = n_\"a\" sigma_\"a\"
++++
"""@en ;
  skos:note """When the target particles of the medium are at rest, stem:[ii(Sigma) = 1//l], where stem:[l] is the mean free path (<<t10-71>>)."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-m^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .