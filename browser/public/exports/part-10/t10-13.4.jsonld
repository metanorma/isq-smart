        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-13.4",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-13.4-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-13.4-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-13.4-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-13.4-2"
        }
      ],
      "skos:definition": {
        "@value": "atomic quantum number related to the stem:[z] component stem:[l_z], stem:[j_z] or stem:[s_z], of the orbital, total, or spin angular momentum",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[l_z = m_i &#8463;], stem:[j_z = m_j &#8463;], and stem:[s_z = m_s &#8463;], with the ranges from stem:[-l] to stem:[l], from stem:[-j] to stem:[j], and stem:[pm 1//2], respectively.\n\nstem:[m_i] refers to a specific particle stem:[i]. stem:[M] is used for the whole system.\n\nSubscripts stem:[l], stem:[s], stem:[j], etc., as appropriate, indicate the angular momentum involved.\n\nstem:[&#8463;] is the reduced Planck constant (<<iso80000-1>>).\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
