      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-18",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-18",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-18-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-18-0"
        }
      ],
      "skos:definition": {
        "@value": "stem:[z] component of the diagonalized tensor of nuclear quadrupole moment:\n\n[stem%unnumbered]\n++++\nQ = (1/e) int (3z^2-r^2) rho(x,y,z) \"d\"V\n++++\n\nin the quantum state with the nuclear spin in the field direction (stem:[z]), where\n\nstem:[e]:: is the elementary charge (<<iso80000-1>>), +\nstem:[r^2 = x^2 + y^2 + z^2],\nstem:[rho(x,y,z)]:: is the nuclear electric charge density (<<iec80000-6>>), and\nstem:[\"d\"V]:: is the volume element stem:[\"d\"x] stem:[\"d\"y] stem:[\"d\"z]\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The electric nuclear quadrupole moment is stem:[eQ].\n\nThis value is equal to the stem:[z] component of the diagonalized tensor of quadrupole moment.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^2"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    }
  ]
