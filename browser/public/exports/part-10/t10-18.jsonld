        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "nuclear quadrupole moment",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-18-0",
