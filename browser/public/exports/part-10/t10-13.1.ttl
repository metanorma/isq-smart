isoiec80000:term-t10-13.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "quantum number"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-13.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "N"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t10-13.1-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "L"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t10-13.1-2 a smart:Term, skosxl:Label ;
  skosxl:literalForm "M"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t10-13.1-3 a smart:Term, skosxl:Label ;
  skosxl:literalForm "j"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t10-13.1-4 a smart:Term, skosxl:Label ;
  skosxl:literalForm "s"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t10-13.1-5 a smart:Term, skosxl:Label ;
  skosxl:literalForm "F"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-13.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-13.1" ;
  skosxl:prefLabel isoiec80000:term-t10-13.1-0 ;
  skosxl:altLabel isoiec80000:sym-t10-13.1-0 ;
  skosxl:altLabel isoiec80000:sym-t10-13.1-1 ;
  skosxl:altLabel isoiec80000:sym-t10-13.1-2 ;
  skosxl:altLabel isoiec80000:sym-t10-13.1-3 ;
  skosxl:altLabel isoiec80000:sym-t10-13.1-4 ;
  skosxl:altLabel isoiec80000:sym-t10-13.1-5 ;
  skos:definition """number describing a particular state of a quantum system"""@en ;
  skos:note """Electron states determine the binding energy stem:[E = E(n,l,m,j,s,f)] in an atom.

Upper case letters stem:[N, L, M, J, S, F] are usually used for the whole system.

The spatial probability distribution of an electron is given by stem:[abs(ii(Psi))^2], where stem:[ii(Psi)] is its wave function. For an electron in an stem:[\"H\"] atom in a non-relativistic approximation, the wave function can be presented as:

[stem%unnumbered]
++++
ii(Psi)(r,vartheta,phi) = R_(nl)*Y_l^m (vartheta,phi)
++++

where

stem:[r, vartheta, phi] are spherical coordinates (<<iso80000-2>>) with respect to the nucleus and to a given (quantization) axis, stem:[R_(nl)(r)] is the radial distribution function, and stem:[Y_l^m(vartheta,phi)] are spherical harmonics.

In the Bohr model of one-electron atoms, stem:[n], stem:[l], and stem:[m] define the possible orbits of an electron about the nucleus.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .