        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-12.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-12.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-12.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-12.1-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-12.1-2"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-12.1-0"
        }
      ],
      "skos:definition": {
        "@value": "proportionality constant between the magnetic dipole moment and the angular momentum:\n\n[stem%unnumbered]\n++++\nbb(ii(mu)) = gamma bb(ii(J))\n++++\n\nwhere\n\nstem:[bb(ii(mu))]:: is the magnetic dipole moment (<<t10-9.1>>), and\nstem:[bb(ii(J))]:: is the total angular momentum (<<t10-11>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[stem%unnumbered]\n++++\n1 \"unitsml(A*m^2/(J*s))\" = 1 \"unitsml(A*s/kg)\" = 1 \"unitsml(T^(-1)*s^(-1))\"\n++++\n\nThe systematic name is \"gyromagnetic coefficient\", but \"gyromagnetic ratio\" is more usual.\n\nThe gyromagnetic ratio of the proton is denoted by stem:[gamma_\"p\"].\n\nThe gyromagnetic ratio of the neutron is denoted by stem:[gamma_\"n\"].\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-A*m^2*J^(-1)*s^(-1)"
        },
        {
          "@id": "isoiec80000:unit-A*s/kg"
        },
        {
          "@id": "isoiec80000:unit-kg^(-1)*s*A"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    }
  ]
