      ],
      "skos:definition": {
        "@value": "quantum number in an atom describing the magnitude of total angular momentum stem:[bb(ii(J))] (<<t10-11>>)",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[j_i] refers to a specific particle stem:[i]; stem:[J] is used for the whole system.\n\nThe quantum number stem:[J] and the magnitude of total angular momentum stem:[bb(ii(J))] (<<t10-11>>) are different quantities.\n\nThe two values of stem:[j] are stem:[l pm 1//2]. (See <<t10-13.3>>.)\n",
        "@language": "en"
      },
