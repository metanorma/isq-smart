      "skos:definition": {
        "@value": "quotient of mass excess and the unified atomic mass constant:\n\n[stem%unnumbered]\n++++\nii(Delta)_\"r\" = ii(Delta)//m_\"u\"\n++++\n\nwhere\n\nstem:[ii(Delta)]:: is mass excess (<<t10-21.1>>), and\nstem:[m_\"u\"]:: is the unified atomic mass constant (<<t10-4.3>>)\n",
        "@language": "en"
      },
