      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-13.7",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-13.7",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-13.7-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-13.7-0"
        }
      ],
      "skos:definition": {
        "@value": "quantum number related to the total angular momentum (<<t10-11>>), stem:[bb(ii(J))], of a nucleus in any specified state, normally called nuclear spin:\n\n[stem%unnumbered]\n++++\nbb(ii(J))^2 = &#8463;^2 I (I+1)\n++++\n\nwhere stem:[&#8463;] is the reduced Planck constant (<<iso80000-1>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Nuclear spin is composed of spins of the nucleons (protons and neutrons) and their (orbital) motions.\n\nIn principle there is no upper limit for the nuclear spin quantum number. It has possible values stem:[I = 0,1,2,...] for even stem:[A] and stem:[I=1/2, 3/2,...] for odd stem:[A].\n\nIn nuclear and particle physics, stem:[bb(ii(J))] is often used.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    }
  ]
