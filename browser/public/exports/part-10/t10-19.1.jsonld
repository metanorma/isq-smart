        }
      ],
      "skos:definition": {
        "@value": "conventional radius (<<iso80000-3>>) of sphere in which the nuclear matter is included",
        "@language": "en"
      },
      "skos:note": {
        "@value": "This quantity is not exactly defined. It is given approximately for nuclei in their ground state by:\n\n[stem%unnumbered]\n++++\nR = r_0 A^(1//3)\n++++\n\nwhere\n\nstem:[r_0 ~~ 1.2 xx 10^(-15) \"unitsml(m)\"], and stem:[A] is the nucleon number (<<t10-1.3>>).\n\nNuclear radius is usually expressed in femtometres, stem:[1 \"unitsml(fm)\" = 10^(-15) \"unitsml(m)\"].\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    }
