      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-62.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-62.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-62.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-62.1-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the mean number stem:[N] of particles in the volume (<<iso80000-3>>) stem:[V] and volume:\n\n[stem%unnumbered]\n++++\nn=N//V\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[n] is the general symbol for the number density of particles.\n\nThe distribution functions expressed in terms of speed and energy, stem:[n_nu] and stem:[n_\"E\"], are related to stem:[n] by:\n\n[stem%unnumbered]\n++++\nn = int n_nu \"d\"nu = int n_\"E\" \"d\"E\n++++\n\nThe word \"particle\" is usually replaced by the name of a specific particle, for example _neutron_ number density.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^(-3)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    }
  ]
