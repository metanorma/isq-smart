        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "binding fraction",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-23.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "b",
        "@language": "en"
      },
