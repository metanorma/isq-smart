        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-13.3",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-13.3",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-13.3-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-13.3-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-13.3-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-13.3-2"
        }
      ],
      "skos:definition": {
        "@value": "atomic quantum number related to the orbital angular momentum stem:[l] of a one-electron state",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[stem%unnumbered]\n++++\nabs(bb(ii(l)))^2 = &#8463;^2 l(l-1),\" \"l=0,1,...,n-1\n++++\n\nstem:[bb(ii(l))] is the orbital angular momentum and stem:[&#8463;] is the reduced Planck constant (<<iso80000-1>>).\n\nIf reference is made to a specific particle stem:[i], the symbol stem:[l_i] is used instead of stem:[l]; +\nif reference is made to the whole system, the symbol stem:[L] is used instead of stem:[l].\n\nAn electron in an stem:[\"H\"] atom for stem:[l = 0] appears as a spherical cloud. In the Bohr model, it is related to the form of the orbit.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-13.4-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "magnetic quantum number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-13.4-0",
