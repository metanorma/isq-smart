      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-67",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-67",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-67-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-67-0"
        }
      ],
      "skos:definition": {
        "@value": "differential quotient of stem:[n] with respect to time, where stem:[n] is the number density of particles that are slowed down in a time interval of duration (<<iso80000-3>>) stem:[t]:\n\n[stem]\n++++\nq = -(\"d\"n)/(\"d\"t)\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^(-3)*s^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
