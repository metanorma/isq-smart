    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-1.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-1.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-1.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-1.1-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-1.1-0"
        }
      ],
      "skos:definition": {
        "@value": "number of protons in an atomic nucleus",
        "@language": "en"
      },
      "skos:note": {
        "@value": "A nuclide is a species of atom with specified numbers of protons and neutrons.\n\nNuclides with the same value of stem:[Z] but different values of stem:[N] are called isotopes of an element.\n\nThe ordinal number of an element in the periodic table is equal to the atomic number.\n\nThe atomic number equals the quotient of the charge (<<iec80000-6>>) of the nucleus and the elementary charge (<<iso80000-1>>).\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-1.2-0",
      "@type": [
        "smart:Term",
