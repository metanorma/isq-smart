    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-2-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-2-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-2-1"
        }
      ],
      "skos:definition": {
        "@value": "for particle stem:[\"X\"], mass (<<iso80000-4>>) of that particle at rest in an inertial frame",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[example]\n====\nstem:[m(\"H\"_2\"O\")] for a water molecule, stem:[m_\"e\"] for an electron.\n\nRest mass is often denoted stem:[m_0].\n\nstem:[1 \"unitsml(u)\"] is equal to stem:[1//12] times the mass of a free carbon 12 atom, at rest and in its ground state.\n\n[stem%unnumbered]\n++++\n1 \"unitsml(Da)\" = 1 \"unitsml(u)\"\n++++\n====\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-kg"
        },
        {
          "@id": "isoiec80000:unit-u"
        },
        {
          "@id": "isoiec80000:unit-Da"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
