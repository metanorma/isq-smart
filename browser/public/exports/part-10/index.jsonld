        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-74.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-74.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-74.1-0"
        }
      ],
      "skos:definition": {
        "@value": "average number of fission neutrons, both prompt and delayed, emitted per fission event",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-74.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "neutron yield per absorption",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-74.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "eta",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-74.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-74.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-74.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-74.2-0"
        }
      ],
      "skos:definition": {
        "@value": "average number of fission neutrons, both prompt and delayed, emitted per neutron absorbed in a fissionable nuclide or in a nuclear fuel, as specified",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[nu//eta] is equal to the quotient of the macroscopic cross section for fission and that for absorption, both for neutrons in the fuel material.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-75-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "fast fission factor",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-75-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "varphi",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-75",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-75",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-75-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-75-0"
        }
      ],
      "skos:definition": {
        "@value": "in an infinite medium, the quotient of the mean number of neutrons produced by fission due to neutrons of all energies (<<iso80000-5>>) and the mean number of neutrons produced by fissions due to thermal neutrons only",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The class of neutrons must be specified, e.g. thermal.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-76-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "thermal utilization factor",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-76-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "f",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-76",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-76",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-76-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-76-0"
        }
      ],
      "skos:definition": {
        "@value": "in an infinite medium, the quotient of the number of thermal neutrons absorbed in a fissionable nuclide or in a nuclear fuel, as specified, and the total number of thermal neutrons absorbed",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-77-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "non-leakage probability",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-77-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "ii(Lambda)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-77",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-77",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-77-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-77-0"
        }
      ],
      "skos:definition": {
        "@value": "probability that a neutron will not escape from the reactor during the slowing-down process or while it diffuses as a thermal neutron",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-78.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "multiplication factor",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-78.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "k",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-78.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-78.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-78.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-78.1-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the total number of fission or fission-dependent neutrons produced in the duration of a time interval and the total number of neutrons lost by absorption and leakage in that duration",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-78.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "infinite multiplication factor",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-78.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "k_(oo)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-78.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-78.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-78.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-78.2-0"
        }
      ],
      "skos:definition": {
        "@value": "multiplication factor (<<t10-78.1>>) for an infinite medium or for an infinite repeating lattice",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For a thermal reactor,\n\n[stem%unnumbered]\n++++\nk_(oo) = eta * epsilon * p * f\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-79-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "reactor time constant",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-79-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "T",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-79",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-79",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-79-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-79-0"
        }
      ],
      "skos:definition": {
        "@value": "duration (<<iso80000-3>>) required for the neutron fluence rate (<<t10-44>>) in a reactor to change by the factor stem:[\"e\"] when the fluence rate is rising or falling exponentially",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Also called reactor period.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-s"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-80.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "energy imparted",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-80.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "epsilon",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-80.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-80.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-80.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-80.1-0"
        }
      ],
      "skos:definition": {
        "@value": "sum of all energy deposits in a given volume:\n\n[stem%unnumbered]\n++++\nepsilon = sum_i epsilon_i\n++++\n\nwhere the summation is performed over all energy (<<iso80000-5>>) deposits stem:[epsilon_i] of interaction stem:[i] in that volume\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Energy imparted is a stochastic quantity.\n\nstem:[epsilon_i] is given by:\n\n[stem%unnumbered]\n++++\nepsilon_i = epsilon_\"in\" - epsilon_\"out\" + Q\n++++\n\nwhere stem:[epsilon_\"in\"] is the energy (<<iso80000-5>>) of the incident ionizing particle, excluding rest energy (<<t10-3>>), stem:[epsilon_\"out\"] is the sum of the energies (<<iso80000-5>>) of all ionizing particles leaving the interaction, excluding rest energy (<<t10-3>>), and stem:[Q] is the change in the rest energies (<<t10-3>>) of the nucleus and of all particles involved in the interaction.\n\nstem:[Q > 0] means decrease of rest energy;\n\nstem:[Q < 0] means increase of rest energy.\n\nStochastic quantities such as the energy imparted and the specific energy imparted (<<t10-81.2>>) and their probability distributions have been introduced as they describe the discontinuous nature of the ionizing radiations as a determinant of radiochemical and radiobiological effects. In radiation applications involving large numbers of ionizing particles, e.g. in medicine, radiation protection and materials testing and processing, these fluctuations are adequately represented by the expectation values of the probability distributions. Non-stochastic quantities such as particle fluence (<<t10-43>>), absorbed dose (<<t10-81.1>>) and kerma (<<t10-86.1>>) are based on these expectation values.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-eV"
        },
        {
          "@id": "isoiec80000:unit-J"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-80.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "mean energy imparted",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-80.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "bar epsilon",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-80.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-80.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-80.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-80.2-0"
        }
      ],
      "skos:definition": {
        "@value": "expectation value of the energy imparted (<<t10-80.1>>):\n\n[stem%unnumbered]\n++++\nbar epsilon = R_\"in\" - R_\"out\" + sum Q\n++++\n\nwhere\n\nstem:[R_\"in\"]:: is the radiant energy (<<t10-45>>) of all those charged and uncharged ionizing particles that enter the volume,\n\nstem:[R_\"out\"]:: is the radiant energy of all those charged and uncharged ionizing particles that leave the volume, and\n\nstem:[sum Q]:: is the sum of all changes of the rest energy (<<t10-3>>) of nuclei and elementary particles that occur in that volume\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Sometimes, it has been called the integral absorbed dose.\n\nstem:[Q > 0] means decrease of rest energy;\n\nstem:[Q < 0] means increase of rest energy.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-eV"
        },
        {
          "@id": "isoiec80000:unit-J"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-81.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "absorbed dose",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-81.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "D",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-81.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-81.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-81.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-81.1-0"
        }
      ],
      "skos:definition": {
        "@value": "differential quotient of stem:[bar epsilon] with respect to stem:[m], where stem:[bar epsilon] is the mean energy (<<iso80000-5>>) imparted by ionizing radiation to matter of mass (<<iso80000-4>>) stem:[m]:\n\n[stem%unnumbered]\n++++\nD = (\"d\"bar epsilon)/(\"d\"m)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The gray is a special name for joule per kilogram, to be used as the coherent SI unit for absorbed dose.\n\n[stem%unnumbered]\n++++\n1 \"unitsml(Gy)\" = 1 \"unitsml(J/kg)\"\n++++\n\n[stem%unnumbered]\n++++\nbar epsilon = int D \"d\"m\n++++\n\nwhere stem:[\"d\"m] is the element of mass of the irradiated matter.\n\nIn the limit of a small domain, the mean specific energy stem:[bar z = (ii(Delta)bar epsilon)/(ii(Delta)m)] is equal to the absorbed dose stem:[D].\n\nThe absorbed dose can also be expressed in terms of the volume of the mass element by:\n\n[stem%unnumbered]\n++++\nD = (\"d\"bar epsilon)/(\"d\"m) = (\"d\"bar epsilon)/(rho \"d\"V)\n++++\n\nwhere stem:[rho] is the mass density of the mass element.\n\nIn report 85a of the ICRU a definition with an equivalent meaning is given as:\n\nThe absorbed dose, stem:[D], is the quotient of stem:[\"d\"bar epsilon] by stem:[\"d\"m], where stem:[\"d\"bar epsilon] is the mean energy imparted by ionizing radiation to matter of mass stem:[\"d\"m]:\n\n[stem%unnumbered]\n++++\nD = (\"d\"bar epsilon)/(\"d\"m).\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Gy"
        },
        {
          "@id": "isoiec80000:unit-J/kg"
        },
        {
          "@id": "isoiec80000:unit-m^2*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-81.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "specific energy imparted",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-81.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "z",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-81.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-81.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-81.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-81.2-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the energy imparted stem:[epsilon] (<<t10-80.1>>) and the mass stem:[m] (<<iso80000-4>>) of the matter in a given volume element:\n\n[stem%unnumbered]\n++++\nz = epsilon/m\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[z] is a stochastic quantity.\n\nIn the limit of a small domain, the mean specific energy stem:[bar z] is equal to the absorbed dose stem:[D].\n\nThe specific energy imparted can be due to one or more (energy-deposition) events.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Gy"
        },
        {
          "@id": "isoiec80000:unit-J/kg"
        },
        {
          "@id": "isoiec80000:unit-m^2*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-82-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "quality factor <ionizing radiation>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-82-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Q",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-82",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-82",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-82-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-82-0"
        }
      ],
      "skos:definition": {
        "@value": "factor in the calculation and measurement of dose equivalent (<<t10-83.1>>), by which the absorbed dose (<<t10-81.1>>) is to be weighted in order to account for different biological effectiveness of radiations, for radiation protection purposes",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[Q] is determined by the linear energy transfer (<<t10-85>>) for stem:[ii(Delta)-> oo], stem:[L_(oo)] (often denoted as stem:[L] or stem:[\"LET\"]), of charged particles passing through a small volume element at this point (the value of stem:[L_(oo)] refers to water, not to tissue; the difference, however, is small). The relationship between stem:[L] and stem:[Q] is given in ICRP Publication 103 (ICRP, 2007).",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-83.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "dose equivalent",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-83.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "H",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-83.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-83.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-83.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-83.1-0"
        }
      ],
      "skos:definition": {
        "@value": "product of the absorbed dose stem:[D] (<<t10-81.1>>) to tissue at the point of interest and the quality factor stem:[Q] (<<t10-82>>) at that point:\n\n[stem%unnumbered]\n++++\nH = DQ\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The sievert (stem:[\"unitsml(Sv)\"]) is a special name for joule per kilogram, and is the coherent SI unit for dose equivalent.\n\n[stem%unnumbered]\n++++\n1 \"unitsml(Sv)\" = 1 \"unitsml(J/kg)\"\n++++\n\nThe dose equivalent at a point in tissue is given by:\n\n[stem%unnumbered]\n++++\nH = int_0^(oo) Q(L)D_L \"d\"L\n++++\n\nwhere stem:[D_L = \"d\"D//\"d\"L] is the distribution of stem:[D] in stem:[L] at the point of interest. See <<icrp>>.\n\nThe quantities measured with radiation protection dosimeters are based on the definition stem:[H = Q D]. If various radiation qualities stem:[i] have to be simultaneously accounted for, the definition is:\n\n[stem%unnumbered]\n++++\nH = sum_i Q_i D_i.\n++++\n\nIn ICRU 51 this quantity is denoted as \"dose equivalent\".\n\nIn order to quantify the radiation exposition of the human body and to specify dose limits, use is made of a quantity defined in ICRP 103, the \"equivalent dose to a tissue or organ\": stem:[H_\"T\" = w_\"T\" sum_\"R\" w_\"R\" D_\"T,R\"]. The weighting factors stem:[w_\"T\"] for various tissues and organs stem:[T] and stem:[w_\"R\"] for various radiation qualities stem:[\"R\"] have been numerically laid down in ICRP 103. stem:[D_\"T,R\"] is the mean absorbed dose to tissue within a tissue or organ stem:[\"T\"], imparted by radiation with radiation quality stem:[\"R\"].\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Sv"
        },
        {
          "@id": "isoiec80000:unit-J/kg"
        },
        {
          "@id": "isoiec80000:unit-m^2*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-83.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "dose equivalent rate",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-83.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "dot H",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-83.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-83.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-83.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-83.2-0"
        }
      ],
      "skos:definition": {
        "@value": "differential quotient of dose equivalent stem:[H] (<<t10-83.1>>) with respect to time (<<iso80000-3>>):\n\n[stem%unnumbered]\n++++\ndot H = (\"d\"H)/(\"d\"t)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[stem%unnumbered]\n++++\n1 \"unitsml(Sv/s)\" = 1 \"unitsml(W/kg)\"\n++++\n\nSee the remarks for <<t10-83.1>>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Sv/s"
        },
        {
          "@id": "isoiec80000:unit-W/kg"
        },
        {
          "@id": "isoiec80000:unit-m^2*s^(-3)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-84-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "absorbed-dose rate",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-84-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "dot D",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-84",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-84",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-84-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-84-0"
        }
      ],
      "skos:definition": {
        "@value": "differential quotient of the absorbed dose stem:[D] (<<t10-81.1>>) with respect to time (<<iso80000-3>>):\n\n[stem%unnumbered]\n++++\ndot D = (\"d\"D)/(\"d\"t)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[stem%unnumbered]\n++++\n1 \"unitsml(Gy/s)\" = 1 \"unitsml(W/kg)\"\n++++\n\nSee the remarks for <<t10-81.1>>.\n\nIn report 85a of the ICRU a definition with an equivalent meaning is given as:\n\nThe absorbed-does rate, stem:[dot D], is the quotient of stem:[\"d\"D] by stem:[\"d\"t], where stem:[\"d\"D] is the increment of absorbed does in the time interval stem:[\"d\"t]:\n\n[stem%unnumbered]\n++++\ndot D = (\"d\"D)/(\"d\"t).\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Gy/s"
        },
        {
          "@id": "isoiec80000:unit-W/kg"
        },
        {
          "@id": "isoiec80000:unit-m^2*s^(-3)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-85-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "linear energy transfer",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-85-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "L_(ii(Delta))",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-85",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-85",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-85-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-85-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the mean energy (<<iso80000-4>>) stem:[\"d\"E_(ii(Delta))] lost by the charged particles due to electronic interactions in traversing a distance (<<iso80000-3>>) stem:[\"d\"l], minus the mean sum of the kinetic energies in excess of stem:[ii(Delta)] of all the electrons released by the charged particles and stem:[\"d\"l]:\n\n[stem%unnumbered]\n++++\nL_(ii(Delta)) = (\"d\"E_(ii(Delta)))/(\"d\"l)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "This quantity is not completely defined unless stem:[ii(Delta)] is specified, i.e. the maximum kinetic energy of secondary electrons whose energy is considered to be \"locally deposited.\" stem:[ii(Delta)] may be expressed in stem:[\"unitsml(eV)\"].\n\nNote that the abbreviation LET specifically refers to the quantity stem:[L_(oo)] mentioned in the remark to <<t10-82>>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-eV/m"
        },
        {
          "@id": "isoiec80000:unit-J/m"
        },
        {
          "@id": "isoiec80000:unit-kg*m*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-86.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "kerma",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-86.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "K",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-86.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-86.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-86.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-86.1-0"
        }
      ],
      "skos:definition": {
        "@value": "for uncharged ionizing radiation, differential quotient of stem:[E_\"tr\"] with respect to stem:[m], where stem:[E_\"tr\"] is the mean sum of the initial kinetic energies (<<iso80000-4>>) of all the charged ionizing particles liberated in a mass (<<iso80000-4>>) stem:[m] of a material:\n\n[stem%unnumbered]\n++++\nK = (\"d\"E_(\"tr\"))/(\"d\"m)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[stem%unnumbered]\n++++\n1 \"unitsml(Gy)\" = 1 \"unitsml(J/kg)\"\n++++\n\nSee the remarks for <<t10-81.1>>.\n\nThe name \"kerma\" is derived from Kinetic Energy Released in MAtter (or MAss or MAterial).\n\nThe quantity stem:[\"d\"E_\"tr\"] includes also the kinetic energy of the charged particles emitted in the decay of excited atoms, molecules, or nuclei.\n\nWhen the mass element stem:[\"d\"m] consists of air the term air kerma is used. It can be convenient to refer to a value of air kerma in free space or at a point inside a material different from air, e.g. to the air kerma at a point inside a water phantom.\n\nIn report 85a of the ICRU a definition with an equivalent meaning is given as:\n\nThe kerma, stem:[K], for ionizing uncharged particles, is the quotient of stem:[\"d\"E_\"tr\"] by stem:[\"d\"m], where stem:[\"d\"E_\"tr\"] is the mean sum of the initial kinetic energies of all the charged particles liberated in a mass stem:[\"d\"m] of a material by the uncharged particles incident on stem:[\"d\"m]:\n\n[stem%unnumbered]\n++++\nK = (\"d\"E_\"tr\")/(\"d\"m).\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Gy"
        },
        {
          "@id": "isoiec80000:unit-J/kg"
        },
        {
          "@id": "isoiec80000:unit-m^2*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-86.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "kerma rate",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-86.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "dot K",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-86.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-86.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-86.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-86.2-0"
        }
      ],
      "skos:definition": {
        "@value": "differential quotient of kerma (<<t10-86.1>>) with respect to time (<<iso80000-3>>):\n\n[stem%unnumbered]\n++++\ndot K = (\"d\"K)/(\"d\"t)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[stem%unnumbered]\n++++\n1 \"unitsml(Gy/s)\" = 1 \"unitsml(W/kg)\"\n++++\n\nSee the Remarks for <<t10-81.1>>.\n\nIn report 85a of the ICRU a definition with an equivalent meaning is given as:\n\nThe kerma rate, stem:[dot K], is the quotient of stem:[\"d\"K] by stem:[\"d\"t], where stem:[\"d\"K] is the increment of kerma in the time interval stem:[\"d\"t]:\n\n[stem%unnumbered]\n++++\ndot K = (\"d\"K)/(\"d\"t).\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Gy/s"
        },
        {
          "@id": "isoiec80000:unit-W/kg"
        },
        {
          "@id": "isoiec80000:unit-m^2*s^(-3)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-87-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "mass energy-transfer coefficient",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-87-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "mu_\"tr\"//rho",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-87",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-87",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-87-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-87-0"
        }
      ],
      "skos:definition": {
        "@value": "for ionizing uncharged particles of a given type and energy, the differential quotient of stem:[R_\"tr\"] with respect to stem:[l]:\n\n[stem%unnumbered]\n++++\n(mu_\"tr\")/rho = 1/rho 1/R (\"d\"R_\"tr\")/(\"d\"l)\n++++\n\nwhere stem:[R_\"tr\"] is the mean energy (<<iso80000-5>>) that is transferred to kinetic energy (<<iso80000-4>>) of charged particles by interactions of the uncharged particles of incident radiant energy stem:[R] (<<t10-45>>) in traversing a distance (<<iso80000-3>>) stem:[l] in the material of density (<<iso80000-4>>) stem:[rho], divided by stem:[rho] and stem:[R]\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[mu_\"tr\"//rho = dot K//ii(Psi)], where stem:[dot K] is kerma rate (<<t10-86.2>>) and stem:[ii(Psi)] is energy fluence rate (<<t10-47>>).\n\nThe quantity:\n\n[stem%unnumbered]\n++++\nmu_\"en\"//rho = (mu_\"tr\"//rho)(1-g)\n++++\n\nwhere stem:[g] is mean fraction of the kinetic energy of the liberated charged particles that is lost in radiative processes in the material, is called mass energy-absorption coefficient.\n\nThe mass energy-absorption coefficient of a compound material depends on the stopping power of the material. Thus, its evaluation cannot, in principle, be reduced to a simple summation of the mass energy-absorption coefficient of the atomic constituents. Such a summation can provide an adequate approximation when the value of stem:[g] is sufficiently small.\n\nIn report 85a of the ICRU a definition with an equivalent meaning is given as:\n\nThe mass energy-transfer coefficient, stem:[mu_\"tr\"//rho], of a material, for uncharged particles of a given type and energy, is the quotient of stem:[\"d\"R_\"tr\"//R] by stem:[rho \"d\"l], where stem:[\"d\"R_\"tr\"] is the mean energy that is transferred to kinetic energy of charged particles by interactions of the uncharged particles of incident radiant energy stem:[R] in traversing a distance stem:[\"d\"l] in the material of density stem:[rho]:\n\n[stem%unnumbered]\n++++\n(mu_\"tr\")/rho = 1/(rho \"d\"l) (\"d\"R_\"tr\")/R.\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-kg^(-1)*m^2"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-88-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "exposure <ionizing radiation>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-88-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "X",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-88",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-88",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-88-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-88-0"
        }
      ],
      "skos:definition": {
        "@value": "for X- or gamma radiation the differential quotient of stem:[q] with respect to stem:[m], where stem:[q] is the absolute value of the mean total electric charge of the ions of one sign produced when all the electrons and positrons liberated or created by photons incident on an element of dry air with mass stem:[m] (<<iso80000-4>>) are completely stopped in dry air:\n\n[stem%unnumbered]\n++++\nX = (\"d\"q)/(\"d\"m)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The ionization produced by electrons emitted in atomic or molecular relaxation is included in stem:[\"d\"q]. The ionization due to photons emitted by radiative processes (i.e. bremsstrahlung and fluorescence photons) is not included in stem:[\"d\"q].\n\nThis quantity should not be confused with the quantity photon exposure (<<iso80000-7>>), radiation exposure (<<iso80000-7>>), or the quantity luminous exposure (<<iso80000-7>>).\n\nIt can be convenient to refer to a value of exposure in free space or at a point inside a material different from air, e.g. to the exposure at a point inside a water phantom.\n\nThe exposure is related to the air kerma, stem:[K_\"a\"], (see <<t10-86.1>>) by:\n\n[stem%unnumbered]\n++++\nX = (e(1-g))/W K_\"a\",\n++++\n\nwhere stem:[e] is the elementary charge (<<iso80000-1>>), stem:[W] the average energy loss per elementary charge produced (<<t10-60>>), and stem:[g] is the fraction of the kinetic energy of liberated charged particles that is lost in radiative processes.\n\nIn report 85a of the ICRU a definition with an equivalent meaning is given as:\n\nThe exposure, stem:[X], is the quotient of stem:[\"d\"q] by stem:[\"d\"m], where stem:[\"d\"q] is the absolute value of the mean total charge of the ions of one sign produced when all the electrons and positrons liberated or created by photons incident on a mass stem:[\"d\"m] of dry air are completely stopped in dry air:\n\n[stem%unnumbered]\n++++\nX = (\"d\"q)/(\"d\"m).\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-C/kg"
        },
        {
          "@id": "isoiec80000:unit-kg^(-1)*s*A"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-89-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "exposure rate",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-89-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "dot X",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-89",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-89",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-89-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-89-0"
        }
      ],
      "skos:definition": {
        "@value": "differential quotient of the exposure stem:[X] (<<t10-88>>) with respect to time (<<iso80000-3>>):\n\n[stem%unnumbered]\n++++\ndot X = (\"d\"X)/(\"d\"t)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[stem%unnumbered]\n++++\n1 \"unitsml(C/(kg*s))\" = 1 \"unitsml(A/kg)\"\n++++\n\nIn report 85a of the ICRU a definition with an equivalent meaning is given as:\n\nThe exposure rate, stem:[dot X], is the quotient of stem:[\"d\"X] by stem:[\"d\"t], where stem:[\"d\"X] is the increment of exposure in the time interval stem:[\"d\"t]:\n\n[stem%unnumbered]\n++++\ndot X = (\"d\"X)/(\"d\"t).\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-C/(kg*s)"
        },
        {
          "@id": "isoiec80000:unit-kg^(-1)*A"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    }
  ]
}