        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-1.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-1.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-1.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-1.2-0"
        }
      ],
      "skos:definition": {
        "@value": "number of neutrons in an atomic nucleus",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Nuclides with the same value of stem:[N] but different values of stem:[Z] are called isotones.\n\nstem:[N - Z] is called the neutron excess number.\n",
        "@language": "en"
      },
