    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-24-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "decay constant",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-24-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "disintegration constant",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-24-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "lambda",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-24",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-24",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-24-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-24-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-24-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of stem:[-\"d\"N//N] and stem:[\"d\"t], where stem:[\"d\"N//N] is the mean fractional change in the number of nuclei in a particular energy state due to spontaneous transformations in a time interval of duration (<<iso80000-3>>) stem:[\"d\"t]:\n\n[stem%unnumbered]\n++++\nlambda = -1/N (\"d\"N)/(\"d\"t)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For exponential decay, this quantity is constant.\n\nFor more than one decay channel,\n\n[stem%unnumbered]\n++++\nlambda = sum lambda_a\n++++\n\nwhere stem:[lambda_a] denotes the decay constant for a specified final state and the sum is taken over all final states.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-s^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-25-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "mean duration of life",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-25-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "mean life time <atomic and nuclear physics>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-25-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "tau",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-25",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-25",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-25-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-25-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-25-0"
        }
      ],
      "skos:definition": {
        "@value": "reciprocal of the decay constant stem:[lambda] (<<t10-24>>):\n\n[stem%unnumbered]\n++++\ntau = 1/lambda\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Mean duration of life is the expected value of the duration of life of an unstable particle or an excited state of a particle when the number of decay events in a short time interval follows a Poisson distribution.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-s"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-26-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "level width",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-26-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "ii(Gamma)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-26",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-26",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-26-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-26-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the reduced Planck constant and the mean life:\n\n[stem%unnumbered]\n++++\nii(Gamma) = &#8463;/tau\n++++\n\nwhere\n\nstem:[&#8463;]:: is the reduced Planck constant (<<iso80000-1>>), and\nstem:[tau]:: is mean duration of life (<<t10-25>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Level width is the uncertainty of the energy of an unstable particle or an excited state of a system due to the Heisenberg principle.\n\nThe term energy level refers to the configuration of the distribution function of the density of states. Energy levels may be considered as discrete, like those in an atom, or may have a finite width, like e.g. this item or like e.g. the valence or conduction band in solid state physics. Energy levels are applicable to both real and virtual particles, e.g. electrons and phonons, respectively.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-eV"
        },
        {
          "@id": "isoiec80000:unit-J"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-27-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "activity",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-27-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "A",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-27",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-27",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-27-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-27-0"
        }
      ],
      "skos:definition": {
        "@value": "differential quotient of stem:[N] with respect to time, where stem:[N] is the mean change in the number of nuclei in a particular energy state due to spontaneous nuclear transformations in a time interval of duration (<<iso80000-3>>) stem:[\"d\"t]:\n\n[stem%unnumbered]\n++++\nA = -(\"d\"N)/(\"d\"t)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For exponential decay, stem:[A = lambda N], where stem:[lambda] is the decay constant (<<t10-24>>).\n\nThe becquerel (stem:[\"unitsml(Bq)\"]) is a special name for second to the power minus one, to be used as the coherent SI unit of activity.\n\nIn report 85a of the ICRU a definition with an equivalent meaning is given as: The activity, stem:[A], of an amount of a radionuclide in a particular energy state at a given time is the quotient of stem:[-\"d\"N] by stem:[\"d\"t], where stem:[\"d\"N] is the mean change in the number of nuclei in that energy state due to spontaneous nuclear transformations in the time interval stem:[\"d\"t]:\n\n[stem%unnumbered]\n++++\nA = -(\"d\"N)/(\"d\"t)\n++++\n\nSee also <<cls-0.3>>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Bq"
        },
        {
          "@id": "isoiec80000:unit-s^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-28-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "specific activity",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-28-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "massic activity",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-28-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "a",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-28",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-28",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-28-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-28-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-28-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the activity stem:[A] (<<t10-27>>) of a sample and the mass stem:[m] (<<iso80000-4>>) of that sample:\n\n[stem%unnumbered]\n++++\na = A//m\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Bq/kg"
        },
        {
          "@id": "isoiec80000:unit-kg^(-1)*s^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-29-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "activity density",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-29-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "volumic activity",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-29-2",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "activity concentration",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-29-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "c_\"A\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-29",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-29",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-29-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-29-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-29-2"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-29-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the activity stem:[A] (<<t10-27>>) of a sample and the volume stem:[V] (<<iso80000-3>>) of that sample:\n\n[stem%unnumbered]\n++++\nc_\"A\" = A//V\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Bq/m^3"
        },
        {
          "@id": "isoiec80000:unit-m^(-3)*s^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-30-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "surface-activity density",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-30-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "a_\"S\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-30",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-30",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-30-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-30-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the activity stem:[A] (<<t10-27>>) of a sample and the total area stem:[S] (<<iso80000-3>>) of the surface of that sample:\n\n[stem%unnumbered]\n++++\na_\"S\" = A//S\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "This value is usually defined for flat sources, where stem:[S] corresponds to the total area of surface of one side of the source.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Bq/m^2"
        },
        {
          "@id": "isoiec80000:unit-m^(-2)*s^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-31-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "half life",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-31-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "T_(1//2)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-31",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-31",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-31-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-31-0"
        }
      ],
      "skos:definition": {
        "@value": "mean duration (<<iso80000-3>>) required for the decay of one half of the atoms or nuclei",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For exponential decay, stem:[T_(1//2) = (\"ln\"2)//lambda], where stem:[lambda] is the decay constant (<<t10-24>>).",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-s"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-32-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "alpha disintegration energy",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-32-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Q_alpha",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-32",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-32",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-32-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-32-0"
        }
      ],
      "skos:definition": {
        "@value": "sum of the kinetic energy (<<iso80000-4>>) of the stem:[alpha]-particle produced in the disintegration process and the recoil energy (<<iso80000-5>>) of the product atom in a reference frame in which the emitting nucleus is at rest before its disintegration",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The ground-state alpha disintegration energy, stem:[Q_(alpha,0)], also includes the energy of any nuclear transitions that take place in the daughter produced.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-eV"
        },
        {
          "@id": "isoiec80000:unit-J"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-33-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "maximum beta-particle energy",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-33-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "E_beta",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-33",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-33",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-33-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-33-0"
        }
      ],
      "skos:definition": {
        "@value": "maximum kinetic energy (<<iso80000-4>>) of the emitted beta particle produced in the nuclear disintegration process",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The maximum kinetic energy corresponds to the highest energy of the beta spectrum.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-eV"
        },
        {
          "@id": "isoiec80000:unit-J"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-34-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "beta disintegration energy",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-34-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Q_beta",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-34",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-34",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-34-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-34-0"
        }
      ],
      "skos:definition": {
        "@value": "sum of the maximum beta-particle kinetic energy (<<t10-33>>) and the recoil energy (<<iso80000-5>>) of the atom produced in a reference frame in which the emitting nucleus is at rest before its disintegration",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For positron emitters, the energy for the production of the annihilation radiation created in the combination of an electron with the positron is part of the beta disintegration energy.\n\nThe ground-state beta disintegration energy, stem:[Q_(beta,0)], also includes the energy of any nuclear transitions that take place in the daughter product.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-eV"
        },
        {
          "@id": "isoiec80000:unit-J"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-35-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "internal conversion factor",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-35-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "alpha",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-35",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-35",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-35-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-35-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the number of internal conversion electrons and the number of gamma quanta emitted by the radioactive atom in a given transition, where a conversion electron represents an orbital electron emitted through the radioactive decay",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The quantity stem:[alpha//(alpha+1)] is also used and called the internal-conversion fraction.\n\nPartial conversion fractions referring to the various electron shells stem:[\"K\", \"L\", ...] are indicated by stem:[alpha_\"K\", alpha_\"L\", ...].\n\nstem:[alpha_\"K\"//alpha_\"L\"] is called the stem:[\"K\"]-to-stem:[\"L\"] internal conversion ratio.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-36-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "particle emission rate",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-36-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "N",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-36",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-36",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-36-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-36-0"
        }
      ],
      "skos:definition": {
        "@value": "differential quotient of stem:[N] with respect to time, where stem:[N] is the number of particles being emitted from an infinitesimally small volume element in the time interval of duration stem:[\"d\"t] (<<iso80000-3>>), and stem:[\"d\"t]:\n\n[stem%unnumbered]\n++++\nN=(\"d\"N)/(\"d\"t)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Usually the kind of particles is specified, e.g. neutron emission rate or alpha particle emission rate.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-37.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "reaction energy",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-37.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Q",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-37.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-37.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-37.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-37.1-0"
        }
      ],
      "skos:definition": {
        "@value": "in a nuclear reaction, sum of the kinetic energies (<<iso80000-4>>) and photon energies (<<iso80000-5>>) of the reaction products minus the sum of the kinetic and photon energies of the reactants",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For exothermic nuclear reactions, stem:[Q>0].\n\nFor endothermic nuclear reactions, stem:[Q<0].\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-eV"
        },
        {
          "@id": "isoiec80000:unit-J"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-37.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "resonance energy",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-37.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "E_\"r\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-37.2-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "E_\"res\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-37.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-37.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-37.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-37.2-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-37.2-1"
        }
      ],
      "skos:definition": {
        "@value": "kinetic energy (<<iso80000-4>>) of an incident particle, in the reference frame of the target, corresponding to a resonance in a nuclear reaction",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The energy of the resonance corresponds to the difference of the energy levels involved of the nucleus.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-eV"
        },
        {
          "@id": "isoiec80000:unit-J"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-38.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "cross section <atomic physics>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-38.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "sigma",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-38.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-38.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-38.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-38.1-0"
        }
      ],
      "skos:definition": {
        "@value": "for a specified target entity and for a specified reaction or process produced by incident charged or uncharged particles of a given type and energy, the quotient of the mean number of such reactions or processes and the incident-particle fluence (<<t10-43>>)",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The type of process is indicated by subscripts, e.g. absorption cross section stem:[sigma_\"a\"], scattering cross section stem:[sigma_\"s\"], fission cross section stem:[sigma_\"f\"].\n\n[stem%unnumbered]\n++++\n1 \" barn (b)\" = 10^(-28) \"unitsml(m^2)\"\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^2"
        },
        {
          "@id": "isoiec80000:unit-stem:[\"b\"]"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-38.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "total cross section <atomic physics>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-38.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "sigma_\"tot\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-38.2-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "sigma_\"T\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-38.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-38.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-38.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-38.2-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-38.2-1"
        }
      ],
      "skos:definition": {
        "@value": "sum of all cross sections (<<t10-38.1>>) corresponding to the various reactions or processes between an incident particle of specified type and energy (<<iso80000-5>>) and a target entity",
        "@language": "en"
      },
      "skos:note": {
        "@value": "In the case of a narrow unidirectional beam of incident particles, this is the effective cross section for the removal of an incident particle from the beam. See the Remarks for <<t10-52>>.\n\n[stem%unnumbered]\n++++\n1 \" barn (b)\" = 10^(-28) \"unitsml(m^2)\"\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^2"
        },
        {
          "@id": "isoiec80000:unit-stem:[\"b\"]"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-39-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "direction distribution of cross section <atomic physics>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-39-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "sigma_(ii(Omega))",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-39",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-39",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-39-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-39-0"
        }
      ],
      "skos:definition": {
        "@value": "differential quotient of stem:[sigma] with respect to stem:[ii(Omega)], where stem:[sigma] is the cross section (<<t10-38.1>>) for ejecting or scattering a particle into a specified direction, and stem:[ii(Omega)] is the solid angle (<<iso80000-3>>) around that direction:\n\n[stem%unnumbered]\n++++\nsigma_(ii(Omega)) = \"d\"sigma // \"d\"ii(Omega)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Quantities listed under <<t10-39>>, <<t10-40>> and <<t10-41>> are sometimes called differential cross sections.\n\nThe type of interaction needs to be specified.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^2*sr^(-1)"
        },
        {
          "@id": "isoiec80000:unit-m^2"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-40-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "energy distribution of cross section <atomic physics>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-40-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "sigma_\"E\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-40",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-40",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-40-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-40-0"
        }
      ],
      "skos:definition": {
        "@value": "differential quotient of stem:[sigma] with respect to energy, where stem:[sigma] is the cross section (<<t10-38.1>>) for a process in which the energy stem:[E] (<<iso80000-5>>) of the ejected or scattered particle is between stem:[E] and stem:[E+\"d\"E]:\n\n[stem%unnumbered]\n++++\nsigma_\"E\" = \"d\"sigma//\"d\"E\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^2//J"
        },
        {
          "@id": "isoiec80000:unit-kg^(-1)*s^2"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-41-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "direction and energy distribution of cross section <atomic physics>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-41-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "sigma_(ii(Omega),E)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-41",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-41",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-41-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-41-0"
        }
      ],
      "skos:definition": {
        "@value": "partial differential quotient of stem:[sigma] with respect to solid angle and energy, where stem:[sigma] is the cross section (<<t10-38.1>>) for ejecting or scattering a particle into a solid angle stem:[\"d\"ii(Omega)] around a specified direction and with an energy between stem:[E] and stem:[E+\"d\"E]:\n\n[stem%unnumbered]\n++++\nsigma_(ii(Omega),E) = (del^2 sigma)/(del ii(Omega) del E)\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^2/(J*sr)"
        },
        {
          "@id": "isoiec80000:unit-kg^(-1)*s^2"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-42.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "volumic cross section",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-42.1-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "macroscopic cross section <atomic physics>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-42.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "ii(Sigma)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-42.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-42.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-42.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-42.1-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-42.1-0"
        }
      ],
      "skos:definition": {
        "@value": "product of the number density stem:[n_\"a\"] of the atoms and of the cross section (<<t10-38.1>>) stem:[sigma_\"a\"] for a given type of atoms:\n\n[stem%unnumbered]\n++++\nii(Sigma) = n_\"a\" sigma_\"a\"\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "When the target particles of the medium are at rest, stem:[ii(Sigma) = 1//l], where stem:[l] is the mean free path (<<t10-71>>).",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-42.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "volumic total cross section",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-42.2-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "macroscopic total cross section <atomic physics>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-42.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "ii(Sigma)_\"tot\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-42.2-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "ii(Sigma)_\"T\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-42.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-42.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-42.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-42.2-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-42.2-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-42.2-1"
        }
      ],
      "skos:definition": {
        "@value": "product of the number density stem:[n_\"a\"] of the atoms and the cross section (<<t10-38.1>>) stem:[sigma_\"tot\"] for a given type of atoms:\n\n[stem%unnumbered]\n++++\nii(Sigma)_\"tot\" = n_\"a\"sigma_\"tot\"\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "See the Remarks for <<t10-49>>.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-43-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "particle fluence",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-43-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "ii(Phi)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-43",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-43",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-43-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-43-0"
        }
      ],
      "skos:definition": {
        "@value": "differential quotient of stem:[N] with respect to stem:[a], where stem:[N] is the number of particles incident on a sphere of cross-sectional area stem:[a] (<<t10-38.1>>):\n\n[stem%unnumbered]\n++++\nii(Phi) = (\"d\"N)/(\"d\"a)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The word \"particle\" is usually replaced by the name of a specific particle, for example _proton_ fluence.\n\nIf a flat area of size stem:[\"d\"A] is passed perpendicularly by a number of stem:[\"d\"N] particles, the corresponding particle fluence is: stem:[ii(Phi) = (\"d\"N)/(\"d\"A)]\n\nA plane area of size stem:[\"d\"A] crossed at an angle stem:[alpha] with respect to the surface normal by a number of stem:[\"d\"N] particles results in the particle fluence:\n\n[stem%unnumbered]\n++++\nii(Phi) = (\"d\"N)/(\"cos\"(alpha)\"d\"A)\n++++\n\nIn report 85a of the ICRU a definition with an equivalent meaning is given as:\n\nThe fluence, stem:[ii(Phi)], is the quotient of stem:[\"d\"N] and stem:[\"d\"a], where stem:[\"d\"N] is the number of particles incident on a sphere of cross-sectional area stem:[\"d\"a]:\n\n[stem%unnumbered]\n++++\nii(Phi) = (\"d\"N)/(\"d\"a)\n++++\n\nSee also <<cls-0.3>>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-44-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "particle fluence rate",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-44-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "ii(Phi)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-44",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-44",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-44-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-44-0"
        }
      ],
      "skos:definition": {
        "@value": "differential quotient of fluence stem:[ii(Phi)] (<<t10-43>>) with respect to time (<<iso80000-3>>):\n\n[stem%unnumbered]\n++++\nii(Phi) = (\"d\"ii(Phi))/(\"d\"t)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The word \"particle\" is usually replaced by the name of a specific particle, for example proton fluence rate.\n\nThe distribution function expressed in terms of speed and energy, stem:[ii(Phi)_nu] and stem:[ii(Phi)_E], are related to by:\n\n[stem%unnumbered]\n++++\nii(Phi) = int ii(Phi)_nu \"d\"nu = int ii(Phi)_E \"d\"E.\n++++\n\nThis quantity has also been termed particle flux density. Because the word \"density\" has several connotations, the term \"fluence rate\" is preferred. For a radiation field composed of particles of velocity stem:[nu], the fluence rate is equal to stem:[n*nu] where stem:[n] is the particle number density.\n\nSee Remarks for <<t10-43>>.\n\nIn report 85a of the ICRU a definition with an equivalent meaning is given as:\n\nThe fluence rate, stem:[ii(Phi)], is the quotient of stem:[\"d\"ii(Phi)] and stem:[\"d\"t], where stem:[\"d\"ii(Phi)] is the increment of the fluence in the time interval stem:[\"d\"t]:\n\n[stem%unnumbered]\n++++\nii(Phi) = (\"d\"ii(Phi))/(\"d\"t)\n++++\n\nSee also <<cls-0.3>>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^(-2)*s^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-45-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "radiant energy <ionizing radiation>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-45-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "R",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-45",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-45",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-45-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-45-0"
        }
      ],
      "skos:definition": {
        "@value": "mean energy (<<iso80000-5>>), excluding rest energy (<<t10-3>>), of the particles that are emitted, transferred, or received",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For particles of energy stem:[E] (excluding rest energy), the radiant energy, stem:[R], is equal to the product stem:[N*E] where stem:[N] is the number of the particles that are emitted, transferred, or received\n\nThe distributions, stem:[N_\"E\"] and stem:[R_\"E\"], of the particle number and the radiant energy with respect to energy are given by stem:[N_\"E\" = \"d\"N//\"d\"E] and +\nstem:[R_\"E\" = \"d\"R//\"d\"E], respectively, where stem:[\"d\"N] is the number of particles with energy between stem:[E] and stem:[E+\"d\"E], and stem:[\"d\"R] is their radiant energy. The two distributions are related by stem:[R_\"E\" = E*N_\"E\"].\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-eV"
        },
        {
          "@id": "isoiec80000:unit-J"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-46-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "energy fluence",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-46-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "ii(Psi)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-46",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-46",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-46-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-46-0"
        }
      ],
      "skos:definition": {
        "@value": "differential quotient of radiant energy stem:[R] (<<t10-45>>) incident on a sphere of cross-sectional area (<<t10-38.1>>) a with respect to that area:\n\n[stem%unnumbered]\n++++\nii(Psi) = (\"d\"R)/(\"d\"a)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "In report 85a of the ICRU a definition with an equivalent meaning is given as:\n\nThe energy fluence, stem:[ii(Psi)], is the quotient of stem:[\"d\"R] and stem:[\"d\"a], where stem:[\"d\"R] is the radiant energy incident on a sphere of cross-sectional area stem:[\"d\"a]:\n\n[stem%unnumbered]\n++++\nii(Psi) = (\"d\"R)/(\"d\"a)\n++++\n\nSee also <<cls-0.3>>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-eV/m^2"
        },
        {
          "@id": "isoiec80000:unit-J/m^2"
        },
        {
          "@id": "isoiec80000:unit-kg*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-47-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "energy fluence rate",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-47-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "ii(dot Psi)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-47",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-47",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-47-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-47-0"
        }
      ],
      "skos:definition": {
        "@value": "differential quotient of the energy fluence stem:[ii(Psi)] (<<t10-46>>) with respect to time (<<iso80000-3>>):\n\n[stem%unnumbered]\n++++\nii(dot Psi) = (\"d\"ii(Psi))/(\"d\"t)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "In report 85a of the ICRU a definition with an equivalent meaning is given as:\n\nThe energy-fluence rate, stem:[ii(dot Psi)], is the quotient of stem:[\"d\"ii(Psi)] by stem:[\"d\"t], where stem:[\"d\"ii(Psi)] is the increment of the energy fluence in the time interval stem:[\"d\"t]:\n\n[stem%unnumbered]\n++++\nii(dot Psi) = (\"d\"ii(Psi))/(\"d\"t)\n++++\n\nSee also <<cls-0.3>>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-W/m^2"
        },
        {
          "@id": "isoiec80000:unit-kg*s^(-3)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-48-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "particle current density",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-48-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "bb(ii(J))",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-48-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "bb(ii(S))",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-48",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-48",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-48-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-48-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-48-1"
        }
      ],
      "skos:definition": {
        "@value": "vector whose component in direction of an area normal is given by:\n\n[stem%unnumbered]\n++++\nbb(ii(J))_n = int ii(Phi)_(ii(Omega)) (theta,alpha) \"cos\" (ii(theta)) \"d\"ii(Omega)\n++++\n\nwhere\n\nstem:[ii(Phi)_(ii(Omega)) (ii(theta),alpha)]:: is the directional distribution of the particle fluence rate (<<t10-44>>), and\nstem:[ii(theta)] and stem:[alpha]:: are polar and azimuthal angles, respectively\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Usually the word \"particle\" is replaced by the name of a specific particle, for example proton current.\n\nSymbol stem:[bb(ii(S))] is recommended when there is a possibility of confusion with the symbol stem:[bb(ii(J))] for electric current density. For neutron current, the symbol stem:[bb(ii(J))] is generally used. The distribution functions expressed in terms of speed and energy, stem:[bb(ii(J))_nu] and stem:[bb(ii(J))_\"E\"], are related to stem:[bb(ii(J))] by:\n\n[stem%unnumbered]\n++++\nbb(ii(J)) = int bb(ii(J))_nu \"d\"nu = int bb(ii(J))_\"E\" \"d\"E.\n++++\n\nThe directional distribution of the particle fluence rate is also denoted as particle radiance.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^(-2)*s^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-49-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "linear attenuation coefficient <ionizing radiation>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-49-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "mu",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-49-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "mu_l",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-49",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-49",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-49-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-49-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-49-1"
        }
      ],
      "skos:definition": {
        "@value": "for uncharged particles of a given type and energy the differential quotient stem:[n] with respect to stem:[l], where stem:[n] is the fraction of stem:[N] incoming particles that experience interactions in traversing a distance (<<iso80000-3>>) stem:[l] in a given material:\n\n[stem%unnumbered]\n++++\nmu = (\"d\"n)/(\"d\"l) = 1/N (\"d\"N)/(\"d\"l)\n++++\n\nwhere stem:[\"d\"N] is the number of particles that experience interactions in traversing stem:[\"d\"l]\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[mu] is equal to the macroscopic total cross section stem:[ii(Sigma)_\"tot\"] for the removal of particles from the beam.\n\nUsing the relation stem:[mu_m = mu//rho] between the linear attenuation coefficient stem:[mu], the mass attenuation coefficient stem:[mu_m] (<<t10-50>>) and the density stem:[rho], the definition given for the mass attenuation coefficient in report 85a of the ICRU can be applied to the linear attenuation coefficient resulting in:\n\nThe linear attenuation coefficient, stem:[mu], of a material, for uncharged particles of a given type and energy, is the quotient of stem:[\"d\"N//N] by stem:[\"d\"l], where stem:[\"d\"N//N] is the mean fraction of the particles that experience interactions in traversing a distance stem:[\"d\"l] in the material:\n\n[stem%unnumbered]\n++++\nmu = 1/(\"d\"l) (\"d\"N)/N.\n++++\n\nThis definition has an equivalent meaning as the one given in column 4 of this item.\n\nSee also <<cls-0.3>>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-50-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "mass attenuation coefficient <ionizing radiation>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-50-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "mu_m",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-50",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-50",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-50-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-50-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the linear attenuation coefficient stem:[mu] (<<t10-49>>) and the mass density stem:[rho] (<<iso80000-4>>) of the medium:\n\n[stem%unnumbered]\n++++\nmu_m = mu//rho\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-kg^(-1)*m^2"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-51-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "molar attenuation coefficient",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-51-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "mu_c",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-51",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-51",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-51-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-51-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of linear attenuation coefficient stem:[mu] (<<t10-49>>) and the amount stem:[c] (<<iso80000-9>>) of the medium:\n\n[stem%unnumbered]\n++++\nmu_c = mu//c\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^2*mol^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-52-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "atomic attenuation coefficient",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-52-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "mu_\"a\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-52",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-52",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-52-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-52-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the linear attenuation coefficient stem:[mu] (<<t10-49>>) and the number density (<<t10-62.1>>), stem:[n], of atoms in the substance:\n\n[stem%unnumbered]\n++++\nmu_\"a\" = mu//n\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[mu] is equal to the total cross section stem:[sigma_\"tot\"] for the removal of particles from the beam.\n\nSee also <<t10-38.2>>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^2"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-53-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "half-value thickness",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-53-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "d_(1//2)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-53",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-53",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-53-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-53-0"
        }
      ],
      "skos:definition": {
        "@value": "thickness (<<iso80000-3>>) of the attenuating layer that reduces the quantity of interest of a unidirectional beam of infinitesimal width to half of its initial value",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For exponential attenuation, stem:[d_(1//2) = \"ln\"(2)//mu]. The quantity of interest is often the air kerma or exposure.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-54-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "total linear stopping power",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-54-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "linear stopping power",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-54-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "S",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-54-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "S_l",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-54",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-54",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-54-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-54-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-54-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-54-1"
        }
      ],
      "skos:definition": {
        "@value": "for charged particles of a given type and energy stem:[E_0] the differential quotient of stem:[E] with respect to stem:[x], where stem:[E] is the mean energy (<<iso80000-4>>) lost by the charged particles in traversing a distance (<<iso80000-3>>) stem:[x] in the given material:\n\n[stem%unnumbered]\n++++\nS = -(\"d\"E)/(\"d\"x)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The total linear stopping power is sometimes also called stopping power.\n\nBoth electronic losses and radiative losses are included.\n\nThe quotient of the total linear stopping power of a substance and that of a reference substance is called the relative linear stopping power.\n\nSee also <<t10-85>>.\n\nUsing the relation stem:[S_m = S//rho] between the total mass stopping power stem:[S_m] (<<t10-55>>), the total linear stopping power stem:[S], and the density stem:[rho], the definition given for the mass stopping in report 85a of the ICRU can be applied to that of the total linear stopping power resulting in:\n\nThe linear stopping power, stem:[S], of a material, for charged particles of a given type and energy, is the quotient of stem:[\"d\"E] by stem:[\"d\"l], where stem:[\"d\"E] is the mean energy lost by the charged particles in traversing a distance stem:[\"d\"l] in the material:\n\n[stem%unnumbered]\n++++\nS = -(\"d\"E)/(\"d\"x)\n++++\n\nThis definition has an equivalent meaning as the one given in column 4 of this item.\n\nSee also <<cls-0.3>>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-eV/m"
        },
        {
          "@id": "isoiec80000:unit-J/m"
        },
        {
          "@id": "isoiec80000:unit-kg*m*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-55-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "total mass stopping power",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-55-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "mass stopping power",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-55-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "S_m",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-55",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-55",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-55-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-55-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-55-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the total linear stopping power stem:[S] (<<t10-54>>) and the mass density stem:[rho] (<<iso80000-4>>) of the material:\n\n[stem%unnumbered]\n++++\nS_m = S//rho\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The quotient of total mass stopping power of a material and that of a reference material is called relative mass stopping power.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-eV*m^(-2)/kg"
        },
        {
          "@id": "isoiec80000:unit-J*m^2/kg"
        },
        {
          "@id": "isoiec80000:unit-m^4*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-56-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "mean linear range",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-56-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "R",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-56-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "R_l",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-56",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-56",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-56-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-56-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-56-1"
        }
      ],
      "skos:definition": {
        "@value": "mean total rectified path length (<<iso80000-3>>) travelled by a particle in the course of slowing down to rest in a given material averaged over a group of particles having the same initial energy (<<iso80000-5>>)",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-57-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "mean mass range",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-57-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "R_rho",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-57-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "R_m",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-57",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-57",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-57-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-57-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-57-1"
        }
      ],
      "skos:definition": {
        "@value": "product of the mean linear range (<<t10-56>>) stem:[R] and the mass density stem:[rho] (<<iso80000-4>>) of the material:\n\n[stem%unnumbered]\n++++\nR_rho = R rho\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-kg*m^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-58-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "linear ionization",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-58-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "N_(\"i\"l)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-58",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-58",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-58-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-58-0"
        }
      ],
      "skos:definition": {
        "@value": "differential quotient of stem:[q] with respect to stem:[l], where stem:[q] is the average total charge (<<iec80000-6>>) of all positive ions produced by an ionizing charged particle over a path stem:[l] (<<iso80000-3>>), divided by the elementary charge, stem:[e] (<<iso80000-1>>):\n\n[stem%unnumbered]\n++++\nN_(\"i\"l) = 1/e (\"d\"q)/(\"d\"l)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Ionization due to secondary ionizing particles is included.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-59-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "total ionization",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-59-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "N_\"i\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-59",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-59",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-59-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-59-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the total mean charge of all positive ions produced by an ionizing charged particle along its entire path and along the paths of any secondary charged particles, and the elementary charge, stem:[e] (<<iso80000-1>>)",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[stem%unnumbered]\n++++\nN_\"i\" = int N_(\"i\"l) \"d\"l\n++++\n\nSee <<t10-58>>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-60-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "average energy loss per elementary charge produced",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-60-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "W_\"i\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-60",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-60",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-60-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-60-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the initial kinetic energy stem:[E_\"k\"] (<<iso80000-4>>) of an ionizing charged particle and the total ionization stem:[N_\"i\"] (<<t10-59>>) produced by that particle:\n\n[stem%unnumbered]\n++++\nW_\"i\" = E_\"k\"//N_\"i\"\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The name \"average energy loss per ion pair formed\" is usually used, although it is ambiguous.\n\nIn the practical dosimetry of ionizing radiation the term stem:[W//e], the quotient of stem:[W], the average energy deposited in dry air per ion pair formed, and stem:[e], the elementary charge, is used as the factor which, when multiplied with the electric charge of one sign carried by all ion pairs formed in dry air of given mass, gives the energy deposited in this amount of dry air in the form of excitations and ionizations.\n\nIn ICRU Report 85a, the mean energy expended in a gas per ion pair formed, stem:[W], is the quotient of stem:[E] by stem:[N], where stem:[N] is the mean total liberated charge of either sign, divided by the elementary charge when the initial kinetic energy stem:[E] of a charged particle introduced into the gas is completely dissipated in the gas. Thus, stem:[W = E//N]. It follows from the definition of stem:[W] that the ions produced by bremsstrahlung or other secondary radiation emitted by the initial and secondary charged particles are included in stem:[N].\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-eV"
        },
        {
          "@id": "isoiec80000:unit-J"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
