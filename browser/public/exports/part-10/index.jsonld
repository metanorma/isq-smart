          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-1.3-0"
        }
      ],
      "skos:definition": {
        "@value": "number of nucleons in an atomic nucleus",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[stem%unnumbered]\n++++\nA = Z + N\n++++\n\nNuclides with the same value of stem:[A] are called isobars.\n",
        "@language": "en"
      },
