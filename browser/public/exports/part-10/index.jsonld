      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-61",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-61",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-61-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-61-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-61-1"
        }
      ],
      "skos:definition": {
        "@value": "quotient of average drift speed (<<iso80000-3>>) imparted to a charged particle in a medium by an electric field, and the electric field strength (<<iec80000-6>>)",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^2/(V*s)"
        },
        {
          "@id": "isoiec80000:unit-kg^(-1)*s^2*A"
        }
      ],
