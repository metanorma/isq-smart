      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-66",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-66",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-66-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-66-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the mean rate of production of particles in a volume, and that volume (<<iso80000-3>>)",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The word \"particle\" is usually replaced by the name of a specific particle, for example _proton_ source density.\n\nThe distribution functions expressed in terms of speed and energy, stem:[S_nu] and stem:[S_E], are related to stem:[S] by:\n\n[stem%unnumbered]\n++++\nS = int S_nu \"d\"nu = int S_E \"d\"E.\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^(-3)*s^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
