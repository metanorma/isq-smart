    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-69",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-69",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-69-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-69-0"
        }
      ],
      "skos:definition": {
        "@value": "for a neutron of kinetic energy stem:[E] (<<iso80000-4>>):\n\n[stem%unnumbered]\n++++\nu = \"ln\"(E_0//E),\n++++\n\nwhere stem:[E_0] is a reference energy\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Lethargy is also referred to as logarithmic energy decrement.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
