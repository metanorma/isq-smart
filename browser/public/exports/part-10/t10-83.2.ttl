isoiec80000:term-t10-83.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "dose equivalent rate"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t10-83.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "dot H"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t10-83.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "10-83.2" ;
  skosxl:prefLabel isoiec80000:term-t10-83.2-0 ;
  skosxl:altLabel isoiec80000:sym-t10-83.2-0 ;
  skos:definition """differential quotient of dose equivalent stem:[H] (<<t10-83.1>>) with respect to time (<<iso80000-3>>):

[stem%unnumbered]
++++
dot H = (\"d\"H)/(\"d\"t)
++++
"""@en ;
  skos:note """[stem%unnumbered]
++++
1 \"unitsml(Sv/s)\" = 1 \"unitsml(W/kg)\"
++++

See the remarks for <<t10-83.1>>.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Sv/s ;
  isoiec80000:hasUnit isoiec80000:unit-W/kg ;
  isoiec80000:hasUnit isoiec80000:unit-m^2*s^(-3) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-10 .