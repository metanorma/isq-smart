      ],
      "skosxl:literalForm": {
        "@value": "absorbed-dose rate",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-84-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
