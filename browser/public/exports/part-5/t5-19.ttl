isoiec80000:term-t5-19-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "specific entropy"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t5-19-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "s"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t5-19 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "5-19" ;
  skosxl:prefLabel isoiec80000:term-t5-19-0 ;
  skosxl:altLabel isoiec80000:sym-t5-19-0 ;
  skos:definition """quotient of entropy and mass:

[stem%unnumbered]
++++
s = S/m
++++

where stem:[S] is entropy (<<t5-18>>) and stem:[m] is mass (<<iso80000-4>>)
"""@en ;
  skos:note """For the corresponding quantity related to amount of substance, see <<iso80000-9>>."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-J/(kg*K) ;
  isoiec80000:hasUnit isoiec80000:unit-m^2*s^(-2)*K^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-5 .