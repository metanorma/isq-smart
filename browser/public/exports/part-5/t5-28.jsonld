      ],
      "skos:definition": {
        "@value": "quotient of mass of water vapour and a specified volume:\n\n[stem%unnumbered]\n++++\nsf(ii(v)) = m/V\n++++\n\nwhere stem:[m] is mass (<<iso80000-4>>) of water vapour and stem:[V] is volume (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Mass concentration of water vapour at saturation is denoted stem:[sf(ii(v))_\"sat\"].",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-kg*m^(-3)"
        }
      ],
