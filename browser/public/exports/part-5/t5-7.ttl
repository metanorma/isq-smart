isoiec80000:term-t5-7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "heat flow rate"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t5-7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "dot Q"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t5-7 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "5-7" ;
  skosxl:prefLabel isoiec80000:term-t5-7-0 ;
  skosxl:altLabel isoiec80000:sym-t5-7-0 ;
  skos:definition """time rate at which heat (<<t5-6.1>>) crosses a given surface"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-W ;
  isoiec80000:hasUnit isoiec80000:unit-J/s ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^2*s^(-3) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-5 .