isoiec80000:term-t5-4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "pressure coefficient"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t5-4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "beta"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t5-4 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "5-4" ;
  skosxl:prefLabel isoiec80000:term-t5-4-0 ;
  skosxl:altLabel isoiec80000:sym-t5-4-0 ;
  skos:definition """change of pressure with temperature at constant volume:

[stem%unnumbered]
++++
beta = ((del p)/(del T))_V
++++

where stem:[p] is pressure (<<iso80000-4>>), stem:[T] is thermodynamic temperature (<<t5-1>>), and stem:[V] is volume (<<iso80000-3>>)
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Pa/K ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^(-1)*s^(-2)*K^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-5 .