isoiec80000:term-t5-34-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "relative mass concentration of vapour"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t5-34-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "varphi"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t5-34 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "5-34" ;
  skosxl:prefLabel isoiec80000:term-t5-34-0 ;
  skosxl:altLabel isoiec80000:sym-t5-34-0 ;
  skos:definition """quotient of mass concentration of water vapour and mass concentration at its saturation:

[stem%unnumbered]
++++
varphi = sf(ii(v))/sf(ii(v))_\"sat\"
++++

where stem:[sf(ii(v))] is mass concentration of water vapour (<<t5-28>>) and stem:[sf(ii(v))_\"sat\"] is its mass concentration of water vapour at saturation of the same temperature
"""@en ;
  skos:note """For water vapour concentrations up to stem:[1 \"unitsml(kg/m^3)\"], the relative humidity (<<t5-33>>) is assumed to be equal to relative mass concentration of vapour. For details see <<lovell>>."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-5 .