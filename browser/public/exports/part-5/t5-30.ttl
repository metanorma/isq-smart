isoiec80000:term-t5-30-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "mass ratio of water vapour to dry gas"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t5-30-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "r"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t5-30-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "(x)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t5-30 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "5-30" ;
  skosxl:prefLabel isoiec80000:term-t5-30-0 ;
  skosxl:altLabel isoiec80000:sym-t5-30-0 ;
  skosxl:altLabel isoiec80000:sym-t5-30-1 ;
  skos:definition """quotient of mass of water vapour and mass of dry gas:

[stem%unnumbered]
++++
r = m/m_\"d\"
++++

where stem:[m] is mass (<<iso80000-4>>) of water vapour and stem:[m_\"d\"] is mass of dry gas
"""@en ;
  skos:note """Mass ratio of water vapour to dry gas at saturation is denoted stem:[r_\"sat\"].

Mass ratio of water vapour to dry gas is also called mixing ratio.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-5 .