isoiec80000:term-t5-22-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Massieu function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t5-22-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "J"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t5-22 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "5-22" ;
  skosxl:prefLabel isoiec80000:term-t5-22-0 ;
  skosxl:altLabel isoiec80000:sym-t5-22-0 ;
  skos:definition """quotient of the negative of Helmholtz energy and temperature:

[stem%unnumbered]
++++
J = -A/T
++++

where stem:[A] is Helmholtz energy (<<t5-20.4>>) and stem:[T] is thermodynamic temperature (<<t5-1>>)
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-J/K ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^2*s^(-2)*K^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-5 .