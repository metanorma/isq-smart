      ],
      "skosxl:literalForm": {
        "@value": "internal energy",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t5-20.2-1",
      "@type": [
