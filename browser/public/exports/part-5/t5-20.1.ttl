isoiec80000:term-t5-20.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "energy <thermodynamics>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t5-20.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "E"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t5-20.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "5-20.1" ;
  skosxl:prefLabel isoiec80000:term-t5-20.1-0 ;
  skosxl:altLabel isoiec80000:sym-t5-20.1-0 ;
  skos:definition """ability of a system to do work (<<iso80000-4>>)"""@en ;
  skos:note """Energy exists in different forms that are mutually transformable into each other, either totally or partially. In contrast to internal energy (<<t5-20.2>>), energy is not a state function."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-J ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^2*s^(-2) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-5 .