isoiec80000:term-t5-12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "thermal resistance"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t5-12-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "R"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t5-12 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "5-12" ;
  skosxl:prefLabel isoiec80000:term-t5-12-0 ;
  skosxl:altLabel isoiec80000:sym-t5-12-0 ;
  skos:definition """quotient of thermodynamic temperature (<<t5-1>>) difference and heat flow rate (<<t5-7>>)"""@en ;
  skos:note """See remark to <<t5-11>>."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-K/W ;
  isoiec80000:hasUnit isoiec80000:unit-kg^(-1)*m^(-2)*s^3*K ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-5 .