      "skos:definition": {
        "@value": "inverse of thermal resistance stem:[R]:\n\n[stem%unnumbered]\n++++\nG = 1/R\n++++\n\nwhere stem:[R] is thermal resistance (<<t5-12>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "See remark to <<t5-11>>. This quantity is also called heat transfer coefficient. See <<t5-10.1>>.",
        "@language": "en"
      },
