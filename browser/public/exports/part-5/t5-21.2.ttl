isoiec80000:term-t5-21.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "specific internal energy"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t5-21.2-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "specific thermodynamic energy"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t5-21.2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "u"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t5-21.2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "5-21.2" ;
  skosxl:prefLabel isoiec80000:term-t5-21.2-0 ;
  skosxl:altLabel isoiec80000:term-t5-21.2-1 ;
  skosxl:altLabel isoiec80000:sym-t5-21.2-0 ;
  skos:definition """quotient of internal energy and mass:

[stem%unnumbered]
++++
u = U/m
++++

where stem:[U] is internal energy (<<t5-20.2>>) and stem:[m] is mass (<<iso80000-4>>)
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-J/kg ;
  isoiec80000:hasUnit isoiec80000:unit-m^2*s^(-2) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-5 .