      "skos:definition": {
        "@value": "temperature at which water vapour in the air reaches saturation under isobaric conditions",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The corresponding Celsius temperature, denoted stem:[t_\"d\"], is still called dew-point temperature.\n\nThe unit for the corresponding Celsius temperature is degree Celsius, symbol stem:[\"unitsml(degC)\"].\n",
        "@language": "en"
      },
