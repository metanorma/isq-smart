      "skos:definition": {
        "@value": "sum of internal energy of the system and the product of pressure and volume of the system:\n\n[stem%unnumbered]\n++++\nH = U + pV\n++++\n\nwhere stem:[U] is internal energy (<<t5-20.2>>), stem:[p] is pressure (<<iso80000-4>>), and stem:[V] is volume (<<iso80000-3>>)\n",
        "@language": "en"
      },
