isoiec80000:term-t5-3.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "linear expansion coefficient"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t5-3.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "alpha_l"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t5-3.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "5-3.1" ;
  skosxl:prefLabel isoiec80000:term-t5-3.1-0 ;
  skosxl:altLabel isoiec80000:sym-t5-3.1-0 ;
  skos:definition """relative change of length with temperature:

[stem%unnumbered]
++++
alpha_l = 1/l (\"d\"l)/(\"d\"T)
++++

where stem:[l] is length (<<iso80000-3>>) and stem:[T] is thermodynamic temperature (<<t5-1>>)
"""@en ;
  skos:note """The subscripts in the symbols may be omitted when there is no risk of confusion."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-K^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-5 .