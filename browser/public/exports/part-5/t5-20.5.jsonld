    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t5-20.5",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "5-20.5",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t5-20.5-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t5-20.5-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t5-20.5-0"
        }
      ],
      "skos:definition": {
        "@value": "difference of the enthalpy and the product of thermodynamic temperature and entropy of the system:\n\n[stem%unnumbered]\n++++\nG = H - TS\n++++\n\nwhere stem:[H] is enthalpy (<<t5-20.3>>), stem:[T] is thermodynamic temperature (<<t5-1>>), and stem:[S] is entropy (<<t5-18>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The name Gibbs free energy is also used. However, this term is not recommended.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-J"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-5"
      }
    }
  ]
