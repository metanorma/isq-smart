      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t5-11",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "5-11",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t5-11-0"
      },
