        }
      ],
      "skos:definition": {
        "@value": "quotient of internal energy and mass:\n\n[stem%unnumbered]\n++++\nu = U/m\n++++\n\nwhere stem:[U] is internal energy (<<t5-20.2>>) and stem:[m] is mass (<<iso80000-4>>)\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
