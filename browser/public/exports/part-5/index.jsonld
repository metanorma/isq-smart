          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t5-11-0"
        }
      ],
      "skos:definition": {
        "@value": "inverse of coefficient of heat transfer stem:[K]:\n\n[stem%unnumbered]\n++++\nM = 1/K\n++++\n\nwhere stem:[K] is coefficient of heat transfer (<<t5-10.1>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "In building technology, this quantity is often called thermal resistance, with the symbol stem:[R].",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^2*K/W"
        },
        {
          "@id": "isoiec80000:unit-kg^(-1)*s^3*K"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
