      ],
      "skos:definition": {
        "@value": "quotient of enthalpy and mass:\n\n[stem%unnumbered]\n++++\nh = H/m\n++++\n\nwhere stem:[H] is enthalpy (<<t5-20.3>>) and stem:[m] is mass (<<iso80000-4>>)\n",
        "@language": "en"
