        "@value": "dot Q",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t5-7",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "5-7",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t5-7-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t5-7-0"
        }
      ],
      "skos:definition": {
        "@value": "time rate at which heat (<<t5-6.1>>) crosses a given surface",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-W"
        },
        {
          "@id": "isoiec80000:unit-J/s"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-3)"
        }
      ],
      "smart:hasBindingnessType": {
