        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "(k)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t5-10.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "5-10.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t5-10.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t5-10.1-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t5-10.1-1"
        }
      ],
      "skos:definition": {
        "@value": "quotient of density of heat flow rate (<<t5-8>>) and thermodynamic temperature (<<t5-1>>) difference",
        "@language": "en"
      },
      "skos:note": {
        "@value": "In building technology, the coefficient of heat transfer is often called thermal transmittance, with the symbol stem:[U] (no longer recommended). See remark to <<t5-13>>.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-W/(m^2*K)"
        },
        {
          "@id": "isoiec80000:unit-kg*s^(-3)*K^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-5"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t5-10.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
