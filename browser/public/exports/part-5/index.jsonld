          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t5-5.2-0"
        }
      ],
      "skos:definition": {
        "@value": "negative relative change of volume with pressure at constant entropy:\n\n[stem%unnumbered]\n++++\nkappa_S = -1/V ((del V)/(del p))_S\n++++\n\nwhere stem:[V] is volume (<<iso80000-3>>), stem:[p] is pressure (<<iso80000-4>>), and stem:[S] is entropy (<<t5-18>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The subscripts in the symbols may be omitted when there is no risk of confusion.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Pa^(-1)"
        },
        {
          "@id": "isoiec80000:unit-kg^(-1)*m*s^2"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-5"
      }
