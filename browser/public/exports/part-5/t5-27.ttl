isoiec80000:term-t5-27-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "mass concentration of water"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t5-27-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "w"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t5-27 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "5-27" ;
  skosxl:prefLabel isoiec80000:term-t5-27-0 ;
  skosxl:altLabel isoiec80000:sym-t5-27-0 ;
  skos:definition """quotient of mass of water and a specified volume:

[stem%unnumbered]
++++
w = m/V
++++

where stem:[m] is mass (<<iso80000-4>>) of water, irrespective of the form of aggregation state, and stem:[V] is volume (<<iso80000-3>>)
"""@en ;
  skos:note """Mass concentration of water at saturation is denoted stem:[w_\"sat\"]."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^(-3) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-5 .