isoiec80000:term-t5-9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "thermal conductivity"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t5-9-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "lambda"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t5-9-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "(kappa)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t5-9 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "5-9" ;
  skosxl:prefLabel isoiec80000:term-t5-9-0 ;
  skosxl:altLabel isoiec80000:sym-t5-9-0 ;
  skosxl:altLabel isoiec80000:sym-t5-9-1 ;
  skos:definition """quotient of density of heat flow rate (<<t5-8>>) and thermodynamic temperature gradient that has the same direction as the heat flow"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-W/(m*K) ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m*s^(-3)*K^(-1) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-5 .