isoiec80000:term-t5-25.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "efficiency <thermodynamics>"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t5-25.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "eta"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t5-25.1 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "5-25.1" ;
  skosxl:prefLabel isoiec80000:term-t5-25.1-0 ;
  skosxl:altLabel isoiec80000:sym-t5-25.1-0 ;
  skos:definition """quotient of work (<<iso80000-4>>) delivered by a heat engine and supplied heat:

[stem%unnumbered]
++++
eta=W/Q
++++

where stem:[W] is work (<<iso80000-4>>) and stem:[Q] is heat (<<t5-6.1>>)
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-5 .