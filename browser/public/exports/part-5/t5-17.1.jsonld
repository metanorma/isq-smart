      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "ratio of specific heat capacities",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t5-17.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "gamma",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t5-17.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "5-17.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t5-17.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t5-17.1-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of specific heat capacity at constant pressure and specific heat capacity at constant volume:\n\n[stem%unnumbered]\n++++\ngamma = c_p/c_V\n++++\n\nwhere stem:[c_p] is specific heat capacity at constant pressure (<<t5-16.2>>) and stem:[c_V] is specific heat capacity at constant volume (<<t5-16.3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "This quantity can also be expressed by\n\n[stem%unnumbered]\n++++\ngamma = C_p/C_V\n++++\n\nwhere stem:[C_p] is heat capacity at constant pressure and stem:[C_V] is heat capacity at constant volume.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-5"
      }
    }
  ]
