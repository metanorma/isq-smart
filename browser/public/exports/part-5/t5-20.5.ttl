isoiec80000:term-t5-20.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Gibbs energy"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t5-20.5-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Gibbs function"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t5-20.5-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "G"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t5-20.5 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "5-20.5" ;
  skosxl:prefLabel isoiec80000:term-t5-20.5-0 ;
  skosxl:altLabel isoiec80000:term-t5-20.5-1 ;
  skosxl:altLabel isoiec80000:sym-t5-20.5-0 ;
  skos:definition """difference of the enthalpy and the product of thermodynamic temperature and entropy of the system:

[stem%unnumbered]
++++
G = H - TS
++++

where stem:[H] is enthalpy (<<t5-20.3>>), stem:[T] is thermodynamic temperature (<<t5-1>>), and stem:[S] is entropy (<<t5-18>>)
"""@en ;
  skos:note """The name Gibbs free energy is also used. However, this term is not recommended."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-J ;
  isoiec80000:hasUnit isoiec80000:unit-kg*m^2*s^(-2) ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-5 .