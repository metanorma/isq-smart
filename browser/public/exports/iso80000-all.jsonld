      "skos:definition": {
        "@value": "linear extent in space between any two points",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Length does not need to be measured along a straight line.\n\nLength is one of the seven base quantities in the International System of Units (<<iso80000-1>>).\n",
        "@language": "en"
