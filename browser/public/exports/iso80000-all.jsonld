        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t5-8-1"
        }
      ],
      "skos:definition": {
        "@value": "quotient of heat flow rate and area:\n\n[stem%unnumbered]\n++++\nq = (dot Q)/A\n++++\n\nwhere stem:[dot Q] is heat flow rate (<<t5-7>>) and stem:[A] is area (<<iso80000-3>>) of a given surface\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-W/m^2"
        },
        {
          "@id": "isoiec80000:unit-kg*s^(-3)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
