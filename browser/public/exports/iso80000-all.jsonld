        }
      ],
      "skos:definition": {
        "@value": "quotient of density of heat flow rate (<<t5-8>>) and thermodynamic temperature gradient that has the same direction as the heat flow",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-W/(m*K)"
