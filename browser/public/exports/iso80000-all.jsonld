      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t13-2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "13-2",
