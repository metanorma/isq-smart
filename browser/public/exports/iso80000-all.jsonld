      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t13-13",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "13-13",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t13-13-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-13-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-13-1"
        }
      ],
      "skos:definition": {
        "@value": "transfer rate (<<t13-11,item 13-11>>) where the data elements are binary digits",
        "@language": "en"
      },
      "skos:note": {
        "@value": "In English, the systematic name would be \"transfer\nrate for binary digits\".\n\nThe bit per second may be combined with prefixes,\nfor example megabit per second, symbol Mbit/s.\n\nSee <<iec60050-704,droploc%locality:item=\"704-16-07\">>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-s^{-1}"
        },
        {
          "@id": "isoiec80000:unit-bit/s"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
