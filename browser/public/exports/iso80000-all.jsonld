      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t4-9.5",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "4-9.5",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t4-9.5-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t4-9.5-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t4-9.5-2"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t4-9.5-0"
        }
      ],
      "skos:definition": {
        "@value": "force (<<t4-9.1>>) resisting the motion when a body rolls on a surface",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For the rolling resistance factor, see <<t4-23.3>>.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-N"
        },
        {
          "@id": "isoiec80000:unit-kg*m*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
