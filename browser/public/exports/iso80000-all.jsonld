        }
      ],
      "skos:definition": {
        "@value": "stem:[\"e\"] to the power of stem:[x], +\nexponential function to the base stem:[\"e\"] of argument stem:[x]\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "See <<t2-15.5>>.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
