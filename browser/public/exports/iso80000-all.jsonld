        }
      ],
      "skos:definition": {
        "@value": "for quantum level, statistical weight of that level",
        "@language": "en"
      },
      "skos:note": {
        "@value": "If stem:[g = 1], the level is called non-degenerate.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
