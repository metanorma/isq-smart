        }
      ],
      "skos:definition": {
        "@value": "[stem%unnumbered]\n++++\nii(T)_\"b\" = 1//r_\"b\"\n++++\n\nwhere stem:[r_\"b\"] is the binary digit rate (<<t13-13>>) when the binary digits are transmitted in series\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-s"
        }
      ],
      "smart:hasBindingnessType": {
