        }
      ],
      "skos:definition": {
        "@value": "minimum length of a straight line segment between a point and a reference line or reference surface",
        "@language": "en"
      },
      "skos:note": {
        "@value": "This quantity is usually signed. The sign expresses the position of the particular point with respect to the reference line or surface and is chosen by convention.\n\nThe symbol stem:[H] is often used to denote altitude, i.e. height above sea level.\n",
        "@language": "en"
      },
