      "skos:definition": {
        "@value": "geometrical characteristic of a shape of a body equal to:\n\nstem:[I_\"p\" = &#8748;_\"M\" r_\"Q\"^2 \"d\"A]\n\nwhere stem:[\"M\"] is the two-dimensional domain of the cross-section of a\nplane and considered body, stem:[r_\"Q\"] is radial distance (<<iso80000-3>>)\nfrom a stem:[\"Q\"]-axis perpendicular to the plane of the surface considered\nand stem:[A] is area (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "This quantity is often referred to wrongly as \"moment of inertia\" (<<t4-7>>).\n\nThe subscript, stem:[p], may be omitted when there is no risk of confusion.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^4"
        }
