    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t5-12.4",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "5-12.4",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t5-12.4-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t5-12.4-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t5-12.4-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t5-12.4-1"
        }
      ],
      "skos:definition": {
        "@value": "quotient of Helmholtz energy and mass:\n\n[stem%unnumbered]\n++++\na = A/m\n++++\n\nwhere stem:[A] is Helmholtz energy (<<t5-20.4>>) and stem:[m] is mass (<<iso80000-4>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The name specific Helmholtz free energy is also used. However, this term is not recommended.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-J/kg"
        },
        {
          "@id": "isoiec80000:unit-m^2*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
