        "smart:TermEntry"
      ],
      "dcterms:identifier": "13-14",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t13-14-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-14-0"
        }
      ],
      "skos:definition": {
        "@value": "stem:[T_{\"bit\"} = 1 // r_{\"bit\"}] where stem:[r_{\"bit\"}] is the binary digit\nrate (<<t13-13,item 13-13>>) when the binary digits are\ntransmitted in series\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "See <<iec60050-171,droploc%locality:item=\"171-06-06\">>.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-s"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-13"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t13-15-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "equivalent binary digit rate, equivalent bit rate",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
