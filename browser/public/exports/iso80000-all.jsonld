      "skos:definition": {
        "@value": "ratio of the circumference of a circle to its diameter",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[pi = 3.1415926...]",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
