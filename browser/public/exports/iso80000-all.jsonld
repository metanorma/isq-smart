        }
      ],
      "skos:definition": {
        "@value": "inverse of coefficient of heat transfer stem:[K]:\n\n[stem%unnumbered]\n++++\nM = 1/K\n++++\n\nwhere stem:[K] is coefficient of heat transfer (<<t5-10.1>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "In building technology, this quantity is often called thermal resistance, with the symbol stem:[R].",
        "@language": "en"
      },
