    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t4-20",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "4-20",
      "skosxl:prefLabel": {
