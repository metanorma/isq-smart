      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t4-20-0"
        }
      ],
      "skos:definition": {
        "@value": "negative relative change of volume stem:[V] (<<iso80000-3>>) of an object\nunder pressure stem:[p] (<<t4-14.1>>) expressed by:\n\nstem:[kappa= -1/V (\"d\"V)/(\"d\"p)]\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Conditions should be specified (e.g. isentropic or isothermal process).\n\nSee also <<iso80000-5>>.\n",
