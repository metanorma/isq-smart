        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t5-10.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "5-10.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t5-10.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t5-10.2-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t5-10.2-1"
        }
      ],
      "skos:definition": {
        "@value": "quotient of density of heat flow rate and the difference of the temperature at the surface and a reference temperature:\n\n[stem%unnumbered]\n++++\nh = q/((T_\"s\"-T_\"r\"))\n++++\n\nwhere stem:[q] is density of heat flow rate (<<t5-8>>), stem:[T_\"s\"] is the thermodynamic temperature (<<t5-1>>) at the surface, and stem:[T_\"r\"] is a reference thermodynamic temperature characterizing the adjacent surroundings\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-W/(m^2*K)"
        },
        {
          "@id": "isoiec80000:unit-kg*s^(-3)*K^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
