        }
      ],
      "skos:definition": {
        "@value": "time constant (<<iso80000-3>>) for recombination or trapping of minority charge carriers in semiconductors",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Indices \"stem:[\"n\"]\" and \"stem:[\"p\"]\" denote negative and positive charge carriers, respectively. Positive charge carriers can also be holes.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
