      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "thermodynamic critical magnetic flux density",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-36.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "B_\"c\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t12-36.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "12-36.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-36.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-36.1-0"
        }
      ],
      "skos:definition": {
        "@value": "quantity given by:\n\n[stem%unnumbered]\n++++\nB_\"c\" = sqrt((2mu_0(G_\"n\"-G_\"s\"))/V)\n++++\n\nwhere stem:[G_\"n\"] and stem:[G_\"s\"] are the Gibbs energies (<<iso80000-5>>) at zero magnetic flux density (<<iec80000-6>>) in a normal conductor and superconductor, respectively, stem:[mu_0] is the magnetic constant (<<iec80000-6>>), and stem:[V] is volume (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "In type I superconductors, stem:[B_\"c\"] is the critical magnetic flux density for disappearance of superconductivity. The symbol stem:[B_\"c3\"] is used for the critical magnetic flux density for disappearance of surface superconductivity.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-T"
        },
        {
          "@id": "isoiec80000:unit-kg*s^(-2)*A^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-12"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-36.2-0",
