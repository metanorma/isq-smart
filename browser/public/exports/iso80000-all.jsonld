      ],
      "skos:definition": {
        "@value": "decimal logarithm of stem:[x], +\ncommon logarithm of stem:[x]\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[\"lg \"x = \"log\"_(10) x]\n\nSee remark to <<t2-13.5>>.\n",
        "@language": "en"
      },
