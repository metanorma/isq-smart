        }
      ],
      "skos:definition": {
        "@value": "imaginary unit",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[\"i\"^2 = \"j\"^2 = -1]\n\nstem:[\"i\"] is used in mathematics and in physics,\n\nstem:[\"j\"] is used in electrotechnology.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
