      "skos:definition": {
        "@value": "natural logarithm of stem:[x]",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[\"ln \"x = \"log\"_e x]\n\nstem:[\"log \"x] shall not be used in place of stem:[\"ln \"x], stem:[\"lg \"x], stem:[\"lb \"x], or stem:[\"log\"_e x], stem:[log_(10) x], stem:[log_2 x].\n",
        "@language": "en"
      },
