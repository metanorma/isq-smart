    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-4.3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "unified atomic mass constant",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-4.3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "m_\"u\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-4.3",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-4.3",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-4.3-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-4.3-0"
        }
      ],
      "skos:definition": {
        "@value": "stem:[1//12] of the mass (<<iso80000-4>>) of an atom of the nuclide stem:[\"\"^(12)\"C\"] in the ground state at rest",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[1 \"unitsml(u)\"] is equal to stem:[1//12] times the mass of a free carbon 12 atom, at rest and in its ground state.\n\n[stem%unnumbered]\n++++\n1 \"unitsml(Da)\" = 1 \"unitsml(u)\"\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-kg"
        },
        {
          "@id": "isoiec80000:unit-u"
        },
        {
          "@id": "isoiec80000:unit-Da"
        }
      ],
      "smart:hasBindingnessType": {
