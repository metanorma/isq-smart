      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t13-22-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-22-0"
        }
      ],
      "skos:definition": {
        "@value": "frequency at which a clock oscillates",
        "@language": "en"
      },
