      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-36-0"
        }
      ],
      "skos:definition": {
        "@value": "stem:[ii(T)(x,y) = sum_(i=1)^n sum_(j=1)^m p(x_i,y_j)ii(T)(x_i,y_j)] for the sets\n\nstem:[ii(X) = {x_1, ..., x_n}], stem:[ii(Y) = {y_1, ..., y_m}],\n\nwhere stem:[p(x_i, y_j)] is the joint probability of events stem:[x_i] and stem:[y_j], and stem:[ii(T)(x_i, y_j)] is their transinformation content (<<t13-35>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "See <<iso2382-16,locality:item=\"16.04.08\">>.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
