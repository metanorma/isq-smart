      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-70-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-70-0"
        }
      ],
      "skos:definition": {
        "@value": "average value of the increase in lethargy (<<t10-69>>) in elastic collisions between neutrons and nuclei whose kinetic energy (<<iso80000-4>>) is negligible compared with that of the neutrons",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
