        }
      ],
      "skos:definition": {
        "@value": "stem:[a] is equal to stem:[b] +\nstem:[a] equals stem:[b]\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The symbol stem:[-=] may be used to emphasize that a particular equality is an identity, i.e. holds universally.\n\nBut see <<t2-8.18>> for another meaning.\n",
