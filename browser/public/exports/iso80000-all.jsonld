      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-78.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "multiplication factor",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-78.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "k",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-78.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-78.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-78.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-78.1-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the total number of fission or fission-dependent neutrons produced in the duration of a time interval and the total number of neutrons lost by absorption and leakage in that duration",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-78.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "infinite multiplication factor",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-78.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "k_(oo)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-78.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-78.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-78.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-78.2-0"
        }
      ],
      "skos:definition": {
        "@value": "multiplication factor (<<t10-78.1>>) for an infinite medium or for an infinite repeating lattice",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For a thermal reactor,\n\n[stem%unnumbered]\n++++\nk_(oo) = eta * epsilon * p * f\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-79-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "reactor time constant",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-79-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "T",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-79",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-79",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-79-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-79-0"
        }
      ],
      "skos:definition": {
        "@value": "duration (<<iso80000-3>>) required for the neutron fluence rate (<<t10-44>>) in a reactor to change by the factor stem:[\"e\"] when the fluence rate is rising or falling exponentially",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Also called reactor period.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-s"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-80.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "energy imparted",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-80.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "epsilon",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-80.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-80.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-80.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-80.1-0"
        }
      ],
      "skos:definition": {
        "@value": "sum of all energy deposits in a given volume:\n\n[stem%unnumbered]\n++++\nepsilon = sum_i epsilon_i\n++++\n\nwhere the summation is performed over all energy (<<iso80000-5>>) deposits stem:[epsilon_i] of interaction stem:[i] in that volume\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Energy imparted is a stochastic quantity.\n\nstem:[epsilon_i] is given by:\n\n[stem%unnumbered]\n++++\nepsilon_i = epsilon_\"in\" - epsilon_\"out\" + Q\n++++\n\nwhere stem:[epsilon_\"in\"] is the energy (<<iso80000-5>>) of the incident ionizing particle, excluding rest energy (<<t10-3>>), stem:[epsilon_\"out\"] is the sum of the energies (<<iso80000-5>>) of all ionizing particles leaving the interaction, excluding rest energy (<<t10-3>>), and stem:[Q] is the change in the rest energies (<<t10-3>>) of the nucleus and of all particles involved in the interaction.\n\nstem:[Q > 0] means decrease of rest energy;\n\nstem:[Q < 0] means increase of rest energy.\n\nStochastic quantities such as the energy imparted and the specific energy imparted (<<t10-81.2>>) and their probability distributions have been introduced as they describe the discontinuous nature of the ionizing radiations as a determinant of radiochemical and radiobiological effects. In radiation applications involving large numbers of ionizing particles, e.g. in medicine, radiation protection and materials testing and processing, these fluctuations are adequately represented by the expectation values of the probability distributions. Non-stochastic quantities such as particle fluence (<<t10-43>>), absorbed dose (<<t10-81.1>>) and kerma (<<t10-86.1>>) are based on these expectation values.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-eV"
        },
        {
          "@id": "isoiec80000:unit-J"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-80.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "mean energy imparted",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-80.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "bar epsilon",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-80.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-80.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-80.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-80.2-0"
        }
      ],
      "skos:definition": {
        "@value": "expectation value of the energy imparted (<<t10-80.1>>):\n\n[stem%unnumbered]\n++++\nbar epsilon = R_\"in\" - R_\"out\" + sum Q\n++++\n\nwhere\n\nstem:[R_\"in\"]:: is the radiant energy (<<t10-45>>) of all those charged and uncharged ionizing particles that enter the volume,\n\nstem:[R_\"out\"]:: is the radiant energy of all those charged and uncharged ionizing particles that leave the volume, and\n\nstem:[sum Q]:: is the sum of all changes of the rest energy (<<t10-3>>) of nuclei and elementary particles that occur in that volume\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Sometimes, it has been called the integral absorbed dose.\n\nstem:[Q > 0] means decrease of rest energy;\n\nstem:[Q < 0] means increase of rest energy.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-eV"
        },
        {
          "@id": "isoiec80000:unit-J"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-81.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "absorbed dose",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-81.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "D",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-81.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-81.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-81.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-81.1-0"
        }
      ],
      "skos:definition": {
        "@value": "differential quotient of stem:[bar epsilon] with respect to stem:[m], where stem:[bar epsilon] is the mean energy (<<iso80000-5>>) imparted by ionizing radiation to matter of mass (<<iso80000-4>>) stem:[m]:\n\n[stem%unnumbered]\n++++\nD = (\"d\"bar epsilon)/(\"d\"m)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The gray is a special name for joule per kilogram, to be used as the coherent SI unit for absorbed dose.\n\n[stem%unnumbered]\n++++\n1 \"unitsml(Gy)\" = 1 \"unitsml(J/kg)\"\n++++\n\n[stem%unnumbered]\n++++\nbar epsilon = int D \"d\"m\n++++\n\nwhere stem:[\"d\"m] is the element of mass of the irradiated matter.\n\nIn the limit of a small domain, the mean specific energy stem:[bar z = (ii(Delta)bar epsilon)/(ii(Delta)m)] is equal to the absorbed dose stem:[D].\n\nThe absorbed dose can also be expressed in terms of the volume of the mass element by:\n\n[stem%unnumbered]\n++++\nD = (\"d\"bar epsilon)/(\"d\"m) = (\"d\"bar epsilon)/(rho \"d\"V)\n++++\n\nwhere stem:[rho] is the mass density of the mass element.\n\nIn report 85a of the ICRU a definition with an equivalent meaning is given as:\n\nThe absorbed dose, stem:[D], is the quotient of stem:[\"d\"bar epsilon] by stem:[\"d\"m], where stem:[\"d\"bar epsilon] is the mean energy imparted by ionizing radiation to matter of mass stem:[\"d\"m]:\n\n[stem%unnumbered]\n++++\nD = (\"d\"bar epsilon)/(\"d\"m).\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Gy"
        },
        {
          "@id": "isoiec80000:unit-J/kg"
        },
        {
          "@id": "isoiec80000:unit-m^2*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-81.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "specific energy imparted",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-81.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "z",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-81.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-81.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-81.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-81.2-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the energy imparted stem:[epsilon] (<<t10-80.1>>) and the mass stem:[m] (<<iso80000-4>>) of the matter in a given volume element:\n\n[stem%unnumbered]\n++++\nz = epsilon/m\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[z] is a stochastic quantity.\n\nIn the limit of a small domain, the mean specific energy stem:[bar z] is equal to the absorbed dose stem:[D].\n\nThe specific energy imparted can be due to one or more (energy-deposition) events.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Gy"
        },
        {
          "@id": "isoiec80000:unit-J/kg"
        },
        {
          "@id": "isoiec80000:unit-m^2*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-82-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "quality factor <ionizing radiation>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-82-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Q",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-82",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-82",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-82-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-82-0"
        }
      ],
      "skos:definition": {
        "@value": "factor in the calculation and measurement of dose equivalent (<<t10-83.1>>), by which the absorbed dose (<<t10-81.1>>) is to be weighted in order to account for different biological effectiveness of radiations, for radiation protection purposes",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[Q] is determined by the linear energy transfer (<<t10-85>>) for stem:[ii(Delta)-> oo], stem:[L_(oo)] (often denoted as stem:[L] or stem:[\"LET\"]), of charged particles passing through a small volume element at this point (the value of stem:[L_(oo)] refers to water, not to tissue; the difference, however, is small). The relationship between stem:[L] and stem:[Q] is given in ICRP Publication 103 (ICRP, 2007).",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-83.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "dose equivalent",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-83.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "H",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-83.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-83.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-83.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-83.1-0"
        }
      ],
      "skos:definition": {
        "@value": "product of the absorbed dose stem:[D] (<<t10-81.1>>) to tissue at the point of interest and the quality factor stem:[Q] (<<t10-82>>) at that point:\n\n[stem%unnumbered]\n++++\nH = DQ\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The sievert (stem:[\"unitsml(Sv)\"]) is a special name for joule per kilogram, and is the coherent SI unit for dose equivalent.\n\n[stem%unnumbered]\n++++\n1 \"unitsml(Sv)\" = 1 \"unitsml(J/kg)\"\n++++\n\nThe dose equivalent at a point in tissue is given by:\n\n[stem%unnumbered]\n++++\nH = int_0^(oo) Q(L)D_L \"d\"L\n++++\n\nwhere stem:[D_L = \"d\"D//\"d\"L] is the distribution of stem:[D] in stem:[L] at the point of interest. See <<icrp>>.\n\nThe quantities measured with radiation protection dosimeters are based on the definition stem:[H = Q D]. If various radiation qualities stem:[i] have to be simultaneously accounted for, the definition is:\n\n[stem%unnumbered]\n++++\nH = sum_i Q_i D_i.\n++++\n\nIn ICRU 51 this quantity is denoted as \"dose equivalent\".\n\nIn order to quantify the radiation exposition of the human body and to specify dose limits, use is made of a quantity defined in ICRP 103, the \"equivalent dose to a tissue or organ\": stem:[H_\"T\" = w_\"T\" sum_\"R\" w_\"R\" D_\"T,R\"]. The weighting factors stem:[w_\"T\"] for various tissues and organs stem:[T] and stem:[w_\"R\"] for various radiation qualities stem:[\"R\"] have been numerically laid down in ICRP 103. stem:[D_\"T,R\"] is the mean absorbed dose to tissue within a tissue or organ stem:[\"T\"], imparted by radiation with radiation quality stem:[\"R\"].\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Sv"
        },
        {
          "@id": "isoiec80000:unit-J/kg"
        },
        {
          "@id": "isoiec80000:unit-m^2*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-83.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "dose equivalent rate",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-83.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "dot H",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-83.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-83.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-83.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-83.2-0"
        }
      ],
      "skos:definition": {
        "@value": "differential quotient of dose equivalent stem:[H] (<<t10-83.1>>) with respect to time (<<iso80000-3>>):\n\n[stem%unnumbered]\n++++\ndot H = (\"d\"H)/(\"d\"t)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[stem%unnumbered]\n++++\n1 \"unitsml(Sv/s)\" = 1 \"unitsml(W/kg)\"\n++++\n\nSee the remarks for <<t10-83.1>>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Sv/s"
        },
        {
          "@id": "isoiec80000:unit-W/kg"
        },
        {
          "@id": "isoiec80000:unit-m^2*s^(-3)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-84-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "absorbed-dose rate",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-84-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "dot D",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-84",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-84",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-84-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-84-0"
        }
      ],
      "skos:definition": {
        "@value": "differential quotient of the absorbed dose stem:[D] (<<t10-81.1>>) with respect to time (<<iso80000-3>>):\n\n[stem%unnumbered]\n++++\ndot D = (\"d\"D)/(\"d\"t)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[stem%unnumbered]\n++++\n1 \"unitsml(Gy/s)\" = 1 \"unitsml(W/kg)\"\n++++\n\nSee the remarks for <<t10-81.1>>.\n\nIn report 85a of the ICRU a definition with an equivalent meaning is given as:\n\nThe absorbed-does rate, stem:[dot D], is the quotient of stem:[\"d\"D] by stem:[\"d\"t], where stem:[\"d\"D] is the increment of absorbed does in the time interval stem:[\"d\"t]:\n\n[stem%unnumbered]\n++++\ndot D = (\"d\"D)/(\"d\"t).\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Gy/s"
        },
        {
          "@id": "isoiec80000:unit-W/kg"
        },
        {
          "@id": "isoiec80000:unit-m^2*s^(-3)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-85-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "linear energy transfer",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-85-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "L_(ii(Delta))",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-85",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-85",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-85-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-85-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the mean energy (<<iso80000-4>>) stem:[\"d\"E_(ii(Delta))] lost by the charged particles due to electronic interactions in traversing a distance (<<iso80000-3>>) stem:[\"d\"l], minus the mean sum of the kinetic energies in excess of stem:[ii(Delta)] of all the electrons released by the charged particles and stem:[\"d\"l]:\n\n[stem%unnumbered]\n++++\nL_(ii(Delta)) = (\"d\"E_(ii(Delta)))/(\"d\"l)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "This quantity is not completely defined unless stem:[ii(Delta)] is specified, i.e. the maximum kinetic energy of secondary electrons whose energy is considered to be \"locally deposited.\" stem:[ii(Delta)] may be expressed in stem:[\"unitsml(eV)\"].\n\nNote that the abbreviation LET specifically refers to the quantity stem:[L_(oo)] mentioned in the remark to <<t10-82>>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-eV/m"
        },
        {
          "@id": "isoiec80000:unit-J/m"
        },
        {
          "@id": "isoiec80000:unit-kg*m*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-86.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "kerma",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-86.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "K",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-86.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-86.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-86.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-86.1-0"
        }
      ],
      "skos:definition": {
        "@value": "for uncharged ionizing radiation, differential quotient of stem:[E_\"tr\"] with respect to stem:[m], where stem:[E_\"tr\"] is the mean sum of the initial kinetic energies (<<iso80000-4>>) of all the charged ionizing particles liberated in a mass (<<iso80000-4>>) stem:[m] of a material:\n\n[stem%unnumbered]\n++++\nK = (\"d\"E_(\"tr\"))/(\"d\"m)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[stem%unnumbered]\n++++\n1 \"unitsml(Gy)\" = 1 \"unitsml(J/kg)\"\n++++\n\nSee the remarks for <<t10-81.1>>.\n\nThe name \"kerma\" is derived from Kinetic Energy Released in MAtter (or MAss or MAterial).\n\nThe quantity stem:[\"d\"E_\"tr\"] includes also the kinetic energy of the charged particles emitted in the decay of excited atoms, molecules, or nuclei.\n\nWhen the mass element stem:[\"d\"m] consists of air the term air kerma is used. It can be convenient to refer to a value of air kerma in free space or at a point inside a material different from air, e.g. to the air kerma at a point inside a water phantom.\n\nIn report 85a of the ICRU a definition with an equivalent meaning is given as:\n\nThe kerma, stem:[K], for ionizing uncharged particles, is the quotient of stem:[\"d\"E_\"tr\"] by stem:[\"d\"m], where stem:[\"d\"E_\"tr\"] is the mean sum of the initial kinetic energies of all the charged particles liberated in a mass stem:[\"d\"m] of a material by the uncharged particles incident on stem:[\"d\"m]:\n\n[stem%unnumbered]\n++++\nK = (\"d\"E_\"tr\")/(\"d\"m).\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Gy"
        },
        {
          "@id": "isoiec80000:unit-J/kg"
        },
        {
          "@id": "isoiec80000:unit-m^2*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-86.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "kerma rate",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-86.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "dot K",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-86.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-86.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-86.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-86.2-0"
        }
      ],
      "skos:definition": {
        "@value": "differential quotient of kerma (<<t10-86.1>>) with respect to time (<<iso80000-3>>):\n\n[stem%unnumbered]\n++++\ndot K = (\"d\"K)/(\"d\"t)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[stem%unnumbered]\n++++\n1 \"unitsml(Gy/s)\" = 1 \"unitsml(W/kg)\"\n++++\n\nSee the Remarks for <<t10-81.1>>.\n\nIn report 85a of the ICRU a definition with an equivalent meaning is given as:\n\nThe kerma rate, stem:[dot K], is the quotient of stem:[\"d\"K] by stem:[\"d\"t], where stem:[\"d\"K] is the increment of kerma in the time interval stem:[\"d\"t]:\n\n[stem%unnumbered]\n++++\ndot K = (\"d\"K)/(\"d\"t).\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Gy/s"
        },
        {
          "@id": "isoiec80000:unit-W/kg"
        },
        {
          "@id": "isoiec80000:unit-m^2*s^(-3)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-87-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "mass energy-transfer coefficient",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-87-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "mu_\"tr\"//rho",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-87",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-87",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-87-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-87-0"
        }
      ],
      "skos:definition": {
        "@value": "for ionizing uncharged particles of a given type and energy, the differential quotient of stem:[R_\"tr\"] with respect to stem:[l]:\n\n[stem%unnumbered]\n++++\n(mu_\"tr\")/rho = 1/rho 1/R (\"d\"R_\"tr\")/(\"d\"l)\n++++\n\nwhere stem:[R_\"tr\"] is the mean energy (<<iso80000-5>>) that is transferred to kinetic energy (<<iso80000-4>>) of charged particles by interactions of the uncharged particles of incident radiant energy stem:[R] (<<t10-45>>) in traversing a distance (<<iso80000-3>>) stem:[l] in the material of density (<<iso80000-4>>) stem:[rho], divided by stem:[rho] and stem:[R]\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[mu_\"tr\"//rho = dot K//ii(Psi)], where stem:[dot K] is kerma rate (<<t10-86.2>>) and stem:[ii(Psi)] is energy fluence rate (<<t10-47>>).\n\nThe quantity:\n\n[stem%unnumbered]\n++++\nmu_\"en\"//rho = (mu_\"tr\"//rho)(1-g)\n++++\n\nwhere stem:[g] is mean fraction of the kinetic energy of the liberated charged particles that is lost in radiative processes in the material, is called mass energy-absorption coefficient.\n\nThe mass energy-absorption coefficient of a compound material depends on the stopping power of the material. Thus, its evaluation cannot, in principle, be reduced to a simple summation of the mass energy-absorption coefficient of the atomic constituents. Such a summation can provide an adequate approximation when the value of stem:[g] is sufficiently small.\n\nIn report 85a of the ICRU a definition with an equivalent meaning is given as:\n\nThe mass energy-transfer coefficient, stem:[mu_\"tr\"//rho], of a material, for uncharged particles of a given type and energy, is the quotient of stem:[\"d\"R_\"tr\"//R] by stem:[rho \"d\"l], where stem:[\"d\"R_\"tr\"] is the mean energy that is transferred to kinetic energy of charged particles by interactions of the uncharged particles of incident radiant energy stem:[R] in traversing a distance stem:[\"d\"l] in the material of density stem:[rho]:\n\n[stem%unnumbered]\n++++\n(mu_\"tr\")/rho = 1/(rho \"d\"l) (\"d\"R_\"tr\")/R.\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-kg^(-1)*m^2"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-88-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "exposure <ionizing radiation>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-88-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "X",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-88",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-88",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-88-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-88-0"
        }
      ],
      "skos:definition": {
        "@value": "for X- or gamma radiation the differential quotient of stem:[q] with respect to stem:[m], where stem:[q] is the absolute value of the mean total electric charge of the ions of one sign produced when all the electrons and positrons liberated or created by photons incident on an element of dry air with mass stem:[m] (<<iso80000-4>>) are completely stopped in dry air:\n\n[stem%unnumbered]\n++++\nX = (\"d\"q)/(\"d\"m)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The ionization produced by electrons emitted in atomic or molecular relaxation is included in stem:[\"d\"q]. The ionization due to photons emitted by radiative processes (i.e. bremsstrahlung and fluorescence photons) is not included in stem:[\"d\"q].\n\nThis quantity should not be confused with the quantity photon exposure (<<iso80000-7>>), radiation exposure (<<iso80000-7>>), or the quantity luminous exposure (<<iso80000-7>>).\n\nIt can be convenient to refer to a value of exposure in free space or at a point inside a material different from air, e.g. to the exposure at a point inside a water phantom.\n\nThe exposure is related to the air kerma, stem:[K_\"a\"], (see <<t10-86.1>>) by:\n\n[stem%unnumbered]\n++++\nX = (e(1-g))/W K_\"a\",\n++++\n\nwhere stem:[e] is the elementary charge (<<iso80000-1>>), stem:[W] the average energy loss per elementary charge produced (<<t10-60>>), and stem:[g] is the fraction of the kinetic energy of liberated charged particles that is lost in radiative processes.\n\nIn report 85a of the ICRU a definition with an equivalent meaning is given as:\n\nThe exposure, stem:[X], is the quotient of stem:[\"d\"q] by stem:[\"d\"m], where stem:[\"d\"q] is the absolute value of the mean total charge of the ions of one sign produced when all the electrons and positrons liberated or created by photons incident on a mass stem:[\"d\"m] of dry air are completely stopped in dry air:\n\n[stem%unnumbered]\n++++\nX = (\"d\"q)/(\"d\"m).\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-C/kg"
        },
        {
          "@id": "isoiec80000:unit-kg^(-1)*s*A"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-89-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "exposure rate",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-89-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "dot X",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-89",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-89",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-89-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-89-0"
        }
      ],
      "skos:definition": {
        "@value": "differential quotient of the exposure stem:[X] (<<t10-88>>) with respect to time (<<iso80000-3>>):\n\n[stem%unnumbered]\n++++\ndot X = (\"d\"X)/(\"d\"t)\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[stem%unnumbered]\n++++\n1 \"unitsml(C/(kg*s))\" = 1 \"unitsml(A/kg)\"\n++++\n\nIn report 85a of the ICRU a definition with an equivalent meaning is given as:\n\nThe exposure rate, stem:[dot X], is the quotient of stem:[\"d\"X] by stem:[\"d\"t], where stem:[\"d\"X] is the increment of exposure in the time interval stem:[\"d\"t]:\n\n[stem%unnumbered]\n++++\ndot X = (\"d\"X)/(\"d\"t).\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-C/(kg*s)"
        },
        {
          "@id": "isoiec80000:unit-kg^(-1)*A"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Reynolds number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Re",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.1-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of inertial forces and viscous forces in a fluid flow, expressed by\n\nstem:[Re = (rho v l)/eta = (v l)/sf(ii(v))]; where\n\nstem:[rho]:: is mass density (<<iso80000-4>>),\nstem:[v]:: is speed (<<iso80000-3>>),\nstem:[l]:: is characteristic length (<<iso80000-3>>),\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>), and\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The value of the Reynolds number gives an estimate on the flow state: laminar flow or turbulent flow.\n\nIn rotating movement, the speed stem:[v= omega l], where stem:[l] is the distance from the rotation axis and stem:[omega] is the angular velocity.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Euler number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Eu",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.2-0"
        }
      ],
      "skos:definition": {
        "@value": "relationship between pressure drop in a flow and the kinetic energy per volume for flow of fluids in a pipe, expressed by\n\nstem:[Eu = (Delta p)/(rho v^2)]; where\n\nstem:[Delta p]:: is drop of pressure (<<iso80000-4>>),\nstem:[rho]:: is mass density (<<iso80000-4>>), and\nstem:[v]:: is speed (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Euler number is used to characterize losses in the flow.\n\nA modification of the Euler number is considering the dimensions of the containment (pipe):\n\nstem:[Eu' = d/l Eu]; where\n\nstem:[d]:: is inner diameter (<<iso80000-3>>) of the pipe, and\nstem:[l]:: is length (<<iso80000-3>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Froude number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Fr",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.3",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.3",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.3-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.3-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of a body's inertial forces and its gravitational forces for flow of fluids, expressed by\n\nstem:[Fr = v/(sqrt(lg))]; where\n\nstem:[v]:: is speed (<<iso80000-3>>) of flow,\nstem:[l]:: is characteristic length (<<iso80000-3>>), and\nstem:[g]:: is acceleration of free fall (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Froude number can be modified by buoyancy.\n\nSometimes the square and sometimes the inverse of the Froude number as defined here is wrongly used.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.4-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Grashof number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.4-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Gr",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.4",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.4",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.4-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.4-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of buoyancy forces due to thermal expansion which results in a change of mass density and viscous forces for free convection due to temperature differences, expressed by\n\nstem:[Gr = l^3 g alpha_V Delta T // sf(ii(v))^2]; where\n\nstem:[l]:: is characteristic length (<<iso80000-3>>),\nstem:[g]:: is acceleration of free fall (<<iso80000-3>>),\nstem:[alpha_V]:: is thermal cubic expansion coefficient (<<iso80000-5>>),\nstem:[Delta T]:: is difference of thermodynamic temperature stem:[T] (<<iso80000-5>>) between surface of the body and the fluid far away from the body, and\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Heating can occur near hot vertical walls, in pipes, or by a bluff body.\n\nThe characteristic length can be the vertical height of a hot plate, the diameter of a pipe, or the effective length of a body.\n\nSee also Rayleigh number (<<t11-5.3>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.5-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Weber number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.5-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "We",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.5",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.5",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.5-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.5-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between inertial forces and capillary forces due to surface tension at the interface between two different fluids, expressed by\n\nstem:[We = rho v^2 l // gamma]; where\n\nstem:[rho]:: is mass density (<<iso80000-4>>),\nstem:[v]:: is speed (<<iso80000-3>>),\nstem:[l]:: is characteristic length (<<iso80000-3>>), and\nstem:[gamma]:: is surface tension (<<iso80000-4>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The fluids can be gases or liquids.\n\nThe different fluids often are drops moving in a gas or bubbles in a liquid.\n\nThe characteristic length is commonly the diameter of bubbles or drops.\n\nThe square root of the Weber number is called Rayleigh number.\n\nSometimes the square root of the Weber number as defined here is called the Weber number. That definition is deprecated.\n\nInterfaces only exist between two fluids which are not miscible.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.6-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Mach number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.6-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ma",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.6",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.6",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.6-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.6-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the speed of flow and the speed of sound, expressed by\n\nstem:[Ma = v//c]; where\n\nstem:[v]:: is speed (<<iso80000-3>>) of the body, and\nstem:[c]:: is speed of sound (<<iso80000-8>>) in the fluid\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Mach number represents the relationship of inertial forces compared to compression forces.\n\nFor an ideal gas\n\nstem:[c = sqrt(gamma p/rho) = sqrt(gamma (RT)/M) = sqrt(gamma (kT)/m)]; where stem:[gamma] is ratio of the specific heat capacity (<<iso80000-5>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.7-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Knudsen number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.7-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Kn",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.7",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.7",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.7-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.7-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of free path length of a particle and a characteristic length, expressed by\n\nstem:[Kn = lambda // l]; where\n\nstem:[lambda]:: is mean free path (<<iso80000-9>>), and\nstem:[l]:: is characteristic length (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Knudsen number is a measure to estimate whether the gas in flow behaves like a continuum.\n\nThe characteristic length, stem:[l], can be a characteristic size of the gas flow region like a pipe diameter.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.8-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Strouhal number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.8-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Thomson number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.8-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Sr",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.8-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Sh",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.8",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.8",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.8-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.8-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.8-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.8-1"
        }
      ],
      "skos:definition": {
        "@value": "relation between a characteristic frequency and a characteristic speed for unsteady flow with periodic behaviour, expressed by\n\nstem:[Sr = fl // v]; where\n\nstem:[f]:: is frequency (<<iso80000-3>>) of vortex shedding,\nstem:[l]:: is characteristic length (<<iso80000-3>>), and\nstem:[v]:: is speed (<<iso80000-3>>) of flow\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The characteristic length, stem:[l], can be the diameter of an obstacle in the flow which can cause vortex shedding, or the length of it.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.9-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "drag coefficient",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.9-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "c_\"D\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.9",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.9",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.9-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.9-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between the effective drag force and inertial forces for a body moving in a fluid, expressed by\n\nstem:[c_\"D\" = (2F_\"D\")/(rho v^2 A)]; where\n\nstem:[F_\"D\"]:: is drag force (<<iso80000-4>>) on the body,\nstem:[rho]:: is mass density (<<iso80000-4>>) of the fluid,\nstem:[v]:: is speed (<<iso80000-3>>) of the body, and\nstem:[A]:: is cross-sectional area (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The drag coefficient is strongly dependant on the shape of the body.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.10-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bagnold number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.10-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bg",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.10",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.10",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.10-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.10-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of drag force and gravitational force for a body moving in a fluid, expressed by\n\nstem:[Bg = (c_\"D\"rho v^2)/(l g rho_\"b\")]; where\n\nstem:[c_\"D\"]:: is drag coefficient (<<t11-4.9>>) of the body,\nstem:[rho]:: is mass density (<<iso80000-4>>) of the fluid,\nstem:[v]:: is speed (<<iso80000-3>>) of the body,\nstem:[l]:: is characteristic length (<<iso80000-3>>),\nstem:[g]:: is acceleration of free fall (<<iso80000-3>>), and\nstem:[rho_\"b\"]:: is mass density (<<iso80000-4>>) of the body\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The characteristic length, stem:[l], is the body's volume divided by its cross-sectional area.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.11-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bagnold number <solid particles>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.11-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ba_2",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.11",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.11",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.11-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.11-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of drag force and viscous force in a fluid transferring solid particles, expressed by\n\nstem:[Ba_2 = (rho_\"s\" d^2 dot gamma)/eta sqrt(1//(f_\"s\"^(1//2)-1))]; where\n\nstem:[rho_\"s\"]:: is mass density (<<iso80000-4>>) of particles,\nstem:[d]:: is diameter (<<iso80000-3>>) of particles,\nstem:[dot gamma = v//d]:: is shear rate time-derivative of shear strain (<<iso80000-4>>),\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>) of fluid, and\nstem:[f_\"s\"]:: is volumic fraction of solid particles\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.12-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "lift coefficient",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.12-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "c_\"l\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.12-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "c_\"A\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.12",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.12",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.12-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.12-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.12-1"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the lift force available from a wing at a given angle and the inertial force for a wing shaped body moving in a fluid, expressed by\n\nstem:[c_\"l\" = (2F_\"l\")/(rho v^2 S) = F_\"l\"/(qS)]; where\n\nstem:[F_\"l\"]:: is lift force (<<iso80000-4>>) on the wing,\nstem:[rho]:: is mass density (<<iso80000-4>>) of the fluid,\nstem:[v]:: is speed (<<iso80000-3>>) of the body,\nstem:[S = A\" cos \"alpha]:: is effective area (<<iso80000-3>>) when stem:[alpha] is the angle of attack and stem:[A] is area of the wing, and\nstem:[q=rho v^2//2]:: is dynamic pressure.\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The lift coefficient is dependant on the shape of the wing.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.13-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "thrust coefficient",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.13-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "c_\"t\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.13",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.13",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.13-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.13-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the effective thrust force available from a propeller and the inertial force in a fluid, expressed by\n\nstem:[c_\"t\" = F_\"T\" // (rho n^2 d^4)]; where\n\nstem:[F_\"T\"]:: is thrust force (<<iso80000-4>>) of the propeller,\nstem:[rho]:: is mass density (<<iso80000-4>>) of the fluid,\nstem:[n]:: is rotational frequency (<<iso80000-3>>), and\nstem:[d]:: is tip diameter (<<iso80000-3>>) of the propeller\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The thrust coefficient is dependant on the shape of the propeller.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.14-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Dean number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.14-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Dn",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.14",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.14",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.14-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.14-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between centrifugal force and inertial force, for flows of fluids in curved pipes, expressed by\n\nstem:[Dn = (2vr)/sf(ii(v)) sqrt(r/R)]; where\n\nstem:[v]:: is (axial) speed (<<iso80000-3>>),\nstem:[r]:: is radius (<<iso80000-3>>) of the pipe,\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>) of the fluid, and\nstem:[R]:: is radius of curvature (<<iso80000-3>>) of the path of the pipe\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.15-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bejan number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.15-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Be",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.15",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.15",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.15-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.15-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of mechanical work and frictional energy loss in fluid dynamics in a pipe, expressed by\n\nstem:[Be = (Delta p l^2)/(eta sf(ii(v))) = (rho Delta p l^2)/eta^2]; where\n\nstem:[Delta p]:: is drop of pressure (<<iso80000-4>>) along the pipe,\nstem:[l]:: is characteristic length (<<iso80000-3>>),\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>),\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>), and\nstem:[rho]:: is mass density (<<iso80000-4>>).\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "A similar number exists for heat transfer (<<t11-5.9>>).\n\nThe kinematic viscosity is also called momentum diffusivity.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.16-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Lagrange number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.16-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Lg",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.16",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.16",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.16-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.16-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of mechanical work and frictional energy loss in fluid dynamics in a pipe, expressed by\n\nstem:[Lg = (l Delta p)/(eta v)]; where\n\nstem:[l]:: is length (<<iso80000-3>>) of the pipe,\nstem:[Delta p]:: is drop of pressure (<<iso80000-4>>) along the pipe,\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>), and\nstem:[v]:: is speed (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Lagrange number is also given by\n\nstem:[La = Re * Eu]; where\n\nstem:[Re]:: is the Reynolds number (<<t11-4.1>>), and\nstem:[Eu]:: is the Euler number (<<t11-4.2>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.17-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bingham number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.17-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "plasticity number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.17-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bm",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.17-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bn",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.17",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.17",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.17-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.17-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.17-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.17-1"
        }
      ],
      "skos:definition": {
        "@value": "quotient of yield stress and viscous stress in a viscous material for flow of viscoplastic material in channels, expressed by\n\nstem:[Bm = (tau d)/(eta v)]; where\n\nstem:[tau]:: is shear stress (<<iso80000-4>>),\nstem:[d]:: is characteristic diameter (<<iso80000-3>>), e.g. effective channel width,\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>), and\nstem:[v]:: is speed (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.18-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Hedström number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.18-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "He",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.18-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Hd",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.18",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.18",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.18-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.18-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.18-1"
        }
      ],
      "skos:definition": {
        "@value": "quotient of yield stress and viscous stress of a viscous material at flow limit for visco-plastic material in a channel, expressed by\n\nstem:[He = (tau_0 d^2 rho)/eta^2]; where\n\nstem:[tau_0]:: is shear stress (<<iso80000-4>>) at flow limit,\nstem:[d]:: is characteristic diameter (<<iso80000-3>>), e.g. effective channel width,\nstem:[rho]:: is mass density (<<iso80000-4>>), and\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>)\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.19-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bodenstein number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.19-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bd",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.19",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.19",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.19-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.19-0"
        }
      ],
      "skos:definition": {
        "@value": "mathematical expression of the transfer of matter by convection in reactors with respect to diffusion,\n\nstem:[Bd = vl//D]; where\n\nstem:[v]:: is speed (<<iso80000-3>>),\nstem:[l]:: is length (<<iso80000-3>>) of the reactor, and\nstem:[D]:: is diffusion coefficient (<<iso80000-9>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Bodenstein number is also given by\n\nstem:[Bd = Pe** = Re * Sc]; where\n\nstem:[Pe**]:: is the Péclet number for mass transfer (<<t11-6.2>>),\nstem:[Re]:: is the Reynolds number (<<t11-4.1>>), and\nstem:[Sc = eta//(rho D) = v//D]:: is Schmidt number (<<t11-7.2>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.20-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Rossby number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.20-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Kiebel number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.20-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ro",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.20",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.20",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.20-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.20-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.20-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of inertial forces and Coriolis forces in the context of transfer of matter in geophysics, expressed by\n\nstem:[Ro = v//(2 l omega_\"E\" \"sin\"varphi)]; where\n\nstem:[v]:: is speed (<<iso80000-3>>) of motion,\nstem:[l]:: is characteristic length (<<iso80000-3>>), the scale of the phenomenon,\nstem:[omega_\"E\"]:: is angular velocity (<<iso80000-3>>) of the Earth's rotation, and\nstem:[varphi]:: is angle (<<iso80000-3>>) of latitude\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Rossby number represents the effect of Earth's rotation on flow in pipes, rivers, ocean currents, tornadoes, etc.\n\nThe quantity stem:[omega_\"E\" \"sin\"varphi] is called Coriolis frequency.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.21-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ekman number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.21-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ek",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.21",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.21",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.21-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.21-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of viscous forces and Coriolis forces in the context of transfer of matter for the flow of a rotating fluid, expressed by\n\nstem:[Ek = sf(ii(v))//(2l^2 omega_\"E\" \"sin\"varphi)]; where\n\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>),\nstem:[l]:: is characteristic length (<<iso80000-3>>), the scale of the phenomenon,\nstem:[omega_\"E\"]:: is angular frequency (<<iso80000-3>>) of the Earth's rotation, and\nstem:[varphi]:: is angle of latitude\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "In plasma physics, the square root of this number is used.\n\nThe Ekman number is also given by\n\nstem:[Ek = Ro//Re]; where\n\nstem:[Ro]:: is the Rossby number (<<t11-4.20>>), and\nstem:[Re]:: is the Reynolds number (<<t11-4.1>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.22-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "elasticity number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.22-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "El",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.22",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.22",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.22-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.22-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between relaxation time and diffusion time in viscoelastic flows, expressed by\n\nstem:[El = t_\"r\" sf(ii(v))//r^2]; where\n\nstem:[t_\"r\"]:: is relaxation time (<<iso80000-12>>),\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>), and\nstem:[r]:: is radius (<<iso80000-3>>) of pipe\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "See also Deborah number (<<t11-7.8>>).",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.23-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Darcy friction factor",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.23-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Moody friction factor",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.23-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "f_\"D\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.23",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.23",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.23-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.23-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.23-0"
        }
      ],
      "skos:definition": {
        "@value": "representation of pressure loss in a pipe due to friction within a laminar or turbulent flow of a fluid in a pipe, expressed by\n\nstem:[f_\"D\" = (2 Delta p)/(rho v^2) d/l]; where\n\nstem:[Delta p]:: is drop of pressure (<<iso80000-4>>) due to friction,\nstem:[rho]:: is mass density (<<iso80000-4>>) of the fluid,\nstem:[v]:: is (average) speed (<<iso80000-3>>) of the fluid in the pipe,\nstem:[d]:: is diameter (<<iso80000-3>>) of the pipe, and\nstem:[l]:: is length (<<iso80000-3>>) of the pipe\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.24-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Fanning number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.24-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "f_\"n\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.24-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "f",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.24",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.24",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.24-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.24-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.24-1"
        }
      ],
      "skos:definition": {
        "@value": "relation between shear stress and dynamic pressure in the flow of a fluid in a containment, expressed by\n\nstem:[f_\"n\" = (2 tau)/(rho v^2)]; where\n\nstem:[tau]:: is shear stress (<<iso80000-4>>) at the wall,\nstem:[rho]:: is mass density (<<iso80000-4>>) of the fluid, and\nstem:[v]:: is speed (<<iso80000-3>>) of the fluid in the pipe\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Fanning number describes the flow of fluids in a pipe with friction at the walls represented by its shear stress.\n\nSymbol stem:[f] may be used where no conflicts are possible.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.25-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Goertler number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.25-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Goertler parameter",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.25-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Go",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.25",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.25",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.25-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.25-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.25-0"
        }
      ],
      "skos:definition": {
        "@value": "characterization of the stability of laminar boundary layer flows in transfer of matter in a boundary layer on curved surfaces, expressed by\n\nstem:[Go = (v l_\"b\")/sf(ii(v)) sqrt((l_\"b\"/r_\"c\"))]; where\n\nstem:[v]:: is speed (<<iso80000-3>>),\nstem:[l_\"b\"]:: is boundary layer thickness (<<iso80000-3>>),\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>), and\nstem:[r_\"c\"]:: is radius of curvature (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Goertler number represents the ratio of centrifugal effects to viscous effects.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.26-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Hagen number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.26-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Hg",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.26-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ha",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.26",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.26",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.26-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.26-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.26-1"
        }
      ],
      "skos:definition": {
        "@value": "generalization of the Grashof number for forced or free convection in laminar flow, expressed by\n\nstem:[Hg = -1/rho (\"d\"p)/(\"d\"x) l^3/v^2]; where\n\nstem:[rho]:: is mass density (<<iso80000-4>>) of fluid,\nstem:[(\"d\"p)/(\"d\"x)]:: is gradient of pressure (<<iso80000-4>>),\nstem:[l]:: is characteristic length (<<iso80000-3>>), and\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For free thermal convection with stem:[(\"d\"p)/(\"d\"x) = rho g alpha_\"V\" Delta T], the Hagen number then coincides with the Grashof number (<<t11-4.4>>). See also the Poiseuille number (<<t11-4.28>>).",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.27-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Laval number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.27-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "La",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.27",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.27",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.27-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.27-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of speed and the (critical) sound speed at the throat of a nozzle, expressed by\n\nstem:[La = v // sqrt((R_\"s\"T 2 gamma)//(gamma + 1))]; where\n\nstem:[v]:: is speed (<<iso80000-3>>),\nstem:[R_\"s\" = R/M]:: is specific gas constant, where\nstem:[R]::: is molar gas constant (<<iso80000-9>>), and\nstem:[M]::: is molar mass (<<iso80000-9>>),\nstem:[T]:: is thermodynamic temperature (<<iso80000-5>>), and\nstem:[gamma]:: is ratio of the specific heat capacities (<<iso80000-5>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Laval number is a specific kind of Mach number (<<t11-4.6>>).",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.28-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Poiseuille number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.28-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Poi",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.28",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.28",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.28-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.28-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of propulsive force by pressure and viscous force for a flow of fluids in a pipe, expressed by\n\nstem:[Poi = (Delta p)/l d^2/(eta v)]; where\n\nstem:[Delta p]:: is drop of pressure (<<iso80000-4>>) along the pipe,\nstem:[l]:: is length (<<iso80000-3>>) of the pipe,\nstem:[d]:: is diameter (<<iso80000-3>>) of the pipe,\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>) of the fluid, and\nstem:[v]:: is characteristic speed (<<iso80000-3>>) of the fluid\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Poiseuille number is stem:[Poi=32] for laminar flow in a round pipe.\n\nSee also the Hagen number (<<t11-4.26>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.29-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "power number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.29-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Pn",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.29",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.29",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.29-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.29-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of power consumption by agitators due to drag and rotational inertial power in fluids, expressed by\n\nstem:[Pn = P//(rho n^3d^5)]; where\n\nstem:[P]:: is active power (<<iec80000-6>>) consumed by a stirrer,\nstem:[rho]:: is mass density (<<iso80000-4>>) of fluid,\nstem:[n]:: is rotational frequency (<<iso80000-3>>), and\nstem:[d]:: is diameter (<<iso80000-3>>) of stirrer\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.30-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Richardson number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.30-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ri",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.30",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.30",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.30-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.30-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of potential energy and kinetic energy for a falling body, expressed by\n\nstem:[Ri = gh//v^2]; where\n\nstem:[g]:: is acceleration of free fall (<<iso80000-3>>),\nstem:[h]:: is characteristic height (<<iso80000-3>>), and\nstem:[v]:: is characteristic speed (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "In geophysics differences of these quantities are of interest.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.31-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Reech number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.31-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ree",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.31",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.31",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.31-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.31-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between the speed of an object submerged in water relative to the water, and wave propagation speed, expressed by\n\nstem:[Ree = sqrt(gl)//v]; where\n\nstem:[g]:: is acceleration of free fall (<<iso80000-3>>),\nstem:[l]:: is characteristic length (<<iso80000-3>>), and\nstem:[v]:: is speed (<<iso80000-3>>) of the object relative to the water\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Reech number can be used to determine the resistance of a partially submerged object (e.g. a ship) of length stem:[l] (in direction of the motion) moving through water.\n\nA similar quantity is defined as the Boussinesq number stem:[Bs = v//sqrt(2gl)].\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.32-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Stokes number <time-related>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.32-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Stk",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.32",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.32",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.32-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.32-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of friction and inertia forces for particles in a fluid or in a plasma, expressed by\n\nstem:[Stkt = t_\"r\"//t_\"a\"]; where\n\nstem:[t_\"r\"]:: is relaxation time (<<iso80000-12>>) of particles to achieve fluid's velocity due to friction (viscosity), and\nstem:[t_\"a\"]:: is time (<<iso80000-3>>) of fluid to alter its velocity under external influence\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "In most cases stem:[t_\"r\"=l//v]; where stem:[l] is characteristic length, and stem:[v] is speed of fluid. The characteristic length can be the diameter of an obstacle or hole.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.33-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Stokes number <vibrating particles>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.33-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Stk_1",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.33",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.33",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.33-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.33-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of friction and inertia forces for the special case of particles vibrating in a fluid or plasma, expressed by\n\nstem:[Stk_1 = sf(ii(v)) // (d^2f)]; where\n\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>) of the fluid or plasma,\nstem:[d]:: is diameter (<<iso80000-3>>) of particle, and\nstem:[f]:: is frequency (<<iso80000-3>>) of particle vibrations\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Sometimes the inverse of this number is wrongly used.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.34-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Stokes number <rotameter>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.34-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "power coefficient <rotameter>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.34-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Stk_2",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.34",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.34",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.34-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.34-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.34-0"
        }
      ],
      "skos:definition": {
        "@value": "Stokes number for calibration of rotameters metering vertical flows of fluids by means of a floating body, expressed by\n\nstem:[Stk_2 = {r^3 g m rho}/{eta^2} {(rho_{\"b\"} - rho)}/{rho_{\"b\"}} = {r^3 g m}/{v^2} (1/{rho} - 1/{rho_{\"b\"}})]; where\n\nstem:[r]:: is ratio of pipe and float radii,\nstem:[g]:: is acceleration of free fall (<<iso80000-3>>),\nstem:[m]:: is mass (<<iso80000-4>>) of the body,\nstem:[rho]:: is mass density (<<iso80000-4>>) of the fluid,\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>) of the fluid,\nstem:[rho_\"b\"]:: is mass density (<<iso80000-4>>) of the body, and\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>) of the fluid\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "In general use, this value is multiplied by stem:[1.042].\n\nSee also the Archimedes number (<<t11-6.12>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.35-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Stokes number <gravity>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.35-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Stk_3",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.35",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.35",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.35-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.35-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between viscous forces and gravity forces for particles falling in a fluid, expressed by\n\nstem:[Stk_3 = v sf(ii(v)) // (gl^2)]; where\n\nstem:[v]:: is characteristic speed (<<iso80000-3>>) of particles,\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>) of the fluid,\nstem:[g]:: is acceleration of free fall (<<iso80000-3>>), and\nstem:[l]:: is length (<<iso80000-3>>) of fall\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.36-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Stokes number <drag>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.36-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Stk_4",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.36",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.36",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.36-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.36-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of drag force and internal friction forces for particles dragged in a fluid\n\nstem:[Stk_4=F_\"D\"//(eta v l)]; where\n\nstem:[F_\"D\"]:: is drag force (<<iso80000-4>>),\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>),\nstem:[v]:: is speed (<<iso80000-3>>), and\nstem:[l]:: is characteristic length (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.37-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Laplace number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.37-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Suratman number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.37-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "La",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.37-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Su",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.37",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.37",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.37-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.37-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.37-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.37-1"
        }
      ],
      "skos:definition": {
        "@value": "relation between capillary forces and viscous forces when characterizing free surface flow, expressed by\n\nstem:[La = Su = gamma p l // eta^2]; where\n\nstem:[gamma]:: is surface tension (<<iso80000-4>>),\nstem:[rho]:: is mass density (<<iso80000-4>>) of the fluid,\nstem:[l]:: is characteristic length (<<iso80000-3>>), and\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>) of the fluid\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Laplace number is also the ratio of surface tension to momentum transfer, especially dissipation, inside a fluid.\n\nThe Laplace number is also given by\n\nstem:[La = Su = 1//Oh^2 = Re^2//We]; where\n\nstem:[Oh]:: is the Ohnesorge number (<<t11-7.4>>),\nstem:[Re]:: is the Reynolds number (<<t11-4.1>>), and\nstem:[We]:: is the Weber number (<<t11-4.5>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.38-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Blake number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.38-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bl",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.38",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.38",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.38-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.38-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between inertial forces and viscous forces in a porous material, expressed by\n\nstem:[Bl = (vpl)/(eta(1-epsilon))]; where\n\nstem:[v]:: is speed (<<iso80000-3>>) of the fluid,\nstem:[rho]:: is mass density (<<iso80000-4>>) of the fluid,\nstem:[l]:: is characteristic length (<<iso80000-3>>) defined as the volume of a particle divided by its surface area,\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>) of the fluid, and\nstem:[epsilon]:: is porosity of the material (=void fraction)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Blake number can be interpreted as a Reynolds number for flow in porous material.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.39-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Sommerfeld number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.39-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "So",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.39-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Sm",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.39",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.39",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.39-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.39-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.39-1"
        }
      ],
      "skos:definition": {
        "@value": "relation between viscous force and load force in a lubrication boundary, expressed by\n\nstem:[So = (eta n)/p (r/c)^2]; where\n\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>) of the lubricant,\nstem:[n]:: is rotational frequency (<<iso80000-3>>),\nstem:[p]:: is mean bearing pressure (<<iso80000-4>>),\nstem:[r]:: is radius (<<iso80000-3>>) of the shaft, and\nstem:[c]:: is radial distance (<<iso80000-3>>) between rotating shaft and annulus\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Sometimes the inverse of this number is wrongly used.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.40-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Taylor number <momentum transfer>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.40-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ta",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.40",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.40",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.40-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.40-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between centrifugal force and viscous force of a rotating shaft, expressed by\n\nstem:[Ta = 4 omega^2 l^4 // sf(ii(v))^2]; where\n\nstem:[omega]:: is angular velocity (<<iso80000-3>>) of rotation,\nstem:[l]:: is length (<<iso80000-3>>) perpendicular to the rotation axis, and\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Sometimes the square root of this quantity is wrongly used.\n\nThe Taylor number for a rotating shaft relative to an annulus is given by\n\nstem:[Ta_\"a\" = (omega//sf(ii(v)))^2 ra^3]; where\n\nstem:[omega]:: is angular velocity (<<iso80000-3>>) of the shaft,\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>),\nstem:[r = (r_2+r_1)//2]:: is mean radius (<<iso80000-3>>) of the annulus, and\nstem:[a = (r_2-r_1)]:: is width of the annulus, where\nstem:[r_1]::: is inner radius of the annulus, and\nstem:[r_2]::: is outer radius of the annulus.\n\nSometimes the square root of this quantity is used; this use is deprecated.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.41-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Galilei number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.41-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ga",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.41",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.41",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.41-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.41-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between gravitational force and viscous force in fluid films flowing over walls, expressed by\n\nstem:[Ga = gl^3 // sf(ii(v))^2]; where\n\nstem:[g]:: is acceleration of free fall (<<iso80000-3>>),\nstem:[l]:: is characteristic length (<<iso80000-3>>), and\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>) of the fluid\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Galilei number is also given by\n\nstem:[Ga = Re^2 * Ri] or +\nstem:[Ga = Re^2 // Fr^2]; where\n\nstem:[Re]:: is the Reynolds number (<<t11-4.1>>),\nstem:[Ri]:: is the Richardson number (<<t11-4.30>>), and\nstem:[Fr]:: is the Froude number (<<t11-4.3>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.42-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Womersley number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.42-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Wo",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.42-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "alpha",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-4.42",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-4.42",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-4.42-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.42-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-4.42-1"
        }
      ],
      "skos:definition": {
        "@value": "relation between inertial forces and viscous forces in oscillating flows of fluids in pipes, expressed by\n\nstem:[Wo = R sqrt(omega//sf(ii(v)))]; where\n\nstem:[R]:: is (effective) radius (<<iso80000-3>>) of the pipe,\nstem:[omega]:: is angular frequency (<<iso80000-3>>) of oscillations, and\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Womersley number is used for pulsating flows e.g. in blood flow.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-4"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Fourier number <heat transfer>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Fo",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-5.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-5.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.1-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between heat conduction rate and the rate of thermal energy storage in a body for conductive heat transfer into a body, expressed by\n\nstem:[Fo = (alpha t)/l^2]; where\n\nstem:[alpha]:: is thermal diffusivity (<<iso80000-5>>),\nstem:[t]:: is time (<<iso80000-3>>), and\nstem:[l]:: is characteristic length (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The characteristic length stem:[l] of the body is often defined as the quotient of the body's volume and its heated surface.\n\nSometimes the reciprocal of this number is wrongly used.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-5"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Péclet number <heat transfer>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Pe",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-5.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-5.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.2-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between convective heat transfer rate and conductive heat transfer rate, expressed by\n\nstem:[Pe = vl//alpha]; where\n\nstem:[v]:: is speed (<<iso80000-3>>),\nstem:[l]:: is length (<<iso80000-3>>) in the direction of heat transfer, and\nstem:[alpha]:: is thermal diffusivity (<<iso80000-5>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The thermal Péclet number is also given by\n\nstem:[Pe = Re * Pr]; where\n\nstem:[Re]:: is the Reynolds number (<<t11-4.1>>), and\nstem:[Pr]:: is the Prandtl number (<<t11-7.1>>).\n\nCompare with <<t11-6.2>>, Péclet number for mass transfer.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-5"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Rayleigh number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ra",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-5.3",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-5.3",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.3-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.3-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between buoyancy forces due to thermal expansion and viscous forces in free convection in buoyancy driven flow near a heated surface perpendicular to the gravity force, expressed by\n\nstem:[Ra = (l^3 g alpha_V Delta T)/(sf(ii(v)) alpha)]; where\n\nstem:[l]:: is distance (<<iso80000-3>>) from the wall,\nstem:[g]:: is acceleration of free fall (<<iso80000-3>>),\nstem:[alpha_V]:: is cubic expansion coefficient (<<iso80000-5>>) of the fluid,\nstem:[Delta T]:: is difference of thermodynamic temperature (<<iso80000-5>>) between surface of the wall and the fluid far away from the wall,\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>) of the fluid, and\nstem:[alpha]:: is thermal diffusivity (<<iso80000-5>>) of the fluid\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Rayleigh number is also given by\n\nstem:[Ra = Gr * Pr]; where\n\nstem:[Gr]:: is the Grashof number (<<t11-4.4>>), and\nstem:[Pr]:: is the Prandtl number (<<t11-7.1>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-5"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.4-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Froude number <heat transfer>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.4-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Fr**",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-5.4",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-5.4",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.4-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.4-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of gravitational forces and thermodiffusion forces for heat transfer in forced convection of fluids, expressed by\n\nstem:[Fr** = (gl^3)/alpha^2]; where\n\nstem:[g]:: is acceleration of free fall (<<iso80000-3>>),\nstem:[l]:: is characteristic length (<<iso80000-3>>), and\nstem:[alpha]:: is thermal diffusivity (<<iso80000-5>>)\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-5"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.5-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Nusselt number <heat transfer>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.5-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "N u",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-5.5",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-5.5",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.5-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.5-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between the internal thermal resistance of a body and its surface thermal resistance in a body transferring heat from a surface into its interior or vice versa, expressed by\n\nstem:[N]stem:[u = Kl // lambda = Kl // (alpha rho c_p)] where\n\nstem:[K]:: is coefficient of heat transfer (<<iso80000-5>>) through the surface,\nstem:[l]:: is length (<<iso80000-3>>) of the body in direction of heat flow,\nstem:[lambda]:: is thermal conductivity (<<iso80000-5>>) of the surface,\nstem:[alpha]:: is thermal diffusivity (<<iso80000-5>>),\nstem:[rho]:: is mass density (<<iso80000-4>>), and\nstem:[c_p]:: is specific heat capacity at constant pressure (<<iso80000-5>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The body under consideration can be a solid body, a fluid, or their combination, and additional heat transfer due to convective motion can occur.\n\nIn case of merely conductive heat transfer especially in a solid body, the \"Biot number for heat transfer\" (<<t11-5.6>>) is used.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-5"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.6-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Biot number <heat transfer>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.6-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bi",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-5.6",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-5.6",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.6-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.6-0"
        }
      ],
      "skos:definition": {
        "@value": "special case of the Nusselt number for heat transfer (item <<t11-5.5>>) in case of conductive heat transfer in a solid body, expressed by\n\nstem:[Bi = Kl // lambda]; where\n\nstem:[K]:: is coefficient of heat transfer (<<iso80000-5>>) through the surface,\nstem:[l]:: is characteristic length (<<iso80000-3>>), and\nstem:[lambda]:: is thermal conductivity (<<iso80000-5>>) of the body\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The characteristic length is commonly defined as the volume of the body divided by its surface area.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-5"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.7-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Stanton number <heat transfer>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.7-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "St",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-5.7",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-5.7",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.7-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.7-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between heat transfer into a fluid from a surface and its heat transfer by convection, expressed by\n\nstem:[St = K // (rho v c_p)]; where\n\nstem:[K]:: is coefficient of heat transfer (<<iso80000-5>>) through the surface,\nstem:[rho]:: is mass density (<<iso80000-4>>),\nstem:[v]:: is speed (<<iso80000-3>>), and\nstem:[c_p]:: is specific heat capacity at constant pressure (<<iso80000-5>>) of the fluid\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Stanton number is also given by\n\nstem:[St = N u // (Re*Pr) = N u//Pe]; where\n\nstem:[N u]:: is Nusselt number for heat transfer (<<t11-5.5>>),\nstem:[Re]:: is the Reynolds number (<<t11-4.1>>),\nstem:[Pr]:: is the Prandtl number (<<t11-7.1>>), and\nstem:[Pe]:: is the Péclet number (<<t11-5.2>>).\n\nSometimes this quantity is called Margoulis number, symbol stem:[Ms] or stem:[Mg].\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-5"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.8-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "stem:[j]-factor <heat transfer>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.8-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "heat transfer factor",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.8-2",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Colburn number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.8-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "j",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.8-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Co",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.8-2",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Jq",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-5.8",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-5.8",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.8-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.8-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.8-2"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.8-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.8-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.8-2"
        }
      ],
      "skos:definition": {
        "@value": "relation between heat transfer and mass transfer in a fluid, expressed by\n\nstem:[j = K/(c_p rho v) ((c_p eta)/lambda)^(2//3)]; where\n\nstem:[K]:: is coefficient of heat transfer (<<iso80000-5>>),\nstem:[c_p]:: is specific heat capacity at constant pressure (<<iso80000-5>>),\nstem:[rho]:: is mass density (<<iso80000-4>>),\nstem:[v]:: is speed (<<iso80000-3>>),\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>), and\nstem:[lambda]:: is thermal conductivity (<<iso80000-5>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The heat transfer factor is also given by\n\nstem:[j=St * Pr^(2//3)]; where\n\nstem:[St]:: is the Stanton number for heat transfer (<<t11-5.7>>), and\nstem:[Pr]:: is the Prandtl number (<<t11-7.1>>).\n\nSee also mass transfer factor (<<t11-6.7>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-5"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.9-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bejan number <heat transfer>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.9-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Be_1",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-5.9",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-5.9",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.9-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.9-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of mechanical work and frictional and thermal diffusion energy losses for a forced flow, expressed by\n\nstem:[Be_1 = (Delta pl^2)/(eta alpha)]; where\n\nstem:[Delta p]:: is drop of pressure (<<iso80000-4>>) along a pipe,\nstem:[l]:: is length (<<iso80000-3>>) of the pipe,\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>), and\nstem:[alpha]:: is thermal diffusivity (<<iso80000-5>>)\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-5"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.10-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bejan number <entropy>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.10-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Be_S",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-5.10",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-5.10",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.10-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.10-0"
        }
      ],
      "skos:definition": {
        "@value": "efficiency of heat transfer by a fluid, expressed by\n\nstem:[Be_S = (S(Delta T))/(S(Delta T) + S(Delta p))]; where\n\nstem:[S(Delta T)]:: is entropy generation contributed by heat transfer, and\nstem:[S(Delta p)]:: is entropy generation contributed by fluid friction\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-5"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.11-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Stefan number <phase transition>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.11-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ste",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.11-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Stf",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-5.11",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-5.11",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.11-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.11-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.11-1"
        }
      ],
      "skos:definition": {
        "@value": "relation between heat content and latent heat content in a binary mixture undergoing a phase transition, expressed by\n\nstem:[Ste = c_p Delta T // Q]; where\n\nstem:[c_p]:: is specific heat capacity at constant pressure (<<iso80000-5>>),\nstem:[Delta T]:: is difference of thermodynamic temperature stem:[T] (<<iso80000-5>>) between the phases, and\nstem:[Q]:: is quotient of latent heat of phase transition (<<iso80000-5>>) and mass (<<iso80000-4>>)\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-5"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.12-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Brinkman number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.12-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Br",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.12-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "N_(Br)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-5.12",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-5.12",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.12-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.12-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.12-1"
        }
      ],
      "skos:definition": {
        "@value": "relation between heat produced by viscosity and heat conducted from a wall adjacent to a fluid moving relative to it, expressed by\n\nstem:[Br = eta v^2 // (lambda Delta T)]; where\n\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>),\nstem:[v]:: is characteristic speed (<<iso80000-3>>),\nstem:[lambda]:: is thermal conductivity (<<iso80000-5>>), and\nstem:[Delta T = T_W - T_0]:: is difference of thermodynamic temperature stem:[T] (<<iso80000-5>>), where\nstem:[T_0]:: is bulk fluid temperature, and\nstem:[T_W]:: is wall temperature\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-5"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.13-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Clausius number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.13-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Cl",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-5.13",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-5.13",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.13-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.13-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between energy transfer associated with fluid momentum and energy transfer by thermal conduction in forced heating, expressed by\n\nstem:[Cl = v^3 l rho // (lambda Delta T)]; where\n\nstem:[v]:: is speed (<<iso80000-3>>),\nstem:[l]:: is length (<<iso80000-3>>) of the path of energy transfer,\nstem:[rho]:: is mass density (<<iso80000-4>>),\nstem:[lambda]:: is thermal conductivity (<<iso80000-5>>), and\nstem:[Delta T]:: is difference of thermodynamic temperature stem:[T] (<<iso80000-5>>) along length stem:[l]\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-5"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.14-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Carnot number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.14-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ca",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-5.14",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-5.14",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.14-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.14-0"
        }
      ],
      "skos:definition": {
        "@value": "theoretical maximum efficiency (<<iso80000-5>>) of a Carnot cycle operating between temperature reservoirs\n\nstem:[Ca = (T_2-T_1)//T_2]; where\n\nstem:[T]:: is thermodynamic temperature (<<iso80000-5>>), and +\nstem:[T_2, T_1]:: are the thermodynamic temperatures of a heat source and a heat sink, respectively\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-5"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.15-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Eckert number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.15-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Dulong number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.15-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ec",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-5.15",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-5.15",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.15-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.15-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.15-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between the kinetic energy of a flow and its enthalpy change in fluid dynamics exhibiting dissipation, expressed by\n\nstem:[Ec = v^2 // (c_p Delta T)]; where\n\nstem:[v]:: is characteristic speed (<<iso80000-3>>),\nstem:[c_p]:: is specific heat capacity at constant pressure (<<iso80000-5>>) of the flow, and\nstem:[Delta T]:: is difference of thermodynamic temperature stem:[T] (<<iso80000-5>>) due to dissipation (by friction)\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-5"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.16-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Graetz number <heat transfer>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.16-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Gz",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-5.16",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-5.16",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.16-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.16-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between heat transferred by convection and heat transferred by conduction in a laminar flow in a pipe, expressed by\n\nstem:[Gz = (vd^2)/(alpha l)]; where\n\nstem:[v]:: is speed (<<iso80000-3>>) of the fluid, +\nstem:[d]:: is diameter (<<iso80000-3>>) of the pipe, +\nstem:[alpha]:: is thermal diffusivity (<<iso80000-5>>) of the fluid, and +\nstem:[l]:: is length (<<iso80000-3>>) of the pipe\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-5"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.17-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "heat transfer number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.17-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "K_Q",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-5.17",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-5.17",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.17-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.17-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between heat transferred by a flow and its kinetic energy, expressed by\n\nstem:[K_Q = Phi // (v^3l^2rho)]; where\n\nstem:[Phi]:: is heat flow rate (<<iso80000-5>>),\nstem:[v]:: is characteristic speed (<<iso80000-3>>),\nstem:[l]:: is characteristic length (<<iso80000-3>>), and\nstem:[rho]:: is mass density (<<iso80000-4>>)\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-5"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.18-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Pomerantsev number <heat transfer>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.18-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Po",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.18-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Pov",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-5.18",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-5.18",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.18-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.18-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.18-1"
        }
      ],
      "skos:definition": {
        "@value": "relation between heat generated in a body and conducted heat in the body, expressed by\n\nstem:[Po = Q_\"m\" l^2 // (lambda Delta T)]; where\n\nstem:[Q_\"m\"]:: is (constant) volumic heat generation rate,\nstem:[l]:: is characteristic length (<<iso80000-3>>),\nstem:[lambda]:: is thermal conductivity (<<iso80000-5>>), and\nstem:[Delta T = T_\"m\" - T_0]:: is difference of thermodynamic temperature (<<iso80000-5>>) between that of the medium (stem:[T_\"m\"]) and the initial temperature of the body (stem:[T_0])\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Similar numbers are known for areic, lineic and point sources of heat, each with decreasing power of length stem:[l] respectively.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-5"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.19-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Boltzmann number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.19-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bz",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.19-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bol",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.19-2",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bo",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-5.19",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-5.19",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.19-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.19-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.19-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.19-2"
        }
      ],
      "skos:definition": {
        "@value": "relation between convective heat and radiant heat for a fluid in a channel, expressed by\n\nstem:[Bz = rho v c_p // (epsilon sigma T^3)]; where\n\nstem:[rho]:: is mass density (<<iso80000-4>>) of the fluid,\nstem:[v]:: is characteristic speed (<<iso80000-3>>) of the fluid,\nstem:[c_p]:: is specific heat capacity at constant pressure (<<iso80000-5>>),\nstem:[epsilon]:: is emissivity (<<iso80000-7>>),\nstem:[sigma]:: is the Stefan-Boltzmann constant (<<iso80000-7>>), and\nstem:[T]:: is thermodynamic temperature (<<iso80000-5>>)\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-5"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.20-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Stark number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.20-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "DEPRECATED: Stefan number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.20-2",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "DEPRECATED: Biot radiation number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.20-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Sk",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-5.20",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-5.20",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.20-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.20-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-5.20-2"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-5.20-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between radiant heat and conductive heat multiplied by the relative temperature difference for a body, expressed by\n\nstem:[Sk = epsilon sigma T^3l//lambda]; where\n\nstem:[epsilon]:: is emissivity (<<iso80000-7>>) of the surface,\nstem:[sigma]:: is the Stefan-Boltzmann constant (<<iso80000-7>>),\nstem:[T]:: is thermodynamic temperature (<<iso80000-5>>),\nstem:[l]:: is characteristic length (<<iso80000-3>>), and\nstem:[lambda]:: is thermal conductivity (<<iso80000-5>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The relative temperature difference is defined by stem:[(Delta T)/T]; where stem:[Delta T = T_\"s\" - T_\"l\"] is the difference of the temperature at the surface, stem:[T_\"s\"], and the temperature at a layer at a distance stem:[l] from the surface, stem:[T_\"l\"].\n\nSometimes this characteristic number is wrongly defined without the factor stem:[epsilon].\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-5"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Fourier number <mass transfer>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Fo**",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-6.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-6.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.1-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between diffusive mass transfer within a given duration and mass storage rate in transient mass transfer, expressed by\n\nstem:[Fo** = (Dt)/l^2]; where\n\nstem:[D]:: is diffusion coefficient (<<iso80000-9>>),\nstem:[t]:: is duration (<<iso80000-3>>) of observation, and\nstem:[l]:: is length (<<iso80000-3>>) of transfer\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Fourier number for mass transfer is also given by\n\nstem:[Fo** = Fo//Le]; where\n\nstem:[Fo]:: is the Fourier number for heat transfer (<<t11-5.1>>), and\nstem:[Le]:: is the Lewis number (<<t11-7.3>>).\n\nSee also the Fourier number for heat transfer (<<t11-5.1>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Péclet number <mass transfer>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.2-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bodenstein number <mass transfer>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Pe**",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.2-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bd",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.2-2",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bod",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-6.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-6.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.2-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.2-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.2-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.2-2"
        }
      ],
      "skos:definition": {
        "@value": "relation between advective mass transfer rate and longitudinal diffusive mass transfer rate for mass transfer in reactors, expressed by\n\nstem:[Pe** = vl//D]; where\n\nstem:[v]:: is speed (<<iso80000-3>>),\nstem:[l]:: is characteristic length (<<iso80000-3>>), and\nstem:[D]:: is diffusion coefficient (<<iso80000-9>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Péclet number for mass transfer is also given by\n\nstem:[Pe** = Pe * Le = Re * Sc]; where\n\nstem:[Pe]:: is the Péclet number for heat transfer,\nstem:[Le]:: is the Lewis number (<<t11-7.3>>),\nstem:[Re]:: is the Reynolds number (<<t11-4.1>>), and\nstem:[Sc]:: is the Schmidt number (<<t11-7.2>>).\n\nCompare with <<t11-5.2>>, the Péclet number for heat transfer.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Grashof number <mass transfer>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Gr**",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-6.3",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-6.3",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.3-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.3-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between buoyancy forces and viscous forces in natural convection of fluids, expressed by\n\nstem:[Gr** = l^3 g beta Delta x // sf(ii(v))^2]; where\n\nstem:[l]:: is characteristic length (<<iso80000-3>>),\nstem:[g]:: is acceleration of free fall (<<iso80000-3>>)\nstem:[beta = -(1//rho)(del rho // del x)_(T,p)], where::\nstem:[rho]::: is mass density (<<iso80000-4>>) of the fluid, and\nstem:[x]::: is amount-of-substance fraction (<<iso80000-9>>),\nstem:[Delta x]:: is difference of amount-of-substance fraction (<<iso80000-9>>) along length stem:[l], and\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Instead of \"amount-of-substance fraction\" the \"amount-of-substance concentration\" (<<iso80000-9>>) is used also.\n\nCompare with <<t11-4.4>>, the Grashof number.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.4-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Nusselt number <mass transfer>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.4-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "N u**",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-6.4",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-6.4",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.4-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.4-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between mass flux at an interface and specific flux by pure molecular diffusion in a layer of thickness stem:[l] for mass transfer at the boundary of a fluid, expressed by\n\nstem:[N u** = k'l//(rho D)]; where\n\nstem:[k']:: is mass flux density stem:[q_m//A] through the surface, where\nstem:[q_m]::: is mass flow rate (<<iso80000-4>>), and\nstem:[A]::: is area (<<iso80000-3>>),\nstem:[l]:: is thickness (<<iso80000-3>>),\nstem:[rho]:: is mass density (<<iso80000-4>>) of the fluid, and\nstem:[D]:: is diffusion coefficient (<<iso80000-9>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Sometimes this quantity is called the Sherwood number, stem:[Sh]. +\n\nCompare with <<t11-5.5>>, Nusselt number for heat transfer.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.5-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Stanton number <mass transfer>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.5-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "St**",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-6.5",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-6.5",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.5-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.5-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between mass transfer perpendicular to the surface of a fluid flow and mass transfer parallel to the surface in a free surface flow, expressed by\n\nstem:[St** = k'//(rho v)]; where\n\nstem:[k']:: is mass flux density stem:[q_m//A] through the surface, where\nstem:[q_m]::: is mass flow rate (<<iso80000-4>>), and\nstem:[A]::: is area (<<iso80000-3>>),\nstem:[rho]:: is mass density (<<iso80000-4>>), and\nstem:[v]:: is speed (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Stanton number for mass transfer is also given by stem:[St** = N]stem:[u** // Pe**]; where\n\nstem:[N u**]:: is the Nusselt number for mass transfer (<<t11-6.4>>), and +\nstem:[Pe**]:: is the Péclet number for mass transfer (<<t11-6.2>>).\n\nCompare with <<t11-5.7>>, the Stanton number for heat transfer.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.6-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Graetz number <mass transfer>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.6-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Gz**",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-6.6",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-6.6",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.6-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.6-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of advective mass transfer rate and radial diffusive mass transfer rate for mass transfer in pipes, expressed by\n\nstem:[Gz** = (vd)/D = d/l Pe**]; where\n\nstem:[v]:: is characteristic speed (<<iso80000-3>>) of the fluid,\nstem:[d]:: is hydraulic diameter (<<iso80000-3>>) of the pipe,\nstem:[D]:: is diffusion coefficient (<<iso80000-9>>),\nstem:[l]:: is length (<<iso80000-3>>) of the pipe, and\nstem:[Pe**]:: is the Péclet number for mass transfer (<<t11-6.2>>)\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.7-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "mass transfer factor",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.7-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "stem:[j]-factor <mass transfer>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.7-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "j**",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-6.7",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-6.7",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.7-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.7-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.7-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between mass transfer perpendicular to the surface of a fluid and mass transfer parallel to the surface in an open flow of fluids, expressed by\n\nstem:[j** = k/v (sf(ii(v))/D)^(2//3)]; where\n\nstem:[k]:: is the mass transfer coefficient through the surface, stem:[k=k'//rho], where\nstem:[rho]::: is mass density (<<iso80000-4>>),\nstem:[k']::: is mass flux density stem:[q_m//A] through the surface, where\nstem:[q_m]:::: is mass flow rate (<<iso80000-4>>), and\nstem:[A]:::: is area (<<iso80000-3>>),\nstem:[v]:: is speed (<<iso80000-3>>),\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>), and\nstem:[D]:: is diffusion coefficient (<<iso80000-9>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The mass transfer factor is also given by\n\nstem:[j_m = j** = St** * Sc^(2//3)]; where\n\nstem:[St**]:: is the Stanton number for mass transfer (<<t11-6.5>>), and\nstem:[Sc]:: is the Schmidt number (<<t11-7.2>>).\n\nSee also heat transfer factor (<<t11-5.17>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.8-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Atwood number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.8-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "At",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-6.8",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-6.8",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.8-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.8-0"
        }
      ],
      "skos:definition": {
        "@value": "scaled density difference of heavier and lighter fluids, expressed by\n\nstem:[At = (rho_1 - rho_2)/(rho_1 + rho_2)]; where\n\nstem:[rho_1]:: is density of heavier fluid, and\nstem:[rho_2]:: is density of lighter fluid\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Atwood number is used in the study of hydrodynamic instabilities in density stratified flows.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.9-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Biot number <mass transfer>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.9-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bi**",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-6.9",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-6.9",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.9-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.9-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between mass transfer rate at the interface and mass transfer rate in the interior of a body, expressed by\n\nstem:[Bi** = kl//D_\"int\"]; where\n\nstem:[k]:: is the mass transfer coefficient through the surface, stem:[k=k'//rho], where\nstem:[rho]::: is mass density (<<iso80000-4>>),\nstem:[k']::: is mass flux density stem:[q_m//A] through the surface, where\nstem:[q_m]:::: is mass flow rate (<<iso80000-4>>), and\nstem:[A]:::: is area (<<iso80000-3>>),\nstem:[l]:: is thickness (<<iso80000-3>>) of layer, and\nstem:[D_\"int\"]:: is diffusion coefficient (<<iso80000-9>>) at the interface\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.10-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Morton number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.10-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Mo",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-6.10",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-6.10",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.10-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.10-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of gravitational forces and viscous forces for gas bubbles in a liquid, or liquid drops in a gas, expressed by\n\nstem:[Mo = (g eta^4)/(rho gamma^3) (rho_\"b\"/rho -1)]; where\n\nstem:[g]:: is acceleration of free fall (<<iso80000-3>>),\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>) of the surrounding fluid,\nstem:[rho]:: is mass density (<<iso80000-4>>) of the surrounding fluid,\nstem:[gamma]:: is surface tension (<<iso80000-4>>) of the interface, and\nstem:[rho_b]:: is mass density (<<iso80000-4>>) of the bubble or drop\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Morton number is used to determine the shape of bubbles or drops.\n\nThe Morton number is also given by\n\nstem:[Mo = We^3 Fr^(-2)Re^(-4)]; where\n\nstem:[We]:: is the Weber number (<<t11-4.5>>),\nstem:[Fr]:: is the Froude number (<<t11-4.3>>), and\nstem:[Re]:: is the Reynolds number (<<t11-4.1>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.11-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bond number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.11-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Eötvös number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.11-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bo",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.11-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Eo",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-6.11",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-6.11",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.11-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.11-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.11-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.11-1"
        }
      ],
      "skos:definition": {
        "@value": "quotient of inertial force and capillary force for gas bubbles or liquid drops in a fluid, expressed by\n\nstem:[Bo = a/gamma rho l^2 (rho_\"b\"/rho -1)]; where\n\nstem:[a]:: is the acceleration of the body (<<iso80000-3>>), mostly acceleration of free fall, stem:[g] (<<iso80000-3>>),\nstem:[gamma]:: is surface tension (<<iso80000-4>>) of the interface,\nstem:[rho]:: is density (<<iso80000-4>>) of the medium,\nstem:[l]:: is characteristic length (<<iso80000-3>>) (radius of a drop or radius of a capillary tube), and\nstem:[rho_\"b\"]:: is mass density (<<iso80000-4>>) of the drop or bubble\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "In the case of gravity stem:[a = g] acceleration of free fall (<<iso80000-3>>), the name Eötvös number is mostly used.\n\nThe Bond number is also given by\n\nstem:[Bo = We//Fr]; where\n\nstem:[We]:: is the Weber number (<<t11-4.5>>), and\nstem:[Fr]:: is the Froude number (<<t11-4.3>>).\n\nThe Bond number is also used for capillary action driven by buoyancy.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.12-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Archimedes number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.12-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ar",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-6.12",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-6.12",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.12-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.12-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of buoyancy forces and viscous forces in fluids motion due to density differences for a body in a fluid, expressed by\n\nstem:[Ar = (gl^3)/sf(ii(v))^2 (rho_\"b\"/rho - 1)]; where\n\nstem:[g]:: is acceleration of free fall (<<iso80000-3>>),\nstem:[l]:: is characteristic length (<<iso80000-3>>) of the body,\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>) of the fluid,\nstem:[rho_\"b\"]:: is mass density (<<iso80000-4>>) of the body, and\nstem:[rho]:: is mass density (<<iso80000-4>>) of the fluid\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "In this definition, the body can be replaced by an immiscible fluid.\n\nSee also Stokes number <rotameter> (<<t11-4.34>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.13-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "expansion number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.13-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ex",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-6.13",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-6.13",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.13-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.13-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of buoyancy force and inertial force in moving fluids due to density differences for gas bubbles rising in a liquid, expressed by\n\nstem:[Ex = (gd)/v^2 (1-rho_\"b\"/rho)]; where\n\nstem:[g]:: is acceleration of free fall (<<iso80000-3>>),\nstem:[d]:: is diameter (<<iso80000-3>>) of bubbles,\nstem:[v]:: is speed (<<iso80000-3>>) of bubbles,\nstem:[rho_\"b\"]:: is mass density (<<iso80000-4>>) of bubbles, and\nstem:[rho]:: is mass density (<<iso80000-4>>) of the liquid\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.14-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Marangoni number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.14-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Mg",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.14-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Mar",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-6.14",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-6.14",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.14-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.14-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.14-1"
        }
      ],
      "skos:definition": {
        "@value": "quotient of heat transferred by Marangoni convection and heat transferred by thermal diffusivity in thermo-capillary convection of liquid films on a free surface, expressed by\n\nstem:[Mg = l (Delta T)/(eta a) ((\"d\"gamma)/(\"d\"T))]; where\n\nstem:[l]:: is characteristic thickness (<<iso80000-3>>) of the film,\nstem:[Delta T]:: is difference of thermodynamic temperature stem:[T] (<<iso80000-5>>) between surface and outer surface of the film,\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>) of the liquid,\nstem:[a]:: is thermal diffusivity (<<iso80000-5>>) of the liquid, and\nstem:[gamma]:: is surface tension (<<iso80000-4>>) of the film\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Marangoni convection is free surface flow due to different surface tensions caused by a temperature gradient.\n\nThis quantity is sometimes called Thompson number.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.15-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Lockhart-Martinelli parameter",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.15-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Lp",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-6.15",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-6.15",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.15-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.15-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of mass flow rates multiplied by the square root of density in a two-phase flow, expressed by\n\nstem:[Lp = (dot m_\"1\")/(dot m_\"g\") sqrt(rho_\"g\"/rho_\"l\")]; where\n\nstem:[dot m_\"l\" = q_\"m\"]:: is liquid phase mass flow rate (<<iso80000-4>>),\nstem:[dot m_\"g\"]:: is gas phase mass flow rate,\nstem:[rho_\"g\"]:: is gas density (<<iso80000-4>>), and\nstem:[rho_\"l\"]:: is liquid density\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Lockhart-Martinelli parameter is used, for example, in boiling or condensing.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.16-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bejan number <mass transfer>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.16-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Be**",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.16-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Be_2",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-6.16",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-6.16",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.16-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.16-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.16-1"
        }
      ],
      "skos:definition": {
        "@value": "quotient of mechanical work and frictional and diffusion energy loss in viscous flow of fluids in pipes, expressed by\n\nstem:[Be** = (Delta pl^2)/(eta D)]; where\n\nstem:[Delta p]:: is drop of pressure (<<iso80000-4>>) along a pipe or channel,\nstem:[l]:: is length (<<iso80000-3>>) of channel,\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>) of the fluid, and\nstem:[D]:: is diffusion coefficient (<<iso80000-9>>), mass diffusivity\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "A similar quantity exists for heat transfer (<<t11-5.9>>).",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.17-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "cavitation number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.17-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ca",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.17-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Cn",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-6.17",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-6.17",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.17-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.17-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.17-1"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the excess of local static head over vapour pressure head and velocity head for fast flow in liquids, expressed by\n\nstem:[Ca = (p-p_\"v\")/(rho v^2//2)]; where\n\nstem:[p]:: is local static pressure (<<iso80000-4>>),\nstem:[p_\"v\"]:: is vapour pressure (<<iso80000-4>>) of the fluid,\nstem:[rho]:: is mass density (<<iso80000-4>>) of the fluid, and\nstem:[v]:: is characteristic speed (<<iso80000-3>>) of the flow\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The cavitation number represents the ratio of the excess of local static head over vapour pressure head to velocity head.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.18-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "absorption number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.18-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ab",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-6.18",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-6.18",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.18-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.18-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between mass flow rate and surface area for gas absorption at wetted walls, expressed by\n\nstem:[Ab = k sqrt((ld)/(Dq_V))]; where\n\nstem:[k]:: is the mass transfer coefficient through the surface, stem:[k=k'//rho], where\nstem:[rho]::: is mass density (<<iso80000-4>>), and\nstem:[k']::: is mass flux density through the surface, stem:[k' = q_\"m\"//A], where\nstem:[q_\"m\"]:::: is mass flow rate (<<iso80000-4>>), and\nstem:[A]:::: is area (<<iso80000-3>>),\nstem:[l]:: is length (<<iso80000-3>>) of wetted surface,\nstem:[d]:: is thickness (<<iso80000-3>>) of liquid film,\nstem:[D]:: is diffusion coefficient (<<iso80000-9>>), and\nstem:[q_V]:: is volume flow rate (<<iso80000-4>>) per wetted perimeter\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.19-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "capillary number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.19-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ca",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-6.19",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-6.19",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.19-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.19-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of gravitational forces and capillary forces for fluids in narrow pipes, expressed by\n\nstem:[Ca = d^2 rho g//gamma]; where\n\nstem:[d]:: is diameter (<<iso80000-3>>) of the pipe,\nstem:[rho]:: is mass density (<<iso80000-4>>) of the fluid,\nstem:[g]:: is acceleration of free fall (<<iso80000-3>>), and\nstem:[gamma]:: is surface tension (<<iso80000-4>>) of the fluid\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.20-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "dynamic capillary number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.20-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ca**",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.20-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Cn",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-6.20",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-6.20",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-6.20-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.20-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-6.20-1"
        }
      ],
      "skos:definition": {
        "@value": "quotient of viscous force and capillary force acting across an interface between a liquid and a gas, or between two immiscible liquids for a flow of fluid influenced by interfacial tension, expressed by\n\nstem:[Ca** = eta v//gamma]; where\n\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>) of the fluid,\nstem:[v]:: is characteristic speed (<<iso80000-3>>), and\nstem:[gamma]:: is surface or interfacial tension (<<iso80000-4>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The dynamic capillary number is also given by the quotient of the Weber number and the Reynolds number.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-6"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-7.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Prandtl number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-7.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Pr",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-7.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-7.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-7.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-7.1-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of kinematic viscosity and thermal diffusivity for a fluid, expressed by\n\nstem:[Pr = sf(ii(v))//a]; where\n\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>), and\nstem:[a]:: is thermal diffusivity (<<iso80000-5>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Prandtl number also represents the quotient of heat produced by viscosity and heat transferred by thermal diffusivity.\n\nThe mass transfer analogue of the Prandtl number is the Schmidt number (<<t11-7.2>>).\n\nThe Prandtl number is also given by\n\nstem:[Pr = Pe//Re]; where\n\nstem:[Pe]:: is the Péclet number (<<t11-5.2>>), and\nstem:[Re]:: is the Reynolds number (<<t11-4.1>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-7"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-7.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Schmidt number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-7.2-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "DEPRECATED: Colburn number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-7.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Sc",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-7.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-7.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-7.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-7.2-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-7.2-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of kinematic viscosity and diffusion coefficient for a fluid, expressed by\n\nstem:[Sc = sf(ii(v))//D]; where\n\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>), and\nstem:[D]:: is diffusion coefficient (<<iso80000-9>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The heat transfer analogue of the Schmidt number is the Prandtl number (<<t11-7.1>>).",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-7"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-7.3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Lewis number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-7.3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Le",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-7.3",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-7.3",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-7.3-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-7.3-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of thermal diffusivity and diffusion coefficient for heat transfer in a fluid, expressed by\n\nstem:[Le = a//D]; where\n\nstem:[a]:: is thermal diffusivity (<<iso80000-5>>), and\nstem:[D]:: is diffusion coefficient (<<iso80000-9>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Lewis number is also given by\n\nstem:[Le = Sc//Pr]; where\n\nstem:[Sc]:: is the Schmidt number (<<t11-7.2>>), and\nstem:[Pr]:: is the Prandtl number (<<t11-7.1>>).\n\nCompare with <<t11-5.2>>.\n\nThe Lewis number is sometimes defined as reciprocal of this quantity.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-7"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-7.4-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ohnesorge number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-7.4-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Oh",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-7.4",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-7.4",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-7.4-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-7.4-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between viscous force and the square root of the product of inertia force and capillary force for atomization of liquids, expressed by\n\nstem:[Oh = eta/(sqrt(gamma rho l))]; where\n\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>),\nstem:[gamma]:: is surface tension (<<iso80000-4>>),\nstem:[rho]:: is mass density (<<iso80000-4>>), and\nstem:[l]:: is characteristic length (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Ohnesorge number is also given by\n\nstem:[Oh = sqrt(We)//Re]; where\n\nstem:[We]:: is the Weber number (<<t11-4.5>>), and\nstem:[Re]:: is the Reynolds number (<<t11-4.1>>).\n\nSee also Laplace number (<<t11-4.37>>).\n\nThe characteristic length typically is the drop diameter.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-7"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-7.5-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Cauchy number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-7.5-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "aeroelasticity parameter",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-7.5-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Cy",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-7.5",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-7.5",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-7.5-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-7.5-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-7.5-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between inertia forces and compression forces in compressible fluids, expressed by\n\nstem:[Cy = rho v^2//K]; where\n\nstem:[rho]:: is mass density (<<iso80000-4>>),\nstem:[v]:: is speed (<<iso80000-3>>), and\nstem:[K]:: is modulus of compression, bulk modulus (<<iso80000-4>>)\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-7"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-7.6-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Hooke number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-7.6-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ho_2",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-7.6",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-7.6",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-7.6-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-7.6-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between inertia forces and linear stress forces in elastic fluids, expressed by\n\nstem:[Ho_2 = rho v^2 // E]; where\n\nstem:[rho]:: is mass density (<<iso80000-4>>),\nstem:[v]:: is speed (<<iso80000-3>>), and\nstem:[E]:: is modulus of elasticity (<<iso80000-4>>)\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-7"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-7.7-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Weissenberg number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-7.7-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Wi",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-7.7",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-7.7",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-7.7-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-7.7-0"
        }
      ],
      "skos:definition": {
        "@value": "product of time derivative of shear rate and relaxation time in viscoelastic flows, expressed by\n\nstem:[Wi = dot gamma t_\"r\"]; where\n\nstem:[dot gamma]:: is time derivative of shear strain (<<iso80000-4>>), and\nstem:[t_\"r\"]:: is relaxation time (<<iso80000-12>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Weissenberg number represents the relative importance of viscous forces when compared to elastic forces.\n\nThe time derivative of shear strain is sometimes called the shear rate.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-7"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-7.8-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Deborah number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-7.8-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "De",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-7.8",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-7.8",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-7.8-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-7.8-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of relaxation time of viscoelastic fluids and observation duration in rheology of viscoelastic fluids, expressed by\n\nstem:[De = t_\"c\"//t_\"p\"]; where\n\nstem:[t_\"c\"]:: is stress relaxation time, and\nstem:[t_\"p\"]:: is observation duration (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The stress relaxation time is sometimes called the Maxwell relaxation time.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-7"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-7.9-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Lorentz number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-7.9-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Lo",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-7.9",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-7.9",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-7.9-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-7.9-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of electrical conductivity and thermal conductivity, expressed by\n\nstem:[Lo = (sigma (Delta U)^2)/(lambda Delta T)]; where\n\nstem:[sigma]:: is electrical conductivity (<<iec80000-6>>),\nstem:[Delta U]:: is difference of voltage stem:[U] (<<iec80000-6>>) between two reference points,\nstem:[lambda]:: is thermal conductivity (<<iso80000-5>>), and\nstem:[Delta T]:: is difference in thermodynamic temperature stem:[T] (<<iso80000-5>>) between the reference points\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-7"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-7.10-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "compressibility number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-7.10-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Z",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-7.10",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-7.10",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-7.10-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-7.10-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of isothermal compressibility (<<iso80000-5>>) of a gas and that of an ideal gas, expressed by\n\nstem:[Z=p/(rho R_\"s\"T)]; where\n\nstem:[p]:: is pressure (<<iso80000-4>>),\nstem:[rho]:: is mass density (<<iso80000-4>>),\nstem:[R_\"s\"]:: is specific gas constant (<<iso80000-5>>), and\nstem:[T]:: is thermodynamic temperature (<<iso80000-5>>)\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-7"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Reynolds magnetic number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Rm",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-8.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-8.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.1-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between inertial force and magneto-dynamic viscous force in an electrically conducting fluid, expressed by\n\nstem:[Rm = vl mu sigma = vl // sf(ii(v))_\"m\"]; where\n\nstem:[v]:: is speed (<<iso80000-3>>) of the fluid,\nstem:[l]:: is characteristic length (<<iso80000-3>>),\nstem:[mu]:: is magnetic permeability (<<iec80000-6>>),\nstem:[sigma]:: is electrical conductivity (<<iec80000-6>>), and\nstem:[sf(ii(v))_\"m\" = 1//(mu sigma)]:: is magnetic viscosity (magnetic diffusivity)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "This number is also called magnetic Reynolds number.\n\nThe Reynolds magnetic number is also given by\n\nstem:[Rm = Re * Pr_\"m\"]; where\n\nstem:[Re]:: is the Reynolds number (<<t11-4.1>>), and\nstem:[Pr_\"m\"]:: is the Prandtl magnetic number (<<t11-8.10>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-8"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Batchelor number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bt",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-8.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-8.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.2-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between inertia and magneto-dynamic diffusion in an electrically conducting liquid, expressed by\n\nstem:[Bt = v l sigma mu // (epsilon_\"r\" mu_\"r\")]; where\n\nstem:[v]:: is speed (<<iso80000-3>>),\nstem:[l]:: is characteristic length (<<iso80000-3>>),\nstem:[sigma]:: is electrical conductivity (<<iec80000-6>>),\nstem:[mu]:: is magnetic permeability (<<iec80000-6>>),\nstem:[epsilon_\"r\"]:: is relative permittivity (<<iec80000-6>>), and\nstem:[mu_\"r\"]:: is relative permeability (<<iec80000-6>>)\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-8"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Nusselt electric number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ne",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-8.3",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-8.3",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.3-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.3-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between convective current and diffusive current of ions in electrochemistry, expressed by\n\nstem:[Ne = vl//D**]; where\n\nstem:[v]:: is speed (<<iso80000-3>>),\nstem:[l]:: is characteristic length (<<iso80000-3>>), and\nstem:[D** = (D^+ + D^-)//2]; where::\nstem:[D^+], stem:[D^-]::: are diffusion coefficients (<<iso80000-9>>) of positive or negative ions respectively\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "This number is also called electric Nusselt number.\n\nSometimes this quantity is called the Reynolds electric number.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-8"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.4-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Alfvén number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.4-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Mach magnetic number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.4-2",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Kárman number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.4-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Al",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-8.4",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-8.4",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.4-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.4-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.4-2"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.4-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between speed of a plasma and the Alfvén wave speed, expressed by\n\nstem:[Al = v/(B//sqrt(rho mu))]; where\n\nstem:[v]:: is speed (<<iso80000-3>>),\nstem:[B]:: is magnetic flux density (<<iec80000-6>>),\nstem:[rho]:: is mass density (<<iso80000-4>>), and\nstem:[mu]:: is magnetic permeability (<<iec80000-6>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Often, the inverse of this number is wrongly used.\n\nThe name \"Alfvén Mach number\" is used in investigations on the solar wind.\n\nThe quantity stem:[v_\"A\"=B//sqrt(rho mu)] is called Alfvén wave speed, where\n\nstem:[B]:: is magnetic flux density (<<iec80000-6>>),\nstem:[rho]:: is mass density (<<iso80000-4>>), and\nstem:[mu]:: is magnetic permeability (<<iec80000-6>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-8"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.5-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Hartmann number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.5-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ha",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-8.5",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-8.5",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.5-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.5-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between magnetically induced stress and hydrodynamic shear stress in an electrically conducting fluid, expressed by\n\nstem:[Ha = Bl sqrt((sigma//mu))]; where\n\nstem:[B]:: is magnetic flux density (<<iec80000-6>>),\nstem:[l]:: is characteristic length (<<iso80000-3>>),\nstem:[sigma]:: is electrical conductivity (<<iec80000-6>>), and\nstem:[mu]:: is dynamic viscosity (<<iso80000-4>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Hartmann number represents also the ratio of magnetic force to viscous force.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-8"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.6-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Cowling number <magnetism>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.6-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Euler magnetic number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.6-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Co",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-8.6",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-8.6",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.6-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.6-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.6-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of magnetic and kinematic energy density in a plasma, expressed by\n\nstem:[Co = B^2 // (mu rho v^2)]; where\n\nstem:[B]:: is magnetic flux density (<<iec80000-6>>),\nstem:[mu]:: is magnetic permeability (<<iec80000-6>>),\nstem:[rho]:: is mass density (<<iso80000-4>>), and\nstem:[v]:: is speed (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Cowling number also represents the ratio of magnetic to dynamic pressure.\n\nThis quantity is equal to the square of the inverse of the Alfvén number.\n\nThis quantity is often called the second Cowling number, stem:[Co_2].\n\nThe first Cowling number is then defined as stem:[Co_1 = Co * Rm]; where stem:[Rm] is the Reynolds magnetic number (<<t11-8.1>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-8"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.7-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Stuart electrical number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.7-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Se",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-8.7",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-8.7",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.7-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.7-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of electric energy density and kinematic energy density in a plasma, expressed by\n\nstem:[Se = epsilon E^2 // (rho v^2)]; where\n\nstem:[epsilon]:: is electric permittivity (<<iec80000-6>>),\nstem:[E]:: is electric field strength (<<iec80000-6>>),\nstem:[rho]:: is mass density (<<iso80000-4>>), and\nstem:[v]:: is speed (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Stuart electrical number is the electrical counterpart of the Cowling number (<<t11-8.6>>).",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-8"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.8-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "magnetic pressure number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.8-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "N_(m p)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-8.8",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-8.8",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.8-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.8-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of gas pressure and magnetic pressure in a gas or plasma, expressed by\n\nstem:[N_(m p) = p (2mu)/B^2]; where\n\nstem:[p]:: is pressure (<<iso80000-4>>),\nstem:[mu]:: is magnetic permeability (<<iec80000-6>>), and\nstem:[B]:: is magnetic flux density (<<iec80000-6>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The quantity stem:[p_\"m\" = B^2//(2mu)] is called magnetic pressure, where\n\nstem:[B]:: is magnetic flux density (<<iec80000-6>>), and\nstem:[mu]:: is magnetic permeability (<<iec80000-6>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-8"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.9-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Chandrasekhar number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.9-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Q",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.9-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ch",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-8.9",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-8.9",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.9-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.9-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.9-1"
        }
      ],
      "skos:definition": {
        "@value": "quotient of Lorentz force and viscous force in magnetic convection in a fluid, expressed by\n\nstem:[Q=(Bl)^2 sigma // rho sf(ii(v))]; where\n\nstem:[B]:: is magnetic flux density (<<iec80000-6>>),\nstem:[l]:: is characteristic length (<<iso80000-3>>), a length scale of the system,\nstem:[sigma]:: is electrical conductivity (<<iec80000-6>>),\nstem:[rho]:: is mass density (<<iso80000-4>>), and\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Chandrasekhar number is also given by stem:[Q = Ha^2] where stem:[Ha] is the Hartmann number (<<t11-8.5>>).",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-8"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.10-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Prandtl magnetic number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.10-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Pr_\"m\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-8.10",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-8.10",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.10-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.10-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of kinematic viscosity and magnetic viscosity in an electrically conducting liquid, expressed by\n\nstem:[Pr_\"m\" = sf(ii(v)) sigma mu]; where\n\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>),\nstem:[sigma]:: is electrical conductivity (<<iec80000-6>>), and\nstem:[mu]:: is magnetic permeability (<<iec80000-6>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The quantity stem:[sf(ii(v))_\"m\" = 1//(mu sigma)] is called magnetic viscosity or magnetic diffusivity. See <<t11-8.11>>.\n\nThe Prandtl magnetic number is also given by\n\nstem:[Pr_\"m\" = Rm//Re]; where\n\nstem:[Rm]:: is the Reynolds magnetic number (<<t11-8.1>>), and\nstem:[Re]:: is the Reynolds number (<<t11-4.1>>).\n\nThis number is also called magnetic Prandtl number.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-8"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.11-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Roberts number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.11-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ro",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-8.11",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-8.11",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.11-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.11-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of thermal diffusivity and magnetic viscosity in an electrically conducting liquid, expressed by\n\nstem:[Ro = alpha sigma mu]; where\n\nstem:[alpha]:: is thermal diffusivity (<<iso80000-5>>),\nstem:[sigma]:: is electrical conductivity (<<iec80000-6>>), and\nstem:[mu]:: is magnetic permeability (<<iec80000-6>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The quantity stem:[v_\"m\" = 1//(mu sigma)] is called magnetic viscosity or magnetic diffusivity; where\n\nstem:[mu]:: is magnetic permeability (<<iec80000-6>>), and\nstem:[sigma]:: is electrical conductivity (<<iec80000-6>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-8"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.12-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Stuart number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.12-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Stw",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-8.12",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-8.12",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.12-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.12-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of magnetic forces and inertia forces in an electrically conducting liquid, expressed by\n\nstem:[Stw = B^2 l sigma // (v rho)]; where\n\nstem:[B]:: is magnetic flux density (<<iec80000-6>>),\nstem:[l]:: is characteristic length (<<iso80000-3>>),\nstem:[sigma]:: is electrical conductivity (<<iec80000-6>>),\nstem:[v]:: is characteristic speed (<<iso80000-3>>), and\nstem:[rho]:: is mass density (<<iso80000-4>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The Stuart number sometimes is called magnetic force parameter.\n\nSometimes the square root is wrongly used.\n\nThe Stuart number is also given by\n\nstem:[Stw = Ha^2//Re]; where\n\nstem:[Ha]:: is the Hartmann number, and\nstem:[Re]:: is the Reynolds number.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-8"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.13-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "magnetic number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.13-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "N_(mg)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-8.13",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-8.13",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.13-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.13-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of magnetic forces and viscous forces in an electrically conducting fluid, expressed by\n\nstem:[N_(mg) = B sqrt(l sigma // (eta v))]; where\n\nstem:[B]:: is magnetic flux density (<<iec80000-6>>),\nstem:[l]:: is characteristic length (<<iso80000-3>>),\nstem:[sigma]:: is electrical conductivity (<<iec80000-6>>),\nstem:[eta]:: is dynamic viscosity (<<iso80000-4>>), and\nstem:[v]:: is speed (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-8"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.14-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "electric field parameter",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.14-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ef",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-8.14",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-8.14",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.14-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.14-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of Coulomb force and Lorentz force on moving electrically charged material or particles, expressed by\n\nstem:[Ef = E // (vB)]; where\n\nstem:[E]:: is electric field strength (<<iec80000-6>>),\nstem:[v]:: is speed (<<iso80000-3>>), and\nstem:[B]:: is magnetic flux density (<<iec80000-6>>)\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-8"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.15-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Hall number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.15-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "H_\"c\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.15-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "C_\"H\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-8.15",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-8.15",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.15-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.15-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.15-1"
        }
      ],
      "skos:definition": {
        "@value": "quotient of gyro frequency and collision frequency in a plasma, expressed by\n\nstem:[H_\"c\" = (omega_\"c\")/(2pi) lambda/v]; where\n\nstem:[omega_\"c\"]:: is cyclotron angular frequency (<<iso80000-10>>),\nstem:[lambda]:: is mean free path (<<iso80000-9>>), and\nstem:[v]:: is average speed (<<iso80000-3>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Sometimes the inverse of this number is wrongly used.\n\nstem:[2pi] times this quantity is called the Hall parameter.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-8"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.16-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Lundquist number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.16-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Lu",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-8.16",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-8.16",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.16-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.16-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of Alfvén speed and magneto-dynamic speed in a plasma, expressed by\n\nstem:[Lu = Bl sigma sqrt(mu/rho)]; where\n\nstem:[B]:: is magnetic flux density (<<iec80000-6>>),\nstem:[l]:: is characteristic length (<<iso80000-3>>),\nstem:[sigma]:: is electrical conductivity (<<iec80000-6>>),\nstem:[mu]:: is magnetic permeability (<<iec80000-6>>), and\nstem:[rho]:: is mass density (<<iso80000-4>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The quantity stem:[v_\"A\" = B//sqrt(phi mu)] is called Alfvén wave speed. See <<t11-8.4>>.\n\nThe quantity stem:[v_\"m\" = 1//(l sigma mu)] is called magneto dynamic speed; where\n\nstem:[l]:: is characteristic length (<<iso80000-3>>),\nstem:[sigma]:: is electrical conductivity (<<iec80000-6>>), and\nstem:[mu]:: is magnetic permeability (<<iec80000-6>>).\n\nThe Lundquist number is also given by\n\nstem:[Lu = Rm//Al]; where\n\nstem:[Rm]:: is the Reynolds magnetic number (<<t11-8.1>>), and\nstem:[Al]:: is the Alfvén number (<<t11-8.4>>).\n\nSee also Hartmann number (<<t11-8.5>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-8"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.17-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Joule magnetic number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.17-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Jo_\"m\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-8.17",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-8.17",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.17-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.17-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of Joule heating energy and magnetic field energy in a plasma, expressed by\n\nstem:[Jo_\"m\" = 2 rho mu c_p Delta T // B^2]; where\n\nstem:[rho]:: is mass density (<<iso80000-4>>),\nstem:[mu]:: is magnetic permeability (<<iec80000-6>>),\nstem:[c_p]:: is specific heat capacity at constant pressure (<<iso80000-5>>),\nstem:[T]:: is thermodynamic temperature (<<iso80000-5>>), and\nstem:[B]:: is magnetic flux density (<<iec80000-6>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "This number is also called magnetic Joule number.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-8"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.18-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Grashof magnetic number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.18-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Gr_\"m\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-8.18",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-8.18",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.18-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.18-0"
        }
      ],
      "skos:definition": {
        "@value": "mathematical expression for the heat transfer by free thermo-magnetic convection of a paramagnetic fluid under gravity,\n\nstem:[Gr_\"m\" = 4 pi sigma_\"e\" mu_\"e\" g alpha_V Delta T l^3 // sf(ii(v))]; where\n\nstem:[sigma_\"e\"]:: is electrical conductivity (<<iec80000-6>>),\nstem:[mu_\"e\"]:: is magnetic permeability (<<iec80000-6>>),\nstem:[g]:: is acceleration of free fall (<<iso80000-3>>),\nstem:[alpha_V]:: is cubic expansion coefficient (<<iso80000-5>>),\nstem:[Delta T = T_\"S\"-T_(oo)]:: is difference of thermodynamic temperature stem:[T] (<<iso80000-5>>), where stem:[T_\"S\"] is surface temperature and stem:[T_(oo)] is bulk temperature\nstem:[l]:: is characteristic length (<<iso80000-3>>), and\nstem:[sf(ii(v))]:: is kinematic viscosity (<<iso80000-4>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "This number is also called magnetic Grashof number.\n\nSee also Grashof number (<<t11-4.4>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-8"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.19-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Naze number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.19-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Na",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-8.19",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-8.19",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.19-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.19-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of velocity of Alfvén waves and velocity of sound in a plasma, expressed by\n\nstem:[Na = B // (c sqrt(rho mu))]; where\n\nstem:[B]:: is magnetic flux density (<<iec80000-6>>),\nstem:[c]:: is speed of sound (<<iso80000-8>>),\nstem:[rho]:: is mass density (<<iso80000-4>>), and\nstem:[mu]:: is magnetic permeability (<<iec80000-6>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The quantity stem:[v_\"A\" = B // sqrt(rho mu)] is called Alfvén wave speed. See <<t11-8.4>>.",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-8"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.20-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Reynolds electric number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.20-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Re_\"e\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-8.20",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-8.20",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.20-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.20-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of speed of a fluid and average drift speed of the charged particles in an electrically conducting fluid, expressed by\n\nstem:[Re_\"e\" = v epsilon_\"e\" // (rho_\"e\" l mu)]; where\n\nstem:[v]:: is characteristic speed (<<iso80000-3>>) of the fluid,\nstem:[epsilon_\"e\"]:: is electric permittivity (<<iec80000-6>>),\nstem:[rho_\"e\"]:: is electric charge density (<<iec80000-6>>),\nstem:[l]:: is characteristic length (<<iso80000-3>>), and\nstem:[mu]:: is mobility (<<iso80000-10>>) of charge carriers\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "This number is also called electrical Reynolds number.\n\nThe drift speed of the charged particles in an electric field is given by stem:[v_\"d\" = 1/(mu E)],where\n\nstem:[E]:: is electric field strength (<<iec80000-6>>), and\nstem:[mu]:: is mobility (<<iso80000-10>>) of charge carriers.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-8"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.21-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Ampère number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.21-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Am",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-8.21",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-8.21",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-8.21-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-8.21-0"
        }
      ],
      "skos:definition": {
        "@value": "relation between electric surface current and magnetic field strength in an electrically conducting liquid, expressed by\n\nstem:[Am = I_A // lH]; where\n\nstem:[I_A]:: is electric surface current,\nstem:[l]:: is characteristic length (<<iso80000-3>>), and\nstem:[H]:: is magnetic field strength (<<iec80000-6>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "This number is also called ((magnetic field number)).\n\nThe electric surface current is given by\n\nstem:[I_A = rho_A I mu E]; where\n\nstem:[rho_A]:: is surface density of electric charge (<<iec80000-6>>),\nstem:[l]:: is characteristic length (<<iso80000-3>>),\nstem:[mu]:: is mobility (<<iso80000-10>>) of charge carriers, and\nstem:[E]:: is electric field strength (<<iec80000-6>>).\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-8"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-9.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Arrhenius number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-9.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "alpha",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-9.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-9.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-9.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-9.1-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of chemical activation energy and thermal energy; in a chemical reaction it is the exponential factor of the reaction rate constant, stem:[k], expressed by\n\nstem:[k ~ \"exp \"(alpha)], with stem:[alpha = E_0 // (RT)]; where\n\nstem:[E_0]:: is activation energy (<<iso80000-5>>),\nstem:[R]:: is molar gas constant (<<iso80000-9>>), and\nstem:[T]:: is thermodynamic temperature (<<iso80000-5>>)\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-9.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Landau-Ginzburg number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-9.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "kappa",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t11-9.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "11-9.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t11-9.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t11-9.2-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of penetration depth of a magnetic field into a superconductor and the coherence length of thermodynamic fluctuations within a superconducting phase in a material at zero thermodynamic temperature, expressed by\n\nstem:[kappa = lambda_\"L\" // (xi sqrt(2))]; where\n\nstem:[lambda_\"L\"]:: is London penetration depth (<<iso80000-12>>), and +\nstem:[xi]:: is coherence length (<<iso80000-12>>)\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-11-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-1.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "lattice vector",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-1.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "bb(ii(R))",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t12-1.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "12-1.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-1.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-1.1-0"
        }
      ],
      "skos:definition": {
        "@value": "translation vector that maps the crystal lattice on itself",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The non-SI unit ångström (stem:[\"unitsml(Aring)\"]) is widely used by x-ray crystallographers and structural chemists.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-12"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-1.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "fundamental lattice vectors",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-1.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "bb(ii(a))_1, bb(ii(a))_2, bb(ii(a))_3",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-1.2-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "bb(ii(a)), bb(ii(b)), bb(ii(c))",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t12-1.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "12-1.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-1.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-1.2-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-1.2-1"
        }
      ],
      "skos:definition": {
        "@value": "fundamental translation vectors for the crystal lattice",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The lattice vector (<<t12-1.1>>) can be given as\n\n[stem%unnumbered]\n++++\nbb(ii(R)) = n_1 bb(ii(a))_1 + n_2 bb(ii(a))_2 + n_3 bb(ii(a))_3\n++++\n\nwhere stem:[n_1], stem:[n_2] and stem:[n_3] are integers.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-12"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-2.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "angular reciprocal lattice vector",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-2.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "bb(ii(G))",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t12-2.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "12-2.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-2.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-2.1-0"
        }
      ],
      "skos:definition": {
        "@value": "vector whose scalar products with all fundamental lattice vectors are integral multiples of stem:[2pi]",
        "@language": "en"
      },
      "skos:note": {
        "@value": "In crystallography, however, the quantity stem:[bb(ii(G))/(2pi)] is sometimes used.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-12"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-2.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "fundamental reciprocal lattice vectors",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-2.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "bb(ii(b))_1, bb(ii(b))_2, bb(ii(b))_3",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t12-2.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "12-2.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-2.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-2.2-0"
        }
      ],
      "skos:definition": {
        "@value": "fundamental translation vectors for the reciprocal lattice",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[stem%unnumbered]\n++++\nbb(ii(a))_i * bb(ii(b))_i = 2pi delta_(ij)\n++++\n\nIn crystallography, however, the quantities stem:[(bb(ii(b))_j)/(2pi)] are also often used.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-12"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "lattice plane spacing",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "d",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t12-3",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "12-3",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-3-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-3-0"
        }
      ],
      "skos:definition": {
        "@value": "distance (<<iso80000-3>>) between successive lattice planes",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The non-SI unit ångström (stem:[\"unitsml(Aring)\"]) is widely used by x-ray crystallographers and structural chemists.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-12"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-4-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bragg angle",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-4-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "vartheta",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t12-4",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "12-4",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-4-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-4-0"
        }
      ],
      "skos:definition": {
        "@value": "angle between the scattered ray and the lattice plane",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Bragg angle stem:[vartheta] is given by\n\n[stem%unnumbered]\n++++\n2d \"sin\" vartheta = n lambda\n++++\n\nwhere stem:[d] is the lattice plane spacing (<<t12-3>>), stem:[lambda] is the wavelength (<<iso80000-7>>) of the radiation, and stem:[n] is the order of reflexion which is an integer.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        },
        {
          "@id": "isoiec80000:unit-deg"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-12"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-5.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "short-range order parameter",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-5.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "r",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-5.1-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "sigma",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t12-5.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "12-5.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-5.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-5.1-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-5.1-1"
        }
      ],
      "skos:definition": {
        "@value": "fraction of nearest-neighbour atom pairs in an Ising ferromagnet having magnetic moments in one direction, minus the fraction having magnetic moments in the opposite direction",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Similar definitions apply to other order-disorder phenomena.\n\nOther symbols are frequently used.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-12"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-5.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "long-range order parameter",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-5.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "R",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-5.2-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "s",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t12-5.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "12-5.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-5.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-5.2-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-5.2-1"
        }
      ],
      "skos:definition": {
        "@value": "fraction of atoms in an Ising ferromagnet having magnetic moments in one direction, minus the fraction having magnetic moments in the opposite direction",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Similar definitions apply to other order-disorder phenomena.\n\nOther symbols are frequently used.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-12"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-5.3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "atomic scattering factor",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-5.3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "f",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t12-5.3",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "12-5.3",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-5.3-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-5.3-0"
        }
      ],
      "skos:definition": {
        "@value": "quotient of radiation amplitude scattered by the atom and radiation amplitude scattered by a single electron",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The atomic scattering factor can be expressed by:\n\n[stem%unnumbered]\n++++\nf = (E_\"a\")/(E_\"e\")\n++++\n\nwhere stem:[E_\"a\"] is the radiation amplitude scattered by the atom and stem:[E_\"e\"] is the radiation amplitude scattered by a single electron.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-12"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-5.4-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "structure factor",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-5.4-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "F(h,k,l)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t12-5.4",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "12-5.4",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-5.4-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-5.4-0"
        }
      ],
      "skos:definition": {
        "@value": "quantity given by:\n\n[stem%unnumbered]\n++++\nF(h,k,l) = sum_(n=1)^N f_n \"exp\" [2pi \"i\" (hx_n + ky_n + lz_n)]\n++++\n\nwhere stem:[f_n] is the atomic scattering factor (<<t12-5.3>>) for atom stem:[n], stem:[x_n], stem:[y_n], stem:[z_n] are fractional coordinates of its position, stem:[N] is the total number of atoms in the unit cell and stem:[h], stem:[k], stem:[l] are the Miller indices\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For the Miller indices stem:[h], stem:[k], stem:[l], see <<annexA>>.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-12"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-6-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Burgers vector",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t12-6-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "bb(ii(b))",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t12-6",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "12-6",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t12-6-0"
      },
      "skosxl:altLabel": [
        {
