        "@value": "x_\"X\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-13-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "y_\"X\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-13",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-13",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-13-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-13-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-13-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-13-1"
        }
      ],
      "skos:definition": {
        "@value": "for substance stem:[\"X\"] in a mixture, quotient of amount of substance stem:[n_\"X\"] (<<t9-2>>) of stem:[\"X\"] and total amount stem:[n] of substance (<<t9-2>>) in the mixture:\n\n[stem%unnumbered]\n++++\nx_\"X\" = n_\"X\"//n\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For condensed phases, stem:[x_\"X\"] is used, and for gaseous mixtures stem:[y_\"X\"] may be used.\n\nThe unsystematic name \"mole fraction\" is still used. However, the use of this name is deprecated.\n\nFor this quantity, the entity used to define the amount of substance should always be a single molecule for every species in the mixture.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-14-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "volume fraction",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-14-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "varphi_\"X\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t9-14",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "9-14",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t9-14-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t9-14-0"
        }
      ],
      "skos:definition": {
        "@value": "for substance stem:[\"X\"], quotient of product of amount of substance fraction stem:[x_\"X\"] (<<t9-13>>) of stem:[\"X\"] and molar volume stem:[V_\"m,X\"] (<<t9-5>>) of the pure substance stem:[\"X\"] at the same temperature (<<iso80000-5>>) and pressure (<<iso80000-4>>), and sum over all substances stem:[i] of products of amount-of-substance fractions stem:[x_i] (<<t9-13>>) of substance stem:[i] and their molar volumes stem:[V_\"m,i\"] (<<t9-5>>):\n\n[stem%unnumbered]\n++++\nvarphi_\"X\" = (x_\"X\"V_\"m,X\")/(sum_i x_i V_(\"m\",i))\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Generally, the volume fraction is temperature dependent.\n\nDecided by the 16^th^ CGPM (1979), both \"l\" and \"L\" are allowed for the symbols for the litre.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-ml/l"
        },
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-9"
      }
    },
