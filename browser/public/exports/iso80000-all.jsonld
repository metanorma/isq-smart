      ],
      "skosxl:literalForm": {
        "@value": "(nu_e)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t13-15",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "13-15",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t13-15-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-15-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-15-1"
        }
      ],
      "skos:definition": {
        "@value": "binary digit rate (<<t13-13,item 13-13>>) equivalent to a transfer rate (<<t13-11,item 13-11>>) for specified data elements",
        "@language": "en"
      },
      "skos:note": {
        "@value": "In English, the systematic name would be \"equivalent\nbinary transfer rate\".\n\nSee <<iec60050-704,droploc%locality:item=\"704-17-05\">>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
