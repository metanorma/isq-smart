      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-4.1-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-4.1-1"
        }
      ],
      "skos:definition": {
        "@value": "rest mass (<<t10-2>>) of an atom stem:[\"X\"] in the ground state",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[(m(\"X\"))/m_\"u\"] is called the relative atomic mass.\n\nstem:[1 \"unitsml(u)\"] is equal to stem:[1//12] times the mass of a free carbon 12 atom, at rest and in its ground state.\n\n[stem%unnumbered]\n++++\n1 \"unitsml(Da)\" = 1 \"unitsml(u)\"\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-kg"
        },
        {
          "@id": "isoiec80000:unit-u"
        },
        {
          "@id": "isoiec80000:unit-Da"
        }
      ],
      "smart:hasBindingnessType": {
