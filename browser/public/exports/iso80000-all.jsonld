          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t13-9-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-9-0"
        }
      ],
      "skos:definition": {
        "@value": "amount of data that can be contained in a storage device, expressed as a number of specified data elements",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The specified data elements depend on the organization of the storage device, for example, binary elements also called bits, octets also called bytes, words of a given number of bits, blocks. A subscript referring to a specified data element can be added to the symbol.\n\n[example]\n====\nstorage capacity for bits, stem:[ii(M)_(\"b\")] or stem:[ii(M)_(\"bit\")]\n\nstorage capacity for octets, stem:[ii(M)_(\"o\")] or stem:[ii(M)_(\"B\")].\n====\n\nFor registers, the term \"register length\" is used with the same meaning.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        },
        {
          "@id": "isoiec80000:unit-bit"
        },
        {
          "@id": "isoiec80000:unit-stem:[\"o\"]"
        },
        {
          "@id": "isoiec80000:unit-stem:[\"B\"]"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-13"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t13-10-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "equivalent binary storage capacity",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-10-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "ii(M)_(\"e\")",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t13-10",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "13-10",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t13-10-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-10-0"
        }
      ],
      "skos:definition": {
        "@value": "[stem%unnumbered]\n++++\nii(M)_(\"e\") = \"lb \"n\n++++\n\nwhere stem:[n] is the number of possible states of the given device\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The minimum storage capacity of a bit-organized storage device which would contain the amount of data in the given storage device is equal to the smallest integer greater than or equal to the equivalent binary storage capacity.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        },
        {
          "@id": "isoiec80000:unit-bit"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-13"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t13-11-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "transfer rate",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-11-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "r",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-11-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "(nu)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t13-11",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "13-11",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t13-11-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-11-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-11-1"
        }
      ],
      "skos:definition": {
        "@value": "quotient of the number of specified data elements transferred in a time interval by the duration of this interval",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The symbol stem:[nu] is the Greek letter nu.\n\nA subscript referring to a specified data element can be added to the symbol.\n\n[example]\n====\ndigit rate, stem:[r_\"d\"] or stem:[nu_\"d\"] (see <<iec60050-702,locality:item=\"702-05-23\">> and <<iec60050-704,locality:item=\"704-16-06\">>);\n\ntransfer rate for octets (or bytes), stem:[r_\"o\"], stem:[r_\"B\"], stem:[nu_\"o\"], or stem:[nu_\"B\"]; binary digit rate or bit rate (<<t13-13>>).\n====\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-s^-1"
        },
        {
          "@id": "isoiec80000:unit-stem:[\"o\"//\"s\"]"
        },
        {
          "@id": "isoiec80000:unit-stem:[\"B\"//\"s\"]"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-13"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t13-12-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "period of data elements",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-12-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "ii(T)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t13-12",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "13-12",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t13-12-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-12-0"
        }
      ],
      "skos:definition": {
        "@value": "[stem%unnumbered]\n++++\nii(T) = 1//r\n++++\n\nwhere stem:[r] is transfer rate (<<t13-11>>) when the data elements are transmitted in series\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "A subscript referring to a specified data element can be added to the symbol.\n\n[example]\n====\nperiod of digits, stem:[ii(T)_\"d\"];\n\nperiod of octets (or bytes), stem:[ii(T)_\"o\"] or stem:[ii(T)_\"B\"].\n====\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-s"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-13"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t13-13-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "binary digit rate",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
