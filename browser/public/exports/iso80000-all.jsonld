      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-5.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "elementary charge",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-5.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "e",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-5.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-5.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-5.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-5.1-0"
        }
      ],
      "skos:definition": {
        "@value": "one of the fundamental constants in the SI system (<<iso80000-1>>), equal to the charge of the proton and opposite to the charge of the electron",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-C"
        },
        {
          "@id": "isoiec80000:unit-s*A"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-5.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "charge number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-5.2-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "ionization number",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-5.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "c",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-5.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-5.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-5.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-5.2-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-5.2-0"
        }
      ],
      "skos:definition": {
        "@value": "for a particle, quotient of the electric charge (<<iec80000-6>>) and the elementary charge (<<iso80000-1>>)",
        "@language": "en"
      },
      "skos:note": {
        "@value": "A particle is said to be electrically neutral if its charge number is equal to zero.\n\nThe charge number of a particle can be positive, negative, or zero.\n\nThe state of charge of a particle may be presented as a superscript to the symbol of that particle, e.g.\n\nstem:[\"H\"^\\+], stem:[\"He\"^(++)], stem:[\"Al\"^(3+)], stem:[\"Cl\"^-], stem:[\"S\"^(--)], stem:[\"N\"^(3-)].\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-6-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bohr radius",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-6-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "a_0",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-6",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-6",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-6-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-6-0"
        }
      ],
      "skos:definition": {
        "@value": "radius (<<iso80000-3>>) of the electron orbital in the hydrogen atom in its ground state in the Bohr model of the atom:\n\n[stem%unnumbered]\n++++\na_0 = (4pi epsilon_0 &#8463;^2)/(m_\"e\"e^2)\n++++\n\nwhere\n\nstem:[epsilon_0]:: is the electric constant (<<iec80000-6>>),\nstem:[&#8463;]:: is the reduced Planck constant (<<iso80000-1>>),\nstem:[m_\"e\"]:: is the rest mass (<<t10-2>>) of electron, and\nstem:[e]:: is the elementary charge (<<iso80000-1>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The radius of the electron orbital in the stem:[\"H\"] atom in its ground state is stem:[a_0] in the Bohr model of the atom.\n\nångström (stem:[\"unitsml(Aring)\"]), stem:[1 \"unitsml(Aring)\" := 10^(-10) \"unitsml(m)\"]\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m"
        },
        {
          "@id": "isoiec80000:unit-Aring"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-7-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Rydberg constant",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-7-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "R_(oo)",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-7",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-7",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-7-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-7-0"
        }
      ],
      "skos:definition": {
        "@value": "spectroscopic constant that determines the wave numbers of the lines in the spectrum of hydrogen:\n\n[stem%unnumbered]\n++++\nR_(oo) = (e^2)/(8pi epsilon_0 a_0 h c_0)\n++++\n\nwhere\n\nstem:[e]:: is the elementary charge (<<iso80000-1>>),\nstem:[epsilon_0]:: is the electric constant (<<iec80000-6>>),\nstem:[a_0]:: is the Bohr radius (<<t10-6>>),\nstem:[h]:: is the Planck constant (<<iso80000-1>>), and\nstem:[c_0]:: is the speed of light in vacuum (<<iso80000-1>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The quantity stem:[R_y = R_(oo)hc_0] is called the Rydberg energy.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-8-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Hartree energy",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-8-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "E_\"H\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-8-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "E_\"h\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-8",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-8",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-8-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-8-0"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-8-1"
        }
      ],
      "skos:definition": {
        "@value": "energy (<<iso80000-5>>) of the electron in a hydrogen atom in its ground state:\n\n[stem%unnumbered]\n++++\nE_\"H\" = (e^2)/(4pi epsilon_0 a_0)\n++++\n\nwhere\n\nstem:[e]:: is the elementary charge (<<iso80000-1>>),\nstem:[epsilon_0]:: is the electric constant (<<iec80000-6>>), and\nstem:[a_0]:: is the Bohr radius (<<t10-6>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The energy of the electron in an stem:[\"H\"] atom in its ground state is stem:[E_\"H\"].",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-eV"
        },
        {
          "@id": "isoiec80000:unit-J"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-2)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-9.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "magnetic dipole moment <atomic physics>",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-9.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "mu",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-9.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-9.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-9.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-9.1-0"
        }
      ],
      "skos:definition": {
        "@value": "for a particle, vector (<<iso80000-2>>) quantity causing a change to its energy (<<iso80000-5>>) stem:[Delta W] in an external magnetic field of field flux density stem:[bb(ii(B))] (<<iec80000-6>>):\n\n[stem%unnumbered]\n++++\nDelta W = -mu * bb(ii(B))\n++++\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For an atom or nucleus, this energy is quantized and can be written as:\n\n[stem%unnumbered]\n++++\nW = g mu_\"x\" M B\n++++\n\nwhere\n\nstem:[g] is the appropriate stem:[g] factor (<<t10-14.1>> or <<t10-14.2>>), stem:[mu_\"x\"] is mostly the Bohr magneton or nuclear magneton (<<t10-9.2>> or <<t10-9.3>>), stem:[M] is magnetic quantum number (<<t10-13.4>>), and stem:[B] is magnitude of the magnetic flux density.\n\nSee also <<iec80000-6>>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^2*A"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-9.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "Bohr magneton",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-9.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "mu_\"B\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-9.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-9.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-9.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-9.2-0"
        }
      ],
      "skos:definition": {
        "@value": "magnitude of the magnetic moment of an electron in a state with orbital angular momentum quantum number stem:[l=1] (<<t10-13.3>>) due to its orbital motion:\n\n[stem%unnumbered]\n++++\nmu_\"B\" = (e &#8463;)/(2m_\"e\")\n++++\n\nwhere\n\nstem:[e]:: is the elementary charge (<<iso80000-1>>),\nstem:[&#8463;]:: is the reduced Planck constant (<<iso80000-1>>), and\nstem:[m_\"e\"]:: is the rest mass (<<t10-2>>) of electron\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^2*A"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-9.3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "nuclear magneton",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-9.3-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "mu_\"N\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-9.3",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-9.3",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-9.3-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-9.3-0"
        }
      ],
      "skos:definition": {
        "@value": "absolute value of the magnetic moment of a nucleus:\n\n[stem%unnumbered]\n++++\nmu_\"N\" = (e&#8463;)/(2m_\"p\")\n++++\n\nwhere\n\nstem:[e]:: is the elementary charge (<<iso80000-1>>),\nstem:[&#8463;]:: is the reduced Planck constant (<<iso80000-1>>), and\nstem:[m_\"p\"]:: is the rest mass (<<t10-2>>) of proton\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Subscript stem:[\"N\"] stands for nucleus. For the neutron magnetic moment, subscript stem:[\"n\"] is used. The magnetic moments of protons and neutrons differ from this quantity by their specific stem:[g] factors (<<t10-14.2>>).",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-m^2*A"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-10-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "spin",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-10-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "bb(ii(s))",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-10",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-10",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-10-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-10-0"
        }
      ],
      "skos:definition": {
        "@value": "vector (<<iso80000-2>>) quantity expressing the internal angular momentum (<<iso80000-4>>) of a particle or a particle system",
        "@language": "en"
      },
      "skos:note": {
        "@value": "Spin is an additive vector quantity.",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-11-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "total angular momentum",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-11-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "bb(ii(J))",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-11",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-11",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-11-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-11-0"
        }
      ],
      "skos:definition": {
        "@value": "vector (<<iso80000-2>>) quantity in a quantum system composed of the vectorial sum of angular momentum stem:[bb(ii(L))] (<<iso80000-4>>) and spin stem:[bb(ii(s))] (<<t10-10>>)",
        "@language": "en"
      },
      "skos:note": {
        "@value": "In atomic and nuclear physics, orbital angular momentum is usually denoted by stem:[bb(ii(l))] or stem:[bb(ii(L))].\n\nThe magnitude of stem:[bb(ii(J))] is quantized so that:\n\n[stem%unnumbered]\n++++\nbb(ii(J))^2 = &#8463;^2 j(j+1)\n++++\n\nwhere stem:[j] is the total angular momentum quantum number (<<t10-13.6>>).\n\nTotal angular momentum and magnetic dipole moment have the same direction.\n\nstem:[j] is not the magnitude of the total angular momentum stem:[bb(ii(J))] but its projection onto the quantization axis, divided by stem:[&#8463;].\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-J*s"
        },
        {
          "@id": "isoiec80000:unit-eV*s"
        },
        {
          "@id": "isoiec80000:unit-kg*m^2*s^(-1)"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-12.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "gyromagnetic ratio",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-12.1-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "magnetogyric ratio",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-12.1-2",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "gyromagnetic coefficient",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-12.1-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "gamma",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-12.1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-12.1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-12.1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-12.1-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-12.1-2"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-12.1-0"
        }
      ],
      "skos:definition": {
        "@value": "proportionality constant between the magnetic dipole moment and the angular momentum:\n\n[stem%unnumbered]\n++++\nbb(ii(mu)) = gamma bb(ii(J))\n++++\n\nwhere\n\nstem:[bb(ii(mu))]:: is the magnetic dipole moment (<<t10-9.1>>), and\nstem:[bb(ii(J))]:: is the total angular momentum (<<t10-11>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[stem%unnumbered]\n++++\n1 \"unitsml(A*m^2/(J*s))\" = 1 \"unitsml(A*s/kg)\" = 1 \"unitsml(T^(-1)*s^(-1))\"\n++++\n\nThe systematic name is \"gyromagnetic coefficient\", but \"gyromagnetic ratio\" is more usual.\n\nThe gyromagnetic ratio of the proton is denoted by stem:[gamma_\"p\"].\n\nThe gyromagnetic ratio of the neutron is denoted by stem:[gamma_\"n\"].\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-A*m^2*J^(-1)*s^(-1)"
        },
        {
          "@id": "isoiec80000:unit-A*s/kg"
        },
        {
          "@id": "isoiec80000:unit-kg^(-1)*s*A"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-10"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-12.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "gyromagnetic ratio of the electron",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-12.2-1",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "magnetogyric ratio of the electron",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-12.2-2",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "gyromagnetic coefficient of the electron",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-12.2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "gamma_\"e\"",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t10-12.2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "10-12.2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-12.2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-12.2-1"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t10-12.2-2"
        },
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t10-12.2-0"
        }
      ],
      "skos:definition": {
        "@value": "proportionality constant between the magnetic dipole moment and the angular momentum of the electron\n\n[stem%unnumbered]\n++++\nbb(ii(mu)) = gamma_\"e\" bb(ii(J))\n++++\n\nwhere\n\nstem:[bb(ii(mu))]:: is the magnetic dipole moment (<<t10-9.1>>), and\nstem:[bb(ii(J))]:: is the total angular momentum (<<t10-11>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "[stem%unnumbered]\n++++\n1 \"unitsml(A*m^2/(J*s))\" = 1 \"unitsml(A*s/kg)\" = 1 \"unitsml(T^(-1)*s^(-1))\"\n++++\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-A*m^2*J^(-1)*s^(-1)"
        },
        {
          "@id": "isoiec80000:unit-A*s/kg"
        },
        {
          "@id": "isoiec80000:unit-kg^(-1)*s*A"
        }
      ],
      "smart:hasBindingnessType": {
