      "skos:definition": {
        "@value": "stem:[E_{\"bit\"} = P_C T_{\"bit\"}]\nwhere stem:[P_C] is carrier power (<<t13-18,item 13-18>>)\nand stem:[T_{\"bit\"}] is period of binary digits (item\n13-14)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For the unit joule, see <<iec60050-113,droploc%locality:item=\"113-03-46\">>.\n\nSee <<iec60050-171,droploc%locality:item=\"171-06-07\">>.\n",
