isoiec80000:term-t13-35-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "transinformation content, mutual information"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-35-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "T(x,y)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-35 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-35" ;
  skosxl:prefLabel isoiec80000:term-t13-35-0 ;
  skosxl:altLabel isoiec80000:sym-t13-35-0 ;
  skos:definition """stem:[T(x,y) = I(x) + I(y) - I(x,y)]

where stem:[I(x)] and stem:[I(y)] are the information
contents (<<t13-24,13-24>>) of events stem:[x] and stem:[y],
respectively, and stem:[I(x,y)] is their joint
information content (<<t13-30,item 13-30>>)
"""@en ;
  skos:note """See <<iec60050-171,droploc%locality:item=\"171-07-26\">>."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-Sh ;
  isoiec80000:hasUnit isoiec80000:unit-Hart ;
  isoiec80000:hasUnit isoiec80000:unit-nat ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .