    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t13-36",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "13-36",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t13-36-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-36-0"
        }
      ],
      "skos:definition": {
        "@value": "stem:[T(X,Y) = sum_{i=1}^n sum_{j=1}^m p(x_i,y_j) T(x_i,y_j)]\n\nfor the sets stem:[X = {x_1,...,x_n}],\nstem:[Y = {y_1,...,y_m}],\n\nwhere stem:[p(x_i,y_j)] is the joint probability of\nevents stem:[x_i] and stem:[y_j], and stem:[T(x_i,y_j)] is their\ntransinformation content (<<t13-35,item 13-35>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "In practice, the unit \"shannon per character\" is\ngenerally used, and sometimes the units \"hartley per\ncharacter\" and \"natural unit per character\".\n\nSee <<iec60050-171,droploc%locality:item=\"171-07-27\">>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-Sh"
        },
        {
          "@id": "isoiec80000:unit-Hart"
        },
        {
          "@id": "isoiec80000:unit-nat"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-13"
      }
    }
  ]
