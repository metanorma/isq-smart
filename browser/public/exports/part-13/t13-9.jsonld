      "skosxl:literalForm": {
        "@value": "storage capacity, storage size",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-9-0",
