  skosxl:literalForm "traffic offered intensity"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-2-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "ii(A)_o"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-2 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-2" ;
  skosxl:prefLabel isoiec80000:term-t13-2-0 ;
  skosxl:altLabel isoiec80000:sym-t13-2-0 ;
  skos:definition """traffic intensity (<<t13-1>>) of the traffic that would have been generated by the users of a pool of resources if their use had not been limited by the size of the pool"""@en ;
  skos:note """See <<iec60050-715,locality:item=\"715-05-05\">>."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-stem:["E"] ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

isoiec80000:term-t13-3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "traffic carried intensity"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t13-3-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "traffic load"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "ii(Y)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-3 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-3" ;
  skosxl:prefLabel isoiec80000:term-t13-3-0 ;
  skosxl:altLabel isoiec80000:term-t13-3-1 ;
  skosxl:altLabel isoiec80000:sym-t13-3-0 ;
  skos:definition """traffic intensity (<<t13-1>>) of the traffic served by a particular pool of resources"""@en ;
  skos:note """General practice is to estimate the traffic intensity as an average over a specified time interval, e.g. the busy hour.

See <<iec60050-715,locality:item=\"715-05-04\">>.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-stem:["E"] ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

isoiec80000:term-t13-4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "mean queue length"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-4-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "ii(L)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t13-4-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "(ii(Omega))"@en ;
  smart:hasTermFormType smart:symbol .

