  dcterms:identifier "13-5" ;
  skosxl:prefLabel isoiec80000:term-t13-5-0 ;
  skosxl:altLabel isoiec80000:sym-t13-5-0 ;
  skos:definition """probability for losing a call attempt"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

