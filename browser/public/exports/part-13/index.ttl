  skosxl:altLabel isoiec80000:sym-t13-8-0 ;
  skos:definition """call intensity (<<t13-7,item 13-7>>) for the call attempts that result in the transmission of an answer signal"""@en ;
  skos:note """For a definition of the complete call attempt,
see <<iec60050-715,droploc%locality:item=\"715-03-11\">>.
"""@en ;
