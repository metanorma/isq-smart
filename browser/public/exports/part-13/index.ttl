  skosxl:literalForm "ii(W)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-6 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-6" ;
  skosxl:prefLabel isoiec80000:term-t13-6-0 ;
  skosxl:altLabel isoiec80000:sym-t13-6-0 ;
  skos:definition """probability for waiting for a resource"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

isoiec80000:term-t13-7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "call intensity"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:term-t13-7-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "calling rate"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-7-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "lambda"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-7 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-7" ;
  skosxl:prefLabel isoiec80000:term-t13-7-0 ;
  skosxl:altLabel isoiec80000:term-t13-7-1 ;
  skosxl:altLabel isoiec80000:sym-t13-7-0 ;
  skos:definition """number of call attempts over a specified time interval divided by the duration (<<iso80000-3,locality:item=\"3-7\">>) of this interval"""@en ;
  skos:note """See <<iec60050-715,locality:item=\"715-03-13\">>."""@en ;
  isoiec80000:hasUnit isoiec80000:unit-s^-1 ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .

