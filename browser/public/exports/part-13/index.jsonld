        }
      ],
      "skos:definition": {
        "@value": "quotient of the number of specified data elements transferred in a time interval by the duration of this interval",
        "@language": "en"
      },
      "skos:note": {
        "@value": "The symbol stem:[nu] is the Greek letter nu.\n\nA subscript referring to a specified data element can be added to the symbol.\n\n[example]\n====\ndigit rate, stem:[r_\"d\"] or stem:[nu_\"d\"] (see <<iec60050-702,locality:item=\"702-05-23\">> and <<iec60050-704,locality:item=\"704-16-06\">>);\n\ntransfer rate for octets (or bytes), stem:[r_\"o\"], stem:[r_\"B\"], stem:[nu_\"o\"], or stem:[nu_\"B\"]; binary digit rate or bit rate (<<t13-13>>).\n====\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-s^-1"
        },
        {
          "@id": "isoiec80000:unit-stem:[\"o\"//\"s\"]"
        },
        {
          "@id": "isoiec80000:unit-stem:[\"B\"//\"s\"]"
        }
      ],
