        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "signal energy per binary digit",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-19-0",
