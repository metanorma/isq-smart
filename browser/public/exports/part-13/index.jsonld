      "skos:definition": {
        "@value": "call intensity (<<t13-7,item 13-7>>) for the call attempts that result in the transmission of an answer signal",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For a definition of the complete call attempt,\nsee <<iec60050-715,droploc%locality:item=\"715-03-11\">>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-s^{-1}"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
