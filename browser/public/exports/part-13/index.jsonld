      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "T_Q",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t13-17",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "13-17",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t13-17-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-17-0"
        }
      ],
      "skos:definition": {
        "@value": "distortion of a signal resulting from the process of quantizing an original signal when the values to be quantized are within the working range of the quantizer",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For the unit watt, see <<iec60050-113,droploc%locality:item=\"113-03-55\">>.\n\nSee <<iec60050-704,droploc%locality:item=\"704-24-13\">>.\n\nThe unit of the quantizing distortion is the same as\nthe unit of the signal. This may not always be the\nwatt.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-W"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
