      "skos:definition": {
        "@value": "[stem%unnumbered]\n++++\nii(H)' = \"lim\"_(m -> oo) (ii(H)_m)/m\n++++\n\nwhere stem:[ii(H)_m] is the entropy (<<t13-3>>) of the set of all sequences of stem:[m] characters\n",
        "@language": "en"
