      "skos:definition": {
        "@value": "[stem%unnumbered]\n++++\nii(T)' = \"lim\"_(m->oo) (ii(T)_m)/m\n++++\n\nwhere stem:[ii(T)_m] is the mean transinformation content (<<t13-36>>) for all pairs of input and output sequences of stem:[m] characters\n",
        "@language": "en"
