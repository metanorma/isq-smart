      "skos:definition": {
        "@value": "[stem%unnumbered]\n++++\nii(H)** = ii(H)' // t(ii(X))\n++++\n\nwhere stem:[ii(H)'] is character mean entropy (<<t13-37>>) and stem:[t(ii(X))] is the mean value of the duration of a character in the set stem:[ii(X)]\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "See <<iso2382-16,locality:item=\"16.04.10\">>.",
