      "skos:definition": {
        "@value": "traffic intensity (<<t13-1>>) of the traffic served by a particular pool of resources",
        "@language": "en"
      },
      "skos:note": {
        "@value": "General practice is to estimate the traffic intensity as an average over a specified time interval, e.g. the busy hour.\n\nSee <<iec60050-715,locality:item=\"715-05-04\">>.\n",
        "@language": "en"
      },
