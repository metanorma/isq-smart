      "skos:definition": {
        "@value": "stem:[C' = maxT']\n\nwhere stem:[T'] is character mean transinformation content (<<t13-39,item 13-39>>)\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "In practice, the unit \"shannon per character\" is generally used,\nand sometimes the units \"hartley per character\" and \"natural unit per character\".\n\nSee <<iec60050-171,droploc%locality:item=\"171-07-32\">>.\n",
        "@language": "en"
      },
