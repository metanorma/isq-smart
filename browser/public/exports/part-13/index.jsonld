        "@value": "A_o",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t13-2",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "13-2",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t13-2-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-2-0"
        }
      ],
      "skos:definition": {
        "@value": "traffic intensity (<<t13-1,item 13-1>>) of the traffic that would have been generated by the users of a pool of resources if their use had not been limited by the size of the pool",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[1 \" E\"] corresponds to the occupancy of one resource.\n\nSee <<iec60050-715,droploc%locality:item=\"715-05-05\">>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-E"
        }
      ],
