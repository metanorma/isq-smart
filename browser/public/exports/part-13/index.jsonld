        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-40-0"
        }
      ],
      "skos:definition": {
        "@value": "[stem%unnumbered]\n++++\nii(T)** = (ii(T)')/(sum_(i=1)^n sum_(j=1)^m p(x_i,y_j)t(x_i,y_j))\n++++\n\nwhere stem:[ii(T)'] is character mean transinformation content (<<t13-39>>) and stem:[t(x_i, y_j)] is the mean duration of the pair of characters stem:[(x_i, y_j)] with joint probability stem:[p(x_i, y_j)]\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "See <<iso2382-16,locality:item=\"16.04.12\">>.",
        "@language": "en"
      },
