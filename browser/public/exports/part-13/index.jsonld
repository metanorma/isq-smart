      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-14-0"
        }
      ],
      "skos:definition": {
        "@value": "stem:[T_{\"bit\"} = 1 // r_{\"bit\"}] where stem:[r_{\"bit\"}] is the binary digit\nrate (<<t13-13,item 13-13>>) when the binary digits are\ntransmitted in series\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "See <<iec60050-171,droploc%locality:item=\"171-06-06\">>.",
        "@language": "en"
      },
