      "skosxl:literalForm": {
        "@value": "A",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t13-1",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "13-1",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t13-1-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-1-0"
        }
      ],
      "skos:definition": {
        "@value": "number of simultaneously busy resources in a particular pool of resources",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[1 \" E\"] corresponds to the occupancy of one resource.\n\nThe name \"erlang\" was given to the traffic intensity\nunit in 1946 by the International Telephone\nConsultative Committee (CCIF), in honour of the\nDanish mathematician, A. K. Erlang (1878-1929), who\nwas the founder of traffic theory in telephony.\n\nSee <<iec60050-715,droploc%locality:item=\"715-05-02\">>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-E"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-13"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t13-2-0",
      "@type": [
        "smart:Term",
        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "traffic offered intensity",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:fullForm"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-2-0",
