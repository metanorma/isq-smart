      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-23-0"
        }
      ],
      "skos:definition": {
        "@value": "stem:[D_a = log_a\\ n]\n\nwhere stem:[a] is the number of possibilities at\neach decision and stem:[n] the number of\nevents\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For the unit one, see the <<intro>>.\n\nWhen the same base is used for the same number of\nevents then stem:[D_a = H_0] where stem:[H_0] is maximum entropy\n(<<t13-26,item 13-26>>).\n\nSee <<iec60050-171,droploc%locality:item=\"171-07-10\">>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        }
      ],
