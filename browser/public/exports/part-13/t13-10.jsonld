        "skosxl:Label"
      ],
      "skosxl:literalForm": {
        "@value": "M_e",
        "@language": "en"
      },
      "smart:hasTermFormType": {
        "@id": "smart:symbol"
      }
    },
    {
      "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/t13-10",
      "@type": [
        "isoiec80000:Quantity",
        "smart:TermEntry"
      ],
      "dcterms:identifier": "13-10",
      "skosxl:prefLabel": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/term-t13-10-0"
      },
      "skosxl:altLabel": [
        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t13-10-0"
        }
      ],
      "skos:definition": {
        "@value": "stem:[M_e = \"lb\"\\ n]\n\nwhere stem:[n] is the number of possible states\nof the given device\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "For the unit one, see the <<intro>>.\n\nThe minimum storage capacity of a bit-organized\nstorage device which would contain the amount of\ndata in the given storage device is equal to the\nsmallest integer greater than or equal to the\nequivalent binary storage capacity.\n\nWhen used to express a storage capacity or an\nequivalent binary storage capacity, the bit may be\ncombined with SI prefixes or prefixes for binary\nmultiples (see <<sec_4>>).\n\nIn this context, \"bit\" is a special name as well as\nsymbol for the coherent unit one. For the unit one,\nsee the <<intro>>.\n",
        "@language": "en"
      },
      "isoiec80000:hasUnit": [
        {
          "@id": "isoiec80000:unit-1"
        },
        {
          "@id": "isoiec80000:unit-bit"
        }
      ],
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-13"
      }
    }
  ]
}