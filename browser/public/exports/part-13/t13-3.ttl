isoiec80000:term-t13-3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "traffic carried intensity, traffic load"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-3-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Y"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-3 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-3" ;
  skosxl:prefLabel isoiec80000:term-t13-3-0 ;
  skosxl:altLabel isoiec80000:sym-t13-3-0 ;
  skos:definition """traffic intensity (<<t13-1,item 13-1>>) of the traffic served by a particular pool of resources"""@en ;
  skos:note """stem:[1 \" E\"] corresponds to the occupancy of one resource.

General practice is to estimate the traffic intensity as
an average over a specified time interval, e.g. the
busy hour.

See <<iec60050-715,droploc%locality:item=\"715-05-04\">>.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-E ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .