isoiec80000:term-t13-15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "equivalent binary digit rate, equivalent bit rate"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t13-15-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "r_e"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:sym-t13-15-1 a smart:Term, skosxl:Label ;
  skosxl:literalForm "(nu_e)"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t13-15 a isoiec80000:Quantity, smart:TermEntry ;
  dcterms:identifier "13-15" ;
  skosxl:prefLabel isoiec80000:term-t13-15-0 ;
  skosxl:altLabel isoiec80000:sym-t13-15-0 ;
  skosxl:altLabel isoiec80000:sym-t13-15-1 ;
  skos:definition """binary digit rate (<<t13-13,item 13-13>>) equivalent to a transfer rate (<<t13-11,item 13-11>>) for specified data elements"""@en ;
  skos:note """In English, the systematic name would be \"equivalent
binary transfer rate\".

See <<iec60050-704,droploc%locality:item=\"704-17-05\">>.
"""@en ;
  isoiec80000:hasUnit isoiec80000:unit-s^{-1} ;
  isoiec80000:hasUnit isoiec80000:unit-bit/s ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-13 .