      ],
      "skos:definition": {
        "@value": "Heaviside function, +\nunit step function\n",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[H(x) = {(1,\"for\",x>0),(0,\"for\",x<0):}]\n\nstem:[H(0) in [0,1\\]], depending on the field of application.\n\nstem:[U(x)] is also used.\n\nstem:[vartheta(t)] is used for the unit step function of time.\n\n[example]\nstem:[(&#x1D4DB;H)(s) = 1//s] (for stem:[\"Re \"s>0])\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-2-19"
      }
