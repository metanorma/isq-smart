        {
          "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/sym-t2-19.2-0"
        }
      ],
      "skos:definition": {
        "@value": "Laplace transform of stem:[f]",
        "@language": "en"
      },
      "skos:note": {
        "@value": "stem:[(&#x1D4DB; f)(s) = int_0^(oo) e^(-st) f(t) \"d\"t]\n\n(where stem:[s in bb(sf(C))])\n\nThis is often denoted by stem:[&#x1D4DB;(s)].\n\nThe two-sided Laplace transform is also used, defined by the same formula, but with minus infinity instead of zero.\n",
        "@language": "en"
      },
      "smart:hasBindingnessType": {
        "@id": "smart:normative"
      },
      "dcterms:isPartOf": {
        "@id": "https://w3id.org/standards/isoiec80000/ontologies/core/part-2-19"
      }
    }
  ]
