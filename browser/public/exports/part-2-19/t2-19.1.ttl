isoiec80000:term-t2-19.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "Fourier transform"@en ;
  smart:hasTermFormType smart:fullForm .

isoiec80000:sym-t2-19.1-0 a smart:Term, skosxl:Label ;
  skosxl:literalForm "&#x1D4D5; f"@en ;
  smart:hasTermFormType smart:symbol .

isoiec80000:t2-19.1 a isoiec80000:MathConcept, smart:TermEntry ;
  dcterms:identifier "2-19.1" ;
  skosxl:prefLabel isoiec80000:term-t2-19.1-0 ;
  skosxl:altLabel isoiec80000:sym-t2-19.1-0 ;
  skos:definition """Fourier transform of stem:[f]"""@en ;
  skos:note """stem:[(&#x1D4D5; f)(omega) = int_(-oo)^(+oo) e^(-i omega t) f(t) \"d\"t]

(where stem:[omega in bb(sf(R))])

This is often denoted by stem:[&#x1D4D5;(omega)].

stem:[(&#x1D4D5;f)(omega) = 1/(sqrt(2pi)) int_(-oo)^(+oo) e^(-i omega t) f(t) \"d\"t]

is also used.
"""@en ;
  smart:hasBindingnessType smart:normative ;
  dcterms:isPartOf isoiec80000:part-2-19 .