@prefix : <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix smart: <https://w3id.org/standards/smart/ontologies/core/> .
@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .
@base <https://w3id.org/standards/isoiec80000/ontologies/core/> .

<https://w3id.org/standards/isoiec80000/ontologies/core/> rdf:type owl:Ontology ;
  owl:imports <https://w3id.org/standards/smart/ontologies/core/> ;
  dcterms:title "ISO/IEC 80000 Domain Ontology"@en ;
  dcterms:description "Extends the SmartSDU Core Ontology with domain classes for ISO/IEC 80000 quantities, units, and mathematical concepts."@en ;
  dcterms:publisher <https://www.iso.org> , <https://www.iec.ch> ;
  rdfs:label "ISO/IEC 80000 Domain Ontology"@en ;
  owl:versionInfo "1.0.0" .

#################################################################
#    Classes
#################################################################

### Quantity
isoiec80000:Quantity rdf:type owl:Class ;
  rdfs:subClassOf smart:TermEntry ;
  rdfs:label "Quantity"@en ;
  skos:definition "A physical quantity as defined in ISO/IEC 80000, with associated symbols, definitions, and units of measurement."@en ;
  skos:prefLabel "Quantity"@en .

### Unit
isoiec80000:Unit rdf:type owl:Class ;
  rdfs:subClassOf smart:TermEntry ;
  rdfs:label "Unit of measurement"@en ;
  skos:definition "A unit of measurement used to express the magnitude of a physical quantity."@en ;
  skos:prefLabel "Unit"@en .

### MathConcept
isoiec80000:MathConcept rdf:type owl:Class ;
  rdfs:subClassOf smart:TermEntry ;
  rdfs:label "Mathematical concept"@en ;
  skos:definition "A mathematical concept as defined in ISO/IEC 80000 Part 2."@en ;
  skos:prefLabel "Mathematical concept"@en .

### Dimension
isoiec80000:Dimension rdf:type owl:Class ;
  rdfs:subClassOf smart:TermEntry ;
  rdfs:label "Dimension"@en ;
  skos:definition "A dimensional domain that groups quantities sharing the same dimensional expression, relating base quantity dimensions (length, mass, time, electric current, thermodynamic temperature, amount of substance, luminous intensity)."@en ;
  skos:prefLabel "Dimension"@en ;
  skos:scopeNote "Each part of ISO/IEC 80000 defines quantities in a distinct dimensional domain. Quantities with the same dimension are of the same kind and can be meaningfully compared."@en .

#################################################################
#    Object Properties
#################################################################

### hasUnit
isoiec80000:hasUnit rdf:type owl:ObjectProperty ;
  rdfs:domain isoiec80000:Quantity ;
  rdfs:range isoiec80000:Unit ;
  rdfs:label "has unit"@en ;
  skos:definition "Relates a quantity to a unit of measurement used to express its magnitude."@en ;
  skos:prefLabel "has unit"@en .

### hasDimension
isoiec80000:hasDimension rdf:type owl:ObjectProperty ;
  rdfs:domain isoiec80000:Quantity ;
  rdfs:range isoiec80000:Dimension ;
  rdfs:label "has dimension"@en ;
  skos:definition "Relates a quantity to its dimensional domain."@en ;
  skos:prefLabel "has dimension"@en .

