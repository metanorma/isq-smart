@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl:  <http://www.w3.org/2008/05/skos-xl#> .
@prefix smart:   <https://w3id.org/standards/smart/ontologies/core/> .
@prefix isoiec80000: <https://w3id.org/standards/isoiec80000/ontologies/core/> .

##

# Quantity: physical quantity, typed as isoiec80000:Quantity + smart:TermEntry

isoiec80000:QuantityShape
    a sh:NodeShape ;
    sh:targetClass isoiec80000:Quantity ;
    sh:property [
        sh:path rdf:type ;
        sh:hasValue smart:TermEntry ;
        sh:minCount 2 ;
    ] ;
    sh:property [
        sh:path dcterms:identifier ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path skosxl:prefLabel ;
        sh:nodeKind sh:IRI ;
        sh:class smart:Term ;
        sh:minCount 1 ;
    ] ;
    sh:property [
        sh:path skosxl:altLabel ;
        sh:nodeKind sh:IRI ;
        sh:class smart:Term ;
    ] ;
    sh:property [
        sh:path skos:definition ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
        sh:uniqueLang true ;
    ] ;
    sh:property [
        sh:path skos:note ;
        sh:datatype rdf:langString ;
    ] ;
    sh:property [
        sh:path isoiec80000:hasUnit ;
        sh:nodeKind sh:IRI ;
        sh:class isoiec80000:Unit ;
    ] ;
    sh:property [
        sh:path smart:hasBindingnessType ;
        sh:nodeKind sh:IRI ;
        sh:class smart:BindingnessType ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path dcterms:isPartOf ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
.

# Unit: unit of measurement

isoiec80000:UnitShape
    a sh:NodeShape ;
    sh:targetClass isoiec80000:Unit ;
    sh:property [
        sh:path rdf:type ;
        sh:hasValue smart:TermEntry ;
        sh:minCount 2 ;
    ] ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
        sh:uniqueLang true ;
    ] ;
    sh:property [
        sh:path skos:notation ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
    ] ;
    sh:property [
        sh:path smart:hasBindingnessType ;
        sh:nodeKind sh:IRI ;
        sh:class smart:BindingnessType ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
.

# MathConcept: mathematical concept, typed as isoiec80000:MathConcept + smart:TermEntry

isoiec80000:MathConceptShape
    a sh:NodeShape ;
    sh:targetClass isoiec80000:MathConcept ;
    sh:property [
        sh:path rdf:type ;
        sh:hasValue smart:TermEntry ;
        sh:minCount 2 ;
    ] ;
    sh:property [
        sh:path dcterms:identifier ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path skosxl:prefLabel ;
        sh:nodeKind sh:IRI ;
        sh:class smart:Term ;
        sh:minCount 1 ;
    ] ;
    sh:property [
        sh:path skosxl:altLabel ;
        sh:nodeKind sh:IRI ;
        sh:class smart:Term ;
    ] ;
    sh:property [
        sh:path skos:definition ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
        sh:uniqueLang true ;
    ] ;
    sh:property [
        sh:path skos:note ;
        sh:datatype rdf:langString ;
    ] ;
    sh:property [
        sh:path smart:hasBindingnessType ;
        sh:nodeKind sh:IRI ;
        sh:class smart:BindingnessType ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path dcterms:isPartOf ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
.

# Term: each designation/symbol is a smart:Term with skosxl:literalForm

smart:TermShape
    a sh:NodeShape ;
    sh:targetClass smart:Term ;
    sh:property [
        sh:path rdf:type ;
        sh:hasValue skosxl:Label ;
        sh:minCount 2 ;
    ] ;
    sh:property [
        sh:path skosxl:literalForm ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path smart:hasTermFormType ;
        sh:nodeKind sh:IRI ;
        sh:class smart:TermFormType ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
.

# PublicationDocument instances for ISO/IEC 80000 parts

isoiec80000:PartDocumentShape
    a sh:NodeShape ;
    sh:targetObjectsOf dcterms:isPartOf ;
    sh:class smart:PublicationDocument ;
    sh:property [
        sh:path rdf:type ;
        sh:hasValue smart:PublicationDocument ;
        sh:minCount 1 ;
    ] ;
    sh:property [
        sh:path dcterms:title ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;
    sh:property [
        sh:path smart:hasPublicationType ;
        sh:nodeKind sh:IRI ;
        sh:class smart:PublicationDocumentType ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path smart:hasBindingnessType ;
        sh:nodeKind sh:IRI ;
        sh:class smart:BindingnessType ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
.

# hasUnit property constraint (must point to Unit)

isoiec80000:HasUnitShape
    a sh:PropertyShape ;
    sh:targetSubjectsOf isoiec80000:hasUnit ;
    sh:path isoiec80000:hasUnit ;
    sh:nodeKind sh:IRI ;
    sh:class isoiec80000:Unit ;
.
