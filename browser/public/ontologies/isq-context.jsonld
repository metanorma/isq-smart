{
  "@context": {
    "smart": "https://w3id.org/standards/smart/ontologies/core/",
    "isq": "https://w3id.org/standards/isq/ontologies/core/",
    "dcterms": "http://purl.org/dc/terms/",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "sh": "http://www.w3.org/ns/shacl#",

    "id": "@id",
    "type": "@type",

    "dcterms:identifier": { "@type": "xsd:string" },
    "dcterms:title": { "@container": "@language" },
    "dcterms:isPartOf": { "@type": "@id" },
    "dcterms:issued": { "@type": "xsd:date" },
    "dcterms:hasVersion": { "@type": "@id", "@container": "@set" },
    "dcterms:replaces": { "@type": "@id" },

    "skos:prefLabel": { "@container": "@language" },
    "skos:altLabel": { "@container": "@language" },
    "skos:definition": { "@container": "@language" },
    "skos:notation": { "@container": "@set" },
    "skos:note": { "@container": "@language" },
    "skos:scopeNote": { "@container": "@language" },
    "skos:inScheme": { "@type": "@id" },

    "smart:hasBindingnessType": { "@type": "@id" },
    "smart:hasProvisionType": { "@type": "@id" },
    "smart:hasPublicationComponentType": { "@type": "@id" },
    "smart:hasPublicationType": { "@type": "@id" },
    "smart:hasSupplement": { "@type": "@id", "@container": "@set" },
    "smart:hasSupplementType": { "@type": "@id" },
    "smart:hasPartOfSpeechType": { "@type": "@id" },
    "smart:hasTermFormType": { "@type": "@id" },
    "smart:isSuccessorOf": { "@type": "@id" },

    "isq:hasUnit": { "@type": "@id", "@container": "@set" },
    "isq:hasDimension": { "@type": "@id" }
  }
}
